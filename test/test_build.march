-- test/test_build.march
-- Tests for the pipe-friendly query builder (Build module).

mod TestBuild do

import Ast
import Build

-- ---- Helpers ----

pfn list_len(lst) do
  match lst do | Nil -> 0 | Cons(_, rest) -> 1 + list_len(rest) end
end

-- ---- Tests ----

fn test_from_table() do
  let q = from("users")
  match q do
  Query(f) -> do
    match f.from_ do
    FromTable(t) -> assert(t == "users")
    _ -> assert(false)
    end
    assert(f.distinct_ == false)
    match f.limit_  do None -> () | Some(_) -> assert(false) end
    match f.offset_ do None -> () | Some(_) -> assert(false) end
  end
  end
end

fn test_select_exprs() do
  let q = select(from("posts"), [Col("id"), Col("title")])
  match q do
  Query(f) ->
    assert(list_len(f.selects) == 2)
  end
end

fn test_select_all() do
  let q = select_all(from("posts"))
  match q do
  Query(f) -> do
    assert(list_len(f.selects) == 1)
    match f.selects do
    Cons(SelectAll, Nil) -> ()
    _ -> assert(false)
    end
  end
  end
end

fn test_where_clause() do
  let q = where_(from("users"), Eq(Col("active"), Lit(PBool(true))))
  match q do
  Query(f) -> do
    assert(list_len(f.wheres) == 1)
    match f.wheres do
    Cons(Where(_), Nil) -> ()
    _ -> assert(false)
    end
  end
  end
end

fn test_or_where() do
  let q = from("users")
         |> where_(Eq(Col("role"), Lit(PString("admin"))))
         |> or_where(Eq(Col("role"), Lit(PString("superuser"))))
  match q do
  Query(f) -> assert(list_len(f.wheres) == 2)
  end
end

fn test_limit_offset() do
  let q = limit(offset(from("events"), 20), 10)
  match q do
  Query(f) -> do
    match f.limit_  do Some(n) -> assert(n == 10) | None -> assert(false) end
    match f.offset_ do Some(n) -> assert(n == 20) | None -> assert(false) end
  end
  end
end

fn test_distinct() do
  let q = distinct(from("tags"))
  match q do
  Query(f) -> assert(f.distinct_ == true)
  end
end

fn test_order_by_asc() do
  let q = order_by(from("logs"), Col("created_at"), Asc)
  match q do
  Query(f) -> do
    assert(list_len(f.orders) == 1)
    match f.orders do
    Cons(OrderExpr(Col("created_at"), Asc), Nil) -> ()
    _ -> assert(false)
    end
  end
  end
end

fn test_inner_join() do
  let q = join(from("orders"), "users", Eq(QCol("orders", "user_id"), QCol("users", "id")))
  match q do
  Query(f) -> do
    assert(list_len(f.joins) == 1)
    match f.joins do
    Cons(JoinClause(Inner, "users", _), Nil) -> ()
    _ -> assert(false)
    end
  end
  end
end

fn test_group_by() do
  let q = group_by(from("sales"), [Col("category"), Col("year")])
  match q do
  Query(f) ->
    assert(list_len(f.group_bys) == 2)
  end
end

fn test_chained_builder() do
  let q = from("users")
         |> select([Col("id"), Col("name")])
         |> where_(Eq(Col("active"), Lit(PBool(true))))
         |> order_by(Col("name"), Asc)
         |> limit(50)
  match q do
  Query(f) -> do
    assert(list_len(f.selects) == 2)
    assert(list_len(f.wheres) == 1)
    assert(list_len(f.orders) == 1)
    match f.limit_ do Some(n) -> assert(n == 50) | None -> assert(false) end
  end
  end
end

fn main() : Unit do
  test_from_table()
  test_select_exprs()
  test_select_all()
  test_where_clause()
  test_or_where()
  test_limit_offset()
  test_distinct()
  test_order_by_asc()
  test_inner_join()
  test_group_by()
  test_chained_builder()
  println("test_build: all tests passed")
end

end
