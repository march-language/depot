-- test/test_build.march
-- Tests for the pipe-friendly query builder (Build module).

mod TestBuild do

import Ast
import Build

-- ---- Helpers ----

fn list_len(lst) do
  match lst do | Nil -> 0 | Cons(_, rest) -> 1 + list_len(rest) end
end

-- ---- Tests ----

test "from table" do
  let q = Build.from("users")
  match q do
  Ast.Query(f) -> do
    match f.from_ do
    FromTable(t) -> assert t == "users"
    _ -> assert false
    end
    let _ = match f.distinct_ do
      NoDistinct -> assert true
      _          -> assert false
    end
    assert f.limit_ == None
    assert f.offset_ == None
  end
  end
end

test "select exprs" do
  let q = Build.select(Build.from("posts"), [Expr.Col("id"), Expr.Col("title")])
  match q do
  Ast.Query(f) ->
    assert list_len(f.selects) == 2
  end
end

test "select_all" do
  let q = Build.select_all(Build.from("posts"))
  match q do
  Ast.Query(f) -> do
    assert list_len(f.selects) == 1
    assert f.selects == [SelectAll]
  end
  end
end

test "WHERE clause" do
  let q = Build.where_(Build.from("users"), Expr.Eq(Expr.Col("active"), Lit(PBool(true))))
  match q do
  Ast.Query(f) ->
    match f.wheres do
    Cons(Where(_), Nil) -> ()
    _ -> assert false
    end
  end
end

test "or_where adds clause" do
  let q = Build.from("users")
         |> Build.where_(Expr.Eq(Expr.Col("role"), Lit(PString("admin"))))
         |> Build.or_where(Expr.Eq(Expr.Col("role"), Lit(PString("superuser"))))
  match q do
  Ast.Query(f) -> assert list_len(f.wheres) == 2
  end
end

test "limit and offset" do
  let q = Build.limit(Build.offset(Build.from("events"), 20), 10)
  match q do
  Ast.Query(f) -> do
    assert f.limit_ == Some(10)
    assert f.offset_ == Some(20)
  end
  end
end

test "distinct" do
  let q = Build.distinct(Build.from("tags"))
  match q do
  Ast.Query(f) -> match f.distinct_ do
    Distinct -> assert true
    _        -> assert false
  end
  end
end

test "order_by ASC" do
  let q = Build.order_by(Build.from("logs"), Expr.Col("created_at"), SortDir.Asc)
  match q do
  Ast.Query(f) ->
    match f.orders do
    Cons(OrderExpr(e, SortDir.Asc), Nil) ->
      match e do
      Expr.Col(name) -> assert name == "created_at"
      _ -> assert false
      end
    _ -> assert false
    end
  end
end

test "INNER JOIN" do
  let q = Build.join(Build.from("orders"), "users", Expr.Eq(QCol("orders", "user_id"), QCol("users", "id")))
  match q do
  Ast.Query(f) ->
    match f.joins do
    Cons(JoinClause(JoinKind.Inner, "users", _), Nil) -> ()
    _ -> assert false
    end
  end
end

test "group_by" do
  let q = Build.group_by(Build.from("sales"), [Expr.Col("category"), Expr.Col("year")])
  match q do
  Ast.Query(f) ->
    assert list_len(f.group_bys) == 2
  end
end

test "LEFT JOIN" do
  let q = Build.left_join(Build.from("orders"), "users", Expr.Eq(QCol("orders", "user_id"), QCol("users", "id")))
  match q do
  Ast.Query(f) ->
    match f.joins do
    Cons(JoinClause(JoinKind.Left, "users", _), Nil) -> ()
    _ -> assert false
    end
  end
end

test "RIGHT JOIN" do
  let q = Build.right_join(Build.from("orders"), "users", Expr.Eq(QCol("orders", "user_id"), QCol("users", "id")))
  match q do
  Ast.Query(f) ->
    match f.joins do
    Cons(JoinClause(JoinKind.Right, "users", _), Nil) -> ()
    _ -> assert false
    end
  end
end

test "FULL OUTER JOIN" do
  let q = Build.full_join(Build.from("a"), "b", Expr.Eq(Expr.Col("a.id"), Expr.Col("b.a_id")))
  match q do
  Ast.Query(f) ->
    match f.joins do
    Cons(JoinClause(FullOuter, "b", _), Nil) -> ()
    _ -> assert false
    end
  end
end

test "CROSS JOIN" do
  let q = Build.cross_join(Build.from("a"), "b")
  match q do
  Ast.Query(f) ->
    match f.joins do
    Cons(JoinClause(Cross, "b", _), Nil) -> ()
    _ -> assert false
    end
  end
end

test "having clause" do
  let q = Build.having(Build.from("sales"), Expr.Gt(Expr.Count(Expr.Col("id")), Lit(PInt(1))))
  match q do
  Ast.Query(f) ->
    match f.havings do
    Cons(Where(_), Nil) -> ()
    _ -> assert false
    end
  end
end

test "order_by DESC" do
  let q = Build.order_by(Build.from("logs"), Expr.Col("created_at"), SortDir.Desc)
  match q do
  Ast.Query(f) ->
    match f.orders do
    Cons(OrderExpr(e, SortDir.Desc), Nil) ->
      match e do
      Expr.Col(name) -> assert name == "created_at"
      _ -> assert false
      end
    _ -> assert false
    end
  end
end

test "from_subquery" do
  let sub = Build.from("events") |> Build.where_(Expr.Eq(Expr.Col("active"), Lit(PBool(true))))
  let q = Build.from_subquery(sub, "e")
  match q do
  Ast.Query(f) ->
    match f.from_ do
    FromSubquery(_, alias_name) -> assert alias_name == "e"
    _ -> assert false
    end
  end
end

test "select_as" do
  let q = Build.select_as(Build.from("posts"), Expr.Count(Expr.Col("id")), "total")
  match q do
  Ast.Query(f) ->
    match f.selects do
    Cons(SelectAs(e, alias_), Nil) -> do
      assert alias_ == "total"
      match e do
      Expr.Count(inner) ->
        match inner do
        Expr.Col(name) -> assert name == "id"
        _ -> assert false
        end
      _ -> assert false
      end
    end
    _ -> assert false
    end
  end
end

test "chained builder" do
  let q = Build.from("users")
         |> Build.select([Expr.Col("id"), Expr.Col("name")])
         |> Build.where_(Expr.Eq(Expr.Col("active"), Lit(PBool(true))))
         |> Build.order_by(Expr.Col("name"), SortDir.Asc)
         |> Build.limit(50)
  match q do
  Ast.Query(f) -> do
    assert list_len(f.selects) == 2
    assert list_len(f.wheres) == 1
    assert list_len(f.orders) == 1
    assert f.limit_ == Some(50)
  end
  end
end

test "order_asc shorthand" do
  let q = Build.order_asc(Build.from("logs"), Expr.Col("created_at"))
  match q do
  Ast.Query(f) ->
    match f.orders do
    Cons(OrderExpr(e, SortDir.Asc), Nil) ->
      match e do
      Expr.Col(name) -> assert name == "created_at"
      _ -> assert false
      end
    _ -> assert false
    end
  end
end

test "order_desc shorthand" do
  let q = Build.order_desc(Build.from("scores"), Expr.Col("points"))
  match q do
  Ast.Query(f) ->
    match f.orders do
    Cons(OrderExpr(e, SortDir.Desc), Nil) ->
      match e do
      Expr.Col(name) -> assert name == "points"
      _ -> assert false
      end
    _ -> assert false
    end
  end
end

test "multiple where_ and or_where" do
  let q = Build.from("events")
         |> Build.where_(Expr.Eq(Expr.Col("active"), Lit(PBool(true))))
         |> Build.where_(Expr.Gt(Expr.Col("score"), Lit(PInt(0))))
         |> Build.or_where(Expr.Eq(Expr.Col("featured"), Lit(PBool(true))))
  match q do
  Ast.Query(f) -> assert list_len(f.wheres) == 3
  end
end

test "multiple group_by accumulates" do
  let q = Build.from("sales")
         |> Build.group_by([Expr.Col("region"), Expr.Col("year"), Expr.Col("quarter")])
  match q do
  Ast.Query(f) -> assert list_len(f.group_bys) == 3
  end
end

test "chained joins" do
  let q = Build.from("orders")
         |> Build.join("users", Expr.Eq(QCol("orders", "user_id"), QCol("users", "id")))
         |> Build.left_join("products", Expr.Eq(QCol("orders", "product_id"), QCol("products", "id")))
  match q do
  Ast.Query(f) -> assert list_len(f.joins) == 2
  end
end

-- ---- Additional Build tests ----

test "from creates query with correct table" do
  let q = Build.from("products")
  match q do
  Ast.Query(f) ->
    match f.from_ do
    FromTable(t) -> assert t == "products"
    _ -> assert false
    end
  end
end

test "where_ appends to wheres list" do
  let q = Build.from("t") |> Build.where_(Expr.Eq(Expr.Col("a"), Lit(PInt(1))))
  match q do
  Ast.Query(f) -> assert list_len(f.wheres) == 1
  end
end

test "multiple where_ calls accumulate" do
  let q = Build.from("t")
    |> Build.where_(Expr.Eq(Expr.Col("a"), Lit(PInt(1))))
    |> Build.where_(Expr.Eq(Expr.Col("b"), Lit(PInt(2))))
    |> Build.where_(Expr.Eq(Expr.Col("c"), Lit(PInt(3))))
  match q do
  Ast.Query(f) -> assert list_len(f.wheres) == 3
  end
end

test "select clears and sets selects" do
  let q = Build.from("t") |> Build.select([Expr.Col("id"), Expr.Col("name"), Expr.Col("email")])
  match q do
  Ast.Query(f) -> assert list_len(f.selects) == 3
  end
end

test "select_all sets SelectAll" do
  let q = Build.from("t") |> select_all
  match q do
  Ast.Query(f) -> do
    assert list_len(f.selects) == 1
    assert f.selects == [SelectAll]
  end
  end
end

test "join adds inner join" do
  let q = Build.from("t") |> Build.join("other", Expr.Eq(Expr.Col("id"), Expr.Col("other_id")))
  match q do
  Ast.Query(f) -> assert list_len(f.joins) == 1
  end
end

test "left_join adds left join" do
  let q = Build.from("t") |> Build.left_join("other", Expr.Eq(Expr.Col("id"), Expr.Col("other_id")))
  match q do
  Ast.Query(f) -> assert list_len(f.joins) == 1
  end
end

test "right_join adds right join" do
  let q = Build.from("t") |> Build.right_join("other", Expr.Eq(Expr.Col("id"), Expr.Col("other_id")))
  match q do
  Ast.Query(f) -> assert list_len(f.joins) == 1
  end
end

test "limit sets limit" do
  let q = Build.from("t") |> Build.limit(10)
  match q do
  Ast.Query(f) -> assert f.limit_ == Some(10)
  end
end

test "offset sets offset" do
  let q = Build.from("t") |> Build.offset(20)
  match q do
  Ast.Query(f) -> assert f.offset_ == Some(20)
  end
end

test "distinct sets distinct flag" do
  let q = Build.from("t") |> distinct
  match q do
  Ast.Query(f) -> match f.distinct_ do
    Distinct -> assert true
    _        -> assert false
  end
  end
end

test "order_asc adds asc order" do
  let q = Build.from("t") |> Build.order_asc(Expr.Col("name"))
  match q do
  Ast.Query(f) -> assert list_len(f.orders) == 1
  end
end

test "order_desc adds desc order" do
  let q = Build.from("t") |> Build.order_desc(Expr.Col("created_at"))
  match q do
  Ast.Query(f) -> assert list_len(f.orders) == 1
  end
end

test "multiple orders accumulate" do
  let q = Build.from("t") |> Build.order_asc(Expr.Col("a")) |> Build.order_desc(Expr.Col("b")) |> Build.order_asc(Expr.Col("c"))
  match q do
  Ast.Query(f) -> assert list_len(f.orders) == 3
  end
end

test "group_by adds group by" do
  let q = Build.from("t") |> Build.group_by([Expr.Col("status")])
  match q do
  Ast.Query(f) -> assert list_len(f.group_bys) == 1
  end
end

test "having adds having clause" do
  let q = Build.from("t") |> Build.having(Expr.Gt(CountAll, Lit(PInt(1))))
  match q do
  Ast.Query(f) -> assert list_len(f.havings) == 1
  end
end

test "complex chained query" do
  let q = Build.from("orders")
    |> Build.join("users", Expr.Eq(QCol("orders", "user_id"), QCol("users", "id")))
    |> Build.where_(Expr.Eq(Expr.Col("status"), Lit(PString("active"))))
    |> Build.group_by([Expr.Col("user_id")])
    |> Build.having(Expr.Gt(Expr.Count(Expr.Col("id")), Lit(PInt(2))))
    |> Build.order_desc(Expr.Col("user_id"))
    |> Build.limit(10)
    |> Build.offset(0)
  match q do
  Ast.Query(f) -> do
    assert list_len(f.joins) == 1
    assert list_len(f.wheres) == 1
    assert list_len(f.group_bys) == 1
    assert list_len(f.havings) == 1
    assert list_len(f.orders) == 1
    assert f.limit_ == Some(10)
    assert f.offset_ == Some(0)
  end
  end
end

test "from starts with no wheres" do
  let q = Build.from("t")
  match q do
  Ast.Query(f) -> assert f.wheres == Nil
  end
end

test "from starts with no joins" do
  let q = Build.from("t")
  match q do
  Ast.Query(f) -> assert f.joins == Nil
  end
end

test "from starts with no orders" do
  let q = Build.from("t")
  match q do
  Ast.Query(f) -> assert f.orders == Nil
  end
end

test "from starts with no group_bys" do
  let q = Build.from("t")
  match q do
  Ast.Query(f) -> assert f.group_bys == Nil
  end
end

test "from starts with no havings" do
  let q = Build.from("t")
  match q do
  Ast.Query(f) -> assert f.havings == Nil
  end
end

test "from starts with no limit" do
  let q = Build.from("t")
  match q do
  Ast.Query(f) -> assert f.limit_ == None
  end
end

test "from starts with no offset" do
  let q = Build.from("t")
  match q do
  Ast.Query(f) -> assert f.offset_ == None
  end
end

test "order_asc with multiple columns" do
  let q = Build.from("users")
    |> Build.order_asc(Expr.Col("last_name"))
    |> Build.order_asc(Expr.Col("first_name"))
  match q do
  Ast.Query(f) -> assert list_len(f.orders) == 2
  end
end

test "group_by multiple columns" do
  let q = Build.from("sales")
    |> Build.group_by([Expr.Col("year"), Expr.Col("month"), Expr.Col("product_id")])
  match q do
  Ast.Query(f) -> assert list_len(f.group_bys) == 3
  end
end

test "limit then offset" do
  let q = Build.from("t") |> Build.limit(5) |> Build.offset(10)
  match q do
  Ast.Query(f) -> do
    assert f.limit_ == Some(5)
    assert f.offset_ == Some(10)
  end
  end
end

-- ---- Phase 1.2: where_in / where_not_in ----

test "where_in adds IN where clause" do
  let q = Build.from("users")
    |> Build.where_in(Expr.Col("id"), [Lit(PInt(1)), Lit(PInt(2)), Lit(PInt(3))])
  match q do
  Ast.Query(f) -> assert list_len(f.wheres) == 1
  end
end

test "where_in empty list adds WHERE FALSE clause" do
  let q = Build.from("users") |> Build.where_in(Expr.Col("id"), Nil)
  match q do
  Ast.Query(f) -> assert list_len(f.wheres) == 1
  end
end

test "where_in empty list clause is Where(Raw)" do
  let q = Build.from("users") |> Build.where_in(Expr.Col("id"), Nil)
  match q do
  Ast.Query(f) ->
    match f.wheres do
    Cons(Where(Raw(_)), Nil) -> ()
    _ -> assert false
    end
  end
end

test "where_not_in adds NOT IN where clause" do
  let q = Build.from("users")
    |> Build.where_not_in(Expr.Col("id"), [Lit(PInt(1)), Lit(PInt(2))])
  match q do
  Ast.Query(f) -> assert list_len(f.wheres) == 1
  end
end

test "where_not_in empty list adds no clause" do
  let q = Build.from("users") |> Build.where_not_in(Expr.Col("id"), Nil)
  match q do
  Ast.Query(f) -> assert f.wheres == Nil
  end
end

test "where_in chains with other conditions" do
  let q = Build.from("users")
    |> Build.where_(Expr.Eq(Expr.Col("active"), Lit(PBool(true))))
    |> Build.where_in(Expr.Col("role"), [Lit(PString("admin")), Lit(PString("mod"))])
  match q do
  Ast.Query(f) -> assert list_len(f.wheres) == 2
  end
end

test "where_not_in chains with conditions" do
  let q = Build.from("users")
    |> Build.where_(Expr.Eq(Expr.Col("active"), Lit(PBool(true))))
    |> Build.where_not_in(Expr.Col("status"), [Lit(PString("banned")), Lit(PString("suspended"))])
  match q do
  Ast.Query(f) -> assert list_len(f.wheres) == 2
  end
end

test "where_in single value" do
  let q = Build.from("users") |> Build.where_in(Expr.Col("id"), [Lit(PInt(42))])
  match q do
  Ast.Query(f) -> assert list_len(f.wheres) == 1
  end
end

-- ---- Phase 1.3: where_or / OR condition grouping ----

test "where_or single condition is equivalent to where_" do
  let q = Build.from("users") |> Build.where_or([Expr.Eq(Expr.Col("active"), Lit(PBool(true)))])
  match q do
  Ast.Query(f) -> assert list_len(f.wheres) == 1
  end
end

test "where_or two conditions adds one OR clause" do
  let q = Build.from("users")
    |> Build.where_or([Expr.Eq(Expr.Col("role"), Lit(PString("admin"))),
                 Expr.Eq(Expr.Col("role"), Lit(PString("mod")))])
  match q do
  Ast.Query(f) -> assert list_len(f.wheres) == 1
  end
end

test "where_or stores Where(Expr.Or(...))" do
  let q = Build.from("users")
    |> Build.where_or([Expr.Eq(Expr.Col("role"), Lit(PString("admin"))),
                 Expr.Eq(Expr.Col("role"), Lit(PString("mod")))])
  match q do
  Ast.Query(f) ->
    match f.wheres do
    Cons(Where(e), Nil) ->
      match e do
      Expr.Or(_, _) -> ()
      _ -> assert false
      end
    _ -> assert false
    end
  end
end

test "where_or empty list adds FALSE clause" do
  let q = Build.from("users") |> Build.where_or(Nil)
  match q do
  Ast.Query(f) -> assert list_len(f.wheres) == 1
  end
end

test "where_or chains with AND conditions" do
  let q = Build.from("users")
    |> Build.where_(Expr.Eq(Expr.Col("active"), Lit(PBool(true))))
    |> Build.where_or([Expr.Eq(Expr.Col("role"), Lit(PString("admin"))),
                 Expr.Eq(Expr.Col("role"), Lit(PString("mod")))])
  match q do
  Ast.Query(f) -> assert list_len(f.wheres) == 2
  end
end

test "where_or three conditions" do
  let q = Build.from("users")
    |> Build.where_or([Expr.Eq(Expr.Col("a"), Lit(PInt(1))),
                 Expr.Eq(Expr.Col("b"), Lit(PInt(2))),
                 Expr.Eq(Expr.Col("c"), Lit(PInt(3)))])
  match q do
  Ast.Query(f) -> assert list_len(f.wheres) == 1
  end
end

-- ---- Phase 1.4: fragment/2 ----

test "fragment adds WHERE Fragment clause" do
  let q = Build.from("users") |> Build.fragment("lower(?) = lower(?)", [Expr.Col("email"), Expr.Col("email")])
  match q do
  Ast.Query(f) ->
    match f.wheres do
    Cons(Where(e), Nil) ->
      match e do
      Fragment(_, _) -> ()
      _ -> assert false
      end
    _ -> assert false
    end
  end
end

test "fragment stores template string" do
  let q = Build.from("users") |> Build.fragment("lower(?) = ?", [Expr.Col("email"), Lit(PString("a@b.com"))])
  match q do
  Ast.Query(f) ->
    match f.wheres do
    Cons(Where(Fragment(tmpl, _)), Nil) -> assert tmpl == "lower(?) = ?"
    _ -> assert false
    end
  end
end

test "fragment stores args list" do
  let q = Build.from("users") |> Build.fragment("? > ?", [Expr.Col("age"), Lit(PInt(18))])
  match q do
  Ast.Query(f) ->
    match f.wheres do
    Cons(Where(Fragment(_, args)), Nil) -> assert list_len(args) == 2
    _ -> assert false
    end
  end
end

test "fragment chains with where_ conditions" do
  let q = Build.from("users")
    |> Build.where_(Expr.Eq(Expr.Col("active"), Lit(PBool(true))))
    |> Build.fragment("lower(?) = ?", [Expr.Col("email"), Lit(PString("alice@test.com"))])
  match q do
  Ast.Query(f) -> assert list_len(f.wheres) == 2
  end
end

test "fragment with no placeholders stores empty args" do
  let q = Build.from("users") |> Build.fragment("1 = 1", Nil)
  match q do
  Ast.Query(f) ->
    match f.wheres do
    Cons(Where(Fragment(tmpl, _)), Nil) -> assert tmpl == "1 = 1"
    _ -> assert false
    end
  end
end

-- ---- Phase 1.5: subquery predicates ----

test "select_col adds SelectField to selects" do
  let q = Build.from("t") |> Build.select_col("id")
  match q do
  Ast.Query(f) ->
    match f.selects do
    Cons(SelectField(_), Nil) -> ()
    _ -> assert false
    end
  end
end

test "where_in_subquery adds InSubquery WHERE clause" do
  let subq = Build.from("admins")
  let q = Build.from("users") |> Build.where_in_subquery("id", subq)
  match q do
  Ast.Query(f) ->
    match f.wheres do
    Cons(Where(e), Nil) ->
      match e do
      InSubquery(_, _) -> ()
      _ -> assert false
      end
    _ -> assert false
    end
  end
end

test "where_in_subquery column name is Col expr" do
  let q = Build.from("users") |> Build.where_in_subquery("dept_id", Build.from("depts"))
  match q do
  Ast.Query(f) ->
    match f.wheres do
    Cons(Where(InSubquery(col_expr, _)), Nil) ->
      match col_expr do
      Expr.Col(name) -> assert name == "dept_id"
      _ -> assert false
      end
    _ -> assert false
    end
  end
end

test "where_in_subquery stores the subquery" do
  let subq = Build.from("admins") |> Build.select_col("user_id")
  let q = Build.from("users") |> Build.where_in_subquery("id", subq)
  match q do
  Ast.Query(f) ->
    match f.wheres do
    Cons(Where(InSubquery(_, sq)), Nil) ->
      match sq do
      Ast.Query(sf) ->
        match sf.from_ do
        FromTable(t) -> assert t == "admins"
        _ -> assert false
        end
      end
    _ -> assert false
    end
  end
end

test "where_exists adds Exists WHERE clause" do
  let q = Build.from("users") |> Build.where_exists(Build.from("admins"))
  match q do
  Ast.Query(f) ->
    match f.wheres do
    Cons(Where(e), Nil) ->
      match e do
      Exists(_) -> ()
      _ -> assert false
      end
    _ -> assert false
    end
  end
end

test "where_not_exists adds NOT(Exists) WHERE clause" do
  let q = Build.from("users") |> Build.where_not_exists(Build.from("admins"))
  match q do
  Ast.Query(f) ->
    match f.wheres do
    Cons(Where(e), Nil) ->
      match e do
      Expr.Not(inner) ->
        match inner do
        Exists(_) -> ()
        _ -> assert false
        end
      _ -> assert false
      end
    _ -> assert false
    end
  end
end

test "where_in_subquery chains with other conditions" do
  let q = Build.from("users")
    |> Build.where_(Expr.Eq(Expr.Col("active"), Lit(PBool(true))))
    |> Build.where_in_subquery("id", Build.from("admins"))
  match q do
  Ast.Query(f) -> assert list_len(f.wheres) == 2
  end
end

test "where_exists chains with other conditions" do
  let q = Build.from("users")
    |> Build.where_(Expr.Eq(Expr.Col("active"), Lit(PBool(true))))
    |> Build.where_exists(Build.from("sessions"))
  match q do
  Ast.Query(f) -> assert list_len(f.wheres) == 2
  end
end

end -- mod TestBuild
