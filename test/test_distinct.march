-- test/test_distinct.march
-- Phase 3.1 — SELECT DISTINCT and DISTINCT ON compile-level coverage.
--
-- Pure compile tests — no live DB. Live verification piggybacks on the
-- existing live join/aggregate suites since DISTINCT is just a SELECT
-- modifier.

mod TestDistinct do

import Ast
import Build
import Compile

test "plain DISTINCT renders before the column list" do
  let q = from("users") |> distinct |> select([Expr.Col("role")])
  let r = Compile.compile_parameterized(q)
  assert r.sql == "SELECT DISTINCT \"role\" FROM \"users\""
end

test "no DISTINCT modifier by default" do
  let q = from("users") |> select([Expr.Col("id")])
  let r = Compile.compile_parameterized(q)
  assert r.sql == "SELECT \"id\" FROM \"users\""
end

test "DISTINCT ON (col) renders column list in parens before SELECT list" do
  let q = from("events")
         |> distinct_on([Expr.Col("user_id")])
         |> select([Expr.Col("user_id"), Expr.Col("created_at")])
  let r = Compile.compile_parameterized(q)
  assert r.sql ==
    "SELECT DISTINCT ON (\"user_id\") \"user_id\", \"created_at\" FROM \"events\""
end

test "DISTINCT ON with multiple expressions is comma-separated" do
  let q = from("t")
         |> distinct_on([Expr.Col("a"), Expr.Col("b")])
         |> select([Expr.Col("a"), Expr.Col("b"), Expr.Col("c")])
  let r = Compile.compile_parameterized(q)
  assert String.contains(r.sql, "DISTINCT ON (\"a\", \"b\")")
end

test "DISTINCT ON composes with WHERE, ORDER BY, LIMIT" do
  let q = from("events")
         |> distinct_on([Expr.Col("user_id")])
         |> select([Expr.Col("user_id"), Expr.Col("ts")])
         |> where_(Expr.Gt(Expr.Col("ts"), Lit(PInt(0))))
         |> order_by(Expr.Col("user_id"), Asc)
         |> order_by(Expr.Col("ts"), Desc)
         |> limit(100)
  let r = Compile.compile_parameterized(q)
  let _ = assert String.contains(r.sql, "DISTINCT ON (\"user_id\")")
  let _ = assert String.contains(r.sql, "WHERE \"ts\" > $1")
  let _ = assert String.contains(r.sql, "ORDER BY \"user_id\" ASC, \"ts\" DESC")
  assert String.contains(r.sql, "LIMIT 100")
end

test "compile_inline honours DISTINCT" do
  let q = from("users") |> distinct |> select([Expr.Col("role")])
  let r = Compile.compile_inline(q)
  assert r.sql == "SELECT DISTINCT \"role\" FROM \"users\""
end

test "compile_inline honours DISTINCT ON" do
  let q = from("events")
         |> distinct_on([Expr.Col("user_id")])
         |> select([Expr.Col("user_id")])
  let r = Compile.compile_inline(q)
  assert r.sql == "SELECT DISTINCT ON (\"user_id\") \"user_id\" FROM \"events\""
end

end -- mod TestDistinct
