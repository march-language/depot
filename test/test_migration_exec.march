-- test/test_migration_exec.march
-- Phase 2.4 — Depot.Migration.run against a live PostgreSQL.

mod TestMigrationExec do

needs Ffi
needs IO.Foreign
needs IO.NetConnect
needs IO.Random
needs IO.Spawn

import Ast
import Build
import Compile
import Connection
import Db
import Depot.Migration
import Depot.Query

fn test_config() do
  default_config("postgres", "depot_test")
end

pfn table_row_count(conn, table) do
  match Db.query(conn, "SELECT COUNT(*)::text FROM " ++ table) do
    Ok(r) ->
      match r.rows do
        Cons(Cons(Some(s), Nil), Nil) -> s
        _ -> "?"
      end
    Err(e) -> "err: " ++ e
  end
end

pfn table_exists(conn, table) do
  match Db.query(conn,
      "SELECT to_regclass('public." ++ table ++ "')::text") do
    Ok(r) ->
      match r.rows do
        Cons(Cons(Some(s), Nil), Nil) -> s == table
        _ -> false
      end
    Err(_) -> false
  end
end

-- Look up a column value in a Depot.Query.exec_sql row (an assoc list of
-- (String, Option(String)) pairs, as produced by zip_cols in depot_query.march).
pfn row_get(row, key) do
  match row do
    Nil -> None
    Cons((k, v), rest) -> if k == key do v else row_get(rest, key) end
  end
end

pfn with_conn(body) do
  match connect(test_config()) do
  Err(e) -> do
    let _ = println("connect: " ++ e)
    assert false
  end
  Ok(raw_conn) -> do
    let conn = Db.from_postgres(raw_conn)
    let _ = Db.query(conn, "DROP TABLE IF EXISTS mig_test")
    let _ = Db.query(conn, "DROP TABLE IF EXISTS mig_test2")
    let result = body(conn)
    let _ = Db.query(conn, "DROP TABLE IF EXISTS mig_test")
    let _ = Db.query(conn, "DROP TABLE IF EXISTS mig_test2")
    let _ = Db.close(conn)
    result
  end
  end
end

test "run_sql executes a single statement inside a transaction" do
  with_conn(fn conn ->
    let outcome = Depot.Migration.run_sql(conn,
      "CREATE TABLE mig_test (v INT)")
    match outcome do
      Err(e) -> do
        let _ = println("run_sql err: " ++ e)
        assert false
      end
      Ok(_) -> do
        let _ = assert table_exists(conn, "mig_test")
        assert table_row_count(conn, "mig_test") == "0"
      end
    end
  )
end

test "run_sql rolls back on SQL error — table is not left behind" do
  with_conn(fn conn ->
    -- Two statements in one call would need run(...); here we use run_sql
    -- with a single statement that errors to exercise the rollback path.
    let outcome = Depot.Migration.run_sql(conn,
      "CREATE TABLE mig_test (v INT NOT NULL DEFAULT invalid_fn())")
    match outcome do
      Ok(_) -> assert false
      Err(_) -> assert (table_exists(conn, "mig_test") == false)
    end
  )
end

test "run drains logged SQL and executes inside a transaction" do
  with_conn(fn conn ->
    let outcome = Depot.Migration.run(conn, fn () ->
      let _ = Depot.Migration.execute("CREATE TABLE mig_test (v INT)")
      Depot.Migration.execute("INSERT INTO mig_test VALUES (1), (2), (3)")
    )
    match outcome do
      Err(e) -> do
        let _ = println("migration err: " ++ e)
        assert false
      end
      Ok(_) -> do
        let _ = assert table_exists(conn, "mig_test")
        assert table_row_count(conn, "mig_test") == "3"
      end
    end
  )
end

test "run rolls back all siblings when a later statement fails" do
  with_conn(fn conn ->
    let outcome = Depot.Migration.run(conn, fn () ->
      let _ = Depot.Migration.execute("CREATE TABLE mig_test (v INT)")
      -- Second stmt deliberately fails — no column `nope` exists.
      Depot.Migration.execute("INSERT INTO mig_test (nope) VALUES (1)")
    )
    match outcome do
      Ok(_) -> assert false
      Err(_) -> do
        -- First create must have been rolled back with its sibling.
        assert (table_exists(conn, "mig_test") == false)
      end
    end
  )
end

test "run catches a panic in migration_fn and drains the log" do
  with_conn(fn conn ->
    let outcome = Depot.Migration.run(conn, fn () ->
      let _ = Depot.Migration.execute("CREATE TABLE mig_test (v INT)")
      -- Panic before the second execute — must not leave stray log
      -- entries for a subsequent migration to pick up.
      let _ = 1 / 0
      Depot.Migration.execute("CREATE TABLE mig_test2 (v INT)")
    )
    match outcome do
      Ok(_) -> assert false
      Err(_) -> do
        -- The first CREATE was logged but the panic aborted before the
        -- transaction opened, so neither table should exist.
        let _ = assert (table_exists(conn, "mig_test") == false)
        let _ = assert (table_exists(conn, "mig_test2") == false)
        -- A follow-up clean migration must not see leaked log entries.
        let follow_up = Depot.Migration.run(conn, fn () ->
          Depot.Migration.execute("CREATE TABLE mig_test2 (v INT)")
        )
        match follow_up do
          Err(_) -> assert false
          Ok(_) -> do
            let _ = assert (table_exists(conn, "mig_test") == false)
            assert table_exists(conn, "mig_test2")
          end
        end
      end
    end
  )
end

test "create_index with using: gin emits a GIN index" do
  with_conn(fn conn ->
    let _ = Db.query(conn, "DROP TABLE IF EXISTS ts_demo")
    let _ = Db.query(conn, "CREATE TABLE ts_demo (id serial primary key, tags tsvector)")
    let outcome = Depot.Migration.run(conn, fn () ->
      Depot.Migration.create_index("ts_demo", ["tags"], { using: "gin" })
    )
    let result = match outcome do
      Err(e) -> do
        let _ = println("create_index using:gin err: " ++ e)
        false
      end
      Ok(_) -> do
        let idx_sql = "SELECT indexdef FROM pg_indexes WHERE tablename = 'ts_demo' AND indexname = 'ts_demo_tags_index'"
        match Db.query(conn, idx_sql) do
          Ok(r) ->
            match r.rows do
              Cons(Cons(Some(def), Nil), Nil) -> String.contains(def, "USING gin")
              _ -> false
            end
          Err(e) -> do
            let _ = println("index lookup failed: " ++ e)
            false
          end
        end
      end
    end
    let _ = Db.query(conn, "DROP TABLE IF EXISTS ts_demo")
    assert result
  )
end

test "create_index_expr builds a GIN index over a to_tsvector expression" do
  with_conn(fn conn ->
    let _ = Db.query(conn, "DROP TABLE IF EXISTS ts_demo2")
    let _ = Db.query(conn, "CREATE TABLE ts_demo2 (id serial primary key, body text)")
    let outcome = Depot.Migration.run(conn, fn () ->
      Depot.Migration.create_index_expr("ts_demo2", "to_tsvector('english', body)", { using: "gin", name: "ts_demo2_body_gin" })
    )
    let result = match outcome do
      Err(e) -> do
        let _ = println("create_index_expr err: " ++ e)
        false
      end
      Ok(_) -> do
        let idx_sql = "SELECT indexdef FROM pg_indexes WHERE tablename = 'ts_demo2' AND indexname = 'ts_demo2_body_gin'"
        match Db.query(conn, idx_sql) do
          Ok(r) ->
            match r.rows do
              Cons(Cons(Some(def), Nil), Nil) -> String.contains(def, "USING gin") && String.contains(def, "to_tsvector")
              _ -> false
            end
          Err(e) -> do
            let _ = println("index lookup failed: " ++ e)
            false
          end
        end
      end
    end
    let _ = Db.query(conn, "DROP TABLE IF EXISTS ts_demo2")
    assert result
  )
end

test "ts_match + ts_rank_expr find and rank rows using a GIN-indexed tsvector column" do
  with_conn(fn conn ->
    let _ = Db.query(conn, "DROP TABLE IF EXISTS ts_search_demo")
    let _ = Db.query(conn,
      "CREATE TABLE ts_search_demo (id serial primary key, title text, body_tsv tsvector)")
    let _ = Db.query(conn,
      "INSERT INTO ts_search_demo (title, body_tsv) VALUES " ++
      "('Postgres intro', to_tsvector('english', 'PostgreSQL is a powerful search engine')), " ++
      "('Cooking', to_tsvector('english', 'A recipe for chocolate cake')), " ++
      "('Search deep dive', to_tsvector('english', 'Full text search in Postgres is fast and powerful'))")

    -- Finding 1's chosen pairing: a real tsvector column indexed via plain
    -- create_index (NOT create_index_expr), matching ts_match's bare-column
    -- predicate and ts_rank_expr's bare-column ranking.
    let idx_outcome = Depot.Migration.run(conn, fn () ->
      Depot.Migration.create_index("ts_search_demo", ["body_tsv"], { using: "gin" })
    )

    match idx_outcome do
      Err(e) -> do
        let _ = println("create_index err: " ++ e)
        let _ = Db.query(conn, "DROP TABLE IF EXISTS ts_search_demo")
        assert false
      end
      Ok(_) -> do
        -- Filter with Depot.Query.ts_match against the bare tsvector column.
        let q = Depot.Query.from_table("ts_search_demo")
          |> Depot.Query.ts_match("body_tsv", "postgres search")
        let match_result = Depot.Query.exec_sql(q, conn)

        -- Rank with Depot.Query.ts_rank_expr against the SAME bare column,
        -- composed via the lower-level Build/Compile path since ranking is
        -- a select_as/order_by projection concern (see ts_rank_expr's doc).
        let rank_expr = Depot.Query.ts_rank_expr("body_tsv", "postgres search")
        let ranked_ast = Build.from("ts_search_demo")
          |> Build.where_(Ast.Expr.Fragment("? @@ plainto_tsquery(?)",
               [Ast.Expr.Col("body_tsv"), Ast.Expr.Lit(Ast.SqlValue.PString("postgres search"))]))
          |> Build.select_as(Ast.Expr.Col("title"), "title")
          |> Build.select_as(rank_expr, "rank")
          |> Build.order_by(rank_expr, Ast.Desc)
        let compiled = Compile.compile_parameterized(ranked_ast)
        let rank_result = Db.exec(conn, compiled.sql, compiled.params)

        let _ = Db.query(conn, "DROP TABLE IF EXISTS ts_search_demo")

        -- plainto_tsquery("postgres search") ANDs the terms ('postgr' & 'search'),
        -- so only the row containing BOTH words matches — "Postgres intro"
        -- (only "postgres") and "Cooking" (neither) are correctly excluded.
        let match_ok = match match_result do
          Ok(rows) ->
            match rows do
              Cons(row, Nil) -> row_get(row, "title") == Some("Search deep dive")
              _ -> false
            end
          Err(e) -> do
            let _ = println("ts_match exec_sql err: " ++ e)
            false
          end
        end

        let rank_ok = match rank_result do
          Ok(r) ->
            match r.rows do
              Cons(Cons(Some(top_title), Cons(Some(_), Nil)), Nil) ->
                top_title == "Search deep dive"
              _ -> false
            end
          Err(e) -> do
            let _ = println("ts_rank_expr exec err: " ++ e)
            false
          end
        end

        assert (match_ok && rank_ok)
      end
    end
  )
end

end -- mod TestMigrationExec
