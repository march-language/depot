-- Tests for Depot.Migration — DDL SQL generation and migration tracking.

mod TestDepotMigration do

test "create_table generates CREATE TABLE SQL" do
  let sql = Depot.Migration.create_table("users", {
    id: ("UUID", { primary_key: true }),
    name: "String",
    email: ("String", { null: false })
  })
  assert String.contains(sql, "CREATE TABLE") == true
  assert String.contains(sql, "\"users\"") == true
end

test "create_table with default values" do
  let sql = Depot.Migration.create_table("posts", {
    id: ("UUID", { primary_key: true }),
    status: ("String", { default: "draft" })
  })
  assert String.contains(sql, "DEFAULT 'draft'") == true
end

test "drop_table generates DROP TABLE SQL" do
  let sql = Depot.Migration.drop_table("old_table")
  assert sql == "DROP TABLE \"old_table\""
end

test "create_index with unique option" do
  let sql = Depot.Migration.create_index("users", ["email"], { unique: true })
  assert String.contains(sql, "UNIQUE") == true
  assert String.contains(sql, "\"users_email_index\"") == true
end

test "create_index with custom name" do
  let sql = Depot.Migration.create_index("users", ["email"], { name: "idx_email" })
  assert String.contains(sql, "\"idx_email\"") == true
end

test "create_index_simple generates basic index" do
  let sql = Depot.Migration.create_index_simple("users", ["name", "email"])
  assert String.contains(sql, "\"users_name_email_index\"") == true
  assert String.contains(sql, "\"name\"") == true
  assert String.contains(sql, "\"email\"") == true
end

test "drop_index generates DROP INDEX SQL" do
  let sql = Depot.Migration.drop_index("users_email_index")
  assert sql == "DROP INDEX \"users_email_index\""
end

test "rename_table generates RENAME TO SQL" do
  let sql = Depot.Migration.rename_table("old_name", "new_name")
  assert sql == "ALTER TABLE \"old_name\" RENAME TO \"new_name\""
end

test "rename_column generates RENAME COLUMN SQL" do
  let sql = Depot.Migration.rename_column("users", "name", "full_name")
  assert sql == "ALTER TABLE \"users\" RENAME COLUMN \"name\" TO \"full_name\""
end

test "execute logs raw SQL" do
  let sql = Depot.Migration.execute("INSERT INTO settings VALUES ('key', 'val')")
  assert sql == "INSERT INTO settings VALUES ('key', 'val')"
end

test "migrations_table creates schema_migrations" do
  let sql = Depot.Migration.migrations_table()
  assert String.contains(sql, "schema_migrations") == true
  assert String.contains(sql, "CREATE TABLE IF NOT EXISTS") == true
end

test "record_migration and applied_migrations" do
  Depot.Migration.record_migration(20240101120000)
  let versions = Depot.Migration.applied_migrations()
  assert List.length(versions) > 0
end

test "is_applied checks version status" do
  Depot.Migration.record_migration(20240601000000)
  assert Depot.Migration.is_applied(20240601000000) == true
  assert Depot.Migration.is_applied(99999999999999) == false
end

test "references builds a reference descriptor" do
  let ref = Depot.Migration.references("posts", { column: "post_id", on_delete: "CASCADE" })
  assert record_get(ref, "table") == Some("posts")
  assert record_get(ref, "column") == Some("post_id")
  assert record_get(ref, "on_delete") == Some("CASCADE")
end

test "alter_table with add columns" do
  let stmts = Depot.Migration.alter_table("users", {
    add: { avatar: "String", bio: "String" }
  })
  assert List.length(stmts) == 2
  let first = List.head(stmts)
  assert String.contains(first, "ADD COLUMN") == true
end

test "alter_table with remove columns" do
  let stmts = Depot.Migration.alter_table("users", {
    remove: ["legacy_field"]
  })
  assert List.length(stmts) == 1
  let first = List.head(stmts)
  assert String.contains(first, "DROP COLUMN") == true
  assert String.contains(first, "\"legacy_field\"") == true
end

test "sql type mapping" do
  -- Verify types through create_table output
  let sql = Depot.Migration.create_table("type_test", {
    a: "Int",
    b: "Float",
    c: "Bool",
    d: "UtcDatetime",
    e: "Map"
  })
  assert String.contains(sql, "BIGINT") == true
  assert String.contains(sql, "FLOAT8") == true
  assert String.contains(sql, "BOOLEAN") == true
  assert String.contains(sql, "TIMESTAMPTZ") == true
  assert String.contains(sql, "JSONB") == true
end

test "sql type Date Time Binary" do
  let sql = Depot.Migration.create_table("type_test2", {
    a: "Date",
    b: "Time",
    c: "Binary"
  })
  assert String.contains(sql, "DATE") == true
  assert String.contains(sql, "TIME") == true
  assert String.contains(sql, "BYTEA") == true
end

test "sql type UUID and String" do
  let sql = Depot.Migration.create_table("type_test3", {
    id: "UUID",
    name: "String"
  })
  assert String.contains(sql, "UUID") == true
  assert String.contains(sql, "TEXT") == true
end

test "alter_table with modify columns" do
  let stmts = Depot.Migration.alter_table("users", {
    modify: { name: "String", age: "Int" }
  })
  assert List.length(stmts) == 2
  let first = List.head(stmts)
  assert String.contains(first, "ALTER COLUMN") == true
  assert String.contains(first, "TYPE") == true
end

test "alter_table modify generates correct type" do
  let stmts = Depot.Migration.alter_table("t", {
    modify: { score: "Float" }
  })
  assert List.length(stmts) == 1
  let stmt = List.head(stmts)
  assert String.contains(stmt, "FLOAT8") == true
  assert String.contains(stmt, "\"score\"") == true
end

test "alter_table with add and modify combined" do
  let stmts = Depot.Migration.alter_table("products", {
    add: { description: "String" },
    modify: { price: "Float" }
  })
  assert List.length(stmts) == 2
end

test "alter_table with add modify remove combined" do
  let stmts = Depot.Migration.alter_table("items", {
    add: { notes: "String" },
    modify: { quantity: "Int" },
    remove: ["legacy_col"]
  })
  assert List.length(stmts) == 3
end

test "column_sql with references on_delete CASCADE" do
  let sql = Depot.Migration.create_table("posts", {
    user_id: ("UUID", { references: Depot.Migration.references("users", { on_delete: "CASCADE" }) })
  })
  assert String.contains(sql, "REFERENCES") == true
  assert String.contains(sql, "ON DELETE CASCADE") == true
end

test "column_sql with references on_update SET NULL" do
  let sql = Depot.Migration.create_table("comments", {
    post_id: ("UUID", { references: Depot.Migration.references("posts", { on_update: "SET NULL" }) })
  })
  assert String.contains(sql, "REFERENCES") == true
  assert String.contains(sql, "ON UPDATE SET NULL") == true
end

test "column_sql with references on_delete and on_update" do
  let sql = Depot.Migration.create_table("items", {
    order_id: ("UUID", { references: Depot.Migration.references("orders", { on_delete: "CASCADE", on_update: "CASCADE" }) })
  })
  assert String.contains(sql, "ON DELETE CASCADE") == true
  assert String.contains(sql, "ON UPDATE CASCADE") == true
end

test "create_table with NOT NULL column" do
  let sql = Depot.Migration.create_table("t", {
    email: ("String", { null: false })
  })
  assert String.contains(sql, "NOT NULL") == true
end

test "create_table with primary key column" do
  let sql = Depot.Migration.create_table("t", {
    id: ("UUID", { primary_key: true })
  })
  assert String.contains(sql, "PRIMARY KEY") == true
end

test "create_table with default and not null" do
  let sql = Depot.Migration.create_table("t", {
    role: ("String", { default: "user", null: false })
  })
  assert String.contains(sql, "DEFAULT 'user'") == true
  assert String.contains(sql, "NOT NULL") == true
end

test "create_index non-unique" do
  let sql = Depot.Migration.create_index("users", ["name"], { unique: false })
  assert String.contains(sql, "INDEX") == true
  assert String.contains(sql, "UNIQUE") == false
end

test "create_index with multiple columns" do
  let sql = Depot.Migration.create_index("t", ["a", "b", "c"], { unique: true })
  assert String.contains(sql, "\"a\"") == true
  assert String.contains(sql, "\"b\"") == true
  assert String.contains(sql, "UNIQUE") == true
end

test "drop_index generates correct SQL" do
  let sql = Depot.Migration.drop_index("my_index")
  assert sql == "DROP INDEX \"my_index\""
end

test "rename_table generates correct SQL" do
  let sql = Depot.Migration.rename_table("users", "accounts")
  assert String.contains(sql, "RENAME TO") == true
  assert String.contains(sql, "\"accounts\"") == true
end

test "rename_column generates correct SQL" do
  let sql = Depot.Migration.rename_column("users", "fname", "first_name")
  assert String.contains(sql, "RENAME COLUMN") == true
  assert String.contains(sql, "\"first_name\"") == true
end

test "execute logs arbitrary SQL" do
  let sql = Depot.Migration.execute("CREATE EXTENSION IF NOT EXISTS \"uuid-ossp\"")
  assert String.contains(sql, "uuid-ossp") == true
end

test "applied_migrations returns list" do
  Depot.Migration.record_migration(20250101000001)
  let vs = Depot.Migration.applied_migrations()
  assert List.length(vs) > 0
end

test "is_applied returns true after record" do
  Depot.Migration.record_migration(20250202000002)
  assert Depot.Migration.is_applied(20250202000002) == true
end

test "is_applied returns false for unknown version" do
  assert Depot.Migration.is_applied(99999999991111) == false
end

test "migrations_table contains IF NOT EXISTS" do
  let sql = Depot.Migration.migrations_table()
  assert String.contains(sql, "IF NOT EXISTS") == true
end

test "alter_table remove multiple columns" do
  let stmts = Depot.Migration.alter_table("t", {
    remove: ["col_a", "col_b", "col_c"]
  })
  assert List.length(stmts) == 3
end

end
