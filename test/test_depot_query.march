-- Tests for Depot.Query — composable lazy query builder.
--
-- In-memory execution tests use typed row literals directly (no Depot.Schema
-- needed) so this file compiles standalone without record-introspection builtins.
-- SQL-generation tests use from_table("users") for the same reason.

mod TestDepotQuery do

-- Sample rows as typed record literals — no Depot.Schema.define needed.
fn sample_rows() do
  [
    { id: "1", name: "Alice",   age: 30, active: true },
    { id: "2", name: "Bob",     age: 25, active: false },
    { id: "3", name: "Charlie", age: 35, active: true },
    { id: "4", name: "Diana",   age: 28, active: true },
    { id: "5", name: "Eve",     age: 22, active: false }
  ]
end

-- ---- In-memory execute path ----

test "execute with no operations returns all rows" do
  let q = Depot.Query.from_table("users")
  let results = Depot.Query.execute(q, sample_rows())
  assert List.length(results) == 5
end

test "where_ filters rows" do
  let q = Depot.Query.from_table("users")
    |> Depot.Query.where_(fn row -> row.active)
  let results = Depot.Query.execute(q, sample_rows())
  assert List.length(results) == 3
end

test "multiple where_ calls are AND-combined" do
  -- Two where_ calls each applying the same field type constraint.
  -- March stores predicates in a polymorphic list; same-field predicates
  -- unify cleanly. Mixed-field predicates should use a single combined fn.
  let rows = [
    { id: "1", name: "Alice", age: 30, active: true },
    { id: "2", name: "Alice", age: 25, active: false },
    { id: "3", name: "Bob",   age: 28, active: true }
  ]
  let q = Depot.Query.from_table("t")
    |> Depot.Query.where_(fn row -> row.active)
    |> Depot.Query.where_(fn row -> row.active)
  let results = Depot.Query.execute(q, rows)
  -- Both where_ apply active=true; 2 active rows remain
  assert List.length(results) == 2
end

test "limit restricts result count" do
  let q = Depot.Query.from_table("users")
    |> Depot.Query.limit(2)
  let results = Depot.Query.execute(q, sample_rows())
  assert List.length(results) == 2
end

test "offset skips rows" do
  let q = Depot.Query.from_table("users")
    |> Depot.Query.offset(3)
  let results = Depot.Query.execute(q, sample_rows())
  assert List.length(results) == 2
end

test "limit and offset combine" do
  let q = Depot.Query.from_table("users")
    |> Depot.Query.offset(1)
    |> Depot.Query.limit(2)
  let results = Depot.Query.execute(q, sample_rows())
  assert List.length(results) == 2
end

test "limit 1 returns first row" do
  let q = Depot.Query.from_table("users")
    |> Depot.Query.limit(1)
  let results = Depot.Query.execute(q, sample_rows())
  assert (List.head(results)).name == "Alice"
end

test "count returns number of matching rows" do
  let q = Depot.Query.from_table("users")
    |> Depot.Query.where_(fn row -> row.active)
  let n = Depot.Query.count(q, sample_rows())
  assert n == 3
end

test "exists returns true when results exist" do
  let q = Depot.Query.from_table("users")
    |> Depot.Query.where_(fn row -> row.active)
  assert Depot.Query.exists(q, sample_rows()) == true
end

test "exists returns false when no results" do
  let q = Depot.Query.from_table("users")
    |> Depot.Query.where_(fn row -> row.age > 100)
  assert Depot.Query.exists(q, sample_rows()) == false
end

test "first returns Some for non-empty results" do
  let q = Depot.Query.from_table("users")
  let result = Depot.Query.first(q, sample_rows())
  match result do
    Some(row) -> assert row.name == "Alice"
    None -> assert false
  end
end

test "first returns None for empty results" do
  let q = Depot.Query.from_table("users")
    |> Depot.Query.where_(fn row -> row.age > 100)
  match Depot.Query.first(q, sample_rows()) do
    None    -> assert true
    Some(_) -> assert false
  end
end

test "offset beyond list length returns empty" do
  let q = Depot.Query.from_table("users")
    |> Depot.Query.offset(100)
  let results = Depot.Query.execute(q, sample_rows())
  assert List.length(results) == 0
end

test "limit zero returns empty" do
  let q = Depot.Query.from_table("users")
    |> Depot.Query.limit(0)
  let results = Depot.Query.execute(q, sample_rows())
  assert List.length(results) == 0
end

test "count on empty list returns zero" do
  let q = Depot.Query.from_table("users")
  let n = Depot.Query.count(q, [])
  assert n == 0
end

test "exists on empty list returns false" do
  let q = Depot.Query.from_table("users")
  assert Depot.Query.exists(q, []) == false
end

test "first on empty list returns None" do
  let q = Depot.Query.from_table("users")
  match Depot.Query.first(q, []) do
    None    -> assert true
    Some(_) -> assert false
  end
end

test "full pipeline: where + offset + limit" do
  let q = Depot.Query.from_table("users")
    |> Depot.Query.where_(fn row -> row.active)
    |> Depot.Query.offset(1)
    |> Depot.Query.limit(1)
  let results = Depot.Query.execute(q, sample_rows())
  -- Active rows (in insertion order): Alice, Charlie, Diana
  -- Offset 1 -> Charlie, Diana; Limit 1 -> Charlie
  assert List.length(results) == 1
end

test "where filters to empty then limit returns empty" do
  let q = Depot.Query.from_table("users")
    |> Depot.Query.where_(fn row -> row.age > 100)
    |> Depot.Query.limit(10)
  let results = Depot.Query.execute(q, sample_rows())
  assert List.length(results) == 0
end

test "chained SQL where conditions use AND" do
  -- Multiple SQL where conditions chain AND-style and appear in to_sql.
  let q = Depot.Query.from_table("users")
    |> Depot.Query.where_gt("age", "22")
    |> Depot.Query.where_lt("age", "35")
  let sql = Depot.Query.to_sql(q)
  assert String.contains(sql, "AND")
  assert String.contains(sql, ">")
  assert String.contains(sql, "<")
end

-- ---- SQL generation tests (to_sql / to_params go through Build/Compile) ----

test "to_sql bare table generates SELECT FROM" do
  let q = Depot.Query.from_table("users")
  let sql = Depot.Query.to_sql(q)
  assert String.contains(sql, "FROM")
  assert String.contains(sql, "users")
end

test "to_sql with where_eq adds WHERE clause" do
  let q = Depot.Query.from_table("users")
    |> Depot.Query.where_eq("name", "Alice")
  let sql = Depot.Query.to_sql(q)
  assert String.contains(sql, "WHERE")
  assert String.contains(sql, "name")
end

test "to_sql with where_ne generates <>" do
  let q = Depot.Query.from_table("users")
    |> Depot.Query.where_ne("active", "false")
  let sql = Depot.Query.to_sql(q)
  assert String.contains(sql, "<>")
end

test "to_sql with where_gt generates >" do
  let q = Depot.Query.from_table("users")
    |> Depot.Query.where_gt("age", "18")
  let sql = Depot.Query.to_sql(q)
  assert String.contains(sql, ">")
end

test "to_sql with where_lt generates <" do
  let q = Depot.Query.from_table("users")
    |> Depot.Query.where_lt("age", "65")
  let sql = Depot.Query.to_sql(q)
  assert String.contains(sql, "<")
end

test "to_sql with where_is_null generates IS NULL" do
  let q = Depot.Query.from_table("users")
    |> Depot.Query.where_is_null("deleted_at")
  let sql = Depot.Query.to_sql(q)
  assert String.contains(sql, "IS NULL")
end

test "to_sql with where_is_not_null generates IS NOT NULL" do
  let q = Depot.Query.from_table("users")
    |> Depot.Query.where_is_not_null("email")
  let sql = Depot.Query.to_sql(q)
  assert String.contains(sql, "IS NOT NULL")
end

test "to_sql with where_like generates LIKE" do
  let q = Depot.Query.from_table("users")
    |> Depot.Query.where_like("name", "%alice%")
  let sql = Depot.Query.to_sql(q)
  assert String.contains(sql, "LIKE")
end

test "to_sql with where_ilike generates ILIKE" do
  let q = Depot.Query.from_table("users")
    |> Depot.Query.where_ilike("name", "%alice%")
  let sql = Depot.Query.to_sql(q)
  assert String.contains(sql, "ILIKE")
end

test "to_sql with limit adds LIMIT" do
  let q = Depot.Query.from_table("users")
    |> Depot.Query.limit(5)
  let sql = Depot.Query.to_sql(q)
  assert String.contains(sql, "LIMIT")
end

test "to_sql with offset adds OFFSET" do
  let q = Depot.Query.from_table("users")
    |> Depot.Query.offset(10)
  let sql = Depot.Query.to_sql(q)
  assert String.contains(sql, "OFFSET")
end

test "order_asc query can be constructed" do
  let q = Depot.Query.from_table("users")
    |> Depot.Query.order_asc("age")
  assert true
end

test "to_sql with order_asc produces non-empty SQL" do
  let q = Depot.Query.from_table("users")
    |> Depot.Query.order_asc("age")
  let sql = Depot.Query.to_sql(q)
  assert String.byte_size(sql) > 10
end

test "to_sql with order_asc adds ORDER BY ASC" do
  let q = Depot.Query.from_table("users")
    |> Depot.Query.order_asc("age")
  let sql = Depot.Query.to_sql(q)
  assert String.contains(sql, "ORDER BY")
  assert String.contains(sql, "ASC")
end

test "to_sql with order_desc adds ORDER BY DESC" do
  let q = Depot.Query.from_table("users")
    |> Depot.Query.order_desc("name")
  let sql = Depot.Query.to_sql(q)
  assert String.contains(sql, "DESC")
end

test "to_sql with multiple where conditions uses AND" do
  let q = Depot.Query.from_table("users")
    |> Depot.Query.where_eq("active", "true")
    |> Depot.Query.where_gt("age", "18")
  let sql = Depot.Query.to_sql(q)
  assert String.contains(sql, "AND")
end

test "to_params returns one param per non-nullary condition" do
  let q = Depot.Query.from_table("users")
    |> Depot.Query.where_eq("name", "Alice")
    |> Depot.Query.where_gt("age", "18")
  let params = Depot.Query.to_params(q)
  assert List.length(params) == 2
end

test "to_params returns empty for IS NULL condition" do
  let q = Depot.Query.from_table("users")
    |> Depot.Query.where_is_null("deleted_at")
  let params = Depot.Query.to_params(q)
  assert List.length(params) == 0
end

test "to_params returns empty for IS NOT NULL condition" do
  let q = Depot.Query.from_table("users")
    |> Depot.Query.where_is_not_null("email")
  let params = Depot.Query.to_params(q)
  assert List.length(params) == 0
end

-- ---- Full-text search helpers ----

test "ts_match appends a plainto_tsquery predicate" do
  let q = Depot.Query.from_table("articles")
    |> Depot.Query.ts_match("body_tsv", "postgres search")
  let sql = Depot.Query.to_sql(q)
  assert (String.contains(sql, "@@ plainto_tsquery"))
  assert (String.contains(sql, "\"body_tsv\""))
end

test "ts_match composes with other where_ predicates" do
  let q = Depot.Query.from_table("articles")
    |> Depot.Query.where_gt("views", "100")
    |> Depot.Query.ts_match("body_tsv", "postgres")
  let sql = Depot.Query.to_sql(q)
  assert (String.contains(sql, "views"))
  assert (String.contains(sql, "plainto_tsquery"))
end

test "ts_rank_expr builds a ts_rank fragment expression over the bare column" do
  let e = Depot.Query.ts_rank_expr("body_tsv", "postgres search")
  match e do
    Expr.Fragment(tmpl, args) ->
      let _ = assert (String.contains(tmpl, "ts_rank"))
      let _ = assert (String.contains(tmpl, "body_tsv"))
      -- Must rank the bare tsvector column directly — NOT re-wrap it in
      -- to_tsvector(...), which would be a Postgres type error since
      -- to_tsvector only accepts text, not tsvector, as input. This is
      -- the column-type contract shared with ts_match (see Finding 1).
      let _ = assert (String.contains(tmpl, "to_tsvector") == false)
      assert (List.length(args) == 1)
    _ -> assert false
  end
end

end
