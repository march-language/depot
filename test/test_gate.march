-- test/test_gate.march
-- Tests for Gate module.

mod TestGate do

import Gate

-- ---- cast ----

fn test_cast_filters_fields() do
  let params = Cons(("name", "Alice"), Cons(("email", "a@b.com"), Cons(("secret", "x"), Nil)))
  let form = cast(params, Cons("name", Cons("email", Nil)))
  assert(get_change(form, "name") == Some("Alice"))
  assert(get_change(form, "email") == Some("a@b.com"))
  assert(get_change(form, "secret") == None)
end

fn test_cast_starts_valid() do
  let form = cast(Cons(("name", "Alice"), Nil), Cons("name", Nil))
  assert(is_valid(form))
end

fn test_cast_empty_params() do
  let form = cast(Nil, Cons("name", Nil))
  assert(is_valid(form))
  assert(get_change(form, "name") == None)
end

-- ---- add_error / is_valid / errors / get_errors ----

fn test_add_error_marks_invalid() do
  let form = cast(Nil, Nil)
  let form2 = add_error(form, "name", "can't be blank")
  assert(!is_valid(form2))
end

fn test_errors_returns_all() do
  let form = cast(Nil, Nil)
  let form2 = add_error(form, "name", "can't be blank")
  let form3 = add_error(form2, "email", "is invalid")
  assert(length(errors(form3)) == 2)
end

fn test_get_errors_field_specific() do
  let form = cast(Nil, Nil)
  let form2 = add_error(form, "email", "is invalid")
  let form3 = add_error(form2, "email", "is too short")
  let errs = get_errors(form3, "email")
  assert(List.member(errs, "is invalid"))
  assert(List.member(errs, "is too short"))
end

fn test_get_errors_empty_for_unknown_field() do
  let form = cast(Nil, Nil)
  assert(get_errors(form, "missing") == Nil)
end

-- ---- put_change / delete_change / changed / changed_fields ----

fn test_put_change_adds_change() do
  let form = cast(Nil, Nil)
  let form2 = put_change(form, "role", "admin")
  assert(get_change(form2, "role") == Some("admin"))
end

fn test_put_change_overwrites() do
  let form = cast(Cons(("role", "user"), Nil), Cons("role", Nil))
  let form2 = put_change(form, "role", "admin")
  assert(get_change(form2, "role") == Some("admin"))
end

fn test_delete_change_removes_field() do
  let form = cast(Cons(("pw", "secret"), Nil), Cons("pw", Nil))
  let form2 = delete_change(form, "pw")
  assert(get_change(form2, "pw") == None)
end

fn test_changed_true_for_present() do
  let form = cast(Cons(("name", "Alice"), Nil), Cons("name", Nil))
  assert(changed(form, "name"))
end

fn test_changed_false_for_absent() do
  let form = cast(Cons(("name", "Alice"), Nil), Cons("name", Nil))
  assert(!changed(form, "email"))
end

fn test_changed_fields_lists_changes() do
  let form = cast(Cons(("name", "Alice"), Cons(("age", "30"), Nil)), Cons("name", Cons("age", Nil)))
  let fields = changed_fields(form)
  assert(List.member(fields, "name"))
  assert(List.member(fields, "age"))
end

-- ---- get_field ----

fn test_get_field_returns_change() do
  let form = cast(Nil, Nil)
  let form2 = put_change(form, "role", "admin")
  assert(get_field(form2, "role") == Some("admin"))
end

fn test_get_field_falls_back_to_params() do
  let params = Cons(("name", "Alice"), Nil)
  let form = cast(params, Nil)
  assert(get_field(form, "name") == Some("Alice"))
end

-- ---- validate_required ----

fn test_validate_required_missing_field() do
  let form = cast(Nil, Nil)
  let form2 = validate_required(form, Cons("name", Nil))
  assert(!is_valid(form2))
  assert(List.member(get_errors(form2, "name"), "can't be blank"))
end

fn test_validate_required_empty_string() do
  let form = cast(Cons(("name", ""), Nil), Cons("name", Nil))
  let form2 = validate_required(form, Cons("name", Nil))
  assert(!is_valid(form2))
end

fn test_validate_required_whitespace_only() do
  let form = cast(Cons(("name", "   "), Nil), Cons("name", Nil))
  let form2 = validate_required(form, Cons("name", Nil))
  assert(!is_valid(form2))
end

fn test_validate_required_present() do
  let form = cast(Cons(("name", "Alice"), Nil), Cons("name", Nil))
  let form2 = validate_required(form, Cons("name", Nil))
  assert(is_valid(form2))
end

fn test_validate_required_multiple_fields() do
  let params = Cons(("name", "Alice"), Cons(("email", ""), Nil))
  let form = cast(params, Cons("name", Cons("email", Nil)))
  let form2 = validate_required(form, Cons("name", Cons("email", Nil)))
  assert(!is_valid(form2))
  assert(get_errors(form2, "name") == Nil)
  assert(List.member(get_errors(form2, "email"), "can't be blank"))
end

-- ---- validate_length ----

fn test_validate_length_min_fail() do
  let form = cast(Cons(("name", "A"), Nil), Cons("name", Nil))
  let form2 = validate_length(form, "name", Cons(LenMin(2), Nil))
  assert(!is_valid(form2))
end

fn test_validate_length_min_pass() do
  let form = cast(Cons(("name", "Alice"), Nil), Cons("name", Nil))
  let form2 = validate_length(form, "name", Cons(LenMin(2), Nil))
  assert(is_valid(form2))
end

fn test_validate_length_max_fail() do
  let form = cast(Cons(("name", "Alice"), Nil), Cons("name", Nil))
  let form2 = validate_length(form, "name", Cons(LenMax(3), Nil))
  assert(!is_valid(form2))
end

fn test_validate_length_max_pass() do
  let form = cast(Cons(("name", "Al"), Nil), Cons("name", Nil))
  let form2 = validate_length(form, "name", Cons(LenMax(3), Nil))
  assert(is_valid(form2))
end

fn test_validate_length_exact_pass() do
  let form = cast(Cons(("code", "ABC"), Nil), Cons("code", Nil))
  let form2 = validate_length(form, "code", Cons(LenExact(3), Nil))
  assert(is_valid(form2))
end

fn test_validate_length_exact_fail() do
  let form = cast(Cons(("code", "AB"), Nil), Cons("code", Nil))
  let form2 = validate_length(form, "code", Cons(LenExact(3), Nil))
  assert(!is_valid(form2))
end

fn test_validate_length_missing_field_skipped() do
  let form = cast(Nil, Nil)
  let form2 = validate_length(form, "name", Cons(LenMin(2), Nil))
  assert(is_valid(form2))
end

-- ---- validate_format ----

fn test_validate_format_pass() do
  let form = cast(Cons(("email", "a@b.com"), Nil), Cons("email", Nil))
  let form2 = validate_format(form, "email", "@")
  assert(is_valid(form2))
end

fn test_validate_format_fail() do
  let form = cast(Cons(("email", "notanemail"), Nil), Cons("email", Nil))
  let form2 = validate_format(form, "email", "@")
  assert(!is_valid(form2))
  assert(List.member(get_errors(form2, "email"), "has invalid format"))
end

fn test_validate_format_missing_field_skipped() do
  let form = cast(Nil, Nil)
  let form2 = validate_format(form, "email", "@")
  assert(is_valid(form2))
end

-- ---- validate_inclusion ----

fn test_validate_inclusion_pass() do
  let form = cast(Cons(("role", "admin"), Nil), Cons("role", Nil))
  let form2 = validate_inclusion(form, "role", Cons("user", Cons("admin", Nil)))
  assert(is_valid(form2))
end

fn test_validate_inclusion_fail() do
  let form = cast(Cons(("role", "superuser"), Nil), Cons("role", Nil))
  let form2 = validate_inclusion(form, "role", Cons("user", Cons("admin", Nil)))
  assert(!is_valid(form2))
  assert(List.member(get_errors(form2, "role"), "is not a valid value"))
end

-- ---- validate_exclusion ----

fn test_validate_exclusion_pass() do
  let form = cast(Cons(("username", "alice"), Nil), Cons("username", Nil))
  let form2 = validate_exclusion(form, "username", Cons("root", Cons("admin", Nil)))
  assert(is_valid(form2))
end

fn test_validate_exclusion_fail() do
  let form = cast(Cons(("username", "root"), Nil), Cons("username", Nil))
  let form2 = validate_exclusion(form, "username", Cons("root", Cons("admin", Nil)))
  assert(!is_valid(form2))
  assert(List.member(get_errors(form2, "username"), "is reserved"))
end

-- ---- validate_number ----

fn test_validate_number_min_pass() do
  let form = cast(Cons(("age", "20"), Nil), Cons("age", Nil))
  let form2 = validate_number(form, "age", Cons(NumMin(13), Nil))
  assert(is_valid(form2))
end

fn test_validate_number_min_fail() do
  let form = cast(Cons(("age", "10"), Nil), Cons("age", Nil))
  let form2 = validate_number(form, "age", Cons(NumMin(13), Nil))
  assert(!is_valid(form2))
end

fn test_validate_number_max_fail() do
  let form = cast(Cons(("age", "200"), Nil), Cons("age", Nil))
  let form2 = validate_number(form, "age", Cons(NumMax(150), Nil))
  assert(!is_valid(form2))
end

fn test_validate_number_not_a_number() do
  let form = cast(Cons(("age", "abc"), Nil), Cons("age", Nil))
  let form2 = validate_number(form, "age", Nil)
  assert(!is_valid(form2))
  assert(List.member(get_errors(form2, "age"), "is not a number"))
end

fn test_validate_number_equal_to_pass() do
  let form = cast(Cons(("qty", "5"), Nil), Cons("qty", Nil))
  let form2 = validate_number(form, "qty", Cons(NumEqualTo(5), Nil))
  assert(is_valid(form2))
end

fn test_validate_number_equal_to_fail() do
  let form = cast(Cons(("qty", "4"), Nil), Cons("qty", Nil))
  let form2 = validate_number(form, "qty", Cons(NumEqualTo(5), Nil))
  assert(!is_valid(form2))
end

fn test_validate_number_greater_than_pass() do
  let form = cast(Cons(("score", "10"), Nil), Cons("score", Nil))
  let form2 = validate_number(form, "score", Cons(NumGreaterThan(5), Nil))
  assert(is_valid(form2))
end

fn test_validate_number_less_than_fail() do
  let form = cast(Cons(("score", "10"), Nil), Cons("score", Nil))
  let form2 = validate_number(form, "score", Cons(NumLessThan(5), Nil))
  assert(!is_valid(form2))
end

-- ---- validate_acceptance ----

fn test_validate_acceptance_true() do
  let form = cast(Cons(("tos", "true"), Nil), Cons("tos", Nil))
  let form2 = validate_acceptance(form, "tos")
  assert(is_valid(form2))
end

fn test_validate_acceptance_one() do
  let form = cast(Cons(("tos", "1"), Nil), Cons("tos", Nil))
  let form2 = validate_acceptance(form, "tos")
  assert(is_valid(form2))
end

fn test_validate_acceptance_false_fails() do
  let form = cast(Cons(("tos", "false"), Nil), Cons("tos", Nil))
  let form2 = validate_acceptance(form, "tos")
  assert(!is_valid(form2))
end

fn test_validate_acceptance_missing_fails() do
  let form = cast(Nil, Nil)
  let form2 = validate_acceptance(form, "tos")
  assert(!is_valid(form2))
end

-- ---- validate_confirmation ----

fn test_validate_confirmation_pass() do
  let params = Cons(("pw", "secret"), Cons(("pw_confirmation", "secret"), Nil))
  let form = cast(params, Cons("pw", Cons("pw_confirmation", Nil)))
  let form2 = validate_confirmation(form, "pw")
  assert(is_valid(form2))
end

fn test_validate_confirmation_mismatch() do
  let params = Cons(("pw", "secret"), Cons(("pw_confirmation", "wrong"), Nil))
  let form = cast(params, Cons("pw", Cons("pw_confirmation", Nil)))
  let form2 = validate_confirmation(form, "pw")
  assert(!is_valid(form2))
end

fn test_validate_confirmation_missing_confirmation() do
  let params = Cons(("pw", "secret"), Nil)
  let form = cast(params, Cons("pw", Nil))
  let form2 = validate_confirmation(form, "pw")
  assert(!is_valid(form2))
end

-- ---- validate_change ----

fn test_validate_change_pass() do
  let form = cast(Cons(("name", "Alice"), Nil), Cons("name", Nil))
  let form2 = validate_change(form, "name", fn v ->
    if String.byte_size(v) >= 2 do None else Some("too short") end)
  assert(is_valid(form2))
end

fn test_validate_change_fail() do
  let form = cast(Cons(("name", "A"), Nil), Cons("name", Nil))
  let form2 = validate_change(form, "name", fn v ->
    if String.byte_size(v) >= 2 do None else Some("too short") end)
  assert(!is_valid(form2))
  assert(List.member(get_errors(form2, "name"), "too short"))
end

fn test_validate_change_missing_field_skipped() do
  let form = cast(Nil, Nil)
  let form2 = validate_change(form, "name", fn _ -> Some("error"))
  assert(is_valid(form2))
end

-- ---- apply_changes ----

fn test_apply_changes_includes_base_and_changes() do
  let params = Cons(("name", "Alice"), Cons(("email", "a@b.com"), Nil))
  let form = cast(params, Cons("name", Cons("email", Nil)))
  let result = apply_changes(form)
  assert(List.member(result, ("name", "Alice")))
  assert(List.member(result, ("email", "a@b.com")))
end

fn test_apply_changes_reflects_put_change() do
  let params = Cons(("role", "user"), Nil)
  let form = cast(params, Cons("role", Nil))
  let form2 = put_change(form, "role", "admin")
  let result = apply_changes(form2)
  assert(List.member(result, ("role", "admin")))
end

-- ---- base / changed_fields ----

fn test_base_returns_original_params() do
  let params = Cons(("name", "Alice"), Nil)
  let form = cast(params, Nil)
  assert(base(form) == params)
end

-- ---- constraint hints ----

fn test_unique_constraint_applied() do
  let form = cast(Nil, Nil)
  let form2 = unique_constraint(form, "email",
    Cons(ConstraintName("users_email_index"), Nil))
  let form3 = apply_constraint_error(form2, "users_email_index")
  assert(!is_valid(form3))
  assert(List.member(get_errors(form3, "email"), "has already been taken"))
end

fn test_unique_constraint_custom_message() do
  let form = cast(Nil, Nil)
  let form2 = unique_constraint(form, "email",
    Cons(ConstraintName("users_email_index"), Cons(ConstraintMessage("already used"), Nil)))
  let form3 = apply_constraint_error(form2, "users_email_index")
  assert(List.member(get_errors(form3, "email"), "already used"))
end

fn test_constraint_no_match_unchanged() do
  let form = cast(Nil, Nil)
  let form2 = unique_constraint(form, "email",
    Cons(ConstraintName("users_email_index"), Nil))
  let form3 = apply_constraint_error(form2, "other_index")
  assert(is_valid(form3))
end

fn test_foreign_key_constraint_applied() do
  let form = cast(Nil, Nil)
  let form2 = foreign_key_constraint(form, "user_id",
    Cons(ConstraintName("posts_user_id_fkey"), Nil))
  let form3 = apply_constraint_error(form2, "posts_user_id_fkey")
  assert(!is_valid(form3))
  assert(List.member(get_errors(form3, "user_id"), "does not exist"))
end

fn test_check_constraint_applied() do
  let form = cast(Nil, Nil)
  let form2 = check_constraint(form, "age",
    Cons(ConstraintName("users_age_check"), Cons(ConstraintMessage("must be 13 or older"), Nil)))
  let form3 = apply_constraint_error(form2, "users_age_check")
  assert(!is_valid(form3))
  assert(List.member(get_errors(form3, "age"), "must be 13 or older"))
end

-- ---- pipeline chaining ----

fn test_pipeline_multiple_validators() do
  let params = Cons(("name", ""), Cons(("email", "notvalid"), Cons(("age", "10"), Nil)))
  let form = cast(params, Cons("name", Cons("email", Cons("age", Nil))))
    |> validate_required(Cons("name", Nil))
    |> validate_format("email", "@")
    |> validate_number("age", Cons(NumMin(13), Nil))
  assert(!is_valid(form))
  assert(List.member(get_errors(form, "name"), "can't be blank"))
  assert(List.member(get_errors(form, "email"), "has invalid format"))
  assert(List.member(get_errors(form, "age"), "must be greater than or equal to 13"))
end

end -- mod TestGate
