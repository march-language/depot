-- test/test_mutation.march
-- Tests for DML ADT types, builders, and compiler.

mod TestMutation do

import Ast
import Message
import Mutation
import MutationBuild
import MutationCompile
import Build
import Compile

-- ---- Helpers ----

fn list_len(lst) do
  match lst do | Nil -> 0 | Cons(_, rest) -> 1 + list_len(rest) end
end

-- ---- ADT type tests ----

test "Insert ADT type" do
  let i = Insert({
    table_: "users",
    columns: ["name", "email"],
    rows: [[PString("Alice"), PString("a@b.com")]],
    on_conflict: None,
    returning_: Nil
  })
  match i do
  Insert(f) -> do
    assert f.table_ == "users"
    assert list_len(f.columns) == 2
    match f.on_conflict do
    None -> ()
    _ -> assert false
    end
  end
  end
end

test "Update ADT type" do
  let u = Update({
    table_: "users",
    sets: [("name", Lit(PString("Bob")))],
    wheres: [Where(Expr.Eq(Expr.Col("id"), Lit(PInt(1))))],
    returning_: [SelectAll]
  })
  match u do
  Update(f) -> do
    assert f.table_ == "users"
    assert List.length(f.sets) == 1
    match f.returning_ do
    Cons(SelectAll, Nil) -> ()
    _ -> assert false
    end
  end
  end
end

test "Delete ADT type" do
  let d = Delete.Delete({
    table_: "posts",
    wheres: [Where(Expr.Eq(Expr.Col("id"), Lit(PInt(99))))],
    returning_: Nil
  })
  match d do
  Delete.Delete(f) -> do
    assert f.table_ == "posts"
    assert List.length(f.wheres) == 1
  end
  end
end

test "DoNothing conflict variant" do
  match DoNothing do
  DoNothing -> ()
  _ -> assert false
  end
end

test "DoUpdate conflict variant" do
  match DoUpdate([("name", Lit(PString("new")))]) do
  DoUpdate(sets) ->
    match sets do
    Cons(("name", _), Nil) -> ()
    _ -> assert false
    end
  _ -> assert false
  end
end

-- ---- Builder tests ----

test "insert builder" do
  let i = insert_into("users")
         |> insert_cols(["id", "name"])
         |> insert_row([PInt(1), PString("Alice")])
         |> insert_row([PInt(2), PString("Bob")])
         |> insert_returning_all()
  match i do
  Insert(f) -> do
    assert f.table_ == "users"
    assert list_len(f.columns) == 2
    assert List.length(f.rows) == 2
    match f.returning_ do
    Cons(SelectAll, Nil) -> ()
    _ -> assert false
    end
  end
  end
end

test "insert ON CONFLICT DO NOTHING builder" do
  let i = insert_into("t")
         |> insert_cols(["x"])
         |> insert_row([PInt(1)])
         |> on_conflict_do_nothing()
  match i do
  Insert(f) ->
    match f.on_conflict do
    Some(DoNothing) -> ()
    _ -> assert false
    end
  end
end

test "update builder" do
  let u = update("users")
         |> set_("name", Lit(PString("Carol")))
         |> set_("active", Lit(PBool(true)))
         |> update_where(Expr.Eq(Expr.Col("id"), Lit(PInt(7))))
         |> update_returning_all()
  match u do
  Update(f) -> do
    assert f.table_ == "users"
    assert List.length(f.sets) == 2
    assert List.length(f.wheres) == 1
    match f.returning_ do
    Cons(SelectAll, Nil) -> ()
    _ -> assert false
    end
  end
  end
end

test "delete builder" do
  let d = delete_from("sessions")
         |> delete_where(Expr.Eq(Expr.Col("user_id"), Lit(PInt(42))))
  match d do
  Delete.Delete(f) -> do
    assert f.table_ == "sessions"
    assert List.length(f.wheres) == 1
  end
  end
end

test "delete with RETURNING builder" do
  let d = delete_from("tokens")
         |> delete_where(Expr.Eq(Expr.Col("user_id"), Lit(PInt(7))))
         |> delete_returning([SelectField(Expr.Col("id"))])
  match d do
  Delete.Delete(f) ->
    match f.returning_ do
    Cons(SelectField(_), Nil) -> ()
    _ -> assert false
    end
  end
end

test "ON CONFLICT DO UPDATE builder" do
  let i = insert_into("tags")
         |> insert_cols(["name", "slug"])
         |> insert_row([PString("Rust"), PString("rust")])
         |> on_conflict_do_update([("slug", Lit(PString("rust")))])
  match i do
  Insert(f) ->
    match f.on_conflict do
    Some(DoUpdate(sets)) ->
      match sets do
      Cons(("slug", _), Nil) -> ()
      _ -> assert false
      end
    _ -> assert false
    end
  end
end

test "insert_many builder" do
  let rows = [
    [PInt(1), PString("Alice")],
    [PInt(2), PString("Bob")],
    [PInt(3), PString("Carol")]
  ]
  let i = insert_many("users", ["id", "name"], rows)
  match i do
  Insert(f) -> do
    assert f.table_ == "users"
    assert List.length(f.rows) == 3
  end
  end
end

-- ---- Compiler tests ----

test "compile INSERT" do
  let i = Insert({ table_: "t", columns: ["x"], rows: [[PInt(1)]], on_conflict: None, returning_: Nil })
  let r = compile_insert(i)
  let sql = r.sql
  assert String.byte_size(sql) > 0
end

test "compile INSERT many rows" do
  let i = insert_many("t", ["x", "y"], [[PInt(1), PInt(2)], [PInt(3), PInt(4)]])
  let r = compile_insert(i)
  let sql = r.sql
  assert sql == "INSERT INTO \"t\" (\"x\", \"y\") VALUES ($1, $2), ($3, $4)"
  assert List.length(r.params) == 4
end

test "compile INSERT ON CONFLICT DO NOTHING" do
  let i = insert_into("t")
         |> insert_cols(["id"])
         |> insert_row([PInt(1)])
         |> on_conflict_do_nothing()
  let r = compile_insert(i)
  let sql = r.sql
  assert sql == "INSERT INTO \"t\" (\"id\") VALUES ($1) ON CONFLICT DO NOTHING"
end

test "compile UPDATE" do
  let u = update("users")
         |> set_("active", Lit(PBool(false)))
         |> update_where(Expr.Eq(Expr.Col("id"), Lit(PInt(42))))
         |> update_returning_all()
  let r = compile_update(u)
  let sql = r.sql
  assert sql == "UPDATE \"users\" SET \"active\" = $1 WHERE \"id\" = $2 RETURNING *"
  assert List.length(r.params) == 2
end

test "compile UPDATE multiple SET" do
  let u = update("orders")
         |> set_("status", Lit(PString("shipped")))
         |> set_("shipped_at", Lit(PString("2026-01-01")))
         |> update_where(Expr.Eq(Expr.Col("id"), Lit(PInt(7))))
  let r = compile_update(u)
  let sql = r.sql
  assert sql == "UPDATE \"orders\" SET \"status\" = $1, \"shipped_at\" = $2 WHERE \"id\" = $3"
  assert List.length(r.params) == 3
end

test "compile DELETE with RETURNING" do
  let d = delete_from("sessions")
         |> delete_where(Expr.Eq(Expr.Col("user_id"), Lit(PInt(5))))
         |> delete_returning_all()
  let r = compile_delete(d)
  let sql = r.sql
  assert sql == "DELETE FROM \"sessions\" WHERE \"user_id\" = $1 RETURNING *"
  assert List.length(r.params) == 1
end

test "compile DELETE without RETURNING" do
  let d = delete_from("logs")
         |> delete_where(Expr.Lt(Expr.Col("created_at"), Lit(PString("2025-01-01"))))
  let r = compile_delete(d)
  let sql = r.sql
  assert sql == "DELETE FROM \"logs\" WHERE \"created_at\" < $1"
  assert List.length(r.params) == 1
end

-- ---- WHERE expression operator tests ----

test "compile UPDATE WHERE Neq" do
  let u = update("t")
         |> set_("v", Lit(PInt(1)))
         |> update_where(Expr.Neq(Expr.Col("id"), Lit(PInt(99))))
  let r = compile_update(u)
  let sql = r.sql
  assert sql == "UPDATE \"t\" SET \"v\" = $1 WHERE \"id\" <> $2"
end

test "compile UPDATE WHERE Lt" do
  let u = update("orders")
         |> set_("flagged", Lit(PBool(true)))
         |> update_where(Expr.Lt(Expr.Col("total"), Lit(PInt(10))))
  let r = compile_update(u)
  let sql = r.sql
  assert sql == "UPDATE \"orders\" SET \"flagged\" = $1 WHERE \"total\" < $2"
end

test "compile UPDATE WHERE Gt" do
  let u = update("users")
         |> set_("senior", Lit(PBool(true)))
         |> update_where(Expr.Gt(Expr.Col("age"), Lit(PInt(60))))
  let r = compile_update(u)
  let sql = r.sql
  assert sql == "UPDATE \"users\" SET \"senior\" = $1 WHERE \"age\" > $2"
end

test "compile UPDATE WHERE Lte" do
  let u = update("items")
         |> set_("active", Lit(PBool(false)))
         |> update_where(Expr.Lte(Expr.Col("stock"), Lit(PInt(0))))
  let r = compile_update(u)
  let sql = r.sql
  assert sql == "UPDATE \"items\" SET \"active\" = $1 WHERE \"stock\" <= $2"
end

test "compile UPDATE WHERE Gte" do
  let u = update("tasks")
         |> set_("priority", Lit(PString("high")))
         |> update_where(Expr.Gte(Expr.Col("score"), Lit(PInt(90))))
  let r = compile_update(u)
  let sql = r.sql
  assert sql == "UPDATE \"tasks\" SET \"priority\" = $1 WHERE \"score\" >= $2"
end

test "compile DELETE WHERE And" do
  let d = delete_from("sessions")
         |> delete_where(Expr.And(
              Expr.Eq(Expr.Col("user_id"), Lit(PInt(1))),
              Expr.Eq(Expr.Col("active"), Lit(PBool(false)))))
  let r = compile_delete(d)
  let sql = r.sql
  assert sql == "DELETE FROM \"sessions\" WHERE (\"user_id\" = $1 AND \"active\" = $2)"
  assert List.length(r.params) == 2
end

test "compile DELETE WHERE Or" do
  let d = delete_from("logs")
         |> delete_where(Expr.Or(
              Expr.Eq(Expr.Col("level"), Lit(PString("debug"))),
              Expr.Eq(Expr.Col("level"), Lit(PString("trace")))))
  let r = compile_delete(d)
  let sql = r.sql
  assert sql == "DELETE FROM \"logs\" WHERE (\"level\" = $1 OR \"level\" = $2)"
end

test "compile DELETE WHERE Not" do
  let d = delete_from("bans")
         |> delete_where(Expr.Not(Expr.Eq(Expr.Col("active"), Lit(PBool(true)))))
  let r = compile_delete(d)
  let sql = r.sql
  assert sql == "DELETE FROM \"bans\" WHERE NOT (\"active\" = $1)"
end

test "compile DELETE WHERE IsNull" do
  let d = delete_from("drafts")
         |> delete_where(Expr.IsNull(Expr.Col("published_at")))
  let r = compile_delete(d)
  let sql = r.sql
  assert sql == "DELETE FROM \"drafts\" WHERE \"published_at\" IS NULL"
  assert List.length(r.params) == 0
end

test "compile DELETE WHERE IsNotNull" do
  let d = delete_from("queue")
         |> delete_where(Expr.IsNotNull(Expr.Col("completed_at")))
  let r = compile_delete(d)
  let sql = r.sql
  assert sql == "DELETE FROM \"queue\" WHERE \"completed_at\" IS NOT NULL"
end

test "compile UPDATE WHERE In" do
  let u = update("users")
         |> set_("notified", Lit(PBool(true)))
         |> update_where(In(Expr.Col("id"), [Lit(PInt(1)), Lit(PInt(2)), Lit(PInt(3))]))
  let r = compile_update(u)
  let sql = r.sql
  assert sql == "UPDATE \"users\" SET \"notified\" = $1 WHERE \"id\" IN ($2, $3, $4)"
  assert List.length(r.params) == 4
end

test "compile UPDATE WHERE NotIn" do
  let u = update("posts")
         |> set_("visible", Lit(PBool(false)))
         |> update_where(NotIn(Expr.Col("status"), [Lit(PString("published")), Lit(PString("featured"))]))
  let r = compile_update(u)
  let sql = r.sql
  assert sql == "UPDATE \"posts\" SET \"visible\" = $1 WHERE \"status\" NOT IN ($2, $3)"
end

test "compile UPDATE WHERE Between" do
  let u = update("products")
         |> set_("on_sale", Lit(PBool(true)))
         |> update_where(Between(Expr.Col("price"), Lit(PInt(10)), Lit(PInt(50))))
  let r = compile_update(u)
  let sql = r.sql
  assert sql == "UPDATE \"products\" SET \"on_sale\" = $1 WHERE \"price\" BETWEEN $2 AND $3"
  assert List.length(r.params) == 3
end

test "compile DELETE WHERE FnCall" do
  let d = delete_from("users")
         |> delete_where(Expr.Eq(FnCall("LOWER", [Expr.Col("email")]), Lit(PString("test@test.com"))))
  let r = compile_delete(d)
  let sql = r.sql
  assert sql == "DELETE FROM \"users\" WHERE LOWER(\"email\") = $1"
end

test "compile DELETE WHERE Like" do
  let d = delete_from("logs")
         |> delete_where(Like(Expr.Col("message"), "%error%"))
  let r = compile_delete(d)
  let sql = r.sql
  assert sql == "DELETE FROM \"logs\" WHERE \"message\" LIKE '%error%'"
end

test "compile DELETE WHERE ILike" do
  let d = delete_from("comments")
         |> delete_where(ILike(Expr.Col("body"), "%spam%"))
  let r = compile_delete(d)
  let sql = r.sql
  assert sql == "DELETE FROM \"comments\" WHERE \"body\" ILIKE '%spam%'"
end

test "compile UPDATE WHERE Raw expr" do
  let u = update("t")
         |> set_("v", Lit(PInt(1)))
         |> update_where(Raw("\"x\" = NOW()"))
  let r = compile_update(u)
  let sql = r.sql
  assert sql == "UPDATE \"t\" SET \"v\" = $1 WHERE \"x\" = NOW()"
end

