test "compile multiple WHERE params in mutation module" do
  let q = Query({ from_: FromTable("t"), selects: Nil,
    wheres: [Where(Expr.Eq(Expr.Col("x"), Lit(PInt(1)))), Where(Expr.Eq(Expr.Col("y"), Lit(PString("z"))))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let r = compile(q)
  let sql = r.sql
  assert String.contains(sql, "WHERE") == true

end

-- ---- compile_expr_m coverage (parameterized mutation expressions) ----

test "mutation UPDATE with all binops" do
  let u = update("t")
    |> set_("a", Lit(PInt(1)))
    |> set_("b", Lit(PFloat(1.5)))
    |> set_("c", Lit(PBool(true)))
    |> set_("d", Lit(PNull))
    |> update_where(Expr.Neq(Expr.Col("a"), Lit(PInt(0))))
    |> update_where(Expr.Lt(Expr.Col("b"), Lit(PInt(10))))
    |> update_where(Expr.Gt(Expr.Col("c"), Lit(PInt(0))))
    |> update_where(Expr.Lte(Expr.Col("d"), Lit(PInt(100))))
    |> update_where(Expr.Gte(Expr.Col("e"), Lit(PInt(5))))
    |> update_where(Expr.And(Expr.IsNull(Expr.Col("x")), Expr.IsNotNull(Expr.Col("y"))))
    |> update_where(Expr.Or(Expr.Eq(Expr.Col("p"), Lit(PInt(1))), Expr.Eq(Expr.Col("p"), Lit(PInt(2)))))
    |> update_where(Expr.Not(Expr.Eq(Expr.Col("q"), Lit(PInt(0)))))
  let r = compile_update(u)
  let sql = r.sql
  assert String.contains(sql, "UPDATE") == true
  let sql = r.sql
  assert String.contains(sql, "SET") == true
  let sql = r.sql
  assert String.contains(sql, "<>") == true
  let sql = r.sql
  assert String.contains(sql, "<") == true
  let sql = r.sql
  assert String.contains(sql, ">") == true
  let sql = r.sql
  assert String.contains(sql, "<=") == true
  let sql = r.sql
  assert String.contains(sql, ">=") == true
  let sql = r.sql
  assert String.contains(sql, "IS NULL") == true
  let sql = r.sql
  assert String.contains(sql, "IS NOT NULL") == true
  let sql = r.sql
  assert String.contains(sql, "AND") == true
  let sql = r.sql
  assert String.contains(sql, "OR") == true
  let sql = r.sql
  assert String.contains(sql, "NOT") == true
end

test "mutation DELETE with complex where" do
  let d = delete_from("t")
    |> delete_where(Expr.And(Expr.Eq(Expr.Col("status"), Lit(PString("deleted"))),
                        Expr.Lt(Expr.Col("updated_at"), Lit(PString("2026-01-01")))))
    |> delete_returning([SelectField(Expr.Col("id"))])
  let r = compile_delete(d)
  let sql = r.sql
  assert String.contains(sql, "DELETE FROM") == true
  let sql = r.sql
  assert String.contains(sql, "AND") == true
  let sql = r.sql
  assert String.contains(sql, "RETURNING") == true
end

test "mutation DELETE returning all" do
  let d = delete_from("t")
    |> delete_where(Expr.Eq(Expr.Col("id"), Lit(PInt(1))))
    |> delete_returning_all()
  let r = compile_delete(d)
  let sql = r.sql
  assert String.contains(sql, "RETURNING *") == true
end

test "mutation INSERT with ON CONFLICT DO NOTHING" do
  let i = insert_into("t")
    |> insert_cols(["a", "b"])
    |> insert_row([PInt(1), PString("x")])
    |> on_conflict_do_nothing()
  let r = compile_insert(i)
  let sql = r.sql
  assert String.contains(sql, "ON CONFLICT DO NOTHING") == true
end

test "mutation INSERT with ON CONFLICT DO UPDATE" do
  let i = insert_into("t")
    |> insert_cols(["a", "b"])
    |> insert_row([PInt(1), PString("x")])
    |> on_conflict_do_update([("a", Expr.Col("a")), ("b", Raw("EXCLUDED.b"))])
  let r = compile_insert(i)
  let sql = r.sql
  assert String.contains(sql, "ON CONFLICT DO UPDATE SET") == true
  let sql = r.sql
  assert String.contains(sql, "EXCLUDED.b") == true
end

test "mutation INSERT returning specific" do
  let i = insert_into("t")
    |> insert_cols(["a"])
    |> insert_row([PInt(1)])
    |> insert_returning([SelectField(Expr.Col("id")), SelectField(Expr.Col("a"))])
  let r = compile_insert(i)
  let sql = r.sql
  assert String.contains(sql, "RETURNING") == true
end

test "mutation INSERT returning all" do
  let i = insert_into("t")
    |> insert_cols(["a"])
    |> insert_row([PInt(1)])
    |> insert_returning_all()
  let r = compile_insert(i)
  let sql = r.sql
  assert String.contains(sql, "RETURNING *") == true
end

test "mutation INSERT multi-row" do
  let i = insert_into("t")
    |> insert_cols(["a", "b"])
    |> insert_row([PInt(1), PString("x")])
    |> insert_row([PInt(2), PString("y")])
    |> insert_row([PInt(3), PString("z")])
  let r = compile_insert(i)
  let sql = r.sql
  assert String.contains(sql, "INSERT INTO") == true
  assert List.length(r.params) == 6
end

end -- mod TestMutation
