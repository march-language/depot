test "compile UPDATE OrWhere" do
  let u = Update({
    table_: "users",
    sets: [("active", Lit(PBool(false)))],
    wheres: [Where(Expr.Eq(Expr.Col("role"), Lit(PString("banned")))),
                  OrWhere(Expr.Eq(Expr.Col("status"), Lit(PString("suspended"))))],
    returning_: Nil
  })
  let r = compile_update(u)
  let sql = r.sql
  assert sql == "UPDATE \"users\" SET \"active\" = $1 WHERE \"role\" = $2 OR \"status\" = $3"
end

test "compile DELETE WHERE QCol" do
  let d = delete_from("order_items")
         |> delete_where(Expr.Eq(QCol("order_items", "order_id"), Lit(PInt(5))))
  let r = compile_delete(d)
  let sql = r.sql
  assert sql == "DELETE FROM \"order_items\" WHERE \"order_items\".\"order_id\" = $1"
end

test "compile INSERT RETURNING SelectAs" do
  let i = insert_into("products")
         |> insert_cols(["name", "price"])
         |> insert_row([PString("Widget"), PInt(10)])
         |> insert_returning([SelectAs(Expr.Col("id"), "new_id"), SelectField(Expr.Col("name"))])
  let r = compile_insert(i)
  let sql = r.sql
  assert sql == "INSERT INTO \"products\" (\"name\", \"price\") VALUES ($1, $2) RETURNING \"id\" AS \"new_id\", \"name\""
end

test "compile INSERT ON CONFLICT DO UPDATE inline expr" do
  let i = insert_into("kv")
         |> insert_cols(["key", "val"])
         |> insert_row([PString("x"), PInt(1)])
         |> on_conflict_do_update([("val", Lit(PInt(99))), ("key", Expr.Col("key"))])
  let r = compile_insert(i)
  let sql = r.sql
  assert sql == "INSERT INTO \"kv\" (\"key\", \"val\") VALUES ($1, $2) ON CONFLICT DO UPDATE SET \"val\" = 99, \"key\" = \"key\""
end

test "compile INSERT 0-row edge case" do
  -- Compile stays pure: a zero-row Insert produces `VALUES ()`, which
  -- Postgres rejects. The no-op short-circuit lives in MutationExec
  -- (gated on `is_empty_insert`) so compile_insert has no special case.
  let i = Insert({
    table_: "t",
    columns: ["x"],
    rows: Nil,
    on_conflict: None,
    returning_: Nil
  })
  let r = compile_insert(i)
  let sql = r.sql
  assert sql == "INSERT INTO \"t\" (\"x\") VALUES ()"
end

test "escape_sql_str handles single quotes" do
  let u = update("t")
         |> set_("name", Lit(PString("O'Brien")))
  let r = compile_update(u)
  -- parameterized: value becomes $1, no escaping needed in SQL
  let sql = r.sql
  assert sql == "UPDATE \"t\" SET \"name\" = $1"
  match r.params do
  Cons(ParamText(p), Nil) -> assert p == "O'Brien"
  _ -> assert false
  end
end

test "compile UPDATE SET with Col expr (no param)" do
  let u = update("counters")
         |> set_("n", Expr.Col("n"))
         |> update_where(Expr.Eq(Expr.Col("id"), Lit(PInt(7))))
  let r = compile_update(u)
  let sql = r.sql
  assert sql == "UPDATE \"counters\" SET \"n\" = \"n\" WHERE \"id\" = $1"
  assert List.length(r.params) == 1
end

test "PFloat value serialized in param" do
  let i = insert_into("metrics")
         |> insert_cols(["val"])
         |> insert_row([PFloat(3.14)])
  let r = compile_insert(i)
  assert List.length(r.params) == 1
end

test "PNull value serialized as ParamNull" do
  let i = insert_into("t")
         |> insert_cols(["x"])
         |> insert_row([PNull])
  let r = compile_insert(i)
  assert r.params == [ParamNull]
end

test "compile DELETE WHERE Like with single-quote pattern" do
  let d = delete_from("docs")
         |> delete_where(Like(Expr.Col("content"), "it's%"))
  let r = compile_delete(d)
  let sql = r.sql
  assert sql == "DELETE FROM \"docs\" WHERE \"content\" LIKE 'it''s%'"
end

test "compile DELETE WHERE ILike with single-quote pattern" do
  let d = delete_from("docs")
         |> delete_where(ILike(Expr.Col("title"), "can't%"))
  let r = compile_delete(d)
  let sql = r.sql
  assert sql == "DELETE FROM \"docs\" WHERE \"title\" ILIKE 'can''t%'"
end

test "compile INSERT ON CONFLICT DO UPDATE PBool(true) inline" do
  let i = insert_into("flags")
         |> insert_cols(["k"])
         |> insert_row([PString("x")])
         |> on_conflict_do_update([("active", Lit(PBool(true)))])
  let r = compile_insert(i)
  let sql = r.sql
  assert sql == "INSERT INTO \"flags\" (\"k\") VALUES ($1) ON CONFLICT DO UPDATE SET \"active\" = TRUE"
end

test "compile INSERT ON CONFLICT DO UPDATE PBool(false) inline" do
  let i = insert_into("flags")
         |> insert_cols(["k"])
         |> insert_row([PString("x")])
         |> on_conflict_do_update([("active", Lit(PBool(false)))])
  let r = compile_insert(i)
  let sql = r.sql
  assert sql == "INSERT INTO \"flags\" (\"k\") VALUES ($1) ON CONFLICT DO UPDATE SET \"active\" = FALSE"
end

test "compile INSERT ON CONFLICT DO UPDATE PNull inline" do
  let i = insert_into("t")
         |> insert_cols(["k"])
         |> insert_row([PString("k1")])
         |> on_conflict_do_update([("v", Lit(PNull))])
  let r = compile_insert(i)
  let sql = r.sql
  assert sql == "INSERT INTO \"t\" (\"k\") VALUES ($1) ON CONFLICT DO UPDATE SET \"v\" = NULL"
end

test "compile INSERT ON CONFLICT DO UPDATE PString inline (quotes it)" do
  let i = insert_into("t")
         |> insert_cols(["k"])
         |> insert_row([PString("k1")])
         |> on_conflict_do_update([("label", Lit(PString("ok")))])
  let r = compile_insert(i)
  let sql = r.sql
  assert sql == "INSERT INTO \"t\" (\"k\") VALUES ($1) ON CONFLICT DO UPDATE SET \"label\" = 'ok'"
end

test "compile INSERT ON CONFLICT DO UPDATE PFloat inline" do
  let i = insert_into("metrics")
         |> insert_cols(["k"])
         |> insert_row([PString("r")])
         |> on_conflict_do_update([("score", Lit(PFloat(0.5)))])
  let r = compile_insert(i)
  let sql = r.sql
  assert String.contains(sql, "ON CONFLICT DO UPDATE SET") == true
end

