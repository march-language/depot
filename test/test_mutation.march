    wheres: Nil, joins: Nil, orders: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let r = compile(q)
  let sql = r.sql
  assert String.contains(sql, "HAVING") == true
end

test "compile ORDER BY ASC DESC in mutation module" do
  let q = Query({ from_: FromTable("t"), selects: Nil,
    orders: [OrderExpr(Expr.Col("name"), Asc), OrderExpr(Expr.Col("created_at"), Desc)],
    wheres: Nil, joins: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let r = compile(q)
  let sql = r.sql
  assert String.contains(sql, "ASC") == true
  let sql = r.sql
  assert String.contains(sql, "DESC") == true
end

