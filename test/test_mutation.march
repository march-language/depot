test "compile UPDATE with empty SET list (degenerate)" do
  let u = Update({
    table_: "t",
    sets: Nil,
    wheres: [Where(Expr.Eq(Expr.Col("id"), Lit(PInt(1))))],
    returning_: Nil
  })
  let r = compile_update(u)
  let sql = r.sql
  assert String.contains(sql, "WHERE") == true
end

test "compile INSERT returning SelectField" do
  let i = insert_into("users")
         |> insert_cols(["name"])
         |> insert_row([PString("Alice")])
         |> insert_returning([SelectField(Expr.Col("id")), SelectField(Expr.Col("name"))])
  let r = compile_insert(i)
  let sql = r.sql
  assert sql == "INSERT INTO \"users\" (\"name\") VALUES ($1) RETURNING \"id\", \"name\""
end

test "compile INSERT RETURNING SelectField(QCol)" do
  let i = insert_into("t")
         |> insert_cols(["x"])
         |> insert_row([PInt(1)])
         |> insert_returning([SelectField(QCol("t", "id"))])
  let r = compile_insert(i)
  let sql = r.sql
  assert sql == "INSERT INTO \"t\" (\"x\") VALUES ($1) RETURNING \"t\".\"id\""
end

test "compile INSERT RETURNING SelectField(Raw)" do
  let i = insert_into("t")
         |> insert_cols(["x"])
         |> insert_row([PInt(1)])
         |> insert_returning([SelectField(Raw("NOW()"))])
  let r = compile_insert(i)
  let sql = r.sql
  assert sql == "INSERT INTO \"t\" (\"x\") VALUES ($1) RETURNING NOW()"
end

test "compile INSERT RETURNING SelectField unsupported expr" do
  let i = insert_into("t")
         |> insert_cols(["x"])
         |> insert_row([PInt(1)])
         |> insert_returning([SelectField(Expr.Add(Expr.Col("x"), Lit(PInt(1))))])
  let r = compile_insert(i)
  let sql = r.sql
  assert String.contains(sql, "/* unsupported */") == true
end

test "compile INSERT RETURNING SelectAs with QCol" do
  let i = insert_into("t")
         |> insert_cols(["x"])
         |> insert_row([PInt(1)])
         |> insert_returning([SelectAs(QCol("t", "created_at"), "ts")])
  let r = compile_insert(i)
  let sql = r.sql
  assert sql == "INSERT INTO \"t\" (\"x\") VALUES ($1) RETURNING \"t\".\"created_at\" AS \"ts\""
end

test "compile INSERT ON CONFLICT DO UPDATE QCol inline" do
  let i = insert_into("t")
         |> insert_cols(["k"])
         |> insert_row([PString("a")])
         |> on_conflict_do_update([("v", QCol("excluded", "v"))])
  let r = compile_insert(i)
  let sql = r.sql
  assert sql == "INSERT INTO \"t\" (\"k\") VALUES ($1) ON CONFLICT DO UPDATE SET \"v\" = \"excluded\".\"v\""
end

test "compile INSERT ON CONFLICT DO UPDATE Raw inline" do
  let i = insert_into("t")
         |> insert_cols(["k"])
         |> insert_row([PString("a")])
         |> on_conflict_do_update([("updated_at", Raw("NOW()"))])
  let r = compile_insert(i)
  let sql = r.sql
  assert sql == "INSERT INTO \"t\" (\"k\") VALUES ($1) ON CONFLICT DO UPDATE SET \"updated_at\" = NOW()"
end

test "compile INSERT RETURNING SelectField(Lit)" do
  let i = insert_into("t")
         |> insert_cols(["x"])
         |> insert_row([PInt(1)])
         |> insert_returning([SelectField(Lit(PInt(42)))])
  let r = compile_insert(i)
  let sql = r.sql
  assert sql == "INSERT INTO \"t\" (\"x\") VALUES ($1) RETURNING 42"
end

