-- test/test_preload.march
-- Tests for preload query construction (pure — no DB required).

mod TestPreload do

import Ast
import Build
import Compile
import Preload

-- ---- Helpers ----

fn list_len(lst) do
  match lst do | Nil -> 0 | Cons(_, rest) -> 1 + list_len(rest) end
end

fn make_result(cols, rows) do
  { columns = cols, rows = rows, tag = "" }
end

-- ---- Tests ----

test "extract_col_values basic" do
  let result = make_result(
    ["id", "user_id", "title"],
    [[Some("1"), Some("10"), Some("Post A")],
     [Some("2"), Some("20"), Some("Post B")],
     [Some("3"), Some("10"), Some("Post C")]]
  )
  let vals = extract_col_values(result, "user_id")
  assert vals == ["10", "20", "10"]
end

test "extract_col_values excludes NULLs" do
  let result = make_result(
    ["id", "user_id"],
    [[Some("1"), None],
     [Some("2"), Some("5")]]
  )
  let vals = extract_col_values(result, "user_id")
  assert vals == ["5"]
end

test "extract_col_values unknown column returns empty" do
  let result = make_result(["id"], [[Some("1")]])
  let vals = extract_col_values(result, "nonexistent")
  assert vals == Nil
end

test "build_preload_query with ids" do
  let q = build_preload_query("posts", "user_id", ["10", "20", "30"])
  let compiled = Compile.compile(q)
  assert compiled.sql == "SELECT * FROM \"posts\" WHERE \"user_id\" IN ($1, $2, $3)"
  assert list_len(compiled.params) == 3
end

test "build_preload_query empty list uses FALSE" do
  let q = build_preload_query("posts", "user_id", Nil)
  let compiled = Compile.compile(q)
  assert compiled.sql == "SELECT * FROM \"posts\" WHERE FALSE"
  assert list_len(compiled.params) == 0
end

test "dedup_strings removes duplicates" do
  let deduped = dedup_strings(["10", "20", "10", "30", "20"])
  assert list_len(deduped) == 3
end

test "dedup_strings empty list returns empty" do
  let deduped = dedup_strings(Nil)
  assert deduped == Nil
end

test "dedup_strings all unique preserves all" do
  let deduped = dedup_strings(["a", "b", "c"])
  assert list_len(deduped) == 3
end

test "dedup_strings single element" do
  let deduped = dedup_strings(["x"])
  assert list_len(deduped) == 1
end

test "extract_col_values with short row (missing index)" do
  -- Row 0 has 2 cols, row 1 only 1 col (shorter than column index 2)
  let result = make_result(
    ["a", "b", "c"],
    [[Some("1"), Some("v1"), Some("ok")],
     [Some("2"), Some("v2")]]
  )
  let vals = extract_col_values(result, "c")
  -- row 1 has no index 2, so nth_opt returns None; only row 0's "ok" collected
  assert list_len(vals) == 1
end

test "extract_col_values first column" do
  let result = make_result(
    ["id", "name"],
    [[Some("42"), Some("Alice")],
     [Some("99"), Some("Bob")]]
  )
  let vals = extract_col_values(result, "id")
  assert list_len(vals) == 2
end

test "build_preload_query deduplicates ids" do
  let q = build_preload_query("posts", "user_id", ["10", "10", "20"])
  let compiled = Compile.compile(q)
  -- dedup_strings removes the duplicate "10", so only 2 params
  assert list_len(compiled.params) == 2
end

-- ---- Additional compile coverage in preload unit ----

test "compile_inline basic in preload module" do
  let q = Build.from("users") |> Build.where_(Expr.Gt(Expr.Col("age"), Lit(PInt(18))))
  let r = compile_inline(q)
  assert String.contains(r.sql, ">") == true
end

test "compile_inline JOIN kinds in preload module" do
  let qi = Build.from("orders")
         |> Build.join("users", Expr.Eq(QCol("orders","user_id"), QCol("users","id")))
  assert String.contains((compile_inline(qi)).sql, "INNER JOIN") == true
  let ql = Build.from("orders")
         |> Build.left_join("users", Expr.Eq(QCol("orders","user_id"), QCol("users","id")))
  assert String.contains((compile_inline(ql)).sql, "LEFT JOIN") == true
  let qr = Build.from("a") |> Build.right_join("b", Expr.Eq(Expr.Col("a_id"), Expr.Col("id")))
  assert String.contains((compile_inline(qr)).sql, "RIGHT JOIN") == true
  let qf = Build.from("a") |> Build.full_join("b", Expr.Eq(Expr.Col("a_id"), Expr.Col("id")))
  assert String.contains((compile_inline(qf)).sql, "FULL OUTER JOIN") == true
  let qc = Build.from("a") |> Build.cross_join("b")
  assert String.contains((compile_inline(qc)).sql, "CROSS JOIN") == true
end

test "compile_inline GROUP BY HAVING in preload module" do
  let q = Build.from("sales")
         |> Build.group_by([Expr.Col("region")])
         |> Build.having(Expr.Gt(CountAll, Lit(PInt(5))))
  let r = compile_inline(q)
  assert String.contains(r.sql, "GROUP BY") == true
  assert String.contains(r.sql, "HAVING") == true
end

test "compile_inline HAVING OrWhere in preload module" do
  let q = Ast.Query({ from_ = FromTable("t"), selects = Nil,
    group_bys = [Expr.Col("x")],
    havings = [Where(Expr.Gt(CountAll, Lit(PInt(1)))),
               OrWhere(Expr.Gt(CountAll, Lit(PInt(10))))],
    wheres = Nil, joins = Nil, orders = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  let r = compile_inline(q)
  assert String.contains(r.sql, "OR") == true
end

test "compile_inline ORDER BY NULLS variants in preload module" do
  let q1 = Ast.Query({ from_ = FromTable("t"), selects = Nil,
    orders = [OrderExpr(Expr.Col("x"), AscNullsFirst)],
    wheres = Nil, joins = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert String.contains((compile_inline(q1)).sql, "ASC NULLS FIRST") == true
  let q2 = Ast.Query({ from_ = FromTable("t"), selects = Nil,
    orders = [OrderExpr(Expr.Col("x"), AscNullsLast)],
    wheres = Nil, joins = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert String.contains((compile_inline(q2)).sql, "ASC NULLS LAST") == true
  let q3 = Ast.Query({ from_ = FromTable("t"), selects = Nil,
    orders = [OrderExpr(Expr.Col("x"), DescNullsFirst)],
    wheres = Nil, joins = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert String.contains((compile_inline(q3)).sql, "DESC NULLS FIRST") == true
  let q4 = Ast.Query({ from_ = FromTable("t"), selects = Nil,
    orders = [OrderExpr(Expr.Col("x"), DescNullsLast)],
    wheres = Nil, joins = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert String.contains((compile_inline(q4)).sql, "DESC NULLS LAST") == true
end

test "compile_inline SelectAll SelectAs in preload module" do
  let q1 = Ast.Query({ from_ = FromTable("t"), selects = [SelectAll],
    wheres = Nil, joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert (compile_inline(q1)).sql == "SELECT * FROM \"t\""
  let q2 = Ast.Query({ from_ = FromTable("t"),
    selects = [SelectAs(Expr.Col("id"), "pk")],
    wheres = Nil, joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert String.contains((compile_inline(q2)).sql, "AS \"pk\"") == true
end

test "compile_inline arithmetic operators in preload module" do
  let q1 = Ast.Query({ from_ = FromTable("t"), selects = Nil,
    wheres = [Where(Expr.Gt(Expr.Add(Expr.Col("a"), Expr.Col("b")), Lit(PInt(0))))],
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert String.contains((compile_inline(q1)).sql, "+") == true
  let q2 = Ast.Query({ from_ = FromTable("t"), selects = Nil,
    wheres = [Where(Expr.Gt(Expr.Sub(Expr.Col("a"), Expr.Col("b")), Lit(PInt(0))))],
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert String.contains((compile_inline(q2)).sql, "-") == true
  let q3 = Ast.Query({ from_ = FromTable("t"), selects = Nil,
    wheres = [Where(Expr.Gt(Expr.Mul(Expr.Col("a"), Expr.Col("b")), Lit(PInt(0))))],
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert String.contains((compile_inline(q3)).sql, "*") == true
  let q4 = Ast.Query({ from_ = FromTable("t"), selects = Nil,
    wheres = [Where(Expr.Gt(Expr.Div(Expr.Col("a"), Expr.Col("b")), Lit(PInt(0))))],
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert String.contains((compile_inline(q4)).sql, "/") == true
end

test "compile_inline boolean And Or Not in preload module" do
  let q1 = Ast.Query({ from_ = FromTable("t"), selects = Nil,
    wheres = [Where(Expr.And(Expr.Gt(Expr.Col("x"), Lit(PInt(0))), Expr.Lt(Expr.Col("x"), Lit(PInt(10)))))],
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert String.contains((compile_inline(q1)).sql, " AND ") == true
  let q2 = Ast.Query({ from_ = FromTable("t"), selects = Nil,
    wheres = [Where(Expr.Or(Expr.Eq(Expr.Col("x"), Lit(PInt(1))), Expr.Eq(Expr.Col("x"), Lit(PInt(2)))))],
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert String.contains((compile_inline(q2)).sql, " OR ") == true
  let q3 = Ast.Query({ from_ = FromTable("t"), selects = Nil,
    wheres = [Where(Expr.Not(Expr.Eq(Expr.Col("x"), Lit(PInt(0)))))],
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert String.contains((compile_inline(q3)).sql, "NOT") == true
end

test "compile_inline Neq Lt Lte Gte in preload module" do
  let q1 = Ast.Query({ from_ = FromTable("t"), selects = Nil,
    wheres = [Where(Expr.Neq(Expr.Col("x"), Lit(PInt(0))))],
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert String.contains((compile_inline(q1)).sql, "<>") == true
  let q2 = Ast.Query({ from_ = FromTable("t"), selects = Nil,
    wheres = [Where(Expr.Lte(Expr.Col("x"), Lit(PInt(5))))],
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert String.contains((compile_inline(q2)).sql, "<=") == true
  let q3 = Ast.Query({ from_ = FromTable("t"), selects = Nil,
    wheres = [Where(Expr.Gte(Expr.Col("x"), Lit(PInt(5))))],
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert String.contains((compile_inline(q3)).sql, ">=") == true
end

test "compile_inline IsNull IsNotNull In NotIn Between in preload module" do
  let q1 = Ast.Query({ from_ = FromTable("t"), selects = Nil,
    wheres = [Where(Expr.IsNull(Expr.Col("x")))],
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert String.contains((compile_inline(q1)).sql, "IS NULL") == true
  let q2 = Ast.Query({ from_ = FromTable("t"), selects = Nil,
    wheres = [Where(Expr.IsNotNull(Expr.Col("x")))],
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert String.contains((compile_inline(q2)).sql, "IS NOT NULL") == true
  let q3 = Ast.Query({ from_ = FromTable("t"), selects = Nil,
    wheres = [Where(In(Expr.Col("id"), [Lit(PInt(1)), Lit(PInt(2))]))],
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert String.contains((compile_inline(q3)).sql, "IN (1, 2)") == true
  let q4 = Ast.Query({ from_ = FromTable("t"), selects = Nil,
    wheres = [Where(Between(Expr.Col("x"), Lit(PInt(1)), Lit(PInt(10))))],
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert String.contains((compile_inline(q4)).sql, "BETWEEN 1 AND 10") == true
end

test "compile_inline FnCall Like ILike aggregates in preload module" do
  let qf = Ast.Query({ from_ = FromTable("t"), selects = Nil,
    wheres = [Where(Expr.Eq(FnCall("LOWER", [Expr.Col("email")]), Lit(PString("x"))))],
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert String.contains((compile_inline(qf)).sql, "LOWER") == true
  let ql = Ast.Query({ from_ = FromTable("t"), selects = Nil,
    wheres = [Where(Like(Expr.Col("n"), "%a%"))],
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert String.contains((compile_inline(ql)).sql, "LIKE") == true
  let qi = Ast.Query({ from_ = FromTable("t"), selects = Nil,
    wheres = [Where(ILike(Expr.Col("n"), "%a%"))],
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert String.contains((compile_inline(qi)).sql, "ILIKE") == true
  let q_sum = Ast.Query({ from_ = FromTable("t"), selects = Nil, group_bys = [Expr.Col("x")],
    havings = [Where(Expr.Gt(Expr.Sum(Expr.Col("v")), Lit(PInt(0))))],
    wheres = Nil, joins = Nil, orders = Nil, limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert String.contains((compile_inline(q_sum)).sql, "SUM") == true
  let q_avg = Ast.Query({ from_ = FromTable("t"), selects = Nil, group_bys = [Expr.Col("x")],
    havings = [Where(Expr.Gt(Avg(Expr.Col("v")), Lit(PFloat(0.0))))],
    wheres = Nil, joins = Nil, orders = Nil, limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert String.contains((compile_inline(q_avg)).sql, "AVG") == true
  let q_min = Ast.Query({ from_ = FromTable("t"), selects = Nil, group_bys = [Expr.Col("x")],
    havings = [Where(Expr.Gt(Expr.Min(Expr.Col("v")), Lit(PInt(0))))],
    wheres = Nil, joins = Nil, orders = Nil, limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert String.contains((compile_inline(q_min)).sql, "MIN") == true
  let q_max = Ast.Query({ from_ = FromTable("t"), selects = Nil, group_bys = [Expr.Col("x")],
    havings = [Where(Expr.Lt(Expr.Max(Expr.Col("v")), Lit(PInt(1000))))],
    wheres = Nil, joins = Nil, orders = Nil, limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert String.contains((compile_inline(q_max)).sql, "MAX") == true
end

test "compile_inline Exists SubqueryExpr in preload module" do
  let sub = Ast.Query({ from_ = FromTable("orders"), selects = Nil,
    wheres = Nil, joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  let qe = Ast.Query({ from_ = FromTable("users"), selects = Nil,
    wheres = [Where(Exists(sub))],
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert String.contains((compile_inline(qe)).sql, "EXISTS") == true
  let qs = Ast.Query({ from_ = FromTable("t"), selects = Nil,
    wheres = [Where(Expr.Gt(Expr.Col("score"), SubqueryExpr(sub)))],
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert String.contains((compile_inline(qs)).sql, "SELECT") == true
end

test "compile ORDER BY NULLS in preload module" do
  let q = Ast.Query({ from_ = FromTable("t"), selects = Nil,
    orders = [OrderExpr(Expr.Col("x"), AscNullsFirst)],
    wheres = Nil, joins = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert String.contains((Compile.compile(q)).sql, "ASC NULLS FIRST") == true
end

test "compile Exists parameterized in preload module" do
  let sub = Ast.Query({ from_ = FromTable("orders"), selects = Nil,
    wheres = Nil, joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  let q = Ast.Query({ from_ = FromTable("users"), selects = Nil,
    wheres = [Where(Exists(sub))],
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert String.contains((Compile.compile(q)).sql, "EXISTS") == true
end

end -- mod TestPreload
