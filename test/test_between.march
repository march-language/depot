-- test/test_between.march
-- Phase 3.2 — WHERE BETWEEN builder coverage.

mod TestBetween do

import Ast
import Build
import Compile

test "where_between appends a Between predicate" do
  let q = Build.from("users")
         |> Build.select([Expr.Col("id")])
         |> Build.where_between(Expr.Col("age"), Lit(PInt(18)), Lit(PInt(65)))
  match q do
  Ast.Query(f) -> match f.wheres do
    Cons(Where(Between(_, _, _)), Nil) -> assert true
    _                                  -> assert false
  end
  end
end

test "where_between compiles to SQL BETWEEN with two placeholders" do
  let q = Build.from("users")
         |> Build.select([Expr.Col("id")])
         |> Build.where_between(Expr.Col("age"), Lit(PInt(18)), Lit(PInt(65)))
  let r = Compile.compile_parameterized(q)
  let _ = assert String.contains(r.sql, "BETWEEN")
  let _ = assert String.contains(r.sql, "$1")
  assert String.contains(r.sql, "$2")
end

test "where_between is equivalent to Gte+Lte on the inclusive bounds" do
  let q1 = Build.from("t")
          |> Build.select([Expr.Col("x")])
          |> Build.where_between(Expr.Col("x"), Lit(PInt(1)), Lit(PInt(10)))
  let q2 = Build.from("t")
          |> Build.select([Expr.Col("x")])
          |> Build.where_(Expr.And(
               Expr.Gte(Expr.Col("x"), Lit(PInt(1))),
               Expr.Lte(Expr.Col("x"), Lit(PInt(10)))
             ))
  let r1 = Compile.compile_parameterized(q1)
  let r2 = Compile.compile_parameterized(q2)
  -- Both forms are accepted by Postgres. We just assert that each
  -- references the column and the two bounds are serialised as
  -- parameters ($1, $2) in the order we supplied them.
  let _ = assert String.contains(r1.sql, "\"x\"")
  let _ = assert String.contains(r2.sql, "\"x\"")
  let _ = assert String.contains(r1.sql, "$1")
  assert String.contains(r2.sql, "$1")
end

end -- mod TestBetween
