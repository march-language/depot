-- test/test_schema.march
-- Tests for Schema module: OID mapping and type coercions.

mod TestSchema do

type MarchType =
    TBool | TInt16 | TInt32 | TInt64 | TFloat32 | TFloat64
  | TNumeric | TText | TVarchar | TChar | TBytea
  | TDate | TTime | TTimestamp | TTimestampTz | TInterval
  | TJson | TJsonb | TUuid | TArray(MarchType) | TUnknown(Int)

type TypedValue =
    VBool(Bool) | VInt(Int) | VFloat(Float) | VString(String)
  | VNull | VBytes(Bytes) | VUnparsed(String)

fn from_oid(oid) do
  if oid == 16 then TBool
  else if oid == 17 then TBytea
  else if oid == 20 then TInt64
  else if oid == 21 then TInt16
  else if oid == 23 then TInt32
  else if oid == 25 then TText
  else if oid == 700 then TFloat32
  else if oid == 701 then TFloat64
  else if oid == 1043 then TVarchar
  else if oid == 1082 then TDate
  else if oid == 1700 then TNumeric
  else if oid == 2950 then TUuid
  else if oid == 3802 then TJsonb
  else if oid == 1007 then TArray(TInt32)
  else if oid == 1009 then TArray(TText)
  else TUnknown(oid)
end

fn to_oid(t) do
  match t do
  | TBool -> 16 | TBytea -> 17 | TInt64 -> 20 | TInt16 -> 21
  | TInt32 -> 23 | TText -> 25 | TFloat32 -> 700 | TFloat64 -> 701
  | TVarchar -> 1043 | TDate -> 1082 | TNumeric -> 1700 | TUuid -> 2950
  | TJsonb -> 3802 | TArray(_) -> 0 | TUnknown(oid) -> oid
  | _ -> 0
  end
end

fn type_name(t) do
  match t do
  | TBool -> "bool" | TBytea -> "bytea" | TChar -> "char"
  | TInt16 -> "int2" | TInt32 -> "int4" | TInt64 -> "int8"
  | TFloat32 -> "float4" | TFloat64 -> "float8" | TNumeric -> "numeric"
  | TText -> "text" | TVarchar -> "varchar"
  | TDate -> "date" | TTime -> "time" | TTimestamp -> "timestamp"
  | TTimestampTz -> "timestamptz" | TInterval -> "interval"
  | TJson -> "json" | TJsonb -> "jsonb" | TUuid -> "uuid"
  | TArray(inner) -> type_name(inner) ++ "[]"
  | TUnknown(oid) -> "unknown(" ++ int_to_string(oid) ++ ")"
  end
end

fn is_numeric(t) do
  match t do
  | TInt16 -> true | TInt32 -> true | TInt64 -> true
  | TFloat32 -> true | TFloat64 -> true | TNumeric -> true | _ -> false
  end
end

fn is_text(t) do
  match t do | TText -> true | TVarchar -> true | TChar -> true | _ -> false end
end

fn is_temporal(t) do
  match t do
  | TDate -> true | TTime -> true | TTimestamp -> true
  | TTimestampTz -> true | TInterval -> true | _ -> false
  end
end

fn parse_text_value(t, text) do
  match t do
  | TBool -> if text == "t" then VBool(true) else VBool(false)
  | TInt32 -> VInt(unwrap_or(string_to_int(text), 0))
  | TInt64 -> VInt(unwrap_or(string_to_int(text), 0))
  | TFloat64 -> VFloat(unwrap_or(string_to_float(text), 0.0))
  | TText -> VString(text) | TVarchar -> VString(text)
  | TUnknown(_) -> VUnparsed(text)
  | _ -> VString(text)
  end
end

-- ---- Tests ----

fn test_from_oid_int4() do
  match from_oid(23) do
  | TInt32 -> ()
  | _ -> assert(false)
  end
end

fn test_from_oid_text() do
  match from_oid(25) do
  | TText -> ()
  | _ -> assert(false)
  end
end

fn test_from_oid_bool() do
  match from_oid(16) do
  | TBool -> ()
  | _ -> assert(false)
  end
end

fn test_from_oid_array_text() do
  match from_oid(1009) do
  | TArray(TText) -> ()
  | _ -> assert(false)
  end
end

fn test_from_oid_unknown() do
  match from_oid(9999) do
  | TUnknown(oid) -> assert(oid == 9999)
  | _ -> assert(false)
  end
end

fn test_to_oid_roundtrip() do
  assert(to_oid(TInt32) == 23)
  assert(to_oid(TText) == 25)
  assert(to_oid(TBool) == 16)
  assert(to_oid(TFloat64) == 701)
  assert(to_oid(TUuid) == 2950)
end

fn test_type_name_primitives() do
  assert(type_name(TInt32) == "int4")
  assert(type_name(TInt64) == "int8")
  assert(type_name(TText) == "text")
  assert(type_name(TBool) == "bool")
  assert(type_name(TFloat64) == "float8")
end

fn test_type_name_array() do
  assert(type_name(TArray(TInt32)) == "int4[]")
  assert(type_name(TArray(TText)) == "text[]")
end

fn test_type_name_unknown() do
  assert(type_name(TUnknown(42)) == "unknown(42)")
end

fn test_is_numeric() do
  assert(is_numeric(TInt32) == true)
  assert(is_numeric(TFloat64) == true)
  assert(is_numeric(TText) == false)
  assert(is_numeric(TBool) == false)
end

fn test_is_text() do
  assert(is_text(TText) == true)
  assert(is_text(TVarchar) == true)
  assert(is_text(TInt32) == false)
end

fn test_is_temporal() do
  assert(is_temporal(TDate) == true)
  assert(is_temporal(TTimestamp) == true)
  assert(is_temporal(TText) == false)
end

fn test_parse_bool_true() do
  match parse_text_value(TBool, "t") do
  | VBool(b) -> assert(b == true)
  | _ -> assert(false)
  end
end

fn test_parse_bool_false() do
  match parse_text_value(TBool, "f") do
  | VBool(b) -> assert(b == false)
  | _ -> assert(false)
  end
end

fn test_parse_int() do
  match parse_text_value(TInt32, "42") do
  | VInt(n) -> assert(n == 42)
  | _ -> assert(false)
  end
end

fn test_parse_text() do
  match parse_text_value(TText, "hello") do
  | VString(s) -> assert(s == "hello")
  | _ -> assert(false)
  end
end

fn test_parse_unknown() do
  match parse_text_value(TUnknown(999), "raw") do
  | VUnparsed(s) -> assert(s == "raw")
  | _ -> assert(false)
  end
end

fn main() : Unit do
  test_from_oid_int4()
  test_from_oid_text()
  test_from_oid_bool()
  test_from_oid_array_text()
  test_from_oid_unknown()
  test_to_oid_roundtrip()
  test_type_name_primitives()
  test_type_name_array()
  test_type_name_unknown()
  test_is_numeric()
  test_is_text()
  test_is_temporal()
  test_parse_bool_true()
  test_parse_bool_false()
  test_parse_int()
  test_parse_text()
  test_parse_unknown()
  println("test_schema: all tests passed")
end

end
