-- test/test_schema.march
-- Tests for Schema module: OID mapping and type coercions.

mod TestSchema do

import Schema

-- ---- Tests ----

fn test_from_oid_int4() do
  match from_oid(23) do
  | TInt32 -> ()
  | _ -> assert(false)
  end
end

fn test_from_oid_text() do
  match from_oid(25) do
  | TText -> ()
  | _ -> assert(false)
  end
end

fn test_from_oid_bool() do
  match from_oid(16) do
  | TBool -> ()
  | _ -> assert(false)
  end
end

fn test_from_oid_array_text() do
  match from_oid(1009) do
  | TArray(TText) -> ()
  | _ -> assert(false)
  end
end

fn test_from_oid_unknown() do
  match from_oid(9999) do
  | TUnknown(oid) -> assert(oid == 9999)
  | _ -> assert(false)
  end
end

fn test_to_oid_roundtrip() do
  assert(to_oid(TInt32) == 23)
  assert(to_oid(TText) == 25)
  assert(to_oid(TBool) == 16)
  assert(to_oid(TFloat64) == 701)
  assert(to_oid(TUuid) == 2950)
end

fn test_type_name_primitives() do
  assert(type_name(TInt32) == "int4")
  assert(type_name(TInt64) == "int8")
  assert(type_name(TText) == "text")
  assert(type_name(TBool) == "bool")
  assert(type_name(TFloat64) == "float8")
end

fn test_type_name_array() do
  assert(type_name(TArray(TInt32)) == "int4[]")
  assert(type_name(TArray(TText)) == "text[]")
end

fn test_type_name_unknown() do
  assert(type_name(TUnknown(42)) == "unknown(42)")
end

fn test_is_numeric() do
  assert(is_numeric(TInt32) == true)
  assert(is_numeric(TFloat64) == true)
  assert(is_numeric(TText) == false)
  assert(is_numeric(TBool) == false)
end

fn test_is_text() do
  assert(is_text(TText) == true)
  assert(is_text(TVarchar) == true)
  assert(is_text(TInt32) == false)
end

fn test_is_temporal() do
  assert(is_temporal(TDate) == true)
  assert(is_temporal(TTimestamp) == true)
  assert(is_temporal(TText) == false)
end

fn test_parse_bool_true() do
  match parse_text_value(TBool, "t") do
  | VBool(b) -> assert(b == true)
  | _ -> assert(false)
  end
end

fn test_parse_bool_false() do
  match parse_text_value(TBool, "f") do
  | VBool(b) -> assert(b == false)
  | _ -> assert(false)
  end
end

fn test_parse_int() do
  match parse_text_value(TInt32, "42") do
  | VInt(n) -> assert(n == 42)
  | _ -> assert(false)
  end
end

fn test_parse_text() do
  match parse_text_value(TText, "hello") do
  | VString(s) -> assert(s == "hello")
  | _ -> assert(false)
  end
end

fn test_parse_unknown() do
  match parse_text_value(TUnknown(999), "raw") do
  | VUnparsed(s) -> assert(s == "raw")
  | _ -> assert(false)
  end
end

fn main() : Unit do
  test_from_oid_int4()
  test_from_oid_text()
  test_from_oid_bool()
  test_from_oid_array_text()
  test_from_oid_unknown()
  test_to_oid_roundtrip()
  test_type_name_primitives()
  test_type_name_array()
  test_type_name_unknown()
  test_is_numeric()
  test_is_text()
  test_is_temporal()
  test_parse_bool_true()
  test_parse_bool_false()
  test_parse_int()
  test_parse_text()
  test_parse_unknown()
  println("test_schema: all tests passed")
end

end
