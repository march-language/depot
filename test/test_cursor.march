-- test/test_cursor.march
-- Tests for cursor SQL generation (pure — no DB required).

mod TestCursor do

import Ast
import Build
import Cursor

test "declare_sql" do
  let q = from("events") |> where_(Expr.Lt(Expr.Col("created_at"), Lit(PString("2026-01-01"))))
  let sql = declare_sql("cur1", q)
  assert sql == "DECLARE \"cur1\" CURSOR FOR SELECT * FROM \"events\" WHERE \"created_at\" < '2026-01-01'"
end

test "fetch_sql" do
  let sql = fetch_sql("cur1", 100)
  assert sql == "FETCH 100 FROM \"cur1\""
end

test "fetch_all_sql" do
  let sql = fetch_all_sql("cur1")
  assert sql == "FETCH ALL FROM \"cur1\""
end

test "close_sql" do
  let sql = close_sql("cur1")
  assert sql == "CLOSE \"cur1\""
end

test "move_sql" do
  let sql = move_sql("cur1", 50)
  assert sql == "MOVE 50 FROM \"cur1\""
end

end -- mod TestCursor
