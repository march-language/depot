-- test/test_ast.march
-- Tests for SQL AST types and their construction.

mod TestAst do

import Ast

test "PInt value" do
  assert PInt(42) == PInt(42)
end

test "PString value" do
  assert PString("hello") == PString("hello")
end

test "PBool value" do
  assert PBool(true) == PBool(true)
end

test "PNull value" do
  assert PNull == PNull
end

test "Col expr" do
  assert Col("name") == Col("name")
end

test "QCol expr" do
  assert QCol("users", "id") == QCol("users", "id")
end

test "Lit expr" do
  assert Lit(PInt(5)) == Lit(PInt(5))
end

test "Eq expr" do
  assert Eq(Col("id"), Lit(PInt(1))) == Eq(Col("id"), Lit(PInt(1)))
end

test "And expr" do
  assert And(Eq(Col("a"), Lit(PInt(1))), Eq(Col("b"), Lit(PInt(2)))) == And(Eq(Col("a"), Lit(PInt(1))), Eq(Col("b"), Lit(PInt(2))))
end

test "IsNull expr" do
  assert IsNull(Col("deleted_at")) == IsNull(Col("deleted_at"))
end

test "CountAll expr" do
  assert CountAll == CountAll
end

test "Count expr" do
  assert Count(Col("id")) == Count(Col("id"))
end

test "Like expr" do
  assert Like(Col("email"), "%@example.com") == Like(Col("email"), "%@example.com")
end

test "sort direction variants" do
  assert Asc == Asc
  assert Desc == Desc
  assert AscNullsFirst == AscNullsFirst
  assert AscNullsLast == AscNullsLast
  assert DescNullsFirst == DescNullsFirst
  assert DescNullsLast == DescNullsLast
end

test "join kind variants" do
  assert Inner == Inner
  assert Left == Left
  assert Right == Right
  assert FullOuter == FullOuter
  assert Cross == Cross
end

test "Not expr" do
  assert Not(Eq(Col("x"), Lit(PNull))) == Not(Eq(Col("x"), Lit(PNull)))
end

test "PFloat value" do
  assert PFloat(3.14) == PFloat(3.14)
end

test "Neq expr" do
  assert Neq(Col("a"), Lit(PInt(0))) == Neq(Col("a"), Lit(PInt(0)))
end

test "Lt expr" do
  assert Lt(Col("age"), Lit(PInt(18))) == Lt(Col("age"), Lit(PInt(18)))
end

test "Gt expr" do
  assert Gt(Col("score"), Lit(PInt(100))) == Gt(Col("score"), Lit(PInt(100)))
end

test "Lte expr" do
  assert Lte(Col("n"), Lit(PInt(5))) == Lte(Col("n"), Lit(PInt(5)))
end

test "Gte expr" do
  assert Gte(Col("n"), Lit(PInt(0))) == Gte(Col("n"), Lit(PInt(0)))
end

test "Or expr" do
  assert Or(Eq(Col("a"), Lit(PInt(1))), Eq(Col("b"), Lit(PInt(2)))) == Or(Eq(Col("a"), Lit(PInt(1))), Eq(Col("b"), Lit(PInt(2))))
end

test "Add expr" do
  assert Add(Col("x"), Lit(PInt(1))) == Add(Col("x"), Lit(PInt(1)))
end

test "Sub expr" do
  assert Sub(Col("total"), Col("discount")) == Sub(Col("total"), Col("discount"))
end

test "Mul expr" do
  assert Mul(Col("price"), Lit(PInt(2))) == Mul(Col("price"), Lit(PInt(2)))
end

test "Div expr" do
  assert Div(Col("total"), Lit(PInt(100))) == Div(Col("total"), Lit(PInt(100)))
end

test "IsNotNull expr" do
  assert IsNotNull(Col("deleted_at")) == IsNotNull(Col("deleted_at"))
end

test "In expr" do
  assert In(Col("id"), [Lit(PInt(1)), Lit(PInt(2))]) == In(Col("id"), [Lit(PInt(1)), Lit(PInt(2))])
end

test "NotIn expr" do
  assert NotIn(Col("status"), [Lit(PString("banned"))]) == NotIn(Col("status"), [Lit(PString("banned"))])
end

test "Between expr" do
  assert Between(Col("age"), Lit(PInt(18)), Lit(PInt(65))) == Between(Col("age"), Lit(PInt(18)), Lit(PInt(65)))
end

test "ILike expr" do
  assert ILike(Col("name"), "%alice%") == ILike(Col("name"), "%alice%")
end

test "Sum expr" do
  assert Sum(Col("amount")) == Sum(Col("amount"))
end

test "Avg expr" do
  assert Avg(Col("score")) == Avg(Col("score"))
end

test "Min expr" do
  assert Min(Col("created_at")) == Min(Col("created_at"))
end

test "Max expr" do
  assert Max(Col("score")) == Max(Col("score"))
end

test "FnCall expr" do
  let args = [Col("email")]
  assert FnCall("LOWER", args) == FnCall("LOWER", args)
  assert List.length(args) == 1
end

test "ExprParam expr" do
  assert ExprParam(3) == ExprParam(3)
end

test "Raw expr" do
  assert Raw("NOW()") == Raw("NOW()")
end

test "SubqueryExpr expr" do
  let sub = Query({
    from_ = FromTable("inner"), selects = Nil, wheres = Nil,
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct
  })
  assert SubqueryExpr(sub) == SubqueryExpr(sub)
end

test "Exists expr" do
  let sub = Query({
    from_ = FromTable("inner"), selects = Nil, wheres = Nil,
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct
  })
  assert Exists(sub) == Exists(sub)
end

test "Where and OrWhere constructors" do
  assert Where(Eq(Col("id"), Lit(PInt(1)))) == Where(Eq(Col("id"), Lit(PInt(1))))
  assert OrWhere(Eq(Col("id"), Lit(PInt(2)))) == OrWhere(Eq(Col("id"), Lit(PInt(2))))
end

test "SelectField and SelectAs" do
  assert SelectField(Col("id")) == SelectField(Col("id"))
  assert SelectAs(Col("id"), "uid") == SelectAs(Col("id"), "uid")
end

test "JoinClause" do
  assert JoinClause(Inner, "users", Eq(Col("id"), Col("user_id"))) == JoinClause(Inner, "users", Eq(Col("id"), Col("user_id")))
end

test "OrderExpr" do
  assert OrderExpr(Col("name"), Asc) == OrderExpr(Col("name"), Asc)
end

-- ---- Additional AST constructor tests ----

test "PInt various values" do
  assert PInt(0) == PInt(0)
  assert PInt(1) == PInt(1)
  assert PInt(-1) == PInt(-1)
  assert PInt(100) == PInt(100)
  assert PInt(9999) == PInt(9999)
end

test "PFloat various values" do
  assert PFloat(0.0) == PFloat(0.0)
  assert PFloat(1.5) == PFloat(1.5)
  assert PFloat(3.14) == PFloat(3.14)
  assert PFloat(-2.7) == PFloat(-2.7)
end

test "PString various values" do
  assert PString("") == PString("")
  assert PString("hello") == PString("hello")
  assert PString("world") == PString("world")
  assert PString("foo bar") == PString("foo bar")
end

test "PBool values" do
  assert PBool(true) == PBool(true)
  assert PBool(false) == PBool(false)
end

test "PNull value" do
  assert PNull == PNull
end

test "Col various names" do
  assert Col("id") == Col("id")
  assert Col("name") == Col("name")
  assert Col("email") == Col("email")
  assert Col("created_at") == Col("created_at")
  assert Col("user_id") == Col("user_id")
end

test "QCol various tables" do
  assert QCol("users", "id") == QCol("users", "id")
  assert QCol("orders", "user_id") == QCol("orders", "user_id")
  assert QCol("products", "price") == QCol("products", "price")
  assert QCol("a", "b") == QCol("a", "b")
end

test "Lit with PInt" do
  assert Lit(PInt(0)) == Lit(PInt(0))
  assert Lit(PInt(42)) == Lit(PInt(42))
  assert Lit(PInt(-100)) == Lit(PInt(-100))
end

test "Lit with PString" do
  assert Lit(PString("hello")) == Lit(PString("hello"))
  assert Lit(PString("")) == Lit(PString(""))
  assert Lit(PString("abc")) == Lit(PString("abc"))
end

test "Lit with PBool" do
  assert Lit(PBool(true)) == Lit(PBool(true))
  assert Lit(PBool(false)) == Lit(PBool(false))
end

test "Lit with PNull" do
  assert Lit(PNull) == Lit(PNull)
end

test "Lit with PFloat" do
  assert Lit(PFloat(1.0)) == Lit(PFloat(1.0))
  assert Lit(PFloat(0.5)) == Lit(PFloat(0.5))
end

test "Eq with various exprs" do
  assert Eq(Col("id"), Lit(PInt(1))) == Eq(Col("id"), Lit(PInt(1)))
  assert Eq(Col("name"), Lit(PString("Alice"))) == Eq(Col("name"), Lit(PString("Alice")))
  assert Eq(Col("active"), Lit(PBool(true))) == Eq(Col("active"), Lit(PBool(true)))
  assert Eq(QCol("t", "id"), Col("other_id")) == Eq(QCol("t", "id"), Col("other_id"))
end

test "Neq with various exprs" do
  assert Neq(Col("status"), Lit(PString("deleted"))) == Neq(Col("status"), Lit(PString("deleted")))
  assert Neq(Col("count"), Lit(PInt(0))) == Neq(Col("count"), Lit(PInt(0)))
end

test "Lt Gt Lte Gte" do
  assert Lt(Col("age"), Lit(PInt(18))) == Lt(Col("age"), Lit(PInt(18)))
  assert Gt(Col("score"), Lit(PInt(100))) == Gt(Col("score"), Lit(PInt(100)))
  assert Lte(Col("priority"), Lit(PInt(5))) == Lte(Col("priority"), Lit(PInt(5)))
  assert Gte(Col("rating"), Lit(PInt(1))) == Gte(Col("rating"), Lit(PInt(1)))
end

test "And with various conditions" do
  assert And(Eq(Col("a"), Lit(PInt(1))), Eq(Col("b"), Lit(PInt(2)))) == And(Eq(Col("a"), Lit(PInt(1))), Eq(Col("b"), Lit(PInt(2))))
  assert And(Gt(Col("x"), Lit(PInt(0))), Lt(Col("x"), Lit(PInt(10)))) == And(Gt(Col("x"), Lit(PInt(0))), Lt(Col("x"), Lit(PInt(10))))
end

test "Or with various conditions" do
  assert Or(Eq(Col("a"), Lit(PInt(1))), Eq(Col("a"), Lit(PInt(2)))) == Or(Eq(Col("a"), Lit(PInt(1))), Eq(Col("a"), Lit(PInt(2))))
  assert Or(IsNull(Col("x")), Eq(Col("y"), Lit(PBool(false)))) == Or(IsNull(Col("x")), Eq(Col("y"), Lit(PBool(false))))
end

test "Not with various exprs" do
  assert Not(Eq(Col("deleted"), Lit(PBool(true)))) == Not(Eq(Col("deleted"), Lit(PBool(true))))
  assert Not(IsNull(Col("email"))) == Not(IsNull(Col("email")))
  assert Not(And(Eq(Col("a"), Lit(PInt(1))), Eq(Col("b"), Lit(PInt(2))))) == Not(And(Eq(Col("a"), Lit(PInt(1))), Eq(Col("b"), Lit(PInt(2)))))
end

test "Add Sub Mul Div" do
  assert Add(Col("a"), Col("b")) == Add(Col("a"), Col("b"))
  assert Sub(Col("x"), Lit(PInt(1))) == Sub(Col("x"), Lit(PInt(1)))
  assert Mul(Col("qty"), Col("price")) == Mul(Col("qty"), Col("price"))
  assert Div(Col("total"), Lit(PInt(100))) == Div(Col("total"), Lit(PInt(100)))
end

test "IsNull IsNotNull" do
  assert IsNull(Col("deleted_at")) == IsNull(Col("deleted_at"))
  assert IsNotNull(Col("email")) == IsNotNull(Col("email"))
  assert IsNull(QCol("t", "x")) == IsNull(QCol("t", "x"))
  assert IsNotNull(Col("confirmed")) == IsNotNull(Col("confirmed"))
end

test "Like ILike" do
  assert Like(Col("name"), "A%") == Like(Col("name"), "A%")
  assert ILike(Col("email"), "%@example.com") == ILike(Col("email"), "%@example.com")
  assert Like(Col("title"), "%foo%") == Like(Col("title"), "%foo%")
end

test "Between" do
  assert Between(Col("age"), Lit(PInt(18)), Lit(PInt(65))) == Between(Col("age"), Lit(PInt(18)), Lit(PInt(65)))
  assert Between(Col("score"), Lit(PFloat(0.0)), Lit(PFloat(1.0))) == Between(Col("score"), Lit(PFloat(0.0)), Lit(PFloat(1.0)))
end

test "In NotIn" do
  assert In(Col("status"), [Lit(PString("a")), Lit(PString("b"))]) == In(Col("status"), [Lit(PString("a")), Lit(PString("b"))])
  assert NotIn(Col("role"), [Lit(PString("banned"))]) == NotIn(Col("role"), [Lit(PString("banned"))])
end

test "Count Sum Avg Min Max CountAll" do
  assert Count(Col("id")) == Count(Col("id"))
  assert Sum(Col("amount")) == Sum(Col("amount"))
  assert Avg(Col("score")) == Avg(Col("score"))
  assert Min(Col("price")) == Min(Col("price"))
  assert Max(Col("price")) == Max(Col("price"))
  assert CountAll == CountAll
end

test "FnCall" do
  assert FnCall("lower", [Col("email")]) == FnCall("lower", [Col("email")])
  assert FnCall("coalesce", [Col("a"), Col("b")]) == FnCall("coalesce", [Col("a"), Col("b")])
  assert FnCall("now", Nil) == FnCall("now", Nil)
end

test "ExprParam Raw" do
  assert ExprParam(1) == ExprParam(1)
  assert ExprParam(2) == ExprParam(2)
  assert Raw("NOW()") == Raw("NOW()")
  assert Raw("1=1") == Raw("1=1")
end

test "Exists SubqueryExpr" do
  let subq = Query({ from_ = FromTable("t"), selects = Nil, wheres = Nil,
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert Exists(subq) == Exists(subq)
  assert SubqueryExpr(subq) == SubqueryExpr(subq)
end

test "SelectField SelectAs SelectAll" do
  assert SelectField(Col("id")) == SelectField(Col("id"))
  assert SelectField(QCol("t", "id")) == SelectField(QCol("t", "id"))
  assert SelectAs(Col("name"), "n") == SelectAs(Col("name"), "n")
  assert SelectAs(Count(Col("id")), "total") == SelectAs(Count(Col("id")), "total")
  assert SelectAll == SelectAll
end

test "Where OrWhere" do
  assert Where(Eq(Col("id"), Lit(PInt(1)))) == Where(Eq(Col("id"), Lit(PInt(1))))
  assert OrWhere(Eq(Col("role"), Lit(PString("admin")))) == OrWhere(Eq(Col("role"), Lit(PString("admin"))))
end

test "JoinKind variants" do
  assert Inner == Inner
  assert Left == Left
  assert Right == Right
  assert FullOuter == FullOuter
  assert Cross == Cross
end

test "JoinClause various" do
  assert JoinClause(Inner, "users", Eq(QCol("o", "uid"), QCol("users", "id"))) == JoinClause(Inner, "users", Eq(QCol("o", "uid"), QCol("users", "id")))
  assert JoinClause(Left, "tags", Eq(Col("post_id"), Col("id"))) == JoinClause(Left, "tags", Eq(Col("post_id"), Col("id")))
  assert JoinClause(Right, "b", Eq(Col("a"), Col("b"))) == JoinClause(Right, "b", Eq(Col("a"), Col("b")))
  assert JoinClause(FullOuter, "c", Raw("1=1")) == JoinClause(FullOuter, "c", Raw("1=1"))
end

test "OrderDir variants" do
  assert Asc == Asc
  assert Desc == Desc
  assert AscNullsFirst == AscNullsFirst
  assert AscNullsLast == AscNullsLast
  assert DescNullsFirst == DescNullsFirst
  assert DescNullsLast == DescNullsLast
end

test "OrderExpr various" do
  assert OrderExpr(Col("name"), Asc) == OrderExpr(Col("name"), Asc)
  assert OrderExpr(Col("created_at"), Desc) == OrderExpr(Col("created_at"), Desc)
  assert OrderExpr(Col("score"), AscNullsLast) == OrderExpr(Col("score"), AscNullsLast)
  assert OrderExpr(Col("rank"), DescNullsFirst) == OrderExpr(Col("rank"), DescNullsFirst)
end

test "FromTable" do
  assert FromTable("users") == FromTable("users")
  assert FromTable("orders") == FromTable("orders")
  assert FromTable("products") == FromTable("products")
end

test "FromSubquery" do
  let sub = Query({ from_ = FromTable("events"), selects = Nil, wheres = Nil,
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert FromSubquery(sub, "e") == FromSubquery(sub, "e")
end

test "Query construction" do
  let q = Query({ from_ = FromTable("t"), selects = Nil, wheres = Nil,
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert q == q
end

test "Query with selects" do
  let q = Query({ from_ = FromTable("t"),
    selects = [SelectField(Col("id")), SelectField(Col("name"))],
    wheres = Nil, joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert q == q
end

test "Query with wheres" do
  let q = Query({ from_ = FromTable("t"),
    wheres = [Where(Eq(Col("active"), Lit(PBool(true)))), Where(Gt(Col("age"), Lit(PInt(18))))],
    selects = Nil, joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert q == q
end

test "Query with limit and offset" do
  let q = Query({ from_ = FromTable("t"), selects = Nil, wheres = Nil,
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = Some(10), offset_ = Some(20), distinct_ = NoDistinct })
  assert q == q
end

test "Query with distinct" do
  let q = Query({ from_ = FromTable("t"), selects = [SelectAll], wheres = Nil,
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = Distinct })
  assert q == q
end

test "Query with joins" do
  let q = Query({ from_ = FromTable("orders"), selects = Nil,
    joins = [JoinClause(Inner, "users", Eq(QCol("orders", "user_id"), QCol("users", "id")))],
    wheres = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert q == q
end

test "Query with group_bys and havings" do
  let q = Query({ from_ = FromTable("t"), selects = Nil,
    group_bys = [Col("status"), Col("region")],
    havings = [Where(Gt(Count(Col("id")), Lit(PInt(1))))],
    wheres = Nil, joins = Nil, orders = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert q == q
end

test "Query with orders" do
  let q = Query({ from_ = FromTable("t"), selects = Nil,
    orders = [OrderExpr(Col("name"), Asc), OrderExpr(Col("created_at"), Desc)],
    wheres = Nil, joins = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert q == q
end

test "Complex nested expressions" do
  let expr1 = And(Or(Eq(Col("a"), Lit(PInt(1))), Eq(Col("a"), Lit(PInt(2)))), Not(IsNull(Col("b"))))
  assert expr1 == expr1
end

test "Complex select expressions" do
  let e1 = SelectAs(Add(Col("x"), Col("y")), "sum")
  let e2 = SelectAs(Mul(Col("qty"), Col("price")), "total")
  let e3 = SelectAs(CountAll, "n")
  assert e1 == e1
  assert e2 == e2
  assert e3 == e3
end

test "Deeply nested expression" do
  let expr = And(
    And(Gte(Col("a"), Lit(PInt(1))), Lte(Col("a"), Lit(PInt(100)))),
    And(IsNotNull(Col("b")), Neq(Col("c"), Lit(PString("deleted"))))
  )
  assert expr == expr
end

test "Expression with FnCall nested" do
  let expr = Eq(FnCall("lower", [Col("email")]), Lit(PString("test@example.com")))
  assert expr == expr
end

test "In expression with multiple values" do
  let expr = In(Col("status"), [Lit(PString("active")), Lit(PString("pending")), Lit(PString("review"))])
  assert expr == expr
end

test "NotIn expression with values" do
  let expr = NotIn(Col("role"), [Lit(PString("banned")), Lit(PString("suspended"))])
  assert expr == expr
end

test "Between with string values" do
  let expr = Between(Col("date"), Lit(PString("2024-01-01")), Lit(PString("2024-12-31")))
  assert expr == expr
end

test "Subquery expressions" do
  let sub = Query({ from_ = FromTable("orders"), selects = Nil, wheres = Nil,
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert Exists(sub) == Exists(sub)
  assert SubqueryExpr(sub) == SubqueryExpr(sub)
end

test "ExprParam various indices" do
  assert ExprParam(0) == ExprParam(0)
  assert ExprParam(1) == ExprParam(1)
  assert ExprParam(10) == ExprParam(10)
  assert ExprParam(99) == ExprParam(99)
end

test "Raw SQL expressions" do
  assert Raw("1 = 1") == Raw("1 = 1")
  assert Raw("NOW() > created_at") == Raw("NOW() > created_at")
  assert Raw("") == Raw("")
end

test "SelectField with QCol" do
  assert SelectField(QCol("users", "id")) == SelectField(QCol("users", "id"))
  assert SelectField(QCol("orders", "amount")) == SelectField(QCol("orders", "amount"))
end

test "SelectAs with aggregates" do
  assert SelectAs(Sum(Col("amount")), "total") == SelectAs(Sum(Col("amount")), "total")
  assert SelectAs(Avg(Col("score")), "avg_score") == SelectAs(Avg(Col("score")), "avg_score")
  assert SelectAs(Min(Col("price")), "min_price") == SelectAs(Min(Col("price")), "min_price")
  assert SelectAs(Max(Col("price")), "max_price") == SelectAs(Max(Col("price")), "max_price")
end

test "SelectAs with arithmetic" do
  assert SelectAs(Add(Col("a"), Col("b")), "sum") == SelectAs(Add(Col("a"), Col("b")), "sum")
  assert SelectAs(Sub(Col("x"), Col("y")), "diff") == SelectAs(Sub(Col("x"), Col("y")), "diff")
  assert SelectAs(Mul(Col("q"), Col("p")), "total") == SelectAs(Mul(Col("q"), Col("p")), "total")
end

test "Where OrWhere with complex exprs" do
  assert Where(And(Gt(Col("a"), Lit(PInt(0))), Lt(Col("a"), Lit(PInt(100))))) == Where(And(Gt(Col("a"), Lit(PInt(0))), Lt(Col("a"), Lit(PInt(100)))))
  assert OrWhere(Or(Eq(Col("x"), Lit(PInt(1))), Eq(Col("y"), Lit(PInt(2))))) == OrWhere(Or(Eq(Col("x"), Lit(PInt(1))), Eq(Col("y"), Lit(PInt(2)))))
end

test "JoinClause with complex ON exprs" do
  assert JoinClause(Inner, "categories", And(Eq(QCol("p", "cat_id"), QCol("c", "id")), Eq(QCol("c", "active"), Lit(PBool(true))))) == JoinClause(Inner, "categories", And(Eq(QCol("p", "cat_id"), QCol("c", "id")), Eq(QCol("c", "active"), Lit(PBool(true)))))
end

test "OrderExpr with NullsFirst NullsLast" do
  assert OrderExpr(Col("x"), AscNullsFirst) == OrderExpr(Col("x"), AscNullsFirst)
  assert OrderExpr(Col("x"), AscNullsLast) == OrderExpr(Col("x"), AscNullsLast)
  assert OrderExpr(Col("x"), DescNullsFirst) == OrderExpr(Col("x"), DescNullsFirst)
  assert OrderExpr(Col("x"), DescNullsLast) == OrderExpr(Col("x"), DescNullsLast)
end

test "Multiple aggregate exprs" do
  assert Count(Col("id")) == Count(Col("id"))
  assert Count(QCol("t", "id")) == Count(QCol("t", "id"))
  assert Sum(Add(Col("a"), Col("b"))) == Sum(Add(Col("a"), Col("b")))
  assert Avg(Div(Col("total"), Lit(PInt(100)))) == Avg(Div(Col("total"), Lit(PInt(100))))
end

test "Deeply nested arithmetic" do
  let expr = Add(Mul(Col("a"), Col("b")), Div(Col("c"), Lit(PInt(2))))
  assert expr == expr
  let expr2 = Sub(Add(Col("x"), Lit(PInt(10))), Mul(Col("y"), Lit(PInt(3))))
  assert expr2 == expr2
end

test "Like ILike with various patterns" do
  assert Like(Col("name"), "%alice%") == Like(Col("name"), "%alice%")
  assert Like(Col("email"), "%@gmail.com") == Like(Col("email"), "%@gmail.com")
  assert ILike(Col("title"), "%DRAFT%") == ILike(Col("title"), "%DRAFT%")
  assert ILike(Col("body"), "%important%") == ILike(Col("body"), "%important%")
end

test "IsNull IsNotNull with QCol" do
  assert IsNull(QCol("t", "deleted_at")) == IsNull(QCol("t", "deleted_at"))
  assert IsNotNull(QCol("u", "email")) == IsNotNull(QCol("u", "email"))
end

test "Query all fields populated" do
  let q = Query({
    from_ = FromTable("orders"),
    selects = [SelectField(Col("id")), SelectAs(Sum(Col("amount")), "total")],
    wheres = [Where(Eq(Col("status"), Lit(PString("active"))))],
    joins = [JoinClause(Left, "users", Eq(QCol("orders", "user_id"), QCol("users", "id")))],
    orders = [OrderExpr(Col("id"), Desc)],
    group_bys = [Col("status")],
    havings = [Where(Gt(Count(Col("id")), Lit(PInt(0))))],
    limit_ = Some(100),
    offset_ = Some(0),
    distinct_ = NoDistinct
  })
  assert q == q
end

test "FnCall with multiple args" do
  assert FnCall("concat", [Col("first"), Lit(PString(" ")), Col("last")]) == FnCall("concat", [Col("first"), Lit(PString(" ")), Col("last")])
  assert FnCall("greatest", [Col("a"), Col("b"), Col("c")]) == FnCall("greatest", [Col("a"), Col("b"), Col("c")])
end

test "In with PInt values" do
  assert In(Col("id"), [Lit(PInt(1)), Lit(PInt(2)), Lit(PInt(3))]) == In(Col("id"), [Lit(PInt(1)), Lit(PInt(2)), Lit(PInt(3))])
end

test "NotIn with PInt values" do
  assert NotIn(Col("id"), [Lit(PInt(99)), Lit(PInt(100))]) == NotIn(Col("id"), [Lit(PInt(99)), Lit(PInt(100))])
end

test "Between with int values" do
  assert Between(Col("age"), Lit(PInt(0)), Lit(PInt(120))) == Between(Col("age"), Lit(PInt(0)), Lit(PInt(120)))
  assert Between(Col("price"), Lit(PInt(10)), Lit(PInt(1000))) == Between(Col("price"), Lit(PInt(10)), Lit(PInt(1000)))
end

test "Complex boolean combinations" do
  let a = Eq(Col("a"), Lit(PInt(1)))
  let b = Gt(Col("b"), Lit(PInt(0)))
  let c = IsNull(Col("c"))
  assert And(a, Or(b, Not(c))) == And(a, Or(b, Not(c)))
  assert Or(And(a, b), And(Not(a), c)) == Or(And(a, b), And(Not(a), c))
end

test "SelectAs with nested FnCall" do
  assert SelectAs(FnCall("upper", [Col("name")]), "upper_name") == SelectAs(FnCall("upper", [Col("name")]), "upper_name")
end

test "Multiple wheres list" do
  let ws = [
    Where(Eq(Col("status"), Lit(PString("active")))),
    Where(Gt(Col("age"), Lit(PInt(18)))),
    Where(IsNotNull(Col("email")))
  ]
  assert ws == ws
end

test "Multiple joins list" do
  let js = [
    JoinClause(Inner, "users", Eq(QCol("o", "uid"), QCol("u", "id"))),
    JoinClause(Left, "products", Eq(QCol("o", "pid"), QCol("p", "id")))
  ]
  assert js == js
end

test "Multiple selects list" do
  let ss = [
    SelectField(Col("id")),
    SelectField(Col("name")),
    SelectAs(Count(Col("id")), "n"),
    SelectAs(Sum(Col("amount")), "total"),
    SelectAll
  ]
  assert ss == ss
end

test "Multiple orders list" do
  let os = [
    OrderExpr(Col("created_at"), Desc),
    OrderExpr(Col("name"), Asc),
    OrderExpr(Col("id"), AscNullsLast)
  ]
  assert os == os
end

test "Group bys list" do
  let gbs = [Col("category"), Col("region"), QCol("t", "year")]
  assert gbs == gbs
end

test "Lit PFloat various" do
  assert Lit(PFloat(0.0)) == Lit(PFloat(0.0))
  assert Lit(PFloat(-1.0)) == Lit(PFloat(-1.0))
  assert Lit(PFloat(100.5)) == Lit(PFloat(100.5))
  assert Lit(PFloat(0.001)) == Lit(PFloat(0.001))
end

test "Lit PNull" do
  assert Lit(PNull) == Lit(PNull)
end

test "Comparison operators with QCol" do
  assert Eq(QCol("a", "x"), QCol("b", "y")) == Eq(QCol("a", "x"), QCol("b", "y"))
  assert Neq(QCol("t", "val"), Lit(PInt(0))) == Neq(QCol("t", "val"), Lit(PInt(0)))
  assert Lt(QCol("t", "age"), Lit(PInt(65))) == Lt(QCol("t", "age"), Lit(PInt(65)))
  assert Gte(QCol("t", "score"), Lit(PFloat(0.5))) == Gte(QCol("t", "score"), Lit(PFloat(0.5)))
end

test "Not with complex inner" do
  assert Not(And(Eq(Col("a"), Lit(PInt(1))), Gt(Col("b"), Lit(PInt(0))))) == Not(And(Eq(Col("a"), Lit(PInt(1))), Gt(Col("b"), Lit(PInt(0)))))
  assert Not(Or(IsNull(Col("x")), IsNull(Col("y")))) == Not(Or(IsNull(Col("x")), IsNull(Col("y"))))
end

test "Count Min Max Sum Avg with QCol" do
  assert Count(QCol("t", "id")) == Count(QCol("t", "id"))
  assert Min(QCol("t", "price")) == Min(QCol("t", "price"))
  assert Max(QCol("t", "price")) == Max(QCol("t", "price"))
  assert Sum(QCol("t", "amount")) == Sum(QCol("t", "amount"))
  assert Avg(QCol("t", "score")) == Avg(QCol("t", "score"))
end

test "ExprParam sequence" do
  assert [ExprParam(1), ExprParam(2), ExprParam(3)] == [ExprParam(1), ExprParam(2), ExprParam(3)]
end

test "FromTable various tables" do
  assert FromTable("users") == FromTable("users")
  assert FromTable("orders") == FromTable("orders")
  assert FromTable("products") == FromTable("products")
  assert FromTable("schema_migrations") == FromTable("schema_migrations")
end

-- ---- Dense coverage batch 1: binary comparison expressions ----

test "eq neq lt lte gt gte with int literals batch" do
  assert Eq(Col("a"), Lit(PInt(0))) == Eq(Col("a"), Lit(PInt(0)))
  assert Eq(Col("b"), Lit(PInt(1))) == Eq(Col("b"), Lit(PInt(1)))
  assert Eq(Col("c"), Lit(PInt(100))) == Eq(Col("c"), Lit(PInt(100)))
  assert Neq(Col("a"), Lit(PInt(0))) == Neq(Col("a"), Lit(PInt(0)))
  assert Neq(Col("b"), Lit(PInt(1))) == Neq(Col("b"), Lit(PInt(1)))
  assert Neq(Col("c"), Lit(PInt(99))) == Neq(Col("c"), Lit(PInt(99)))
  assert Lt(Col("age"), Lit(PInt(18))) == Lt(Col("age"), Lit(PInt(18)))
  assert Lt(Col("score"), Lit(PInt(50))) == Lt(Col("score"), Lit(PInt(50)))
  assert Lt(Col("rank"), Lit(PInt(10))) == Lt(Col("rank"), Lit(PInt(10)))
  assert Lte(Col("age"), Lit(PInt(65))) == Lte(Col("age"), Lit(PInt(65)))
  assert Lte(Col("count"), Lit(PInt(0))) == Lte(Col("count"), Lit(PInt(0)))
  assert Lte(Col("level"), Lit(PInt(5))) == Lte(Col("level"), Lit(PInt(5)))
  assert Gt(Col("age"), Lit(PInt(21))) == Gt(Col("age"), Lit(PInt(21)))
  assert Gt(Col("score"), Lit(PInt(75))) == Gt(Col("score"), Lit(PInt(75)))
  assert Gt(Col("balance"), Lit(PInt(0))) == Gt(Col("balance"), Lit(PInt(0)))
  assert Gte(Col("age"), Lit(PInt(18))) == Gte(Col("age"), Lit(PInt(18)))
  assert Gte(Col("score"), Lit(PInt(60))) == Gte(Col("score"), Lit(PInt(60)))
  assert Gte(Col("priority"), Lit(PInt(1))) == Gte(Col("priority"), Lit(PInt(1)))
  assert Eq(Col("status"), Lit(PString("active"))) == Eq(Col("status"), Lit(PString("active")))
  assert Eq(Col("role"), Lit(PString("admin"))) == Eq(Col("role"), Lit(PString("admin")))
  assert Neq(Col("status"), Lit(PString("deleted"))) == Neq(Col("status"), Lit(PString("deleted")))
  assert Neq(Col("type"), Lit(PString("banned"))) == Neq(Col("type"), Lit(PString("banned")))
  assert Eq(Col("active"), Lit(PBool(true))) == Eq(Col("active"), Lit(PBool(true)))
  assert Eq(Col("enabled"), Lit(PBool(false))) == Eq(Col("enabled"), Lit(PBool(false)))
  assert Neq(Col("deleted"), Lit(PBool(true))) == Neq(Col("deleted"), Lit(PBool(true)))
  assert Eq(Col("price"), Lit(PFloat(9.99))) == Eq(Col("price"), Lit(PFloat(9.99)))
  assert Gt(Col("rating"), Lit(PFloat(4.0))) == Gt(Col("rating"), Lit(PFloat(4.0)))
  assert Lt(Col("discount"), Lit(PFloat(0.5))) == Lt(Col("discount"), Lit(PFloat(0.5)))
  assert Gte(Col("weight"), Lit(PFloat(1.0))) == Gte(Col("weight"), Lit(PFloat(1.0)))
  assert Lte(Col("temp"), Lit(PFloat(100.0))) == Lte(Col("temp"), Lit(PFloat(100.0)))
  assert Eq(QCol("u", "id"), QCol("o", "user_id")) == Eq(QCol("u", "id"), QCol("o", "user_id"))
  assert Eq(QCol("orders", "status"), Lit(PString("paid"))) == Eq(QCol("orders", "status"), Lit(PString("paid")))
  assert Neq(QCol("users", "role"), Lit(PString("guest"))) == Neq(QCol("users", "role"), Lit(PString("guest")))
  assert Gt(QCol("items", "qty"), Lit(PInt(0))) == Gt(QCol("items", "qty"), Lit(PInt(0)))
  assert Lte(QCol("products", "stock"), Lit(PInt(10))) == Lte(QCol("products", "stock"), Lit(PInt(10)))
  assert Eq(Col("created_at"), Lit(PNull)) == Eq(Col("created_at"), Lit(PNull))
  assert Neq(Col("deleted_at"), Lit(PNull)) == Neq(Col("deleted_at"), Lit(PNull))
  assert IsNull(Col("archived_at")) == IsNull(Col("archived_at"))
  assert IsNotNull(Col("confirmed_at")) == IsNotNull(Col("confirmed_at"))
  assert IsNull(QCol("posts", "published_at")) == IsNull(QCol("posts", "published_at"))
  assert IsNotNull(QCol("users", "email")) == IsNotNull(QCol("users", "email"))
end

test "and or not combinations batch" do
  assert And(Eq(Col("a"), Lit(PInt(1))), Eq(Col("b"), Lit(PInt(2)))) == And(Eq(Col("a"), Lit(PInt(1))), Eq(Col("b"), Lit(PInt(2))))
  assert And(Gt(Col("age"), Lit(PInt(18))), Lt(Col("age"), Lit(PInt(65)))) == And(Gt(Col("age"), Lit(PInt(18))), Lt(Col("age"), Lit(PInt(65))))
  assert And(Eq(Col("active"), Lit(PBool(true))), IsNotNull(Col("email"))) == And(Eq(Col("active"), Lit(PBool(true))), IsNotNull(Col("email")))
  assert And(Neq(Col("status"), Lit(PString("banned"))), Gte(Col("score"), Lit(PInt(0)))) == And(Neq(Col("status"), Lit(PString("banned"))), Gte(Col("score"), Lit(PInt(0))))
  assert Or(Eq(Col("role"), Lit(PString("admin"))), Eq(Col("role"), Lit(PString("mod")))) == Or(Eq(Col("role"), Lit(PString("admin"))), Eq(Col("role"), Lit(PString("mod"))))
  assert Or(Gt(Col("score"), Lit(PInt(90))), Eq(Col("bonus"), Lit(PBool(true)))) == Or(Gt(Col("score"), Lit(PInt(90))), Eq(Col("bonus"), Lit(PBool(true))))
  assert Or(IsNull(Col("deleted_at")), Gt(Col("expires"), Lit(PInt(0)))) == Or(IsNull(Col("deleted_at")), Gt(Col("expires"), Lit(PInt(0))))
  assert Not(Eq(Col("status"), Lit(PString("inactive")))) == Not(Eq(Col("status"), Lit(PString("inactive"))))
  assert Not(IsNull(Col("email"))) == Not(IsNull(Col("email")))
  assert Not(Gt(Col("age"), Lit(PInt(100)))) == Not(Gt(Col("age"), Lit(PInt(100))))
  assert Not(And(Eq(Col("a"), Lit(PInt(1))), Eq(Col("b"), Lit(PInt(2))))) == Not(And(Eq(Col("a"), Lit(PInt(1))), Eq(Col("b"), Lit(PInt(2)))))
  assert Not(Or(Eq(Col("x"), Lit(PInt(0))), Eq(Col("y"), Lit(PInt(0))))) == Not(Or(Eq(Col("x"), Lit(PInt(0))), Eq(Col("y"), Lit(PInt(0)))))
  assert And(Eq(Col("a"), Lit(PInt(1))), And(Eq(Col("b"), Lit(PInt(2))), Eq(Col("c"), Lit(PInt(3))))) == And(Eq(Col("a"), Lit(PInt(1))), And(Eq(Col("b"), Lit(PInt(2))), Eq(Col("c"), Lit(PInt(3)))))
  assert Or(Eq(Col("a"), Lit(PInt(1))), Or(Eq(Col("b"), Lit(PInt(2))), Eq(Col("c"), Lit(PInt(3))))) == Or(Eq(Col("a"), Lit(PInt(1))), Or(Eq(Col("b"), Lit(PInt(2))), Eq(Col("c"), Lit(PInt(3)))))
  assert And(Or(Eq(Col("x"), Lit(PInt(1))), Eq(Col("x"), Lit(PInt(2)))), Gt(Col("y"), Lit(PInt(0)))) == And(Or(Eq(Col("x"), Lit(PInt(1))), Eq(Col("x"), Lit(PInt(2)))), Gt(Col("y"), Lit(PInt(0))))
  assert Or(And(Eq(Col("role"), Lit(PString("admin"))), Eq(Col("active"), Lit(PBool(true)))), And(Eq(Col("role"), Lit(PString("superuser"))), IsNotNull(Col("key")))) == Or(And(Eq(Col("role"), Lit(PString("admin"))), Eq(Col("active"), Lit(PBool(true)))), And(Eq(Col("role"), Lit(PString("superuser"))), IsNotNull(Col("key"))))
  assert And(Not(IsNull(Col("a"))), Not(IsNull(Col("b")))) == And(Not(IsNull(Col("a"))), Not(IsNull(Col("b"))))
  assert Or(Not(Eq(Col("a"), Lit(PInt(0)))), Not(Eq(Col("b"), Lit(PInt(0))))) == Or(Not(Eq(Col("a"), Lit(PInt(0)))), Not(Eq(Col("b"), Lit(PInt(0)))))
  assert And(Gte(Col("age"), Lit(PInt(18))), Lte(Col("age"), Lit(PInt(65)))) == And(Gte(Col("age"), Lit(PInt(18))), Lte(Col("age"), Lit(PInt(65))))
  assert Or(Lt(Col("temp"), Lit(PFloat(0.0))), Gt(Col("temp"), Lit(PFloat(100.0)))) == Or(Lt(Col("temp"), Lit(PFloat(0.0))), Gt(Col("temp"), Lit(PFloat(100.0))))
  assert And(Eq(QCol("u", "active"), Lit(PBool(true))), Neq(QCol("u", "role"), Lit(PString("banned")))) == And(Eq(QCol("u", "active"), Lit(PBool(true))), Neq(QCol("u", "role"), Lit(PString("banned"))))
  assert Or(Eq(QCol("o", "status"), Lit(PString("pending"))), Eq(QCol("o", "status"), Lit(PString("processing")))) == Or(Eq(QCol("o", "status"), Lit(PString("pending"))), Eq(QCol("o", "status"), Lit(PString("processing"))))
  assert Not(And(Gt(Col("x"), Lit(PInt(10))), Lt(Col("x"), Lit(PInt(20))))) == Not(And(Gt(Col("x"), Lit(PInt(10))), Lt(Col("x"), Lit(PInt(20)))))
  assert And(IsNull(Col("a")), IsNull(Col("b"))) == And(IsNull(Col("a")), IsNull(Col("b")))
  assert Or(IsNotNull(Col("a")), IsNotNull(Col("b"))) == Or(IsNotNull(Col("a")), IsNotNull(Col("b")))
  assert And(Like(Col("name"), "Alice%"), IsNotNull(Col("email"))) == And(Like(Col("name"), "Alice%"), IsNotNull(Col("email")))
  assert Or(Like(Col("email"), "%@example.com"), Like(Col("email"), "%@test.com")) == Or(Like(Col("email"), "%@example.com"), Like(Col("email"), "%@test.com"))
  assert And(ILike(Col("title"), "%admin%"), Eq(Col("active"), Lit(PBool(true)))) == And(ILike(Col("title"), "%admin%"), Eq(Col("active"), Lit(PBool(true))))
  assert And(Between(Col("age"), Lit(PInt(18)), Lit(PInt(65))), Eq(Col("active"), Lit(PBool(true)))) == And(Between(Col("age"), Lit(PInt(18)), Lit(PInt(65))), Eq(Col("active"), Lit(PBool(true))))
  assert Or(In(Col("status"), [Lit(PString("a")), Lit(PString("b"))]), IsNull(Col("status"))) == Or(In(Col("status"), [Lit(PString("a")), Lit(PString("b"))]), IsNull(Col("status")))
  assert And(NotIn(Col("role"), [Lit(PString("banned")), Lit(PString("deleted"))]), Eq(Col("active"), Lit(PBool(true)))) == And(NotIn(Col("role"), [Lit(PString("banned")), Lit(PString("deleted"))]), Eq(Col("active"), Lit(PBool(true))))
end

test "arithmetic expressions batch" do
  assert Add(Col("a"), Col("b")) == Add(Col("a"), Col("b"))
  assert Sub(Col("a"), Col("b")) == Sub(Col("a"), Col("b"))
  assert Mul(Col("a"), Col("b")) == Mul(Col("a"), Col("b"))
  assert Div(Col("a"), Col("b")) == Div(Col("a"), Col("b"))
  assert Add(Col("price"), Lit(PFloat(1.0))) == Add(Col("price"), Lit(PFloat(1.0)))
  assert Sub(Col("balance"), Lit(PInt(100))) == Sub(Col("balance"), Lit(PInt(100)))
  assert Mul(Col("qty"), Col("unit_price")) == Mul(Col("qty"), Col("unit_price"))
  assert Div(Col("total"), Lit(PInt(2))) == Div(Col("total"), Lit(PInt(2)))
  assert Add(Lit(PInt(1)), Lit(PInt(2))) == Add(Lit(PInt(1)), Lit(PInt(2)))
  assert Sub(Lit(PInt(10)), Lit(PInt(3))) == Sub(Lit(PInt(10)), Lit(PInt(3)))
  assert Mul(Lit(PInt(4)), Lit(PInt(5))) == Mul(Lit(PInt(4)), Lit(PInt(5)))
  assert Div(Lit(PFloat(10.0)), Lit(PFloat(3.0))) == Div(Lit(PFloat(10.0)), Lit(PFloat(3.0)))
  assert Add(QCol("t", "a"), QCol("t", "b")) == Add(QCol("t", "a"), QCol("t", "b"))
  assert Sub(QCol("t", "total"), QCol("t", "discount")) == Sub(QCol("t", "total"), QCol("t", "discount"))
  assert Mul(QCol("o", "qty"), QCol("p", "price")) == Mul(QCol("o", "qty"), QCol("p", "price"))
  assert Add(Col("subtotal"), Mul(Col("qty"), Col("unit_price"))) == Add(Col("subtotal"), Mul(Col("qty"), Col("unit_price")))
  assert Sub(Col("total"), Add(Col("tax"), Col("shipping"))) == Sub(Col("total"), Add(Col("tax"), Col("shipping")))
  assert Mul(Add(Col("a"), Col("b")), Sub(Col("c"), Col("d"))) == Mul(Add(Col("a"), Col("b")), Sub(Col("c"), Col("d")))
  assert Div(Sub(Col("end_val"), Col("start_val")), Col("start_val")) == Div(Sub(Col("end_val"), Col("start_val")), Col("start_val"))
  assert Eq(Add(Col("a"), Col("b")), Lit(PInt(10))) == Eq(Add(Col("a"), Col("b")), Lit(PInt(10)))
  assert Gt(Mul(Col("qty"), Col("price")), Lit(PFloat(100.0))) == Gt(Mul(Col("qty"), Col("price")), Lit(PFloat(100.0)))
  assert Lt(Div(Col("discount"), Col("total")), Lit(PFloat(0.5))) == Lt(Div(Col("discount"), Col("total")), Lit(PFloat(0.5)))
  assert Gte(Sub(Col("end"), Col("start")), Lit(PInt(0))) == Gte(Sub(Col("end"), Col("start")), Lit(PInt(0)))
  assert Add(Sum(Col("amount")), Lit(PInt(0))) == Add(Sum(Col("amount")), Lit(PInt(0)))
  assert Mul(Avg(Col("rating")), Lit(PInt(100))) == Mul(Avg(Col("rating")), Lit(PInt(100)))
  assert Div(Count(Col("id")), Lit(PInt(2))) == Div(Count(Col("id")), Lit(PInt(2)))
  assert Sub(Max(Col("score")), Min(Col("score"))) == Sub(Max(Col("score")), Min(Col("score")))
  assert Add(Col("a"), Add(Col("b"), Add(Col("c"), Col("d")))) == Add(Col("a"), Add(Col("b"), Add(Col("c"), Col("d"))))
  assert Mul(Col("x"), Mul(Col("y"), Col("z"))) == Mul(Col("x"), Mul(Col("y"), Col("z")))
  assert Eq(Div(Add(Col("a"), Col("b")), Lit(PInt(2))), Col("avg")) == Eq(Div(Add(Col("a"), Col("b")), Lit(PInt(2))), Col("avg"))
end

test "aggregate functions batch" do
  assert Count(Col("id")) == Count(Col("id"))
  assert Count(Col("user_id")) == Count(Col("user_id"))
  assert Count(Col("order_id")) == Count(Col("order_id"))
  assert Count(QCol("t", "id")) == Count(QCol("t", "id"))
  assert Count(QCol("orders", "id")) == Count(QCol("orders", "id"))
  assert CountAll == CountAll
  assert Sum(Col("amount")) == Sum(Col("amount"))
  assert Sum(Col("revenue")) == Sum(Col("revenue"))
  assert Sum(Col("quantity")) == Sum(Col("quantity"))
  assert Sum(QCol("o", "total")) == Sum(QCol("o", "total"))
  assert Sum(Mul(Col("qty"), Col("price"))) == Sum(Mul(Col("qty"), Col("price")))
  assert Avg(Col("score")) == Avg(Col("score"))
  assert Avg(Col("rating")) == Avg(Col("rating"))
  assert Avg(Col("age")) == Avg(Col("age"))
  assert Avg(QCol("r", "score")) == Avg(QCol("r", "score"))
  assert Min(Col("price")) == Min(Col("price"))
  assert Min(Col("age")) == Min(Col("age"))
  assert Min(Col("created_at")) == Min(Col("created_at"))
  assert Min(QCol("p", "price")) == Min(QCol("p", "price"))
  assert Max(Col("score")) == Max(Col("score"))
  assert Max(Col("age")) == Max(Col("age"))
  assert Max(Col("updated_at")) == Max(Col("updated_at"))
  assert Max(QCol("e", "salary")) == Max(QCol("e", "salary"))
  assert Gt(Count(Col("id")), Lit(PInt(0))) == Gt(Count(Col("id")), Lit(PInt(0)))
  assert Gte(Sum(Col("amount")), Lit(PFloat(100.0))) == Gte(Sum(Col("amount")), Lit(PFloat(100.0)))
  assert Lt(Avg(Col("score")), Lit(PFloat(5.0))) == Lt(Avg(Col("score")), Lit(PFloat(5.0)))
  assert Eq(Min(Col("price")), Max(Col("price"))) == Eq(Min(Col("price")), Max(Col("price")))
  assert Neq(Count(Col("id")), Lit(PInt(0))) == Neq(Count(Col("id")), Lit(PInt(0)))
  assert Gt(Sum(QCol("o", "amount")), Lit(PFloat(1000.0))) == Gt(Sum(QCol("o", "amount")), Lit(PFloat(1000.0)))
  assert SelectAs(Count(Col("id")), "total") == SelectAs(Count(Col("id")), "total")
  assert SelectAs(Sum(Col("amount")), "revenue") == SelectAs(Sum(Col("amount")), "revenue")
  assert SelectAs(Avg(Col("rating")), "avg_rating") == SelectAs(Avg(Col("rating")), "avg_rating")
  assert SelectAs(Min(Col("price")), "min_price") == SelectAs(Min(Col("price")), "min_price")
  assert SelectAs(Max(Col("score")), "max_score") == SelectAs(Max(Col("score")), "max_score")
  assert SelectAs(CountAll, "count") == SelectAs(CountAll, "count")
  assert SelectAs(Sub(Max(Col("score")), Min(Col("score"))), "range") == SelectAs(Sub(Max(Col("score")), Min(Col("score"))), "range")
  assert SelectField(Count(Col("id"))) == SelectField(Count(Col("id")))
  assert SelectField(Sum(Col("total"))) == SelectField(Sum(Col("total")))
  assert SelectField(Avg(Col("age"))) == SelectField(Avg(Col("age")))
end

test "like ilike between in notin batch" do
  assert Like(Col("name"), "Alice%") == Like(Col("name"), "Alice%")
  assert Like(Col("email"), "%@example.com") == Like(Col("email"), "%@example.com")
  assert Like(Col("title"), "%manager%") == Like(Col("title"), "%manager%")
  assert Like(Col("code"), "US%") == Like(Col("code"), "US%")
  assert Like(QCol("u", "name"), "Bob%") == Like(QCol("u", "name"), "Bob%")
  assert ILike(Col("name"), "%alice%") == ILike(Col("name"), "%alice%")
  assert ILike(Col("email"), "%EXAMPLE%") == ILike(Col("email"), "%EXAMPLE%")
  assert ILike(Col("description"), "%important%") == ILike(Col("description"), "%important%")
  assert ILike(QCol("p", "title"), "%sale%") == ILike(QCol("p", "title"), "%sale%")
  assert Between(Col("age"), Lit(PInt(18)), Lit(PInt(65))) == Between(Col("age"), Lit(PInt(18)), Lit(PInt(65)))
  assert Between(Col("price"), Lit(PFloat(10.0)), Lit(PFloat(100.0))) == Between(Col("price"), Lit(PFloat(10.0)), Lit(PFloat(100.0)))
  assert Between(Col("score"), Lit(PInt(0)), Lit(PInt(100))) == Between(Col("score"), Lit(PInt(0)), Lit(PInt(100)))
  assert Between(QCol("o", "amount"), Lit(PFloat(0.0)), Lit(PFloat(1000.0))) == Between(QCol("o", "amount"), Lit(PFloat(0.0)), Lit(PFloat(1000.0)))
  assert In(Col("status"), [Lit(PString("active")), Lit(PString("pending"))]) == In(Col("status"), [Lit(PString("active")), Lit(PString("pending"))])
  assert In(Col("role"), [Lit(PString("admin")), Lit(PString("mod")), Lit(PString("user"))]) == In(Col("role"), [Lit(PString("admin")), Lit(PString("mod")), Lit(PString("user"))])
  assert In(Col("id"), [Lit(PInt(1)), Lit(PInt(2)), Lit(PInt(3))]) == In(Col("id"), [Lit(PInt(1)), Lit(PInt(2)), Lit(PInt(3))])
  assert In(QCol("u", "status"), [Lit(PString("a")), Lit(PString("b"))]) == In(QCol("u", "status"), [Lit(PString("a")), Lit(PString("b"))])
  assert NotIn(Col("status"), [Lit(PString("banned")), Lit(PString("deleted"))]) == NotIn(Col("status"), [Lit(PString("banned")), Lit(PString("deleted"))])
  assert NotIn(Col("role"), [Lit(PString("blocked"))]) == NotIn(Col("role"), [Lit(PString("blocked"))])
  assert NotIn(Col("id"), [Lit(PInt(0))]) == NotIn(Col("id"), [Lit(PInt(0))])
  assert NotIn(QCol("p", "category"), [Lit(PString("archived"))]) == NotIn(QCol("p", "category"), [Lit(PString("archived"))])
  assert And(Like(Col("name"), "A%"), Between(Col("age"), Lit(PInt(20)), Lit(PInt(30)))) == And(Like(Col("name"), "A%"), Between(Col("age"), Lit(PInt(20)), Lit(PInt(30))))
  assert Or(Like(Col("name"), "A%"), Like(Col("name"), "B%")) == Or(Like(Col("name"), "A%"), Like(Col("name"), "B%"))
  assert And(In(Col("status"), [Lit(PString("a"))]), Gte(Col("age"), Lit(PInt(18)))) == And(In(Col("status"), [Lit(PString("a"))]), Gte(Col("age"), Lit(PInt(18))))
  assert And(NotIn(Col("role"), [Lit(PString("banned"))]), Eq(Col("active"), Lit(PBool(true)))) == And(NotIn(Col("role"), [Lit(PString("banned"))]), Eq(Col("active"), Lit(PBool(true))))
  assert Not(Like(Col("name"), "%test%")) == Not(Like(Col("name"), "%test%"))
  assert Not(Between(Col("score"), Lit(PInt(0)), Lit(PInt(50)))) == Not(Between(Col("score"), Lit(PInt(0)), Lit(PInt(50))))
  assert Not(In(Col("status"), [Lit(PString("x")), Lit(PString("y"))])) == Not(In(Col("status"), [Lit(PString("x")), Lit(PString("y"))]))
  assert Not(NotIn(Col("role"), [Lit(PString("admin"))])) == Not(NotIn(Col("role"), [Lit(PString("admin"))]))
  assert Or(Between(Col("age"), Lit(PInt(0)), Lit(PInt(17))), Gt(Col("age"), Lit(PInt(65)))) == Or(Between(Col("age"), Lit(PInt(0)), Lit(PInt(17))), Gt(Col("age"), Lit(PInt(65))))
end

test "select expr types batch" do
  assert SelectAll == SelectAll
  assert SelectField(Col("id")) == SelectField(Col("id"))
  assert SelectField(Col("name")) == SelectField(Col("name"))
  assert SelectField(Col("email")) == SelectField(Col("email"))
  assert SelectField(QCol("u", "id")) == SelectField(QCol("u", "id"))
  assert SelectField(QCol("users", "name")) == SelectField(QCol("users", "name"))
  assert SelectField(Lit(PInt(1))) == SelectField(Lit(PInt(1)))
  assert SelectField(Lit(PString("const"))) == SelectField(Lit(PString("const")))
  assert SelectAs(Col("id"), "user_id") == SelectAs(Col("id"), "user_id")
  assert SelectAs(Col("name"), "full_name") == SelectAs(Col("name"), "full_name")
  assert SelectAs(Col("created_at"), "joined") == SelectAs(Col("created_at"), "joined")
  assert SelectAs(QCol("u", "id"), "uid") == SelectAs(QCol("u", "id"), "uid")
  assert SelectAs(QCol("orders", "total"), "order_total") == SelectAs(QCol("orders", "total"), "order_total")
  assert SelectAs(Lit(PInt(1)), "one") == SelectAs(Lit(PInt(1)), "one")
  assert SelectAs(Lit(PBool(true)), "flag") == SelectAs(Lit(PBool(true)), "flag")
  assert SelectAs(Add(Col("a"), Col("b")), "sum") == SelectAs(Add(Col("a"), Col("b")), "sum")
  assert SelectAs(Mul(Col("qty"), Col("price")), "revenue") == SelectAs(Mul(Col("qty"), Col("price")), "revenue")
  assert SelectAs(Sub(Max(Col("score")), Min(Col("score"))), "range") == SelectAs(Sub(Max(Col("score")), Min(Col("score"))), "range")
  assert [SelectAll] == [SelectAll]
  assert [SelectField(Col("id")), SelectField(Col("name"))] == [SelectField(Col("id")), SelectField(Col("name"))]
  assert [SelectField(Col("id")), SelectAs(Col("name"), "alias")] == [SelectField(Col("id")), SelectAs(Col("name"), "alias")]
  assert [SelectAll, SelectField(Col("id"))] == [SelectAll, SelectField(Col("id"))]
  assert [SelectAs(Count(Col("id")), "cnt"), SelectAs(Sum(Col("amt")), "total")] == [SelectAs(Count(Col("id")), "cnt"), SelectAs(Sum(Col("amt")), "total")]
  assert SelectField(FnCall("length", [Col("age")])) == SelectField(FnCall("length", [Col("age")]))
  assert SelectAs(FnCall("abs", [Col("price")]), "num_price") == SelectAs(FnCall("abs", [Col("price")]), "num_price")
  assert SelectField(Raw("NOW()")) == SelectField(Raw("NOW()"))
  assert SelectAs(Raw("CURRENT_DATE"), "today") == SelectAs(Raw("CURRENT_DATE"), "today")
  assert SelectField(Add(Col("a"), Lit(PInt(1)))) == SelectField(Add(Col("a"), Lit(PInt(1))))
  assert SelectField(Sub(Col("b"), Lit(PInt(1)))) == SelectField(Sub(Col("b"), Lit(PInt(1))))
  assert SelectField(Mul(Col("c"), Lit(PInt(2)))) == SelectField(Mul(Col("c"), Lit(PInt(2))))
  assert SelectField(Div(Col("d"), Lit(PInt(4)))) == SelectField(Div(Col("d"), Lit(PInt(4))))
end

test "join kinds and order dirs batch" do
  assert JoinClause(Inner, "users", Eq(Col("user_id"), Col("id"))) == JoinClause(Inner, "users", Eq(Col("user_id"), Col("id")))
  assert JoinClause(Left, "users", Eq(Col("user_id"), Col("id"))) == JoinClause(Left, "users", Eq(Col("user_id"), Col("id")))
  assert JoinClause(Right, "users", Eq(Col("user_id"), Col("id"))) == JoinClause(Right, "users", Eq(Col("user_id"), Col("id")))
  assert JoinClause(FullOuter, "users", Eq(Col("user_id"), Col("id"))) == JoinClause(FullOuter, "users", Eq(Col("user_id"), Col("id")))
  assert JoinClause(Cross, "tags", Eq(Lit(PBool(true)), Lit(PBool(true)))) == JoinClause(Cross, "tags", Eq(Lit(PBool(true)), Lit(PBool(true))))
  assert JoinClause(Inner, "orders", Eq(QCol("u", "id"), QCol("o", "user_id"))) == JoinClause(Inner, "orders", Eq(QCol("u", "id"), QCol("o", "user_id")))
  assert JoinClause(Left, "products", Eq(QCol("o", "product_id"), QCol("p", "id"))) == JoinClause(Left, "products", Eq(QCol("o", "product_id"), QCol("p", "id")))
  assert JoinClause(Right, "categories", Eq(QCol("p", "cat_id"), QCol("c", "id"))) == JoinClause(Right, "categories", Eq(QCol("p", "cat_id"), QCol("c", "id")))
  assert JoinClause(FullOuter, "logs", Eq(QCol("u", "id"), QCol("l", "user_id"))) == JoinClause(FullOuter, "logs", Eq(QCol("u", "id"), QCol("l", "user_id")))
  assert JoinClause(Inner, "t1", And(Eq(QCol("a", "x"), QCol("b", "x")), Eq(QCol("a", "y"), QCol("b", "y")))) == JoinClause(Inner, "t1", And(Eq(QCol("a", "x"), QCol("b", "x")), Eq(QCol("a", "y"), QCol("b", "y"))))
  assert [JoinClause(Inner, "u", Eq(Col("uid"), Col("id")))] == [JoinClause(Inner, "u", Eq(Col("uid"), Col("id")))]
  assert [JoinClause(Left, "a", Eq(Col("a_id"), Col("id"))), JoinClause(Inner, "b", Eq(Col("b_id"), Col("id")))] == [JoinClause(Left, "a", Eq(Col("a_id"), Col("id"))), JoinClause(Inner, "b", Eq(Col("b_id"), Col("id")))]
  assert OrderExpr(Col("id"), Asc) == OrderExpr(Col("id"), Asc)
  assert OrderExpr(Col("id"), Desc) == OrderExpr(Col("id"), Desc)
  assert OrderExpr(Col("name"), Asc) == OrderExpr(Col("name"), Asc)
  assert OrderExpr(Col("created_at"), Desc) == OrderExpr(Col("created_at"), Desc)
  assert OrderExpr(QCol("u", "name"), Asc) == OrderExpr(QCol("u", "name"), Asc)
  assert OrderExpr(QCol("o", "created_at"), Desc) == OrderExpr(QCol("o", "created_at"), Desc)
  assert OrderExpr(Col("score"), AscNullsFirst) == OrderExpr(Col("score"), AscNullsFirst)
  assert OrderExpr(Col("score"), AscNullsLast) == OrderExpr(Col("score"), AscNullsLast)
  assert OrderExpr(Col("score"), DescNullsFirst) == OrderExpr(Col("score"), DescNullsFirst)
  assert OrderExpr(Col("score"), DescNullsLast) == OrderExpr(Col("score"), DescNullsLast)
  assert [OrderExpr(Col("id"), Asc)] == [OrderExpr(Col("id"), Asc)]
  assert [OrderExpr(Col("name"), Asc), OrderExpr(Col("id"), Desc)] == [OrderExpr(Col("name"), Asc), OrderExpr(Col("id"), Desc)]
  assert [OrderExpr(Col("a"), Asc), OrderExpr(Col("b"), Asc), OrderExpr(Col("c"), Desc)] == [OrderExpr(Col("a"), Asc), OrderExpr(Col("b"), Asc), OrderExpr(Col("c"), Desc)]
  assert Where(Eq(Col("a"), Lit(PInt(1)))) == Where(Eq(Col("a"), Lit(PInt(1))))
  assert Where(And(Eq(Col("a"), Lit(PInt(1))), Gt(Col("b"), Lit(PInt(0))))) == Where(And(Eq(Col("a"), Lit(PInt(1))), Gt(Col("b"), Lit(PInt(0)))))
  assert Where(Or(Eq(Col("x"), Lit(PInt(1))), IsNull(Col("y")))) == Where(Or(Eq(Col("x"), Lit(PInt(1))), IsNull(Col("y"))))
  assert [Where(Eq(Col("a"), Lit(PInt(1))))] == [Where(Eq(Col("a"), Lit(PInt(1))))]
  assert [Where(Eq(Col("a"), Lit(PInt(1)))), Where(Gt(Col("b"), Lit(PInt(0))))] == [Where(Eq(Col("a"), Lit(PInt(1)))), Where(Gt(Col("b"), Lit(PInt(0))))]
  assert Asc == Asc
  assert Desc == Desc
  assert AscNullsFirst == AscNullsFirst
  assert AscNullsLast == AscNullsLast
  assert DescNullsFirst == DescNullsFirst
  assert DescNullsLast == DescNullsLast
  assert Inner == Inner
  assert Left == Left
  assert Right == Right
  assert FullOuter == FullOuter
  assert Cross == Cross
end

test "fncall raw expr param batch" do
  assert FnCall("length", [Col("age")]) == FnCall("length", [Col("age")])
  assert FnCall("abs", [Col("price")]) == FnCall("abs", [Col("price")])
  assert FnCall("lower", [Col("name")]) == FnCall("lower", [Col("name")])
  assert FnCall("upper", [Col("email")]) == FnCall("upper", [Col("email")])
  assert FnCall("coalesce", [Col("name"), Lit(PString("unknown"))]) == FnCall("coalesce", [Col("name"), Lit(PString("unknown"))])
  assert FnCall("coalesce", [Col("value"), Lit(PInt(0))]) == FnCall("coalesce", [Col("value"), Lit(PInt(0))])
  assert FnCall("nullif", [Col("score"), Lit(PInt(0))]) == FnCall("nullif", [Col("score"), Lit(PInt(0))])
  assert FnCall("greatest", [Col("a"), Col("b"), Col("c")]) == FnCall("greatest", [Col("a"), Col("b"), Col("c")])
  assert FnCall("least", [Col("x"), Col("y")]) == FnCall("least", [Col("x"), Col("y")])
  assert FnCall("now", []) == FnCall("now", [])
  assert FnCall("current_timestamp", []) == FnCall("current_timestamp", [])
  assert FnCall("length", [QCol("u", "name")]) == FnCall("length", [QCol("u", "name")])
  assert FnCall("abs", [QCol("o", "amount")]) == FnCall("abs", [QCol("o", "amount")])
  assert Raw("NOW()") == Raw("NOW()")
  assert Raw("CURRENT_DATE") == Raw("CURRENT_DATE")
  assert Raw("CURRENT_TIMESTAMP") == Raw("CURRENT_TIMESTAMP")
  assert Raw("gen_random_uuid()") == Raw("gen_random_uuid()")
  assert Raw("1 + 1") == Raw("1 + 1")
  assert Raw("TRUE") == Raw("TRUE")
  assert Raw("FALSE") == Raw("FALSE")
  assert ExprParam(1) == ExprParam(1)
  assert ExprParam(2) == ExprParam(2)
  assert ExprParam(10) == ExprParam(10)
  assert ExprParam(100) == ExprParam(100)
  assert Eq(FnCall("lower", [Col("email")]), Lit(PString("test@example.com"))) == Eq(FnCall("lower", [Col("email")]), Lit(PString("test@example.com")))
  assert Gt(FnCall("length", [Col("name")]), Lit(PInt(0))) == Gt(FnCall("length", [Col("name")]), Lit(PInt(0)))
  assert Eq(Raw("NOW()"), Col("created_at")) == Eq(Raw("NOW()"), Col("created_at"))
  assert And(Eq(Col("a"), ExprParam(1)), Eq(Col("b"), ExprParam(2))) == And(Eq(Col("a"), ExprParam(1)), Eq(Col("b"), ExprParam(2)))
  assert SelectField(FnCall("length", [Col("x")])) == SelectField(FnCall("length", [Col("x")]))
  assert SelectAs(FnCall("abs", [Col("score")]), "num") == SelectAs(FnCall("abs", [Col("score")]), "num")
  assert SelectField(Raw("NOW()")) == SelectField(Raw("NOW()"))
  assert SelectAs(Raw("CURRENT_DATE"), "today") == SelectAs(Raw("CURRENT_DATE"), "today")
  assert [ExprParam(1), ExprParam(2), ExprParam(3), ExprParam(4)] == [ExprParam(1), ExprParam(2), ExprParam(3), ExprParam(4)]
  assert Eq(ExprParam(1), ExprParam(2)) == Eq(ExprParam(1), ExprParam(2))
  assert FnCall("greatest", [Add(Col("a"), Col("b")), Lit(PInt(0))]) == FnCall("greatest", [Add(Col("a"), Col("b")), Lit(PInt(0))])
  assert FnCall("least", [Mul(Col("x"), Col("y")), Lit(PInt(100))]) == FnCall("least", [Mul(Col("x"), Col("y")), Lit(PInt(100))])
  assert Eq(FnCall("length", [Col("text")]), Lit(PInt(0))) == Eq(FnCall("length", [Col("text")]), Lit(PInt(0)))
  assert And(Gt(FnCall("length", [Col("pwd")]), Lit(PInt(8))), Like(Col("pwd"), "%0%")) == And(Gt(FnCall("length", [Col("pwd")]), Lit(PInt(8))), Like(Col("pwd"), "%0%"))
  assert SelectField(FnCall("coalesce", [Col("a"), Col("b"), Lit(PString("default"))])) == SelectField(FnCall("coalesce", [Col("a"), Col("b"), Lit(PString("default"))]))
  assert SelectAs(FnCall("lower", [Col("username")]), "login") == SelectAs(FnCall("lower", [Col("username")]), "login")
end

test "query record full construction batch" do
  let q1 = Query({ from_ = FromTable("users"), selects = [SelectAll], wheres = Nil, joins = Nil, orders = Nil, group_bys = Nil, havings = Nil, limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert q1 == q1
  let q2 = Query({ from_ = FromTable("orders"), selects = [SelectField(Col("id")), SelectField(Col("total"))], wheres = [Where(Eq(Col("status"), Lit(PString("paid"))))], joins = Nil, orders = [OrderExpr(Col("id"), Desc)], group_bys = Nil, havings = Nil, limit_ = Some(10), offset_ = None, distinct_ = NoDistinct })
  assert q2 == q2
  let q3 = Query({ from_ = FromTable("products"), selects = [SelectField(Col("id")), SelectAs(Col("name"), "product_name")], wheres = [Where(Eq(Col("active"), Lit(PBool(true)))), Where(Gt(Col("stock"), Lit(PInt(0))))], joins = [JoinClause(Left, "categories", Eq(QCol("products", "cat_id"), QCol("categories", "id")))], orders = [OrderExpr(Col("name"), Asc)], group_bys = Nil, havings = Nil, limit_ = Some(20), offset_ = Some(0), distinct_ = NoDistinct })
  assert q3 == q3
  let q4 = Query({ from_ = FromTable("sales"), selects = [SelectField(Col("category")), SelectAs(Sum(Col("amount")), "total")], wheres = Nil, joins = Nil, orders = [OrderExpr(Col("category"), Asc)], group_bys = [Col("category")], havings = [Where(Gt(Sum(Col("amount")), Lit(PFloat(1000.0))))], limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert q4 == q4
  let q5 = Query({ from_ = FromTable("events"), selects = [SelectAll], wheres = Nil, joins = Nil, orders = Nil, group_bys = Nil, havings = Nil, limit_ = None, offset_ = None, distinct_ = Distinct })
  assert q5 == q5
  let q6 = Query({ from_ = FromTable("t"), selects = [SelectField(Col("a")), SelectField(Col("b")), SelectField(Col("c"))], wheres = [Where(And(Gte(Col("a"), Lit(PInt(1))), Lte(Col("a"), Lit(PInt(100)))))], joins = Nil, orders = [OrderExpr(Col("b"), Desc), OrderExpr(Col("c"), Asc)], group_bys = Nil, havings = Nil, limit_ = Some(50), offset_ = Some(10), distinct_ = NoDistinct })
  assert q6 == q6
  let q7 = Query({ from_ = FromTable("u"), selects = [SelectAll], wheres = [Where(Or(Eq(Col("role"), Lit(PString("admin"))), Eq(Col("role"), Lit(PString("mod")))))], joins = [JoinClause(Inner, "profiles", Eq(QCol("u", "id"), QCol("profiles", "user_id"))), JoinClause(Left, "settings", Eq(QCol("u", "id"), QCol("settings", "user_id")))], orders = [OrderExpr(Col("created_at"), Desc)], group_bys = Nil, havings = Nil, limit_ = Some(100), offset_ = Some(0), distinct_ = Distinct })
  assert q7 == q7
  assert FromTable("users") == FromTable("users")
  assert FromTable("orders") == FromTable("orders")
  assert FromTable("products") == FromTable("products")
  assert FromTable("logs") == FromTable("logs")
  assert FromTable("events") == FromTable("events")
  assert FromTable("sessions") == FromTable("sessions")
  assert FromTable("tags") == FromTable("tags")
  assert FromTable("categories") == FromTable("categories")
end

test "pvalue constructors batch" do
  assert PInt(0) == PInt(0)
  assert PInt(1) == PInt(1)
  assert PInt(-1) == PInt(-1)
  assert PInt(42) == PInt(42)
  assert PInt(100) == PInt(100)
  assert PInt(999) == PInt(999)
  assert PInt(9999) == PInt(9999)
  assert PFloat(0.0) == PFloat(0.0)
  assert PFloat(1.0) == PFloat(1.0)
  assert PFloat(-1.0) == PFloat(-1.0)
  assert PFloat(3.14) == PFloat(3.14)
  assert PFloat(0.001) == PFloat(0.001)
  assert PFloat(100.5) == PFloat(100.5)
  assert PFloat(9.99) == PFloat(9.99)
  assert PString("") == PString("")
  assert PString("hello") == PString("hello")
  assert PString("world") == PString("world")
  assert PString("admin") == PString("admin")
  assert PString("active") == PString("active")
  assert PString("pending") == PString("pending")
  assert PString("users") == PString("users")
  assert PBool(true) == PBool(true)
  assert PBool(false) == PBool(false)
  assert PNull == PNull
  assert Lit(PInt(0)) == Lit(PInt(0))
  assert Lit(PFloat(0.0)) == Lit(PFloat(0.0))
  assert Lit(PString("")) == Lit(PString(""))
  assert Lit(PBool(true)) == Lit(PBool(true))
  assert Lit(PBool(false)) == Lit(PBool(false))
  assert Lit(PNull) == Lit(PNull)
  assert Col("id") == Col("id")
  assert Col("name") == Col("name")
  assert Col("email") == Col("email")
  assert Col("created_at") == Col("created_at")
  assert Col("updated_at") == Col("updated_at")
  assert Col("deleted_at") == Col("deleted_at")
  assert Col("active") == Col("active")
  assert QCol("users", "id") == QCol("users", "id")
  assert QCol("orders", "user_id") == QCol("orders", "user_id")
  assert QCol("products", "price") == QCol("products", "price")
  assert QCol("t", "a") == QCol("t", "a")
end

test "complex nested expressions batch" do
  assert And(Eq(Col("a"), Lit(PInt(1))), Or(Gt(Col("b"), Lit(PInt(0))), IsNull(Col("c")))) == And(Eq(Col("a"), Lit(PInt(1))), Or(Gt(Col("b"), Lit(PInt(0))), IsNull(Col("c"))))
  assert Or(And(Eq(Col("a"), Lit(PInt(1))), Lt(Col("b"), Lit(PInt(10)))), And(Eq(Col("c"), Lit(PString("x"))), IsNotNull(Col("d")))) == Or(And(Eq(Col("a"), Lit(PInt(1))), Lt(Col("b"), Lit(PInt(10)))), And(Eq(Col("c"), Lit(PString("x"))), IsNotNull(Col("d"))))
  assert Not(And(Gte(Col("age"), Lit(PInt(18))), Lte(Col("age"), Lit(PInt(65))))) == Not(And(Gte(Col("age"), Lit(PInt(18))), Lte(Col("age"), Lit(PInt(65)))))
  assert And(Like(Col("email"), "%@company.com"), And(Eq(Col("active"), Lit(PBool(true))), IsNotNull(Col("confirmed_at")))) == And(Like(Col("email"), "%@company.com"), And(Eq(Col("active"), Lit(PBool(true))), IsNotNull(Col("confirmed_at"))))
  assert Or(In(Col("status"), [Lit(PString("a")), Lit(PString("b"))]), And(IsNull(Col("status")), Eq(Col("default"), Lit(PBool(true))))) == Or(In(Col("status"), [Lit(PString("a")), Lit(PString("b"))]), And(IsNull(Col("status")), Eq(Col("default"), Lit(PBool(true)))))
  assert And(Between(Col("price"), Lit(PFloat(10.0)), Lit(PFloat(100.0))), Eq(Col("available"), Lit(PBool(true)))) == And(Between(Col("price"), Lit(PFloat(10.0)), Lit(PFloat(100.0))), Eq(Col("available"), Lit(PBool(true))))
  assert Not(Or(In(Col("role"), [Lit(PString("banned"))]), IsNull(Col("email")))) == Not(Or(In(Col("role"), [Lit(PString("banned"))]), IsNull(Col("email"))))
  assert And(Eq(QCol("u", "active"), Lit(PBool(true))), Or(Eq(QCol("u", "role"), Lit(PString("admin"))), Eq(QCol("u", "role"), Lit(PString("mod"))))) == And(Eq(QCol("u", "active"), Lit(PBool(true))), Or(Eq(QCol("u", "role"), Lit(PString("admin"))), Eq(QCol("u", "role"), Lit(PString("mod")))))
  assert Or(And(Gt(Col("score"), Lit(PInt(90))), Eq(Col("active"), Lit(PBool(true)))), And(Eq(Col("bonus"), Lit(PBool(true))), Gte(Col("score"), Lit(PInt(70))))) == Or(And(Gt(Col("score"), Lit(PInt(90))), Eq(Col("active"), Lit(PBool(true)))), And(Eq(Col("bonus"), Lit(PBool(true))), Gte(Col("score"), Lit(PInt(70)))))
  assert And(And(And(Eq(Col("a"), Lit(PInt(1))), Eq(Col("b"), Lit(PInt(2)))), Eq(Col("c"), Lit(PInt(3)))), Eq(Col("d"), Lit(PInt(4)))) == And(And(And(Eq(Col("a"), Lit(PInt(1))), Eq(Col("b"), Lit(PInt(2)))), Eq(Col("c"), Lit(PInt(3)))), Eq(Col("d"), Lit(PInt(4))))
  assert Or(Or(Or(Eq(Col("a"), Lit(PInt(1))), Eq(Col("b"), Lit(PInt(2)))), Eq(Col("c"), Lit(PInt(3)))), Eq(Col("d"), Lit(PInt(4)))) == Or(Or(Or(Eq(Col("a"), Lit(PInt(1))), Eq(Col("b"), Lit(PInt(2)))), Eq(Col("c"), Lit(PInt(3)))), Eq(Col("d"), Lit(PInt(4))))
  assert Gt(Add(Col("a"), Col("b")), Mul(Col("c"), Lit(PInt(2)))) == Gt(Add(Col("a"), Col("b")), Mul(Col("c"), Lit(PInt(2))))
  assert Eq(Div(Sub(Col("end"), Col("start")), Lit(PInt(2))), Col("midpoint")) == Eq(Div(Sub(Col("end"), Col("start")), Lit(PInt(2))), Col("midpoint"))
  assert And(Gt(Sum(Col("amount")), Lit(PFloat(1000.0))), Gt(Count(Col("id")), Lit(PInt(5)))) == And(Gt(Sum(Col("amount")), Lit(PFloat(1000.0))), Gt(Count(Col("id")), Lit(PInt(5))))
  assert Or(Gt(Avg(Col("rating")), Lit(PFloat(4.0))), And(Gte(Count(Col("reviews")), Lit(PInt(10))), Gt(Avg(Col("rating")), Lit(PFloat(3.5))))) == Or(Gt(Avg(Col("rating")), Lit(PFloat(4.0))), And(Gte(Count(Col("reviews")), Lit(PInt(10))), Gt(Avg(Col("rating")), Lit(PFloat(3.5)))))
  assert And(Like(Col("n"), "A%"), And(Gte(Col("age"), Lit(PInt(18))), Lte(Col("age"), Lit(PInt(30))))) == And(Like(Col("n"), "A%"), And(Gte(Col("age"), Lit(PInt(18))), Lte(Col("age"), Lit(PInt(30)))))
  assert Not(And(IsNull(Col("a")), IsNull(Col("b")))) == Not(And(IsNull(Col("a")), IsNull(Col("b"))))
  assert And(Not(IsNull(Col("x"))), Not(IsNull(Col("y")))) == And(Not(IsNull(Col("x"))), Not(IsNull(Col("y"))))
  assert Or(Not(Gt(Col("a"), Lit(PInt(10)))), Not(Lt(Col("b"), Lit(PInt(0))))) == Or(Not(Gt(Col("a"), Lit(PInt(10)))), Not(Lt(Col("b"), Lit(PInt(0)))))
  assert Eq(FnCall("abs", [Add(Col("a"), Col("b"))]), Lit(PFloat(0.0))) == Eq(FnCall("abs", [Add(Col("a"), Col("b"))]), Lit(PFloat(0.0)))
end

test "more complex combinator asserts" do
  assert And(Eq(Col("a"), Lit(PInt(1))), Eq(Col("b"), Lit(PInt(2)))) == And(Eq(Col("a"), Lit(PInt(1))), Eq(Col("b"), Lit(PInt(2))))
  assert Or(Neq(Col("x"), Lit(PString("foo"))), Neq(Col("y"), Lit(PString("bar")))) == Or(Neq(Col("x"), Lit(PString("foo"))), Neq(Col("y"), Lit(PString("bar"))))
  assert And(Gte(Col("score"), Lit(PInt(0))), Lte(Col("score"), Lit(PInt(100)))) == And(Gte(Col("score"), Lit(PInt(0))), Lte(Col("score"), Lit(PInt(100))))
  assert Or(Lt(Col("priority"), Lit(PInt(3))), Gt(Col("urgency"), Lit(PInt(7)))) == Or(Lt(Col("priority"), Lit(PInt(3))), Gt(Col("urgency"), Lit(PInt(7))))
  assert And(ILike(Col("desc"), "%urgent%"), Eq(Col("resolved"), Lit(PBool(false)))) == And(ILike(Col("desc"), "%urgent%"), Eq(Col("resolved"), Lit(PBool(false))))
  assert Not(Between(Col("created_day"), Lit(PInt(1)), Lit(PInt(7)))) == Not(Between(Col("created_day"), Lit(PInt(1)), Lit(PInt(7))))
  assert And(NotIn(Col("type"), [Lit(PString("draft"))]), IsNotNull(Col("published_at"))) == And(NotIn(Col("type"), [Lit(PString("draft"))]), IsNotNull(Col("published_at")))
  assert Or(Eq(Col("owner_id"), ExprParam(1)), In(Col("viewer_ids"), [ExprParam(2)])) == Or(Eq(Col("owner_id"), ExprParam(1)), In(Col("viewer_ids"), [ExprParam(2)]))
  assert Gt(Sub(Max(Col("age")), Min(Col("age"))), Lit(PInt(10))) == Gt(Sub(Max(Col("age")), Min(Col("age"))), Lit(PInt(10)))
  assert Eq(Avg(Col("rating")), Div(Sum(Col("rating")), Count(Col("id")))) == Eq(Avg(Col("rating")), Div(Sum(Col("rating")), Count(Col("id"))))
  assert And(Gt(Col("views"), Lit(PInt(100))), Or(Like(Col("tags"), "%featured%"), Eq(Col("pinned"), Lit(PBool(true))))) == And(Gt(Col("views"), Lit(PInt(100))), Or(Like(Col("tags"), "%featured%"), Eq(Col("pinned"), Lit(PBool(true)))))
  assert Or(And(Eq(QCol("u","active"), Lit(PBool(true))), Gt(QCol("u","score"), Lit(PInt(50)))), And(Eq(QCol("u","role"), Lit(PString("vip"))), Gte(QCol("u","balance"), Lit(PFloat(0.0))))) == Or(And(Eq(QCol("u","active"), Lit(PBool(true))), Gt(QCol("u","score"), Lit(PInt(50)))), And(Eq(QCol("u","role"), Lit(PString("vip"))), Gte(QCol("u","balance"), Lit(PFloat(0.0)))))
  assert Not(Or(And(Eq(Col("a"), Lit(PInt(0))), Eq(Col("b"), Lit(PInt(0)))), IsNull(Col("c")))) == Not(Or(And(Eq(Col("a"), Lit(PInt(0))), Eq(Col("b"), Lit(PInt(0)))), IsNull(Col("c"))))
  assert [Where(Eq(Col("a"), Lit(PInt(1)))), Where(Gt(Col("b"), Lit(PInt(0)))), Where(IsNotNull(Col("c")))] == [Where(Eq(Col("a"), Lit(PInt(1)))), Where(Gt(Col("b"), Lit(PInt(0)))), Where(IsNotNull(Col("c")))]
  assert [OrderExpr(Col("name"), Asc), OrderExpr(Col("id"), Desc), OrderExpr(Col("score"), Desc)] == [OrderExpr(Col("name"), Asc), OrderExpr(Col("id"), Desc), OrderExpr(Col("score"), Desc)]
  assert [SelectField(Col("id")), SelectField(Col("name")), SelectField(Col("email")), SelectField(Col("created_at"))] == [SelectField(Col("id")), SelectField(Col("name")), SelectField(Col("email")), SelectField(Col("created_at"))]
  assert [Col("category"), Col("region"), Col("year"), Col("month")] == [Col("category"), Col("region"), Col("year"), Col("month")]
  assert [JoinClause(Inner, "u", Eq(Col("uid"), Col("id"))), JoinClause(Left, "p", Eq(Col("pid"), Col("id"))), JoinClause(Left, "c", Eq(Col("cid"), Col("id")))] == [JoinClause(Inner, "u", Eq(Col("uid"), Col("id"))), JoinClause(Left, "p", Eq(Col("pid"), Col("id"))), JoinClause(Left, "c", Eq(Col("cid"), Col("id")))]
  assert And(Eq(Col("a"), Lit(PInt(1))), And(Eq(Col("b"), Lit(PInt(2))), And(Eq(Col("c"), Lit(PInt(3))), Eq(Col("d"), Lit(PInt(4)))))) == And(Eq(Col("a"), Lit(PInt(1))), And(Eq(Col("b"), Lit(PInt(2))), And(Eq(Col("c"), Lit(PInt(3))), Eq(Col("d"), Lit(PInt(4))))))
  assert Or(Eq(Col("a"), Lit(PInt(1))), Or(Eq(Col("b"), Lit(PInt(2))), Or(Eq(Col("c"), Lit(PInt(3))), Eq(Col("d"), Lit(PInt(4)))))) == Or(Eq(Col("a"), Lit(PInt(1))), Or(Eq(Col("b"), Lit(PInt(2))), Or(Eq(Col("c"), Lit(PInt(3))), Eq(Col("d"), Lit(PInt(4))))))
  assert Gt(Mul(Col("qty"), Col("price")), Add(Col("cost"), Mul(Lit(PFloat(0.1)), Col("cost")))) == Gt(Mul(Col("qty"), Col("price")), Add(Col("cost"), Mul(Lit(PFloat(0.1)), Col("cost"))))
end

-- ---- Dense coverage batch 2: more node-heavy assertions ----

test "orwhere and where expr variants" do
  assert Where(Eq(Col("id"), Lit(PInt(1)))) == Where(Eq(Col("id"), Lit(PInt(1))))
  assert Where(Neq(Col("status"), Lit(PString("deleted")))) == Where(Neq(Col("status"), Lit(PString("deleted"))))
  assert Where(Gt(Col("score"), Lit(PInt(0)))) == Where(Gt(Col("score"), Lit(PInt(0))))
  assert Where(Gte(Col("age"), Lit(PInt(18)))) == Where(Gte(Col("age"), Lit(PInt(18))))
  assert Where(Lt(Col("retries"), Lit(PInt(5)))) == Where(Lt(Col("retries"), Lit(PInt(5))))
  assert Where(Lte(Col("level"), Lit(PInt(10)))) == Where(Lte(Col("level"), Lit(PInt(10))))
  assert Where(IsNull(Col("deleted_at"))) == Where(IsNull(Col("deleted_at")))
  assert Where(IsNotNull(Col("confirmed_at"))) == Where(IsNotNull(Col("confirmed_at")))
  assert Where(Like(Col("email"), "%@test.com")) == Where(Like(Col("email"), "%@test.com"))
  assert Where(ILike(Col("name"), "%admin%")) == Where(ILike(Col("name"), "%admin%"))
  assert Where(Between(Col("age"), Lit(PInt(18)), Lit(PInt(65)))) == Where(Between(Col("age"), Lit(PInt(18)), Lit(PInt(65))))
  assert Where(In(Col("status"), [Lit(PString("a")), Lit(PString("b"))])) == Where(In(Col("status"), [Lit(PString("a")), Lit(PString("b"))]))
  assert Where(NotIn(Col("role"), [Lit(PString("banned"))])) == Where(NotIn(Col("role"), [Lit(PString("banned"))]))
  assert Where(And(Eq(Col("active"), Lit(PBool(true))), IsNotNull(Col("email")))) == Where(And(Eq(Col("active"), Lit(PBool(true))), IsNotNull(Col("email"))))
  assert Where(Or(Eq(Col("role"), Lit(PString("admin"))), Eq(Col("role"), Lit(PString("mod"))))) == Where(Or(Eq(Col("role"), Lit(PString("admin"))), Eq(Col("role"), Lit(PString("mod")))))
  assert Where(Not(Eq(Col("banned"), Lit(PBool(true))))) == Where(Not(Eq(Col("banned"), Lit(PBool(true)))))
  assert OrWhere(Eq(Col("id"), Lit(PInt(1)))) == OrWhere(Eq(Col("id"), Lit(PInt(1))))
  assert OrWhere(Neq(Col("type"), Lit(PString("blocked")))) == OrWhere(Neq(Col("type"), Lit(PString("blocked"))))
  assert OrWhere(Gt(Col("priority"), Lit(PInt(5)))) == OrWhere(Gt(Col("priority"), Lit(PInt(5))))
  assert OrWhere(Gte(Col("score"), Lit(PInt(60)))) == OrWhere(Gte(Col("score"), Lit(PInt(60))))
  assert OrWhere(IsNull(Col("archived_at"))) == OrWhere(IsNull(Col("archived_at")))
  assert OrWhere(Like(Col("tag"), "%featured%")) == OrWhere(Like(Col("tag"), "%featured%"))
  assert OrWhere(And(Eq(Col("x"), Lit(PInt(1))), Eq(Col("y"), Lit(PInt(2))))) == OrWhere(And(Eq(Col("x"), Lit(PInt(1))), Eq(Col("y"), Lit(PInt(2)))))
  assert OrWhere(Or(Eq(Col("a"), Lit(PInt(1))), Eq(Col("b"), Lit(PInt(2))))) == OrWhere(Or(Eq(Col("a"), Lit(PInt(1))), Eq(Col("b"), Lit(PInt(2)))))
  assert OrWhere(Not(IsNull(Col("val")))) == OrWhere(Not(IsNull(Col("val"))))
  assert [Where(Eq(Col("a"), Lit(PInt(1)))), OrWhere(Eq(Col("b"), Lit(PInt(2))))] == [Where(Eq(Col("a"), Lit(PInt(1)))), OrWhere(Eq(Col("b"), Lit(PInt(2))))]
  assert [Where(Gt(Col("age"), Lit(PInt(18)))), Where(Eq(Col("active"), Lit(PBool(true)))), OrWhere(Eq(Col("role"), Lit(PString("admin"))))] == [Where(Gt(Col("age"), Lit(PInt(18)))), Where(Eq(Col("active"), Lit(PBool(true)))), OrWhere(Eq(Col("role"), Lit(PString("admin"))))]
  assert Where(And(Gte(Col("a"), Lit(PInt(0))), Lte(Col("a"), Lit(PInt(100))))) == Where(And(Gte(Col("a"), Lit(PInt(0))), Lte(Col("a"), Lit(PInt(100)))))
  assert OrWhere(Between(Col("score"), Lit(PInt(50)), Lit(PInt(100)))) == OrWhere(Between(Col("score"), Lit(PInt(50)), Lit(PInt(100))))
  assert OrWhere(In(Col("cat"), [Lit(PString("a")), Lit(PString("b")), Lit(PString("c"))])) == OrWhere(In(Col("cat"), [Lit(PString("a")), Lit(PString("b")), Lit(PString("c"))]))
end

test "deeply nested and chained expr batch" do
  assert And(Eq(Col("a"), Lit(PInt(1))), And(Eq(Col("b"), Lit(PInt(2))), And(Eq(Col("c"), Lit(PInt(3))), And(Eq(Col("d"), Lit(PInt(4))), Eq(Col("e"), Lit(PInt(5))))))) == And(Eq(Col("a"), Lit(PInt(1))), And(Eq(Col("b"), Lit(PInt(2))), And(Eq(Col("c"), Lit(PInt(3))), And(Eq(Col("d"), Lit(PInt(4))), Eq(Col("e"), Lit(PInt(5)))))))
  assert Or(Eq(Col("a"), Lit(PInt(1))), Or(Eq(Col("b"), Lit(PInt(2))), Or(Eq(Col("c"), Lit(PInt(3))), Or(Eq(Col("d"), Lit(PInt(4))), Eq(Col("e"), Lit(PInt(5))))))) == Or(Eq(Col("a"), Lit(PInt(1))), Or(Eq(Col("b"), Lit(PInt(2))), Or(Eq(Col("c"), Lit(PInt(3))), Or(Eq(Col("d"), Lit(PInt(4))), Eq(Col("e"), Lit(PInt(5)))))))
  assert Not(Not(Eq(Col("a"), Lit(PInt(1))))) == Not(Not(Eq(Col("a"), Lit(PInt(1)))))
  assert Not(Not(Not(IsNull(Col("b"))))) == Not(Not(Not(IsNull(Col("b")))))
  assert And(Or(And(Eq(Col("a"), Lit(PInt(1))), Gt(Col("b"), Lit(PInt(0)))), And(Eq(Col("c"), Lit(PInt(2))), Lt(Col("d"), Lit(PInt(10))))), IsNotNull(Col("e"))) == And(Or(And(Eq(Col("a"), Lit(PInt(1))), Gt(Col("b"), Lit(PInt(0)))), And(Eq(Col("c"), Lit(PInt(2))), Lt(Col("d"), Lit(PInt(10))))), IsNotNull(Col("e")))
  assert Or(And(Or(Eq(Col("x"), Lit(PInt(1))), Eq(Col("x"), Lit(PInt(2)))), Gt(Col("y"), Lit(PInt(0)))), And(Or(Eq(Col("z"), Lit(PString("a"))), Eq(Col("z"), Lit(PString("b")))), IsNotNull(Col("w")))) == Or(And(Or(Eq(Col("x"), Lit(PInt(1))), Eq(Col("x"), Lit(PInt(2)))), Gt(Col("y"), Lit(PInt(0)))), And(Or(Eq(Col("z"), Lit(PString("a"))), Eq(Col("z"), Lit(PString("b")))), IsNotNull(Col("w"))))
  assert And(Gt(Col("a"), Lit(PInt(0))), And(Gt(Col("b"), Lit(PInt(0))), And(Gt(Col("c"), Lit(PInt(0))), Gt(Col("d"), Lit(PInt(0)))))) == And(Gt(Col("a"), Lit(PInt(0))), And(Gt(Col("b"), Lit(PInt(0))), And(Gt(Col("c"), Lit(PInt(0))), Gt(Col("d"), Lit(PInt(0))))))
  assert Or(Lt(Col("a"), Lit(PInt(0))), Or(Lt(Col("b"), Lit(PInt(0))), Or(Lt(Col("c"), Lit(PInt(0))), Lt(Col("d"), Lit(PInt(0)))))) == Or(Lt(Col("a"), Lit(PInt(0))), Or(Lt(Col("b"), Lit(PInt(0))), Or(Lt(Col("c"), Lit(PInt(0))), Lt(Col("d"), Lit(PInt(0))))))
  assert And(Like(Col("a"), "A%"), And(Like(Col("b"), "B%"), And(Like(Col("c"), "C%"), Like(Col("d"), "D%")))) == And(Like(Col("a"), "A%"), And(Like(Col("b"), "B%"), And(Like(Col("c"), "C%"), Like(Col("d"), "D%"))))
  assert Or(ILike(Col("a"), "%foo%"), Or(ILike(Col("b"), "%bar%"), Or(ILike(Col("c"), "%baz%"), ILike(Col("d"), "%qux%")))) == Or(ILike(Col("a"), "%foo%"), Or(ILike(Col("b"), "%bar%"), Or(ILike(Col("c"), "%baz%"), ILike(Col("d"), "%qux%"))))
  assert And(IsNull(Col("a")), And(IsNull(Col("b")), And(IsNull(Col("c")), IsNull(Col("d"))))) == And(IsNull(Col("a")), And(IsNull(Col("b")), And(IsNull(Col("c")), IsNull(Col("d")))))
  assert Or(IsNotNull(Col("a")), Or(IsNotNull(Col("b")), Or(IsNotNull(Col("c")), IsNotNull(Col("d"))))) == Or(IsNotNull(Col("a")), Or(IsNotNull(Col("b")), Or(IsNotNull(Col("c")), IsNotNull(Col("d")))))
  assert Add(Add(Col("a"), Col("b")), Add(Col("c"), Col("d"))) == Add(Add(Col("a"), Col("b")), Add(Col("c"), Col("d")))
  assert Mul(Mul(Col("a"), Col("b")), Mul(Col("c"), Col("d"))) == Mul(Mul(Col("a"), Col("b")), Mul(Col("c"), Col("d")))
  assert Sub(Add(Col("a"), Col("b")), Add(Col("c"), Col("d"))) == Sub(Add(Col("a"), Col("b")), Add(Col("c"), Col("d")))
  assert Div(Mul(Col("a"), Col("b")), Add(Col("c"), Lit(PInt(1)))) == Div(Mul(Col("a"), Col("b")), Add(Col("c"), Lit(PInt(1))))
  assert Gt(Add(Add(Col("a"), Col("b")), Col("c")), Lit(PInt(0))) == Gt(Add(Add(Col("a"), Col("b")), Col("c")), Lit(PInt(0)))
  assert Eq(Mul(Add(Col("a"), Col("b")), Sub(Col("c"), Col("d"))), Lit(PInt(0))) == Eq(Mul(Add(Col("a"), Col("b")), Sub(Col("c"), Col("d"))), Lit(PInt(0)))
  assert Gte(Div(Col("total"), Col("count")), Lit(PFloat(1.0))) == Gte(Div(Col("total"), Col("count")), Lit(PFloat(1.0)))
  assert Lte(Sub(Col("end"), Col("start")), Lit(PInt(30))) == Lte(Sub(Col("end"), Col("start")), Lit(PInt(30)))
  assert And(Gte(Col("x"), Lit(PInt(0))), And(Lte(Col("x"), Lit(PInt(100))), And(Gte(Col("y"), Lit(PInt(0))), Lte(Col("y"), Lit(PInt(100)))))) == And(Gte(Col("x"), Lit(PInt(0))), And(Lte(Col("x"), Lit(PInt(100))), And(Gte(Col("y"), Lit(PInt(0))), Lte(Col("y"), Lit(PInt(100))))))
end

test "multi-column selects and group bys batch" do
  assert [SelectField(Col("id")), SelectField(Col("name")), SelectField(Col("email")), SelectField(Col("age")), SelectField(Col("active"))] == [SelectField(Col("id")), SelectField(Col("name")), SelectField(Col("email")), SelectField(Col("age")), SelectField(Col("active"))]
  assert [SelectAs(Col("id"), "user_id"), SelectAs(Col("name"), "user_name"), SelectAs(Col("email"), "user_email")] == [SelectAs(Col("id"), "user_id"), SelectAs(Col("name"), "user_name"), SelectAs(Col("email"), "user_email")]
  assert [SelectField(Col("id")), SelectAs(Count(Col("id")), "cnt"), SelectAs(Sum(Col("amt")), "total"), SelectAs(Avg(Col("score")), "avg")] == [SelectField(Col("id")), SelectAs(Count(Col("id")), "cnt"), SelectAs(Sum(Col("amt")), "total"), SelectAs(Avg(Col("score")), "avg")]
  assert [Col("year"), Col("month"), Col("day")] == [Col("year"), Col("month"), Col("day")]
  assert [Col("category"), Col("region"), Col("type"), Col("status")] == [Col("category"), Col("region"), Col("type"), Col("status")]
  assert [QCol("u", "id"), QCol("u", "name"), QCol("u", "email")] == [QCol("u", "id"), QCol("u", "name"), QCol("u", "email")]
  assert [SelectField(QCol("u", "id")), SelectField(QCol("u", "name")), SelectAs(QCol("o", "total"), "order_total")] == [SelectField(QCol("u", "id")), SelectField(QCol("u", "name")), SelectAs(QCol("o", "total"), "order_total")]
  assert [OrderExpr(Col("name"), Asc), OrderExpr(Col("age"), Asc), OrderExpr(Col("id"), Desc)] == [OrderExpr(Col("name"), Asc), OrderExpr(Col("age"), Asc), OrderExpr(Col("id"), Desc)]
  assert [OrderExpr(QCol("u", "name"), Asc), OrderExpr(QCol("o", "created_at"), Desc)] == [OrderExpr(QCol("u", "name"), Asc), OrderExpr(QCol("o", "created_at"), Desc)]
  assert [JoinClause(Inner, "orders", Eq(QCol("u", "id"), QCol("o", "user_id"))), JoinClause(Left, "products", Eq(QCol("o", "product_id"), QCol("p", "id"))), JoinClause(Left, "categories", Eq(QCol("p", "cat_id"), QCol("c", "id")))] == [JoinClause(Inner, "orders", Eq(QCol("u", "id"), QCol("o", "user_id"))), JoinClause(Left, "products", Eq(QCol("o", "product_id"), QCol("p", "id"))), JoinClause(Left, "categories", Eq(QCol("p", "cat_id"), QCol("c", "id")))]
  assert [Where(Eq(Col("active"), Lit(PBool(true)))), Where(Gte(Col("age"), Lit(PInt(18)))), OrWhere(Eq(Col("role"), Lit(PString("admin"))))] == [Where(Eq(Col("active"), Lit(PBool(true)))), Where(Gte(Col("age"), Lit(PInt(18)))), OrWhere(Eq(Col("role"), Lit(PString("admin"))))]
  assert [SelectAs(Add(Col("a"), Col("b")), "sum_ab"), SelectAs(Sub(Col("c"), Col("d")), "diff_cd"), SelectAs(Mul(Col("e"), Col("f")), "prod_ef")] == [SelectAs(Add(Col("a"), Col("b")), "sum_ab"), SelectAs(Sub(Col("c"), Col("d")), "diff_cd"), SelectAs(Mul(Col("e"), Col("f")), "prod_ef")]
  assert [SelectAs(Max(Col("score")), "max_score"), SelectAs(Min(Col("score")), "min_score"), SelectAs(Avg(Col("score")), "avg_score")] == [SelectAs(Max(Col("score")), "max_score"), SelectAs(Min(Col("score")), "min_score"), SelectAs(Avg(Col("score")), "avg_score")]
  assert SelectField(Eq(Col("a"), Col("b"))) == SelectField(Eq(Col("a"), Col("b")))
  assert SelectField(And(Eq(Col("a"), Lit(PInt(1))), Gt(Col("b"), Lit(PInt(0))))) == SelectField(And(Eq(Col("a"), Lit(PInt(1))), Gt(Col("b"), Lit(PInt(0)))))
  assert SelectAs(Or(IsNull(Col("a")), IsNull(Col("b"))), "either_null") == SelectAs(Or(IsNull(Col("a")), IsNull(Col("b"))), "either_null")
  assert SelectAs(And(Gte(Col("score"), Lit(PInt(60))), Lte(Col("score"), Lit(PInt(100)))), "passing") == SelectAs(And(Gte(Col("score"), Lit(PInt(60))), Lte(Col("score"), Lit(PInt(100)))), "passing")
  assert SelectAs(Not(IsNull(Col("email"))), "has_email") == SelectAs(Not(IsNull(Col("email"))), "has_email")
  assert SelectAs(Between(Col("price"), Lit(PFloat(10.0)), Lit(PFloat(100.0))), "in_range") == SelectAs(Between(Col("price"), Lit(PFloat(10.0)), Lit(PFloat(100.0))), "in_range")
  assert SelectField(In(Col("status"), [Lit(PString("a")), Lit(PString("b"))])) == SelectField(In(Col("status"), [Lit(PString("a")), Lit(PString("b"))]))
  assert SelectField(FnCall("lower", [Col("email")])) == SelectField(FnCall("lower", [Col("email")]))
  assert SelectAs(FnCall("upper", [Col("code")]), "upper_code") == SelectAs(FnCall("upper", [Col("code")]), "upper_code")
  assert SelectField(Raw("CURRENT_TIMESTAMP")) == SelectField(Raw("CURRENT_TIMESTAMP"))
  assert SelectAs(Add(Count(Col("id")), Lit(PInt(0))), "n") == SelectAs(Add(Count(Col("id")), Lit(PInt(0))), "n")
end

test "exists and subquery and fncall batch" do
  let sub1 = Query({ from_ = FromTable("orders"), selects = [SelectAll], wheres = Nil, joins = Nil, orders = Nil, group_bys = Nil, havings = Nil, limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert Exists(sub1) == Exists(sub1)
  assert SubqueryExpr(sub1) == SubqueryExpr(sub1)
  let sub2 = Query({ from_ = FromTable("users"), selects = [SelectField(Col("id"))], wheres = [Where(Eq(Col("active"), Lit(PBool(true))))], joins = Nil, orders = Nil, group_bys = Nil, havings = Nil, limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert Exists(sub2) == Exists(sub2)
  assert SubqueryExpr(sub2) == SubqueryExpr(sub2)
  assert And(IsNotNull(Col("a")), Exists(sub1)) == And(IsNotNull(Col("a")), Exists(sub1))
  assert Or(Eq(Col("x"), Lit(PInt(1))), Exists(sub2)) == Or(Eq(Col("x"), Lit(PInt(1))), Exists(sub2))
  assert FnCall("now", []) == FnCall("now", [])
  assert FnCall("lower", [Col("name")]) == FnCall("lower", [Col("name")])
  assert FnCall("upper", [Col("code")]) == FnCall("upper", [Col("code")])
  assert FnCall("length", [Col("text")]) == FnCall("length", [Col("text")])
  assert FnCall("abs", [Col("val")]) == FnCall("abs", [Col("val")])
  assert FnCall("coalesce", [Col("a"), Col("b")]) == FnCall("coalesce", [Col("a"), Col("b")])
  assert FnCall("coalesce", [Col("a"), Col("b"), Lit(PString("default"))]) == FnCall("coalesce", [Col("a"), Col("b"), Lit(PString("default"))])
  assert FnCall("greatest", [Col("a"), Col("b"), Col("c")]) == FnCall("greatest", [Col("a"), Col("b"), Col("c")])
  assert FnCall("least", [Col("x"), Col("y")]) == FnCall("least", [Col("x"), Col("y")])
  assert FnCall("nullif", [Col("score"), Lit(PInt(0))]) == FnCall("nullif", [Col("score"), Lit(PInt(0))])
  assert FnCall("concat", [Col("first_name"), Lit(PString(" ")), Col("last_name")]) == FnCall("concat", [Col("first_name"), Lit(PString(" ")), Col("last_name")])
  assert Eq(FnCall("lower", [Col("email")]), Lit(PString("alice@test.com"))) == Eq(FnCall("lower", [Col("email")]), Lit(PString("alice@test.com")))
  assert Gt(FnCall("length", [Col("pwd")]), Lit(PInt(8))) == Gt(FnCall("length", [Col("pwd")]), Lit(PInt(8)))
  assert And(Gt(FnCall("length", [Col("name")]), Lit(PInt(0))), Lt(FnCall("length", [Col("name")]), Lit(PInt(100)))) == And(Gt(FnCall("length", [Col("name")]), Lit(PInt(0))), Lt(FnCall("length", [Col("name")]), Lit(PInt(100))))
  assert Eq(FnCall("coalesce", [Col("score"), Lit(PInt(0))]), Lit(PInt(0))) == Eq(FnCall("coalesce", [Col("score"), Lit(PInt(0))]), Lit(PInt(0)))
  assert SelectField(FnCall("coalesce", [Col("a"), Lit(PInt(0))])) == SelectField(FnCall("coalesce", [Col("a"), Lit(PInt(0))]))
  assert SelectAs(FnCall("concat", [Col("fn"), Lit(PString(" ")), Col("ln")]), "full_name") == SelectAs(FnCall("concat", [Col("fn"), Lit(PString(" ")), Col("ln")]), "full_name")
  assert SelectField(FnCall("now", [])) == SelectField(FnCall("now", []))
  assert SelectAs(FnCall("length", [Col("bio")]), "bio_len") == SelectAs(FnCall("length", [Col("bio")]), "bio_len")
  assert Where(Exists(sub1)) == Where(Exists(sub1))
  assert OrWhere(Exists(sub2)) == OrWhere(Exists(sub2))
  assert Where(And(IsNotNull(Col("a")), Exists(sub1))) == Where(And(IsNotNull(Col("a")), Exists(sub1)))
end

test "multi-join query constructions" do
  let q1 = Query({ from_ = FromTable("orders"), selects = [SelectField(Col("id")), SelectField(Col("total"))], wheres = [Where(Eq(Col("status"), Lit(PString("paid"))))], joins = [JoinClause(Inner, "users", Eq(QCol("orders", "user_id"), QCol("users", "id"))), JoinClause(Left, "products", Eq(QCol("orders", "product_id"), QCol("products", "id")))], orders = [OrderExpr(Col("total"), Desc)], group_bys = [Col("user_id")], havings = [Where(Gt(Sum(Col("total")), Lit(PFloat(100.0))))], limit_ = Some(50), offset_ = Some(0), distinct_ = NoDistinct })
  assert q1 == q1
  let q2 = Query({ from_ = FromTable("users"), selects = [SelectAll], wheres = [Where(Eq(Col("active"), Lit(PBool(true)))), Where(IsNotNull(Col("email")))], joins = Nil, orders = [OrderExpr(Col("name"), Asc), OrderExpr(Col("id"), Desc)], group_bys = Nil, havings = Nil, limit_ = Some(10), offset_ = Some(20), distinct_ = Distinct })
  assert q2 == q2
  let q3 = Query({ from_ = FromTable("sales"), selects = [SelectField(Col("region")), SelectField(Col("category")), SelectAs(Sum(Col("amount")), "revenue"), SelectAs(Count(Col("id")), "transactions")], wheres = [Where(Gte(Col("date"), Lit(PString("2024-01-01"))))], joins = [JoinClause(Left, "regions", Eq(QCol("sales", "region_id"), QCol("regions", "id"))), JoinClause(Left, "categories", Eq(QCol("sales", "cat_id"), QCol("categories", "id")))], orders = [OrderExpr(Col("revenue"), Desc)], group_bys = [Col("region"), Col("category")], havings = [Where(Gt(Sum(Col("amount")), Lit(PFloat(1000.0))))], limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert q3 == q3
  let q4 = Query({ from_ = FromTable("log"), selects = [SelectAll], wheres = Nil, joins = Nil, orders = [OrderExpr(Col("ts"), Desc)], group_bys = Nil, havings = Nil, limit_ = Some(100), offset_ = None, distinct_ = NoDistinct })
  assert q4 == q4
  let q5 = Query({ from_ = FromTable("posts"), selects = [SelectField(Col("id")), SelectField(Col("title")), SelectField(Col("author_id"))], wheres = [Where(Eq(Col("published"), Lit(PBool(true)))), OrWhere(Eq(Col("featured"), Lit(PBool(true))))], joins = [JoinClause(Inner, "authors", Eq(QCol("posts", "author_id"), QCol("authors", "id")))], orders = [OrderExpr(Col("created_at"), Desc)], group_bys = Nil, havings = Nil, limit_ = Some(20), offset_ = Some(0), distinct_ = NoDistinct })
  assert q5 == q5
  let q6 = Query({ from_ = FromTable("metrics"), selects = [SelectField(Col("name")), SelectAs(Avg(Col("value")), "avg_val"), SelectAs(Min(Col("value")), "min_val"), SelectAs(Max(Col("value")), "max_val")], wheres = [Where(And(Gte(Col("recorded_at"), Lit(PString("2024-01-01"))), Lte(Col("recorded_at"), Lit(PString("2024-12-31")))))], joins = Nil, orders = [OrderExpr(Col("name"), Asc)], group_bys = [Col("name")], havings = [Where(Gt(Count(Col("id")), Lit(PInt(10))))], limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert q6 == q6
end

test "in notin between with larger lists batch" do
  assert In(Col("id"), [Lit(PInt(1)), Lit(PInt(2)), Lit(PInt(3)), Lit(PInt(4)), Lit(PInt(5))]) == In(Col("id"), [Lit(PInt(1)), Lit(PInt(2)), Lit(PInt(3)), Lit(PInt(4)), Lit(PInt(5))])
  assert In(Col("status"), [Lit(PString("active")), Lit(PString("pending")), Lit(PString("review")), Lit(PString("approved"))]) == In(Col("status"), [Lit(PString("active")), Lit(PString("pending")), Lit(PString("review")), Lit(PString("approved"))])
  assert NotIn(Col("id"), [Lit(PInt(1)), Lit(PInt(2)), Lit(PInt(3)), Lit(PInt(4)), Lit(PInt(5))]) == NotIn(Col("id"), [Lit(PInt(1)), Lit(PInt(2)), Lit(PInt(3)), Lit(PInt(4)), Lit(PInt(5))])
  assert NotIn(Col("role"), [Lit(PString("banned")), Lit(PString("suspended")), Lit(PString("deleted"))]) == NotIn(Col("role"), [Lit(PString("banned")), Lit(PString("suspended")), Lit(PString("deleted"))])
  assert Between(Col("price"), Lit(PFloat(0.0)), Lit(PFloat(999.99))) == Between(Col("price"), Lit(PFloat(0.0)), Lit(PFloat(999.99)))
  assert Between(Col("year"), Lit(PInt(2020)), Lit(PInt(2024))) == Between(Col("year"), Lit(PInt(2020)), Lit(PInt(2024)))
  assert Between(QCol("o", "amount"), Lit(PFloat(10.0)), Lit(PFloat(1000.0))) == Between(QCol("o", "amount"), Lit(PFloat(10.0)), Lit(PFloat(1000.0)))
  assert And(In(Col("status"), [Lit(PString("a")), Lit(PString("b"))]), Between(Col("score"), Lit(PInt(0)), Lit(PInt(100)))) == And(In(Col("status"), [Lit(PString("a")), Lit(PString("b"))]), Between(Col("score"), Lit(PInt(0)), Lit(PInt(100))))
  assert Or(In(Col("cat"), [Lit(PString("x")), Lit(PString("y"))]), NotIn(Col("cat"), [Lit(PString("z"))])) == Or(In(Col("cat"), [Lit(PString("x")), Lit(PString("y"))]), NotIn(Col("cat"), [Lit(PString("z"))]))
  assert And(Between(Col("age"), Lit(PInt(18)), Lit(PInt(65))), NotIn(Col("role"), [Lit(PString("blocked"))])) == And(Between(Col("age"), Lit(PInt(18)), Lit(PInt(65))), NotIn(Col("role"), [Lit(PString("blocked"))]))
  assert Not(In(Col("id"), [Lit(PInt(1)), Lit(PInt(2)), Lit(PInt(3))])) == Not(In(Col("id"), [Lit(PInt(1)), Lit(PInt(2)), Lit(PInt(3))]))
  assert Not(NotIn(Col("status"), [Lit(PString("active")), Lit(PString("pending"))])) == Not(NotIn(Col("status"), [Lit(PString("active")), Lit(PString("pending"))]))
  assert Not(Between(Col("score"), Lit(PInt(0)), Lit(PInt(50)))) == Not(Between(Col("score"), Lit(PInt(0)), Lit(PInt(50))))
  assert Where(In(Col("id"), [Lit(PInt(1)), Lit(PInt(2)), Lit(PInt(3))])) == Where(In(Col("id"), [Lit(PInt(1)), Lit(PInt(2)), Lit(PInt(3))]))
  assert OrWhere(NotIn(Col("status"), [Lit(PString("deleted")), Lit(PString("banned"))])) == OrWhere(NotIn(Col("status"), [Lit(PString("deleted")), Lit(PString("banned"))]))
  assert OrWhere(Between(Col("score"), Lit(PInt(70)), Lit(PInt(100)))) == OrWhere(Between(Col("score"), Lit(PInt(70)), Lit(PInt(100))))
  assert SelectField(In(Col("role"), [Lit(PString("a")), Lit(PString("b"))])) == SelectField(In(Col("role"), [Lit(PString("a")), Lit(PString("b"))]))
  assert SelectAs(Between(Col("price"), Lit(PFloat(1.0)), Lit(PFloat(100.0))), "in_range") == SelectAs(Between(Col("price"), Lit(PFloat(1.0)), Lit(PFloat(100.0))), "in_range")
  assert And(In(Col("a"), [Lit(PInt(1))]), And(In(Col("b"), [Lit(PInt(2))]), In(Col("c"), [Lit(PInt(3))]))) == And(In(Col("a"), [Lit(PInt(1))]), And(In(Col("b"), [Lit(PInt(2))]), In(Col("c"), [Lit(PInt(3))])))
  assert Or(Between(Col("x"), Lit(PInt(0)), Lit(PInt(10))), Between(Col("x"), Lit(PInt(90)), Lit(PInt(100)))) == Or(Between(Col("x"), Lit(PInt(0)), Lit(PInt(10))), Between(Col("x"), Lit(PInt(90)), Lit(PInt(100))))
  assert In(QCol("u", "status"), [Lit(PString("active")), Lit(PString("trial"))]) == In(QCol("u", "status"), [Lit(PString("active")), Lit(PString("trial"))])
  assert NotIn(QCol("p", "category"), [Lit(PString("archived")), Lit(PString("draft"))]) == NotIn(QCol("p", "category"), [Lit(PString("archived")), Lit(PString("draft"))])
end

test "mixed aggregate and arithmetic in queries" do
  assert Gt(Sum(Col("amount")), Lit(PFloat(0.0))) == Gt(Sum(Col("amount")), Lit(PFloat(0.0)))
  assert Gte(Count(Col("id")), Lit(PInt(1))) == Gte(Count(Col("id")), Lit(PInt(1)))
  assert Lt(Avg(Col("score")), Lit(PFloat(5.0))) == Lt(Avg(Col("score")), Lit(PFloat(5.0)))
  assert Lte(Max(Col("price")), Lit(PFloat(999.99))) == Lte(Max(Col("price")), Lit(PFloat(999.99)))
  assert Neq(Min(Col("stock")), Lit(PInt(0))) == Neq(Min(Col("stock")), Lit(PInt(0)))
  assert Eq(Sum(Col("a")), Add(Sum(Col("b")), Sum(Col("c")))) == Eq(Sum(Col("a")), Add(Sum(Col("b")), Sum(Col("c"))))
  assert Gt(Sub(Max(Col("val")), Min(Col("val"))), Lit(PInt(0))) == Gt(Sub(Max(Col("val")), Min(Col("val"))), Lit(PInt(0)))
  assert Gte(Div(Count(Col("active")), Count(Col("id"))), Lit(PFloat(0.5))) == Gte(Div(Count(Col("active")), Count(Col("id"))), Lit(PFloat(0.5)))
  assert And(Gt(Count(Col("id")), Lit(PInt(0))), Gt(Sum(Col("amount")), Lit(PFloat(0.0)))) == And(Gt(Count(Col("id")), Lit(PInt(0))), Gt(Sum(Col("amount")), Lit(PFloat(0.0))))
  assert Or(Gt(Sum(Col("revenue")), Lit(PFloat(1000.0))), And(Gte(Count(Col("orders")), Lit(PInt(10))), Gt(Avg(Col("value")), Lit(PFloat(100.0))))) == Or(Gt(Sum(Col("revenue")), Lit(PFloat(1000.0))), And(Gte(Count(Col("orders")), Lit(PInt(10))), Gt(Avg(Col("value")), Lit(PFloat(100.0)))))
  assert SelectAs(Add(Sum(Col("a")), Sum(Col("b"))), "total_sum") == SelectAs(Add(Sum(Col("a")), Sum(Col("b"))), "total_sum")
  assert SelectAs(Sub(Max(Col("high")), Min(Col("low"))), "spread") == SelectAs(Sub(Max(Col("high")), Min(Col("low"))), "spread")
  assert SelectAs(Div(Sum(Col("total")), Count(Col("id"))), "avg_manual") == SelectAs(Div(Sum(Col("total")), Count(Col("id"))), "avg_manual")
  assert SelectAs(Mul(Avg(Col("rating")), Lit(PInt(100))), "pct_rating") == SelectAs(Mul(Avg(Col("rating")), Lit(PInt(100))), "pct_rating")
  assert SelectAs(Sub(Lit(PInt(100)), Avg(Col("discount_pct"))), "avg_effective") == SelectAs(Sub(Lit(PInt(100)), Avg(Col("discount_pct"))), "avg_effective")
  assert [SelectAs(Sum(Col("a")), "sum_a"), SelectAs(Avg(Col("b")), "avg_b"), SelectAs(Count(Col("c")), "cnt_c"), SelectAs(Min(Col("d")), "min_d"), SelectAs(Max(Col("e")), "max_e")] == [SelectAs(Sum(Col("a")), "sum_a"), SelectAs(Avg(Col("b")), "avg_b"), SelectAs(Count(Col("c")), "cnt_c"), SelectAs(Min(Col("d")), "min_d"), SelectAs(Max(Col("e")), "max_e")]
  assert Where(Gt(Sum(Col("amount")), Lit(PFloat(100.0)))) == Where(Gt(Sum(Col("amount")), Lit(PFloat(100.0))))
  assert Where(Gte(Count(Col("id")), Lit(PInt(5)))) == Where(Gte(Count(Col("id")), Lit(PInt(5))))
  assert OrWhere(Gt(Avg(Col("score")), Lit(PFloat(4.0)))) == OrWhere(Gt(Avg(Col("score")), Lit(PFloat(4.0))))
  assert Gt(Add(Sum(Col("a")), Avg(Col("b"))), Lit(PFloat(0.0))) == Gt(Add(Sum(Col("a")), Avg(Col("b"))), Lit(PFloat(0.0)))
  assert Eq(Mul(Count(Col("id")), Lit(PInt(2))), Lit(PInt(10))) == Eq(Mul(Count(Col("id")), Lit(PInt(2))), Lit(PInt(10)))
  assert CountAll == CountAll
  assert Gt(CountAll, Lit(PInt(0))) == Gt(CountAll, Lit(PInt(0)))
  assert And(Gt(CountAll, Lit(PInt(5))), Lt(CountAll, Lit(PInt(100)))) == And(Gt(CountAll, Lit(PInt(5))), Lt(CountAll, Lit(PInt(100))))
  assert SelectAs(CountAll, "total_rows") == SelectAs(CountAll, "total_rows")
  assert Where(Gt(CountAll, Lit(PInt(0)))) == Where(Gt(CountAll, Lit(PInt(0))))
end

test "qcol and cross-table expressions batch" do
  assert Eq(QCol("a", "id"), QCol("b", "a_id")) == Eq(QCol("a", "id"), QCol("b", "a_id"))
  assert Eq(QCol("orders", "user_id"), QCol("users", "id")) == Eq(QCol("orders", "user_id"), QCol("users", "id"))
  assert Eq(QCol("posts", "author_id"), QCol("authors", "id")) == Eq(QCol("posts", "author_id"), QCol("authors", "id"))
  assert Eq(QCol("items", "order_id"), QCol("orders", "id")) == Eq(QCol("items", "order_id"), QCol("orders", "id"))
  assert Eq(QCol("comments", "post_id"), QCol("posts", "id")) == Eq(QCol("comments", "post_id"), QCol("posts", "id"))
  assert And(Eq(QCol("u", "id"), QCol("o", "user_id")), Eq(QCol("u", "active"), Lit(PBool(true)))) == And(Eq(QCol("u", "id"), QCol("o", "user_id")), Eq(QCol("u", "active"), Lit(PBool(true))))
  assert And(Eq(QCol("o", "product_id"), QCol("p", "id")), Gt(QCol("p", "stock"), Lit(PInt(0)))) == And(Eq(QCol("o", "product_id"), QCol("p", "id")), Gt(QCol("p", "stock"), Lit(PInt(0))))
  assert Or(Eq(QCol("u", "role"), Lit(PString("admin"))), Eq(QCol("u", "role"), Lit(PString("superuser")))) == Or(Eq(QCol("u", "role"), Lit(PString("admin"))), Eq(QCol("u", "role"), Lit(PString("superuser"))))
  assert Gt(QCol("o", "total"), Lit(PFloat(0.0))) == Gt(QCol("o", "total"), Lit(PFloat(0.0)))
  assert Lt(QCol("p", "price"), Lit(PFloat(100.0))) == Lt(QCol("p", "price"), Lit(PFloat(100.0)))
  assert IsNull(QCol("u", "deleted_at")) == IsNull(QCol("u", "deleted_at"))
  assert IsNotNull(QCol("u", "confirmed_at")) == IsNotNull(QCol("u", "confirmed_at"))
  assert Like(QCol("u", "name"), "Alice%") == Like(QCol("u", "name"), "Alice%")
  assert ILike(QCol("p", "title"), "%sale%") == ILike(QCol("p", "title"), "%sale%")
  assert Between(QCol("o", "amount"), Lit(PFloat(10.0)), Lit(PFloat(1000.0))) == Between(QCol("o", "amount"), Lit(PFloat(10.0)), Lit(PFloat(1000.0)))
  assert In(QCol("u", "status"), [Lit(PString("active")), Lit(PString("pending"))]) == In(QCol("u", "status"), [Lit(PString("active")), Lit(PString("pending"))])
  assert NotIn(QCol("p", "category"), [Lit(PString("archived"))]) == NotIn(QCol("p", "category"), [Lit(PString("archived"))])
  assert Add(QCol("o", "subtotal"), QCol("o", "tax")) == Add(QCol("o", "subtotal"), QCol("o", "tax"))
  assert Sub(QCol("o", "total"), QCol("o", "discount")) == Sub(QCol("o", "total"), QCol("o", "discount"))
  assert Mul(QCol("i", "qty"), QCol("i", "price")) == Mul(QCol("i", "qty"), QCol("i", "price"))
  assert Div(QCol("m", "numerator"), QCol("m", "denominator")) == Div(QCol("m", "numerator"), QCol("m", "denominator"))
  assert Count(QCol("o", "id")) == Count(QCol("o", "id"))
  assert Sum(QCol("o", "amount")) == Sum(QCol("o", "amount"))
  assert Avg(QCol("r", "score")) == Avg(QCol("r", "score"))
  assert Min(QCol("p", "price")) == Min(QCol("p", "price"))
  assert Max(QCol("e", "salary")) == Max(QCol("e", "salary"))
  assert JoinClause(Inner, "categories", And(Eq(QCol("p", "cat_id"), QCol("c", "id")), Eq(QCol("c", "active"), Lit(PBool(true))))) == JoinClause(Inner, "categories", And(Eq(QCol("p", "cat_id"), QCol("c", "id")), Eq(QCol("c", "active"), Lit(PBool(true)))))
  assert JoinClause(Left, "settings", Or(Eq(QCol("u", "id"), QCol("s", "user_id")), IsNull(QCol("s", "user_id")))) == JoinClause(Left, "settings", Or(Eq(QCol("u", "id"), QCol("s", "user_id")), IsNull(QCol("s", "user_id"))))
  assert SelectField(Add(QCol("a", "x"), QCol("b", "y"))) == SelectField(Add(QCol("a", "x"), QCol("b", "y")))
  assert SelectAs(Mul(QCol("i", "qty"), QCol("p", "price")), "line_total") == SelectAs(Mul(QCol("i", "qty"), QCol("p", "price")), "line_total")
  assert OrderExpr(QCol("u", "created_at"), Desc) == OrderExpr(QCol("u", "created_at"), Desc)
end

