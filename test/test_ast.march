  assert JoinClause(JoinKind.Inner, "profiles", Expr.And(Expr.Eq(QCol("u", "id"), QCol("p", "user_id")), Expr.Eq(QCol("p", "active"), Lit(PBool(true))))) == JoinClause(JoinKind.Inner, "profiles", Expr.And(Expr.Eq(QCol("u", "id"), QCol("p", "user_id")), Expr.Eq(QCol("p", "active"), Lit(PBool(true)))))
  assert JoinClause(JoinKind.Left, "addresses", Expr.Or(Expr.Eq(QCol("u", "id"), QCol("a", "user_id")), Expr.IsNull(QCol("a", "user_id")))) == JoinClause(JoinKind.Left, "addresses", Expr.Or(Expr.Eq(QCol("u", "id"), QCol("a", "user_id")), Expr.IsNull(QCol("a", "user_id"))))
  assert OrderExpr(Expr.Add(Expr.Col("a"), Expr.Col("b")), SortDir.Desc) == OrderExpr(Expr.Add(Expr.Col("a"), Expr.Col("b")), SortDir.Desc)
  assert OrderExpr(FnCall("lower", [Expr.Col("name")]), SortDir.Asc) == OrderExpr(FnCall("lower", [Expr.Col("name")]), SortDir.Asc)
  assert OrderExpr(Expr.Mul(Expr.Col("qty"), Expr.Col("price")), SortDir.Desc) == OrderExpr(Expr.Mul(Expr.Col("qty"), Expr.Col("price")), SortDir.Desc)
  assert [Where(Expr.Eq(QCol("u", "active"), Lit(PBool(true)))), Where(Expr.IsNotNull(QCol("u", "email"))), OrWhere(Expr.Eq(QCol("u", "role"), Lit(PString("admin"))))] == [Where(Expr.Eq(QCol("u", "active"), Lit(PBool(true)))), Where(Expr.IsNotNull(QCol("u", "email"))), OrWhere(Expr.Eq(QCol("u", "role"), Lit(PString("admin"))))]
  assert [OrderExpr(Expr.Col("name"), SortDir.Asc), OrderExpr(Expr.Col("created_at"), SortDir.Desc), OrderExpr(Expr.Col("id"), SortDir.Asc)] == [OrderExpr(Expr.Col("name"), SortDir.Asc), OrderExpr(Expr.Col("created_at"), SortDir.Desc), OrderExpr(Expr.Col("id"), SortDir.Asc)]
  assert [Expr.Col("year"), Expr.Col("quarter"), Expr.Col("month"), Expr.Col("week"), Expr.Col("day")] == [Expr.Col("year"), Expr.Col("quarter"), Expr.Col("month"), Expr.Col("week"), Expr.Col("day")]
end

