-- test/test_ast.march
-- Tests for SQL AST types and their construction.

mod TestAst do

import Ast

test "PInt value" do
  assert PInt(42) == PInt(42)
end

test "PString value" do
  assert PString("hello") == PString("hello")
end

test "PBool value" do
  assert PBool(true) == PBool(true)
end

test "PNull value" do
  assert PNull == PNull
end

test "Col expr" do
  assert Expr.Col("name") == Expr.Col("name")
end

test "QCol expr" do
  assert QCol("users", "id") == QCol("users", "id")
end

test "Lit expr" do
  assert Lit(PInt(5)) == Lit(PInt(5))
end

test "Eq expr" do
  assert Expr.Eq(Expr.Col("id"), Lit(PInt(1))) == Expr.Eq(Expr.Col("id"), Lit(PInt(1)))
end

test "And expr" do
  assert Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Eq(Expr.Col("b"), Lit(PInt(2)))) == Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Eq(Expr.Col("b"), Lit(PInt(2))))
end

test "IsNull expr" do
  assert Expr.IsNull(Expr.Col("deleted_at")) == Expr.IsNull(Expr.Col("deleted_at"))
end

test "CountAll expr" do
  assert CountAll == CountAll
end

test "Count expr" do
  assert Expr.Count(Expr.Col("id")) == Expr.Count(Expr.Col("id"))
end

test "Like expr" do
  assert Like(Expr.Col("email"), "%@example.com") == Like(Expr.Col("email"), "%@example.com")
end

test "sort direction variants" do
  assert SortDir.Asc == SortDir.Asc
  assert SortDir.Desc == SortDir.Desc
  assert AscNullsFirst == AscNullsFirst
  assert AscNullsLast == AscNullsLast
  assert DescNullsFirst == DescNullsFirst
  assert DescNullsLast == DescNullsLast
end

test "join kind variants" do
  assert JoinKind.Inner == JoinKind.Inner
  assert JoinKind.Left == JoinKind.Left
  assert JoinKind.Right == JoinKind.Right
  assert FullOuter == FullOuter
  assert Cross == Cross
end

test "Not expr" do
  assert Expr.Not(Expr.Eq(Expr.Col("x"), Lit(PNull))) == Expr.Not(Expr.Eq(Expr.Col("x"), Lit(PNull)))
end

test "PFloat value" do
  assert PFloat(3.14) == PFloat(3.14)
end

test "Neq expr" do
  assert Expr.Neq(Expr.Col("a"), Lit(PInt(0))) == Expr.Neq(Expr.Col("a"), Lit(PInt(0)))
end

test "Lt expr" do
  assert Expr.Lt(Expr.Col("age"), Lit(PInt(18))) == Expr.Lt(Expr.Col("age"), Lit(PInt(18)))
end

test "Gt expr" do
  assert Expr.Gt(Expr.Col("score"), Lit(PInt(100))) == Expr.Gt(Expr.Col("score"), Lit(PInt(100)))
end

test "Lte expr" do
  assert Expr.Lte(Expr.Col("n"), Lit(PInt(5))) == Expr.Lte(Expr.Col("n"), Lit(PInt(5)))
end

test "Gte expr" do
  assert Expr.Gte(Expr.Col("n"), Lit(PInt(0))) == Expr.Gte(Expr.Col("n"), Lit(PInt(0)))
end

test "Or expr" do
  assert Expr.Or(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Eq(Expr.Col("b"), Lit(PInt(2)))) == Expr.Or(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Eq(Expr.Col("b"), Lit(PInt(2))))
end

test "Add expr" do
  assert Expr.Add(Expr.Col("x"), Lit(PInt(1))) == Expr.Add(Expr.Col("x"), Lit(PInt(1)))
end

test "Sub expr" do
  assert Expr.Sub(Expr.Col("total"), Expr.Col("discount")) == Expr.Sub(Expr.Col("total"), Expr.Col("discount"))
end

test "Mul expr" do
  assert Expr.Mul(Expr.Col("price"), Lit(PInt(2))) == Expr.Mul(Expr.Col("price"), Lit(PInt(2)))
end

test "Div expr" do
  assert Expr.Div(Expr.Col("total"), Lit(PInt(100))) == Expr.Div(Expr.Col("total"), Lit(PInt(100)))
end

test "IsNotNull expr" do
  assert Expr.IsNotNull(Expr.Col("deleted_at")) == Expr.IsNotNull(Expr.Col("deleted_at"))
end

test "In expr" do
  assert In(Expr.Col("id"), [Lit(PInt(1)), Lit(PInt(2))]) == In(Expr.Col("id"), [Lit(PInt(1)), Lit(PInt(2))])
end

test "NotIn expr" do
  assert NotIn(Expr.Col("status"), [Lit(PString("banned"))]) == NotIn(Expr.Col("status"), [Lit(PString("banned"))])
end

test "Between expr" do
  assert Between(Expr.Col("age"), Lit(PInt(18)), Lit(PInt(65))) == Between(Expr.Col("age"), Lit(PInt(18)), Lit(PInt(65)))
end

test "ILike expr" do
  assert ILike(Expr.Col("name"), "%alice%") == ILike(Expr.Col("name"), "%alice%")
end

test "Sum expr" do
  assert Expr.Sum(Expr.Col("amount")) == Expr.Sum(Expr.Col("amount"))
end

test "Avg expr" do
  assert Avg(Expr.Col("score")) == Avg(Expr.Col("score"))
end

test "Min expr" do
  assert Expr.Min(Expr.Col("created_at")) == Expr.Min(Expr.Col("created_at"))
end

test "Max expr" do
  assert Expr.Max(Expr.Col("score")) == Expr.Max(Expr.Col("score"))
end

test "FnCall expr" do
  let args = [Expr.Col("email")]
  assert FnCall("LOWER", args) == FnCall("LOWER", args)
  assert List.length(args) == 1
end

test "ExprParam expr" do
  assert ExprParam(3) == ExprParam(3)
end

test "Raw expr" do
  assert Raw("NOW()") == Raw("NOW()")
end

test "SubqueryExpr expr" do
  let sub = Query({
    from_ = FromTable("inner"), selects = Nil, wheres = Nil,
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct
  })
  assert SubqueryExpr(sub) == SubqueryExpr(sub)
end

test "Exists expr" do
  let sub = Query({
    from_ = FromTable("inner"), selects = Nil, wheres = Nil,
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct
  })
  assert Exists(sub) == Exists(sub)
end

test "Where and OrWhere constructors" do
  assert Where(Expr.Eq(Expr.Col("id"), Lit(PInt(1)))) == Where(Expr.Eq(Expr.Col("id"), Lit(PInt(1))))
  assert OrWhere(Expr.Eq(Expr.Col("id"), Lit(PInt(2)))) == OrWhere(Expr.Eq(Expr.Col("id"), Lit(PInt(2))))
end

test "SelectField and SelectAs" do
  assert SelectField(Expr.Col("id")) == SelectField(Expr.Col("id"))
  assert SelectAs(Expr.Col("id"), "uid") == SelectAs(Expr.Col("id"), "uid")
end

test "JoinClause" do
  assert JoinClause(JoinKind.Inner, "users", Expr.Eq(Expr.Col("id"), Expr.Col("user_id"))) == JoinClause(JoinKind.Inner, "users", Expr.Eq(Expr.Col("id"), Expr.Col("user_id")))
end

test "OrderExpr" do
  assert OrderExpr(Expr.Col("name"), SortDir.Asc) == OrderExpr(Expr.Col("name"), SortDir.Asc)
end

-- ---- Additional AST constructor tests ----

test "PInt various values" do
  assert PInt(0) == PInt(0)
  assert PInt(1) == PInt(1)
  assert PInt(-1) == PInt(-1)
  assert PInt(100) == PInt(100)
  assert PInt(9999) == PInt(9999)
end

test "PFloat various values" do
  assert PFloat(0.0) == PFloat(0.0)
  assert PFloat(1.5) == PFloat(1.5)
  assert PFloat(3.14) == PFloat(3.14)
  assert PFloat(-2.7) == PFloat(-2.7)
end

test "PString various values" do
  assert PString("") == PString("")
  assert PString("hello") == PString("hello")
  assert PString("world") == PString("world")
  assert PString("foo bar") == PString("foo bar")
end

test "PBool values" do
  assert PBool(true) == PBool(true)
  assert PBool(false) == PBool(false)
end

test "PNull value" do
  assert PNull == PNull
end

test "Col various names" do
  assert Expr.Col("id") == Expr.Col("id")
  assert Expr.Col("name") == Expr.Col("name")
  assert Expr.Col("email") == Expr.Col("email")
  assert Expr.Col("created_at") == Expr.Col("created_at")
  assert Expr.Col("user_id") == Expr.Col("user_id")
end

test "QCol various tables" do
  assert QCol("users", "id") == QCol("users", "id")
  assert QCol("orders", "user_id") == QCol("orders", "user_id")
  assert QCol("products", "price") == QCol("products", "price")
  assert QCol("a", "b") == QCol("a", "b")
end

test "Lit with PInt" do
  assert Lit(PInt(0)) == Lit(PInt(0))
  assert Lit(PInt(42)) == Lit(PInt(42))
  assert Lit(PInt(-100)) == Lit(PInt(-100))
end

test "Lit with PString" do
  assert Lit(PString("hello")) == Lit(PString("hello"))
  assert Lit(PString("")) == Lit(PString(""))
  assert Lit(PString("abc")) == Lit(PString("abc"))
end

test "Lit with PBool" do
  assert Lit(PBool(true)) == Lit(PBool(true))
  assert Lit(PBool(false)) == Lit(PBool(false))
end

test "Lit with PNull" do
  assert Lit(PNull) == Lit(PNull)
end

test "Lit with PFloat" do
  assert Lit(PFloat(1.0)) == Lit(PFloat(1.0))
  assert Lit(PFloat(0.5)) == Lit(PFloat(0.5))
end

test "Eq with various exprs" do
  assert Expr.Eq(Expr.Col("id"), Lit(PInt(1))) == Expr.Eq(Expr.Col("id"), Lit(PInt(1)))
  assert Expr.Eq(Expr.Col("name"), Lit(PString("Alice"))) == Expr.Eq(Expr.Col("name"), Lit(PString("Alice")))
  assert Expr.Eq(Expr.Col("active"), Lit(PBool(true))) == Expr.Eq(Expr.Col("active"), Lit(PBool(true)))
  assert Expr.Eq(QCol("t", "id"), Expr.Col("other_id")) == Expr.Eq(QCol("t", "id"), Expr.Col("other_id"))
end

test "Neq with various exprs" do
  assert Expr.Neq(Expr.Col("status"), Lit(PString("deleted"))) == Expr.Neq(Expr.Col("status"), Lit(PString("deleted")))
  assert Expr.Neq(Expr.Col("count"), Lit(PInt(0))) == Expr.Neq(Expr.Col("count"), Lit(PInt(0)))
end

test "Lt Gt Lte Gte" do
  assert Expr.Lt(Expr.Col("age"), Lit(PInt(18))) == Expr.Lt(Expr.Col("age"), Lit(PInt(18)))
  assert Expr.Gt(Expr.Col("score"), Lit(PInt(100))) == Expr.Gt(Expr.Col("score"), Lit(PInt(100)))
  assert Expr.Lte(Expr.Col("priority"), Lit(PInt(5))) == Expr.Lte(Expr.Col("priority"), Lit(PInt(5)))
  assert Expr.Gte(Expr.Col("rating"), Lit(PInt(1))) == Expr.Gte(Expr.Col("rating"), Lit(PInt(1)))
end

test "And with various conditions" do
  assert Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Eq(Expr.Col("b"), Lit(PInt(2)))) == Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Eq(Expr.Col("b"), Lit(PInt(2))))
  assert Expr.And(Expr.Gt(Expr.Col("x"), Lit(PInt(0))), Expr.Lt(Expr.Col("x"), Lit(PInt(10)))) == Expr.And(Expr.Gt(Expr.Col("x"), Lit(PInt(0))), Expr.Lt(Expr.Col("x"), Lit(PInt(10))))
end

test "Or with various conditions" do
  assert Expr.Or(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Eq(Expr.Col("a"), Lit(PInt(2)))) == Expr.Or(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Eq(Expr.Col("a"), Lit(PInt(2))))
  assert Expr.Or(Expr.IsNull(Expr.Col("x")), Expr.Eq(Expr.Col("y"), Lit(PBool(false)))) == Expr.Or(Expr.IsNull(Expr.Col("x")), Expr.Eq(Expr.Col("y"), Lit(PBool(false))))
end

test "Not with various exprs" do
  assert Expr.Not(Expr.Eq(Expr.Col("deleted"), Lit(PBool(true)))) == Expr.Not(Expr.Eq(Expr.Col("deleted"), Lit(PBool(true))))
  assert Expr.Not(Expr.IsNull(Expr.Col("email"))) == Expr.Not(Expr.IsNull(Expr.Col("email")))
  assert Expr.Not(Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Eq(Expr.Col("b"), Lit(PInt(2))))) == Expr.Not(Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Eq(Expr.Col("b"), Lit(PInt(2)))))
end

test "Add Sub Mul Div" do
  assert Expr.Add(Expr.Col("a"), Expr.Col("b")) == Expr.Add(Expr.Col("a"), Expr.Col("b"))
  assert Expr.Sub(Expr.Col("x"), Lit(PInt(1))) == Expr.Sub(Expr.Col("x"), Lit(PInt(1)))
  assert Expr.Mul(Expr.Col("qty"), Expr.Col("price")) == Expr.Mul(Expr.Col("qty"), Expr.Col("price"))
  assert Expr.Div(Expr.Col("total"), Lit(PInt(100))) == Expr.Div(Expr.Col("total"), Lit(PInt(100)))
end

test "IsNull IsNotNull" do
  assert Expr.IsNull(Expr.Col("deleted_at")) == Expr.IsNull(Expr.Col("deleted_at"))
  assert Expr.IsNotNull(Expr.Col("email")) == Expr.IsNotNull(Expr.Col("email"))
  assert Expr.IsNull(QCol("t", "x")) == Expr.IsNull(QCol("t", "x"))
  assert Expr.IsNotNull(Expr.Col("confirmed")) == Expr.IsNotNull(Expr.Col("confirmed"))
end

test "Like ILike" do
  assert Like(Expr.Col("name"), "A%") == Like(Expr.Col("name"), "A%")
  assert ILike(Expr.Col("email"), "%@example.com") == ILike(Expr.Col("email"), "%@example.com")
  assert Like(Expr.Col("title"), "%foo%") == Like(Expr.Col("title"), "%foo%")
end

test "Between" do
  assert Between(Expr.Col("age"), Lit(PInt(18)), Lit(PInt(65))) == Between(Expr.Col("age"), Lit(PInt(18)), Lit(PInt(65)))
  assert Between(Expr.Col("score"), Lit(PFloat(0.0)), Lit(PFloat(1.0))) == Between(Expr.Col("score"), Lit(PFloat(0.0)), Lit(PFloat(1.0)))
end

test "In NotIn" do
  assert In(Expr.Col("status"), [Lit(PString("a")), Lit(PString("b"))]) == In(Expr.Col("status"), [Lit(PString("a")), Lit(PString("b"))])
  assert NotIn(Expr.Col("role"), [Lit(PString("banned"))]) == NotIn(Expr.Col("role"), [Lit(PString("banned"))])
end

test "Count Sum Avg Min Max CountAll" do
  assert Expr.Count(Expr.Col("id")) == Expr.Count(Expr.Col("id"))
  assert Expr.Sum(Expr.Col("amount")) == Expr.Sum(Expr.Col("amount"))
  assert Avg(Expr.Col("score")) == Avg(Expr.Col("score"))
  assert Expr.Min(Expr.Col("price")) == Expr.Min(Expr.Col("price"))
  assert Expr.Max(Expr.Col("price")) == Expr.Max(Expr.Col("price"))
  assert CountAll == CountAll
end

test "FnCall" do
  assert FnCall("lower", [Expr.Col("email")]) == FnCall("lower", [Expr.Col("email")])
  assert FnCall("coalesce", [Expr.Col("a"), Expr.Col("b")]) == FnCall("coalesce", [Expr.Col("a"), Expr.Col("b")])
  assert FnCall("now", Nil) == FnCall("now", Nil)
end

test "ExprParam Raw" do
  assert ExprParam(1) == ExprParam(1)
  assert ExprParam(2) == ExprParam(2)
  assert Raw("NOW()") == Raw("NOW()")
  assert Raw("1=1") == Raw("1=1")
end

test "Exists SubqueryExpr" do
  let subq = Query({ from_ = FromTable("t"), selects = Nil, wheres = Nil,
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert Exists(subq) == Exists(subq)
  assert SubqueryExpr(subq) == SubqueryExpr(subq)
end

test "SelectField SelectAs SelectAll" do
  assert SelectField(Expr.Col("id")) == SelectField(Expr.Col("id"))
  assert SelectField(QCol("t", "id")) == SelectField(QCol("t", "id"))
  assert SelectAs(Expr.Col("name"), "n") == SelectAs(Expr.Col("name"), "n")
  assert SelectAs(Expr.Count(Expr.Col("id")), "total") == SelectAs(Expr.Count(Expr.Col("id")), "total")
  assert SelectAll == SelectAll
end

test "Where OrWhere" do
  assert Where(Expr.Eq(Expr.Col("id"), Lit(PInt(1)))) == Where(Expr.Eq(Expr.Col("id"), Lit(PInt(1))))
  assert OrWhere(Expr.Eq(Expr.Col("role"), Lit(PString("admin")))) == OrWhere(Expr.Eq(Expr.Col("role"), Lit(PString("admin"))))
end

test "JoinKind variants" do
  assert JoinKind.Inner == JoinKind.Inner
  assert JoinKind.Left == JoinKind.Left
  assert JoinKind.Right == JoinKind.Right
  assert FullOuter == FullOuter
  assert Cross == Cross
end

test "JoinClause various" do
  assert JoinClause(JoinKind.Inner, "users", Expr.Eq(QCol("o", "uid"), QCol("users", "id"))) == JoinClause(JoinKind.Inner, "users", Expr.Eq(QCol("o", "uid"), QCol("users", "id")))
  assert JoinClause(JoinKind.Left, "tags", Expr.Eq(Expr.Col("post_id"), Expr.Col("id"))) == JoinClause(JoinKind.Left, "tags", Expr.Eq(Expr.Col("post_id"), Expr.Col("id")))
  assert JoinClause(JoinKind.Right, "b", Expr.Eq(Expr.Col("a"), Expr.Col("b"))) == JoinClause(JoinKind.Right, "b", Expr.Eq(Expr.Col("a"), Expr.Col("b")))
  assert JoinClause(FullOuter, "c", Raw("1=1")) == JoinClause(FullOuter, "c", Raw("1=1"))
end

test "OrderDir variants" do
  assert SortDir.Asc == SortDir.Asc
  assert SortDir.Desc == SortDir.Desc
  assert AscNullsFirst == AscNullsFirst
  assert AscNullsLast == AscNullsLast
  assert DescNullsFirst == DescNullsFirst
  assert DescNullsLast == DescNullsLast
end

test "OrderExpr various" do
  assert OrderExpr(Expr.Col("name"), SortDir.Asc) == OrderExpr(Expr.Col("name"), SortDir.Asc)
  assert OrderExpr(Expr.Col("created_at"), SortDir.Desc) == OrderExpr(Expr.Col("created_at"), SortDir.Desc)
  assert OrderExpr(Expr.Col("score"), AscNullsLast) == OrderExpr(Expr.Col("score"), AscNullsLast)
  assert OrderExpr(Expr.Col("rank"), DescNullsFirst) == OrderExpr(Expr.Col("rank"), DescNullsFirst)
end

test "FromTable" do
  assert FromTable("users") == FromTable("users")
  assert FromTable("orders") == FromTable("orders")
  assert FromTable("products") == FromTable("products")
end

test "FromSubquery" do
  let sub = Query({ from_ = FromTable("events"), selects = Nil, wheres = Nil,
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert FromSubquery(sub, "e") == FromSubquery(sub, "e")
end

test "Query construction" do
  let q = Query({ from_ = FromTable("t"), selects = Nil, wheres = Nil,
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert q == q
end

test "Query with selects" do
  let q = Query({ from_ = FromTable("t"),
    selects = [SelectField(Expr.Col("id")), SelectField(Expr.Col("name"))],
    wheres = Nil, joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert q == q
end

test "Query with wheres" do
  let q = Query({ from_ = FromTable("t"),
    wheres = [Where(Expr.Eq(Expr.Col("active"), Lit(PBool(true)))), Where(Expr.Gt(Expr.Col("age"), Lit(PInt(18))))],
    selects = Nil, joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert q == q
end

test "Query with limit and offset" do
  let q = Query({ from_ = FromTable("t"), selects = Nil, wheres = Nil,
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = Some(10), offset_ = Some(20), distinct_ = NoDistinct })
  assert q == q
end

test "Query with distinct" do
  let q = Query({ from_ = FromTable("t"), selects = [SelectAll], wheres = Nil,
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = Distinct })
  assert q == q
end

test "Query with joins" do
  let q = Query({ from_ = FromTable("orders"), selects = Nil,
    joins = [JoinClause(JoinKind.Inner, "users", Expr.Eq(QCol("orders", "user_id"), QCol("users", "id")))],
    wheres = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert q == q
end

test "Query with group_bys and havings" do
  let q = Query({ from_ = FromTable("t"), selects = Nil,
    group_bys = [Expr.Col("status"), Expr.Col("region")],
    havings = [Where(Expr.Gt(Expr.Count(Expr.Col("id")), Lit(PInt(1))))],
    wheres = Nil, joins = Nil, orders = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert q == q
end

test "Query with orders" do
  let q = Query({ from_ = FromTable("t"), selects = Nil,
    orders = [OrderExpr(Expr.Col("name"), SortDir.Asc), OrderExpr(Expr.Col("created_at"), SortDir.Desc)],
    wheres = Nil, joins = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert q == q
end

test "Complex nested expressions" do
  let expr1 = Expr.And(Expr.Or(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Eq(Expr.Col("a"), Lit(PInt(2)))), Expr.Not(Expr.IsNull(Expr.Col("b"))))
  assert expr1 == expr1
end

test "Complex select expressions" do
  let e1 = SelectAs(Expr.Add(Expr.Col("x"), Expr.Col("y")), "sum")
  let e2 = SelectAs(Expr.Mul(Expr.Col("qty"), Expr.Col("price")), "total")
  let e3 = SelectAs(CountAll, "n")
  assert e1 == e1
  assert e2 == e2
  assert e3 == e3
end

test "Deeply nested expression" do
  let expr = Expr.And(
    Expr.And(Expr.Gte(Expr.Col("a"), Lit(PInt(1))), Expr.Lte(Expr.Col("a"), Lit(PInt(100)))),
    Expr.And(Expr.IsNotNull(Expr.Col("b")), Expr.Neq(Expr.Col("c"), Lit(PString("deleted"))))
  )
  assert expr == expr
end

test "Expression with FnCall nested" do
  let expr = Expr.Eq(FnCall("lower", [Expr.Col("email")]), Lit(PString("test@example.com")))
  assert expr == expr
end

test "In expression with multiple values" do
  let expr = In(Expr.Col("status"), [Lit(PString("active")), Lit(PString("pending")), Lit(PString("review"))])
  assert expr == expr
end

test "NotIn expression with values" do
  let expr = NotIn(Expr.Col("role"), [Lit(PString("banned")), Lit(PString("suspended"))])
  assert expr == expr
end

test "Between with string values" do
  let expr = Between(Expr.Col("date"), Lit(PString("2024-01-01")), Lit(PString("2024-12-31")))
  assert expr == expr
end

test "Subquery expressions" do
  let sub = Query({ from_ = FromTable("orders"), selects = Nil, wheres = Nil,
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert Exists(sub) == Exists(sub)
  assert SubqueryExpr(sub) == SubqueryExpr(sub)
end

test "ExprParam various indices" do
  assert ExprParam(0) == ExprParam(0)
  assert ExprParam(1) == ExprParam(1)
  assert ExprParam(10) == ExprParam(10)
  assert ExprParam(99) == ExprParam(99)
end

test "Raw SQL expressions" do
  assert Raw("1 = 1") == Raw("1 = 1")
  assert Raw("NOW() > created_at") == Raw("NOW() > created_at")
  assert Raw("") == Raw("")
end

test "SelectField with QCol" do
  assert SelectField(QCol("users", "id")) == SelectField(QCol("users", "id"))
  assert SelectField(QCol("orders", "amount")) == SelectField(QCol("orders", "amount"))
end

test "SelectAs with aggregates" do
  assert SelectAs(Expr.Sum(Expr.Col("amount")), "total") == SelectAs(Expr.Sum(Expr.Col("amount")), "total")
  assert SelectAs(Avg(Expr.Col("score")), "avg_score") == SelectAs(Avg(Expr.Col("score")), "avg_score")
  assert SelectAs(Expr.Min(Expr.Col("price")), "min_price") == SelectAs(Expr.Min(Expr.Col("price")), "min_price")
  assert SelectAs(Expr.Max(Expr.Col("price")), "max_price") == SelectAs(Expr.Max(Expr.Col("price")), "max_price")
end

test "SelectAs with arithmetic" do
  assert SelectAs(Expr.Add(Expr.Col("a"), Expr.Col("b")), "sum") == SelectAs(Expr.Add(Expr.Col("a"), Expr.Col("b")), "sum")
  assert SelectAs(Expr.Sub(Expr.Col("x"), Expr.Col("y")), "diff") == SelectAs(Expr.Sub(Expr.Col("x"), Expr.Col("y")), "diff")
  assert SelectAs(Expr.Mul(Expr.Col("q"), Expr.Col("p")), "total") == SelectAs(Expr.Mul(Expr.Col("q"), Expr.Col("p")), "total")
end

test "Where OrWhere with complex exprs" do
  assert Where(Expr.And(Expr.Gt(Expr.Col("a"), Lit(PInt(0))), Expr.Lt(Expr.Col("a"), Lit(PInt(100))))) == Where(Expr.And(Expr.Gt(Expr.Col("a"), Lit(PInt(0))), Expr.Lt(Expr.Col("a"), Lit(PInt(100)))))
  assert OrWhere(Expr.Or(Expr.Eq(Expr.Col("x"), Lit(PInt(1))), Expr.Eq(Expr.Col("y"), Lit(PInt(2))))) == OrWhere(Expr.Or(Expr.Eq(Expr.Col("x"), Lit(PInt(1))), Expr.Eq(Expr.Col("y"), Lit(PInt(2)))))
end

test "JoinClause with complex ON exprs" do
  assert JoinClause(JoinKind.Inner, "categories", Expr.And(Expr.Eq(QCol("p", "cat_id"), QCol("c", "id")), Expr.Eq(QCol("c", "active"), Lit(PBool(true))))) == JoinClause(JoinKind.Inner, "categories", Expr.And(Expr.Eq(QCol("p", "cat_id"), QCol("c", "id")), Expr.Eq(QCol("c", "active"), Lit(PBool(true)))))
end

test "OrderExpr with NullsFirst NullsLast" do
  assert OrderExpr(Expr.Col("x"), AscNullsFirst) == OrderExpr(Expr.Col("x"), AscNullsFirst)
  assert OrderExpr(Expr.Col("x"), AscNullsLast) == OrderExpr(Expr.Col("x"), AscNullsLast)
  assert OrderExpr(Expr.Col("x"), DescNullsFirst) == OrderExpr(Expr.Col("x"), DescNullsFirst)
  assert OrderExpr(Expr.Col("x"), DescNullsLast) == OrderExpr(Expr.Col("x"), DescNullsLast)
end

test "Multiple aggregate exprs" do
  assert Expr.Count(Expr.Col("id")) == Expr.Count(Expr.Col("id"))
  assert Expr.Count(QCol("t", "id")) == Expr.Count(QCol("t", "id"))
  assert Expr.Sum(Expr.Add(Expr.Col("a"), Expr.Col("b"))) == Expr.Sum(Expr.Add(Expr.Col("a"), Expr.Col("b")))
  assert Avg(Expr.Div(Expr.Col("total"), Lit(PInt(100)))) == Avg(Expr.Div(Expr.Col("total"), Lit(PInt(100))))
end

test "Deeply nested arithmetic" do
  let expr = Expr.Add(Expr.Mul(Expr.Col("a"), Expr.Col("b")), Expr.Div(Expr.Col("c"), Lit(PInt(2))))
  assert expr == expr
  let expr2 = Expr.Sub(Expr.Add(Expr.Col("x"), Lit(PInt(10))), Expr.Mul(Expr.Col("y"), Lit(PInt(3))))
  assert expr2 == expr2
end

test "Like ILike with various patterns" do
  assert Like(Expr.Col("name"), "%alice%") == Like(Expr.Col("name"), "%alice%")
  assert Like(Expr.Col("email"), "%@gmail.com") == Like(Expr.Col("email"), "%@gmail.com")
  assert ILike(Expr.Col("title"), "%DRAFT%") == ILike(Expr.Col("title"), "%DRAFT%")
  assert ILike(Expr.Col("body"), "%important%") == ILike(Expr.Col("body"), "%important%")
end

test "IsNull IsNotNull with QCol" do
  assert Expr.IsNull(QCol("t", "deleted_at")) == Expr.IsNull(QCol("t", "deleted_at"))
  assert Expr.IsNotNull(QCol("u", "email")) == Expr.IsNotNull(QCol("u", "email"))
end

test "Query all fields populated" do
  let q = Query({
    from_ = FromTable("orders"),
    selects = [SelectField(Expr.Col("id")), SelectAs(Expr.Sum(Expr.Col("amount")), "total")],
    wheres = [Where(Expr.Eq(Expr.Col("status"), Lit(PString("active"))))],
    joins = [JoinClause(JoinKind.Left, "users", Expr.Eq(QCol("orders", "user_id"), QCol("users", "id")))],
    orders = [OrderExpr(Expr.Col("id"), SortDir.Desc)],
    group_bys = [Expr.Col("status")],
    havings = [Where(Expr.Gt(Expr.Count(Expr.Col("id")), Lit(PInt(0))))],
    limit_ = Some(100),
    offset_ = Some(0),
    distinct_ = NoDistinct
  })
  assert q == q
end

test "FnCall with multiple args" do
  assert FnCall("concat", [Expr.Col("first"), Lit(PString(" ")), Expr.Col("last")]) == FnCall("concat", [Expr.Col("first"), Lit(PString(" ")), Expr.Col("last")])
  assert FnCall("greatest", [Expr.Col("a"), Expr.Col("b"), Expr.Col("c")]) == FnCall("greatest", [Expr.Col("a"), Expr.Col("b"), Expr.Col("c")])
end

test "In with PInt values" do
  assert In(Expr.Col("id"), [Lit(PInt(1)), Lit(PInt(2)), Lit(PInt(3))]) == In(Expr.Col("id"), [Lit(PInt(1)), Lit(PInt(2)), Lit(PInt(3))])
end

test "NotIn with PInt values" do
  assert NotIn(Expr.Col("id"), [Lit(PInt(99)), Lit(PInt(100))]) == NotIn(Expr.Col("id"), [Lit(PInt(99)), Lit(PInt(100))])
end

test "Between with int values" do
  assert Between(Expr.Col("age"), Lit(PInt(0)), Lit(PInt(120))) == Between(Expr.Col("age"), Lit(PInt(0)), Lit(PInt(120)))
  assert Between(Expr.Col("price"), Lit(PInt(10)), Lit(PInt(1000))) == Between(Expr.Col("price"), Lit(PInt(10)), Lit(PInt(1000)))
end

test "Complex boolean combinations" do
  let a = Expr.Eq(Expr.Col("a"), Lit(PInt(1)))
  let b = Expr.Gt(Expr.Col("b"), Lit(PInt(0)))
  let c = Expr.IsNull(Expr.Col("c"))
  assert Expr.And(a, Expr.Or(b, Expr.Not(c))) == Expr.And(a, Expr.Or(b, Expr.Not(c)))
  assert Expr.Or(Expr.And(a, b), Expr.And(Expr.Not(a), c)) == Expr.Or(Expr.And(a, b), Expr.And(Expr.Not(a), c))
end

test "SelectAs with nested FnCall" do
  assert SelectAs(FnCall("upper", [Expr.Col("name")]), "upper_name") == SelectAs(FnCall("upper", [Expr.Col("name")]), "upper_name")
end

test "Multiple wheres list" do
  let ws = [
    Where(Expr.Eq(Expr.Col("status"), Lit(PString("active")))),
    Where(Expr.Gt(Expr.Col("age"), Lit(PInt(18)))),
    Where(Expr.IsNotNull(Expr.Col("email")))
  ]
  assert ws == ws
end

test "Multiple joins list" do
  let js = [
    JoinClause(JoinKind.Inner, "users", Expr.Eq(QCol("o", "uid"), QCol("u", "id"))),
    JoinClause(JoinKind.Left, "products", Expr.Eq(QCol("o", "pid"), QCol("p", "id")))
  ]
  assert js == js
end

test "Multiple selects list" do
  let ss = [
    SelectField(Expr.Col("id")),
    SelectField(Expr.Col("name")),
    SelectAs(Expr.Count(Expr.Col("id")), "n"),
    SelectAs(Expr.Sum(Expr.Col("amount")), "total"),
    SelectAll
  ]
  assert ss == ss
end

test "Multiple orders list" do
  let os = [
    OrderExpr(Expr.Col("created_at"), SortDir.Desc),
    OrderExpr(Expr.Col("name"), SortDir.Asc),
    OrderExpr(Expr.Col("id"), AscNullsLast)
  ]
  assert os == os
end

test "Group bys list" do
  let gbs = [Expr.Col("category"), Expr.Col("region"), QCol("t", "year")]
  assert gbs == gbs
end

test "Lit PFloat various" do
  assert Lit(PFloat(0.0)) == Lit(PFloat(0.0))
  assert Lit(PFloat(-1.0)) == Lit(PFloat(-1.0))
  assert Lit(PFloat(100.5)) == Lit(PFloat(100.5))
  assert Lit(PFloat(0.001)) == Lit(PFloat(0.001))
end

test "Lit PNull" do
  assert Lit(PNull) == Lit(PNull)
end

test "Comparison operators with QCol" do
  assert Expr.Eq(QCol("a", "x"), QCol("b", "y")) == Expr.Eq(QCol("a", "x"), QCol("b", "y"))
  assert Expr.Neq(QCol("t", "val"), Lit(PInt(0))) == Expr.Neq(QCol("t", "val"), Lit(PInt(0)))
  assert Expr.Lt(QCol("t", "age"), Lit(PInt(65))) == Expr.Lt(QCol("t", "age"), Lit(PInt(65)))
  assert Expr.Gte(QCol("t", "score"), Lit(PFloat(0.5))) == Expr.Gte(QCol("t", "score"), Lit(PFloat(0.5)))
end

test "Not with complex inner" do
  assert Expr.Not(Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Gt(Expr.Col("b"), Lit(PInt(0))))) == Expr.Not(Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Gt(Expr.Col("b"), Lit(PInt(0)))))
  assert Expr.Not(Expr.Or(Expr.IsNull(Expr.Col("x")), Expr.IsNull(Expr.Col("y")))) == Expr.Not(Expr.Or(Expr.IsNull(Expr.Col("x")), Expr.IsNull(Expr.Col("y"))))
end

test "Count Min Max Sum Avg with QCol" do
  assert Expr.Count(QCol("t", "id")) == Expr.Count(QCol("t", "id"))
  assert Expr.Min(QCol("t", "price")) == Expr.Min(QCol("t", "price"))
  assert Expr.Max(QCol("t", "price")) == Expr.Max(QCol("t", "price"))
  assert Expr.Sum(QCol("t", "amount")) == Expr.Sum(QCol("t", "amount"))
  assert Avg(QCol("t", "score")) == Avg(QCol("t", "score"))
end

test "ExprParam sequence" do
  assert [ExprParam(1), ExprParam(2), ExprParam(3)] == [ExprParam(1), ExprParam(2), ExprParam(3)]
end

test "FromTable various tables" do
  assert FromTable("users") == FromTable("users")
  assert FromTable("orders") == FromTable("orders")
  assert FromTable("products") == FromTable("products")
  assert FromTable("schema_migrations") == FromTable("schema_migrations")
end

-- ---- Dense coverage batch 1: binary comparison expressions ----

test "eq neq lt lte gt gte with int literals batch" do
  assert Expr.Eq(Expr.Col("a"), Lit(PInt(0))) == Expr.Eq(Expr.Col("a"), Lit(PInt(0)))
  assert Expr.Eq(Expr.Col("b"), Lit(PInt(1))) == Expr.Eq(Expr.Col("b"), Lit(PInt(1)))
  assert Expr.Eq(Expr.Col("c"), Lit(PInt(100))) == Expr.Eq(Expr.Col("c"), Lit(PInt(100)))
  assert Expr.Neq(Expr.Col("a"), Lit(PInt(0))) == Expr.Neq(Expr.Col("a"), Lit(PInt(0)))
  assert Expr.Neq(Expr.Col("b"), Lit(PInt(1))) == Expr.Neq(Expr.Col("b"), Lit(PInt(1)))
  assert Expr.Neq(Expr.Col("c"), Lit(PInt(99))) == Expr.Neq(Expr.Col("c"), Lit(PInt(99)))
  assert Expr.Lt(Expr.Col("age"), Lit(PInt(18))) == Expr.Lt(Expr.Col("age"), Lit(PInt(18)))
  assert Expr.Lt(Expr.Col("score"), Lit(PInt(50))) == Expr.Lt(Expr.Col("score"), Lit(PInt(50)))
  assert Expr.Lt(Expr.Col("rank"), Lit(PInt(10))) == Expr.Lt(Expr.Col("rank"), Lit(PInt(10)))
  assert Expr.Lte(Expr.Col("age"), Lit(PInt(65))) == Expr.Lte(Expr.Col("age"), Lit(PInt(65)))
  assert Expr.Lte(Expr.Col("count"), Lit(PInt(0))) == Expr.Lte(Expr.Col("count"), Lit(PInt(0)))
  assert Expr.Lte(Expr.Col("level"), Lit(PInt(5))) == Expr.Lte(Expr.Col("level"), Lit(PInt(5)))
  assert Expr.Gt(Expr.Col("age"), Lit(PInt(21))) == Expr.Gt(Expr.Col("age"), Lit(PInt(21)))
  assert Expr.Gt(Expr.Col("score"), Lit(PInt(75))) == Expr.Gt(Expr.Col("score"), Lit(PInt(75)))
  assert Expr.Gt(Expr.Col("balance"), Lit(PInt(0))) == Expr.Gt(Expr.Col("balance"), Lit(PInt(0)))
  assert Expr.Gte(Expr.Col("age"), Lit(PInt(18))) == Expr.Gte(Expr.Col("age"), Lit(PInt(18)))
  assert Expr.Gte(Expr.Col("score"), Lit(PInt(60))) == Expr.Gte(Expr.Col("score"), Lit(PInt(60)))
  assert Expr.Gte(Expr.Col("priority"), Lit(PInt(1))) == Expr.Gte(Expr.Col("priority"), Lit(PInt(1)))
  assert Expr.Eq(Expr.Col("status"), Lit(PString("active"))) == Expr.Eq(Expr.Col("status"), Lit(PString("active")))
  assert Expr.Eq(Expr.Col("role"), Lit(PString("admin"))) == Expr.Eq(Expr.Col("role"), Lit(PString("admin")))
  assert Expr.Neq(Expr.Col("status"), Lit(PString("deleted"))) == Expr.Neq(Expr.Col("status"), Lit(PString("deleted")))
  assert Expr.Neq(Expr.Col("type"), Lit(PString("banned"))) == Expr.Neq(Expr.Col("type"), Lit(PString("banned")))
  assert Expr.Eq(Expr.Col("active"), Lit(PBool(true))) == Expr.Eq(Expr.Col("active"), Lit(PBool(true)))
  assert Expr.Eq(Expr.Col("enabled"), Lit(PBool(false))) == Expr.Eq(Expr.Col("enabled"), Lit(PBool(false)))
  assert Expr.Neq(Expr.Col("deleted"), Lit(PBool(true))) == Expr.Neq(Expr.Col("deleted"), Lit(PBool(true)))
  assert Expr.Eq(Expr.Col("price"), Lit(PFloat(9.99))) == Expr.Eq(Expr.Col("price"), Lit(PFloat(9.99)))
  assert Expr.Gt(Expr.Col("rating"), Lit(PFloat(4.0))) == Expr.Gt(Expr.Col("rating"), Lit(PFloat(4.0)))
  assert Expr.Lt(Expr.Col("discount"), Lit(PFloat(0.5))) == Expr.Lt(Expr.Col("discount"), Lit(PFloat(0.5)))
  assert Expr.Gte(Expr.Col("weight"), Lit(PFloat(1.0))) == Expr.Gte(Expr.Col("weight"), Lit(PFloat(1.0)))
  assert Expr.Lte(Expr.Col("temp"), Lit(PFloat(100.0))) == Expr.Lte(Expr.Col("temp"), Lit(PFloat(100.0)))
  assert Expr.Eq(QCol("u", "id"), QCol("o", "user_id")) == Expr.Eq(QCol("u", "id"), QCol("o", "user_id"))
  assert Expr.Eq(QCol("orders", "status"), Lit(PString("paid"))) == Expr.Eq(QCol("orders", "status"), Lit(PString("paid")))
  assert Expr.Neq(QCol("users", "role"), Lit(PString("guest"))) == Expr.Neq(QCol("users", "role"), Lit(PString("guest")))
  assert Expr.Gt(QCol("items", "qty"), Lit(PInt(0))) == Expr.Gt(QCol("items", "qty"), Lit(PInt(0)))
  assert Expr.Lte(QCol("products", "stock"), Lit(PInt(10))) == Expr.Lte(QCol("products", "stock"), Lit(PInt(10)))
  assert Expr.Eq(Expr.Col("created_at"), Lit(PNull)) == Expr.Eq(Expr.Col("created_at"), Lit(PNull))
  assert Expr.Neq(Expr.Col("deleted_at"), Lit(PNull)) == Expr.Neq(Expr.Col("deleted_at"), Lit(PNull))
  assert Expr.IsNull(Expr.Col("archived_at")) == Expr.IsNull(Expr.Col("archived_at"))
  assert Expr.IsNotNull(Expr.Col("confirmed_at")) == Expr.IsNotNull(Expr.Col("confirmed_at"))
  assert Expr.IsNull(QCol("posts", "published_at")) == Expr.IsNull(QCol("posts", "published_at"))
  assert Expr.IsNotNull(QCol("users", "email")) == Expr.IsNotNull(QCol("users", "email"))
end

test "and or not combinations batch" do
  assert Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Eq(Expr.Col("b"), Lit(PInt(2)))) == Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Eq(Expr.Col("b"), Lit(PInt(2))))
  assert Expr.And(Expr.Gt(Expr.Col("age"), Lit(PInt(18))), Expr.Lt(Expr.Col("age"), Lit(PInt(65)))) == Expr.And(Expr.Gt(Expr.Col("age"), Lit(PInt(18))), Expr.Lt(Expr.Col("age"), Lit(PInt(65))))
  assert Expr.And(Expr.Eq(Expr.Col("active"), Lit(PBool(true))), Expr.IsNotNull(Expr.Col("email"))) == Expr.And(Expr.Eq(Expr.Col("active"), Lit(PBool(true))), Expr.IsNotNull(Expr.Col("email")))
  assert Expr.And(Expr.Neq(Expr.Col("status"), Lit(PString("banned"))), Expr.Gte(Expr.Col("score"), Lit(PInt(0)))) == Expr.And(Expr.Neq(Expr.Col("status"), Lit(PString("banned"))), Expr.Gte(Expr.Col("score"), Lit(PInt(0))))
  assert Expr.Or(Expr.Eq(Expr.Col("role"), Lit(PString("admin"))), Expr.Eq(Expr.Col("role"), Lit(PString("mod")))) == Expr.Or(Expr.Eq(Expr.Col("role"), Lit(PString("admin"))), Expr.Eq(Expr.Col("role"), Lit(PString("mod"))))
  assert Expr.Or(Expr.Gt(Expr.Col("score"), Lit(PInt(90))), Expr.Eq(Expr.Col("bonus"), Lit(PBool(true)))) == Expr.Or(Expr.Gt(Expr.Col("score"), Lit(PInt(90))), Expr.Eq(Expr.Col("bonus"), Lit(PBool(true))))
  assert Expr.Or(Expr.IsNull(Expr.Col("deleted_at")), Expr.Gt(Expr.Col("expires"), Lit(PInt(0)))) == Expr.Or(Expr.IsNull(Expr.Col("deleted_at")), Expr.Gt(Expr.Col("expires"), Lit(PInt(0))))
  assert Expr.Not(Expr.Eq(Expr.Col("status"), Lit(PString("inactive")))) == Expr.Not(Expr.Eq(Expr.Col("status"), Lit(PString("inactive"))))
  assert Expr.Not(Expr.IsNull(Expr.Col("email"))) == Expr.Not(Expr.IsNull(Expr.Col("email")))
  assert Expr.Not(Expr.Gt(Expr.Col("age"), Lit(PInt(100)))) == Expr.Not(Expr.Gt(Expr.Col("age"), Lit(PInt(100))))
  assert Expr.Not(Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Eq(Expr.Col("b"), Lit(PInt(2))))) == Expr.Not(Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Eq(Expr.Col("b"), Lit(PInt(2)))))
  assert Expr.Not(Expr.Or(Expr.Eq(Expr.Col("x"), Lit(PInt(0))), Expr.Eq(Expr.Col("y"), Lit(PInt(0))))) == Expr.Not(Expr.Or(Expr.Eq(Expr.Col("x"), Lit(PInt(0))), Expr.Eq(Expr.Col("y"), Lit(PInt(0)))))
  assert Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.And(Expr.Eq(Expr.Col("b"), Lit(PInt(2))), Expr.Eq(Expr.Col("c"), Lit(PInt(3))))) == Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.And(Expr.Eq(Expr.Col("b"), Lit(PInt(2))), Expr.Eq(Expr.Col("c"), Lit(PInt(3)))))
  assert Expr.Or(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Or(Expr.Eq(Expr.Col("b"), Lit(PInt(2))), Expr.Eq(Expr.Col("c"), Lit(PInt(3))))) == Expr.Or(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Or(Expr.Eq(Expr.Col("b"), Lit(PInt(2))), Expr.Eq(Expr.Col("c"), Lit(PInt(3)))))
  assert Expr.And(Expr.Or(Expr.Eq(Expr.Col("x"), Lit(PInt(1))), Expr.Eq(Expr.Col("x"), Lit(PInt(2)))), Expr.Gt(Expr.Col("y"), Lit(PInt(0)))) == Expr.And(Expr.Or(Expr.Eq(Expr.Col("x"), Lit(PInt(1))), Expr.Eq(Expr.Col("x"), Lit(PInt(2)))), Expr.Gt(Expr.Col("y"), Lit(PInt(0))))
  assert Expr.Or(Expr.And(Expr.Eq(Expr.Col("role"), Lit(PString("admin"))), Expr.Eq(Expr.Col("active"), Lit(PBool(true)))), Expr.And(Expr.Eq(Expr.Col("role"), Lit(PString("superuser"))), Expr.IsNotNull(Expr.Col("key")))) == Expr.Or(Expr.And(Expr.Eq(Expr.Col("role"), Lit(PString("admin"))), Expr.Eq(Expr.Col("active"), Lit(PBool(true)))), Expr.And(Expr.Eq(Expr.Col("role"), Lit(PString("superuser"))), Expr.IsNotNull(Expr.Col("key"))))
  assert Expr.And(Expr.Not(Expr.IsNull(Expr.Col("a"))), Expr.Not(Expr.IsNull(Expr.Col("b")))) == Expr.And(Expr.Not(Expr.IsNull(Expr.Col("a"))), Expr.Not(Expr.IsNull(Expr.Col("b"))))
  assert Expr.Or(Expr.Not(Expr.Eq(Expr.Col("a"), Lit(PInt(0)))), Expr.Not(Expr.Eq(Expr.Col("b"), Lit(PInt(0))))) == Expr.Or(Expr.Not(Expr.Eq(Expr.Col("a"), Lit(PInt(0)))), Expr.Not(Expr.Eq(Expr.Col("b"), Lit(PInt(0)))))
  assert Expr.And(Expr.Gte(Expr.Col("age"), Lit(PInt(18))), Expr.Lte(Expr.Col("age"), Lit(PInt(65)))) == Expr.And(Expr.Gte(Expr.Col("age"), Lit(PInt(18))), Expr.Lte(Expr.Col("age"), Lit(PInt(65))))
  assert Expr.Or(Expr.Lt(Expr.Col("temp"), Lit(PFloat(0.0))), Expr.Gt(Expr.Col("temp"), Lit(PFloat(100.0)))) == Expr.Or(Expr.Lt(Expr.Col("temp"), Lit(PFloat(0.0))), Expr.Gt(Expr.Col("temp"), Lit(PFloat(100.0))))
  assert Expr.And(Expr.Eq(QCol("u", "active"), Lit(PBool(true))), Expr.Neq(QCol("u", "role"), Lit(PString("banned")))) == Expr.And(Expr.Eq(QCol("u", "active"), Lit(PBool(true))), Expr.Neq(QCol("u", "role"), Lit(PString("banned"))))
  assert Expr.Or(Expr.Eq(QCol("o", "status"), Lit(PString("pending"))), Expr.Eq(QCol("o", "status"), Lit(PString("processing")))) == Expr.Or(Expr.Eq(QCol("o", "status"), Lit(PString("pending"))), Expr.Eq(QCol("o", "status"), Lit(PString("processing"))))
  assert Expr.Not(Expr.And(Expr.Gt(Expr.Col("x"), Lit(PInt(10))), Expr.Lt(Expr.Col("x"), Lit(PInt(20))))) == Expr.Not(Expr.And(Expr.Gt(Expr.Col("x"), Lit(PInt(10))), Expr.Lt(Expr.Col("x"), Lit(PInt(20)))))
  assert Expr.And(Expr.IsNull(Expr.Col("a")), Expr.IsNull(Expr.Col("b"))) == Expr.And(Expr.IsNull(Expr.Col("a")), Expr.IsNull(Expr.Col("b")))
  assert Expr.Or(Expr.IsNotNull(Expr.Col("a")), Expr.IsNotNull(Expr.Col("b"))) == Expr.Or(Expr.IsNotNull(Expr.Col("a")), Expr.IsNotNull(Expr.Col("b")))
  assert Expr.And(Like(Expr.Col("name"), "Alice%"), Expr.IsNotNull(Expr.Col("email"))) == Expr.And(Like(Expr.Col("name"), "Alice%"), Expr.IsNotNull(Expr.Col("email")))
  assert Expr.Or(Like(Expr.Col("email"), "%@example.com"), Like(Expr.Col("email"), "%@test.com")) == Expr.Or(Like(Expr.Col("email"), "%@example.com"), Like(Expr.Col("email"), "%@test.com"))
  assert Expr.And(ILike(Expr.Col("title"), "%admin%"), Expr.Eq(Expr.Col("active"), Lit(PBool(true)))) == Expr.And(ILike(Expr.Col("title"), "%admin%"), Expr.Eq(Expr.Col("active"), Lit(PBool(true))))
  assert Expr.And(Between(Expr.Col("age"), Lit(PInt(18)), Lit(PInt(65))), Expr.Eq(Expr.Col("active"), Lit(PBool(true)))) == Expr.And(Between(Expr.Col("age"), Lit(PInt(18)), Lit(PInt(65))), Expr.Eq(Expr.Col("active"), Lit(PBool(true))))
  assert Expr.Or(In(Expr.Col("status"), [Lit(PString("a")), Lit(PString("b"))]), Expr.IsNull(Expr.Col("status"))) == Expr.Or(In(Expr.Col("status"), [Lit(PString("a")), Lit(PString("b"))]), Expr.IsNull(Expr.Col("status")))
  assert Expr.And(NotIn(Expr.Col("role"), [Lit(PString("banned")), Lit(PString("deleted"))]), Expr.Eq(Expr.Col("active"), Lit(PBool(true)))) == Expr.And(NotIn(Expr.Col("role"), [Lit(PString("banned")), Lit(PString("deleted"))]), Expr.Eq(Expr.Col("active"), Lit(PBool(true))))
end

test "arithmetic expressions batch" do
  assert Expr.Add(Expr.Col("a"), Expr.Col("b")) == Expr.Add(Expr.Col("a"), Expr.Col("b"))
  assert Expr.Sub(Expr.Col("a"), Expr.Col("b")) == Expr.Sub(Expr.Col("a"), Expr.Col("b"))
  assert Expr.Mul(Expr.Col("a"), Expr.Col("b")) == Expr.Mul(Expr.Col("a"), Expr.Col("b"))
  assert Expr.Div(Expr.Col("a"), Expr.Col("b")) == Expr.Div(Expr.Col("a"), Expr.Col("b"))
  assert Expr.Add(Expr.Col("price"), Lit(PFloat(1.0))) == Expr.Add(Expr.Col("price"), Lit(PFloat(1.0)))
  assert Expr.Sub(Expr.Col("balance"), Lit(PInt(100))) == Expr.Sub(Expr.Col("balance"), Lit(PInt(100)))
  assert Expr.Mul(Expr.Col("qty"), Expr.Col("unit_price")) == Expr.Mul(Expr.Col("qty"), Expr.Col("unit_price"))
  assert Expr.Div(Expr.Col("total"), Lit(PInt(2))) == Expr.Div(Expr.Col("total"), Lit(PInt(2)))
  assert Expr.Add(Lit(PInt(1)), Lit(PInt(2))) == Expr.Add(Lit(PInt(1)), Lit(PInt(2)))
  assert Expr.Sub(Lit(PInt(10)), Lit(PInt(3))) == Expr.Sub(Lit(PInt(10)), Lit(PInt(3)))
  assert Expr.Mul(Lit(PInt(4)), Lit(PInt(5))) == Expr.Mul(Lit(PInt(4)), Lit(PInt(5)))
  assert Expr.Div(Lit(PFloat(10.0)), Lit(PFloat(3.0))) == Expr.Div(Lit(PFloat(10.0)), Lit(PFloat(3.0)))
  assert Expr.Add(QCol("t", "a"), QCol("t", "b")) == Expr.Add(QCol("t", "a"), QCol("t", "b"))
  assert Expr.Sub(QCol("t", "total"), QCol("t", "discount")) == Expr.Sub(QCol("t", "total"), QCol("t", "discount"))
  assert Expr.Mul(QCol("o", "qty"), QCol("p", "price")) == Expr.Mul(QCol("o", "qty"), QCol("p", "price"))
  assert Expr.Add(Expr.Col("subtotal"), Expr.Mul(Expr.Col("qty"), Expr.Col("unit_price"))) == Expr.Add(Expr.Col("subtotal"), Expr.Mul(Expr.Col("qty"), Expr.Col("unit_price")))
  assert Expr.Sub(Expr.Col("total"), Expr.Add(Expr.Col("tax"), Expr.Col("shipping"))) == Expr.Sub(Expr.Col("total"), Expr.Add(Expr.Col("tax"), Expr.Col("shipping")))
  assert Expr.Mul(Expr.Add(Expr.Col("a"), Expr.Col("b")), Expr.Sub(Expr.Col("c"), Expr.Col("d"))) == Expr.Mul(Expr.Add(Expr.Col("a"), Expr.Col("b")), Expr.Sub(Expr.Col("c"), Expr.Col("d")))
  assert Expr.Div(Expr.Sub(Expr.Col("end_val"), Expr.Col("start_val")), Expr.Col("start_val")) == Expr.Div(Expr.Sub(Expr.Col("end_val"), Expr.Col("start_val")), Expr.Col("start_val"))
  assert Expr.Eq(Expr.Add(Expr.Col("a"), Expr.Col("b")), Lit(PInt(10))) == Expr.Eq(Expr.Add(Expr.Col("a"), Expr.Col("b")), Lit(PInt(10)))
  assert Expr.Gt(Expr.Mul(Expr.Col("qty"), Expr.Col("price")), Lit(PFloat(100.0))) == Expr.Gt(Expr.Mul(Expr.Col("qty"), Expr.Col("price")), Lit(PFloat(100.0)))
  assert Expr.Lt(Expr.Div(Expr.Col("discount"), Expr.Col("total")), Lit(PFloat(0.5))) == Expr.Lt(Expr.Div(Expr.Col("discount"), Expr.Col("total")), Lit(PFloat(0.5)))
  assert Expr.Gte(Expr.Sub(Expr.Col("end"), Expr.Col("start")), Lit(PInt(0))) == Expr.Gte(Expr.Sub(Expr.Col("end"), Expr.Col("start")), Lit(PInt(0)))
  assert Expr.Add(Expr.Sum(Expr.Col("amount")), Lit(PInt(0))) == Expr.Add(Expr.Sum(Expr.Col("amount")), Lit(PInt(0)))
  assert Expr.Mul(Avg(Expr.Col("rating")), Lit(PInt(100))) == Expr.Mul(Avg(Expr.Col("rating")), Lit(PInt(100)))
  assert Expr.Div(Expr.Count(Expr.Col("id")), Lit(PInt(2))) == Expr.Div(Expr.Count(Expr.Col("id")), Lit(PInt(2)))
  assert Expr.Sub(Expr.Max(Expr.Col("score")), Expr.Min(Expr.Col("score"))) == Expr.Sub(Expr.Max(Expr.Col("score")), Expr.Min(Expr.Col("score")))
  assert Expr.Add(Expr.Col("a"), Expr.Add(Expr.Col("b"), Expr.Add(Expr.Col("c"), Expr.Col("d")))) == Expr.Add(Expr.Col("a"), Expr.Add(Expr.Col("b"), Expr.Add(Expr.Col("c"), Expr.Col("d"))))
  assert Expr.Mul(Expr.Col("x"), Expr.Mul(Expr.Col("y"), Expr.Col("z"))) == Expr.Mul(Expr.Col("x"), Expr.Mul(Expr.Col("y"), Expr.Col("z")))
  assert Expr.Eq(Expr.Div(Expr.Add(Expr.Col("a"), Expr.Col("b")), Lit(PInt(2))), Expr.Col("avg")) == Expr.Eq(Expr.Div(Expr.Add(Expr.Col("a"), Expr.Col("b")), Lit(PInt(2))), Expr.Col("avg"))
end

test "aggregate functions batch" do
  assert Expr.Count(Expr.Col("id")) == Expr.Count(Expr.Col("id"))
  assert Expr.Count(Expr.Col("user_id")) == Expr.Count(Expr.Col("user_id"))
  assert Expr.Count(Expr.Col("order_id")) == Expr.Count(Expr.Col("order_id"))
  assert Expr.Count(QCol("t", "id")) == Expr.Count(QCol("t", "id"))
  assert Expr.Count(QCol("orders", "id")) == Expr.Count(QCol("orders", "id"))
  assert CountAll == CountAll
  assert Expr.Sum(Expr.Col("amount")) == Expr.Sum(Expr.Col("amount"))
  assert Expr.Sum(Expr.Col("revenue")) == Expr.Sum(Expr.Col("revenue"))
  assert Expr.Sum(Expr.Col("quantity")) == Expr.Sum(Expr.Col("quantity"))
  assert Expr.Sum(QCol("o", "total")) == Expr.Sum(QCol("o", "total"))
  assert Expr.Sum(Expr.Mul(Expr.Col("qty"), Expr.Col("price"))) == Expr.Sum(Expr.Mul(Expr.Col("qty"), Expr.Col("price")))
  assert Avg(Expr.Col("score")) == Avg(Expr.Col("score"))
  assert Avg(Expr.Col("rating")) == Avg(Expr.Col("rating"))
  assert Avg(Expr.Col("age")) == Avg(Expr.Col("age"))
  assert Avg(QCol("r", "score")) == Avg(QCol("r", "score"))
  assert Expr.Min(Expr.Col("price")) == Expr.Min(Expr.Col("price"))
  assert Expr.Min(Expr.Col("age")) == Expr.Min(Expr.Col("age"))
  assert Expr.Min(Expr.Col("created_at")) == Expr.Min(Expr.Col("created_at"))
  assert Expr.Min(QCol("p", "price")) == Expr.Min(QCol("p", "price"))
  assert Expr.Max(Expr.Col("score")) == Expr.Max(Expr.Col("score"))
  assert Expr.Max(Expr.Col("age")) == Expr.Max(Expr.Col("age"))
  assert Expr.Max(Expr.Col("updated_at")) == Expr.Max(Expr.Col("updated_at"))
  assert Expr.Max(QCol("e", "salary")) == Expr.Max(QCol("e", "salary"))
  assert Expr.Gt(Expr.Count(Expr.Col("id")), Lit(PInt(0))) == Expr.Gt(Expr.Count(Expr.Col("id")), Lit(PInt(0)))
  assert Expr.Gte(Expr.Sum(Expr.Col("amount")), Lit(PFloat(100.0))) == Expr.Gte(Expr.Sum(Expr.Col("amount")), Lit(PFloat(100.0)))
  assert Expr.Lt(Avg(Expr.Col("score")), Lit(PFloat(5.0))) == Expr.Lt(Avg(Expr.Col("score")), Lit(PFloat(5.0)))
  assert Expr.Eq(Expr.Min(Expr.Col("price")), Expr.Max(Expr.Col("price"))) == Expr.Eq(Expr.Min(Expr.Col("price")), Expr.Max(Expr.Col("price")))
  assert Expr.Neq(Expr.Count(Expr.Col("id")), Lit(PInt(0))) == Expr.Neq(Expr.Count(Expr.Col("id")), Lit(PInt(0)))
  assert Expr.Gt(Expr.Sum(QCol("o", "amount")), Lit(PFloat(1000.0))) == Expr.Gt(Expr.Sum(QCol("o", "amount")), Lit(PFloat(1000.0)))
  assert SelectAs(Expr.Count(Expr.Col("id")), "total") == SelectAs(Expr.Count(Expr.Col("id")), "total")
  assert SelectAs(Expr.Sum(Expr.Col("amount")), "revenue") == SelectAs(Expr.Sum(Expr.Col("amount")), "revenue")
  assert SelectAs(Avg(Expr.Col("rating")), "avg_rating") == SelectAs(Avg(Expr.Col("rating")), "avg_rating")
  assert SelectAs(Expr.Min(Expr.Col("price")), "min_price") == SelectAs(Expr.Min(Expr.Col("price")), "min_price")
  assert SelectAs(Expr.Max(Expr.Col("score")), "max_score") == SelectAs(Expr.Max(Expr.Col("score")), "max_score")
  assert SelectAs(CountAll, "count") == SelectAs(CountAll, "count")
  assert SelectAs(Expr.Sub(Expr.Max(Expr.Col("score")), Expr.Min(Expr.Col("score"))), "range") == SelectAs(Expr.Sub(Expr.Max(Expr.Col("score")), Expr.Min(Expr.Col("score"))), "range")
  assert SelectField(Expr.Count(Expr.Col("id"))) == SelectField(Expr.Count(Expr.Col("id")))
  assert SelectField(Expr.Sum(Expr.Col("total"))) == SelectField(Expr.Sum(Expr.Col("total")))
  assert SelectField(Avg(Expr.Col("age"))) == SelectField(Avg(Expr.Col("age")))
end

test "like ilike between in notin batch" do
  assert Like(Expr.Col("name"), "Alice%") == Like(Expr.Col("name"), "Alice%")
  assert Like(Expr.Col("email"), "%@example.com") == Like(Expr.Col("email"), "%@example.com")
  assert Like(Expr.Col("title"), "%manager%") == Like(Expr.Col("title"), "%manager%")
  assert Like(Expr.Col("code"), "US%") == Like(Expr.Col("code"), "US%")
  assert Like(QCol("u", "name"), "Bob%") == Like(QCol("u", "name"), "Bob%")
  assert ILike(Expr.Col("name"), "%alice%") == ILike(Expr.Col("name"), "%alice%")
  assert ILike(Expr.Col("email"), "%EXAMPLE%") == ILike(Expr.Col("email"), "%EXAMPLE%")
  assert ILike(Expr.Col("description"), "%important%") == ILike(Expr.Col("description"), "%important%")
  assert ILike(QCol("p", "title"), "%sale%") == ILike(QCol("p", "title"), "%sale%")
  assert Between(Expr.Col("age"), Lit(PInt(18)), Lit(PInt(65))) == Between(Expr.Col("age"), Lit(PInt(18)), Lit(PInt(65)))
  assert Between(Expr.Col("price"), Lit(PFloat(10.0)), Lit(PFloat(100.0))) == Between(Expr.Col("price"), Lit(PFloat(10.0)), Lit(PFloat(100.0)))
  assert Between(Expr.Col("score"), Lit(PInt(0)), Lit(PInt(100))) == Between(Expr.Col("score"), Lit(PInt(0)), Lit(PInt(100)))
  assert Between(QCol("o", "amount"), Lit(PFloat(0.0)), Lit(PFloat(1000.0))) == Between(QCol("o", "amount"), Lit(PFloat(0.0)), Lit(PFloat(1000.0)))
  assert In(Expr.Col("status"), [Lit(PString("active")), Lit(PString("pending"))]) == In(Expr.Col("status"), [Lit(PString("active")), Lit(PString("pending"))])
  assert In(Expr.Col("role"), [Lit(PString("admin")), Lit(PString("mod")), Lit(PString("user"))]) == In(Expr.Col("role"), [Lit(PString("admin")), Lit(PString("mod")), Lit(PString("user"))])
  assert In(Expr.Col("id"), [Lit(PInt(1)), Lit(PInt(2)), Lit(PInt(3))]) == In(Expr.Col("id"), [Lit(PInt(1)), Lit(PInt(2)), Lit(PInt(3))])
  assert In(QCol("u", "status"), [Lit(PString("a")), Lit(PString("b"))]) == In(QCol("u", "status"), [Lit(PString("a")), Lit(PString("b"))])
  assert NotIn(Expr.Col("status"), [Lit(PString("banned")), Lit(PString("deleted"))]) == NotIn(Expr.Col("status"), [Lit(PString("banned")), Lit(PString("deleted"))])
  assert NotIn(Expr.Col("role"), [Lit(PString("blocked"))]) == NotIn(Expr.Col("role"), [Lit(PString("blocked"))])
  assert NotIn(Expr.Col("id"), [Lit(PInt(0))]) == NotIn(Expr.Col("id"), [Lit(PInt(0))])
  assert NotIn(QCol("p", "category"), [Lit(PString("archived"))]) == NotIn(QCol("p", "category"), [Lit(PString("archived"))])
  assert Expr.And(Like(Expr.Col("name"), "A%"), Between(Expr.Col("age"), Lit(PInt(20)), Lit(PInt(30)))) == Expr.And(Like(Expr.Col("name"), "A%"), Between(Expr.Col("age"), Lit(PInt(20)), Lit(PInt(30))))
  assert Expr.Or(Like(Expr.Col("name"), "A%"), Like(Expr.Col("name"), "B%")) == Expr.Or(Like(Expr.Col("name"), "A%"), Like(Expr.Col("name"), "B%"))
  assert Expr.And(In(Expr.Col("status"), [Lit(PString("a"))]), Expr.Gte(Expr.Col("age"), Lit(PInt(18)))) == Expr.And(In(Expr.Col("status"), [Lit(PString("a"))]), Expr.Gte(Expr.Col("age"), Lit(PInt(18))))
  assert Expr.And(NotIn(Expr.Col("role"), [Lit(PString("banned"))]), Expr.Eq(Expr.Col("active"), Lit(PBool(true)))) == Expr.And(NotIn(Expr.Col("role"), [Lit(PString("banned"))]), Expr.Eq(Expr.Col("active"), Lit(PBool(true))))
  assert Expr.Not(Like(Expr.Col("name"), "%test%")) == Expr.Not(Like(Expr.Col("name"), "%test%"))
  assert Expr.Not(Between(Expr.Col("score"), Lit(PInt(0)), Lit(PInt(50)))) == Expr.Not(Between(Expr.Col("score"), Lit(PInt(0)), Lit(PInt(50))))
  assert Expr.Not(In(Expr.Col("status"), [Lit(PString("x")), Lit(PString("y"))])) == Expr.Not(In(Expr.Col("status"), [Lit(PString("x")), Lit(PString("y"))]))
  assert Expr.Not(NotIn(Expr.Col("role"), [Lit(PString("admin"))])) == Expr.Not(NotIn(Expr.Col("role"), [Lit(PString("admin"))]))
  assert Expr.Or(Between(Expr.Col("age"), Lit(PInt(0)), Lit(PInt(17))), Expr.Gt(Expr.Col("age"), Lit(PInt(65)))) == Expr.Or(Between(Expr.Col("age"), Lit(PInt(0)), Lit(PInt(17))), Expr.Gt(Expr.Col("age"), Lit(PInt(65))))
end

test "select expr types batch" do
  assert SelectAll == SelectAll
  assert SelectField(Expr.Col("id")) == SelectField(Expr.Col("id"))
  assert SelectField(Expr.Col("name")) == SelectField(Expr.Col("name"))
  assert SelectField(Expr.Col("email")) == SelectField(Expr.Col("email"))
  assert SelectField(QCol("u", "id")) == SelectField(QCol("u", "id"))
  assert SelectField(QCol("users", "name")) == SelectField(QCol("users", "name"))
  assert SelectField(Lit(PInt(1))) == SelectField(Lit(PInt(1)))
  assert SelectField(Lit(PString("const"))) == SelectField(Lit(PString("const")))
  assert SelectAs(Expr.Col("id"), "user_id") == SelectAs(Expr.Col("id"), "user_id")
  assert SelectAs(Expr.Col("name"), "full_name") == SelectAs(Expr.Col("name"), "full_name")
  assert SelectAs(Expr.Col("created_at"), "joined") == SelectAs(Expr.Col("created_at"), "joined")
  assert SelectAs(QCol("u", "id"), "uid") == SelectAs(QCol("u", "id"), "uid")
  assert SelectAs(QCol("orders", "total"), "order_total") == SelectAs(QCol("orders", "total"), "order_total")
  assert SelectAs(Lit(PInt(1)), "one") == SelectAs(Lit(PInt(1)), "one")
  assert SelectAs(Lit(PBool(true)), "flag") == SelectAs(Lit(PBool(true)), "flag")
  assert SelectAs(Expr.Add(Expr.Col("a"), Expr.Col("b")), "sum") == SelectAs(Expr.Add(Expr.Col("a"), Expr.Col("b")), "sum")
  assert SelectAs(Expr.Mul(Expr.Col("qty"), Expr.Col("price")), "revenue") == SelectAs(Expr.Mul(Expr.Col("qty"), Expr.Col("price")), "revenue")
  assert SelectAs(Expr.Sub(Expr.Max(Expr.Col("score")), Expr.Min(Expr.Col("score"))), "range") == SelectAs(Expr.Sub(Expr.Max(Expr.Col("score")), Expr.Min(Expr.Col("score"))), "range")
  assert [SelectAll] == [SelectAll]
  assert [SelectField(Expr.Col("id")), SelectField(Expr.Col("name"))] == [SelectField(Expr.Col("id")), SelectField(Expr.Col("name"))]
  assert [SelectField(Expr.Col("id")), SelectAs(Expr.Col("name"), "alias")] == [SelectField(Expr.Col("id")), SelectAs(Expr.Col("name"), "alias")]
  assert [SelectAll, SelectField(Expr.Col("id"))] == [SelectAll, SelectField(Expr.Col("id"))]
  assert [SelectAs(Expr.Count(Expr.Col("id")), "cnt"), SelectAs(Expr.Sum(Expr.Col("amt")), "total")] == [SelectAs(Expr.Count(Expr.Col("id")), "cnt"), SelectAs(Expr.Sum(Expr.Col("amt")), "total")]
  assert SelectField(FnCall("length", [Expr.Col("age")])) == SelectField(FnCall("length", [Expr.Col("age")]))
  assert SelectAs(FnCall("abs", [Expr.Col("price")]), "num_price") == SelectAs(FnCall("abs", [Expr.Col("price")]), "num_price")
  assert SelectField(Raw("NOW()")) == SelectField(Raw("NOW()"))
  assert SelectAs(Raw("CURRENT_DATE"), "today") == SelectAs(Raw("CURRENT_DATE"), "today")
  assert SelectField(Expr.Add(Expr.Col("a"), Lit(PInt(1)))) == SelectField(Expr.Add(Expr.Col("a"), Lit(PInt(1))))
  assert SelectField(Expr.Sub(Expr.Col("b"), Lit(PInt(1)))) == SelectField(Expr.Sub(Expr.Col("b"), Lit(PInt(1))))
  assert SelectField(Expr.Mul(Expr.Col("c"), Lit(PInt(2)))) == SelectField(Expr.Mul(Expr.Col("c"), Lit(PInt(2))))
  assert SelectField(Expr.Div(Expr.Col("d"), Lit(PInt(4)))) == SelectField(Expr.Div(Expr.Col("d"), Lit(PInt(4))))
end

test "join kinds and order dirs batch" do
  assert JoinClause(JoinKind.Inner, "users", Expr.Eq(Expr.Col("user_id"), Expr.Col("id"))) == JoinClause(JoinKind.Inner, "users", Expr.Eq(Expr.Col("user_id"), Expr.Col("id")))
  assert JoinClause(JoinKind.Left, "users", Expr.Eq(Expr.Col("user_id"), Expr.Col("id"))) == JoinClause(JoinKind.Left, "users", Expr.Eq(Expr.Col("user_id"), Expr.Col("id")))
  assert JoinClause(JoinKind.Right, "users", Expr.Eq(Expr.Col("user_id"), Expr.Col("id"))) == JoinClause(JoinKind.Right, "users", Expr.Eq(Expr.Col("user_id"), Expr.Col("id")))
  assert JoinClause(FullOuter, "users", Expr.Eq(Expr.Col("user_id"), Expr.Col("id"))) == JoinClause(FullOuter, "users", Expr.Eq(Expr.Col("user_id"), Expr.Col("id")))
  assert JoinClause(Cross, "tags", Expr.Eq(Lit(PBool(true)), Lit(PBool(true)))) == JoinClause(Cross, "tags", Expr.Eq(Lit(PBool(true)), Lit(PBool(true))))
  assert JoinClause(JoinKind.Inner, "orders", Expr.Eq(QCol("u", "id"), QCol("o", "user_id"))) == JoinClause(JoinKind.Inner, "orders", Expr.Eq(QCol("u", "id"), QCol("o", "user_id")))
  assert JoinClause(JoinKind.Left, "products", Expr.Eq(QCol("o", "product_id"), QCol("p", "id"))) == JoinClause(JoinKind.Left, "products", Expr.Eq(QCol("o", "product_id"), QCol("p", "id")))
  assert JoinClause(JoinKind.Right, "categories", Expr.Eq(QCol("p", "cat_id"), QCol("c", "id"))) == JoinClause(JoinKind.Right, "categories", Expr.Eq(QCol("p", "cat_id"), QCol("c", "id")))
  assert JoinClause(FullOuter, "logs", Expr.Eq(QCol("u", "id"), QCol("l", "user_id"))) == JoinClause(FullOuter, "logs", Expr.Eq(QCol("u", "id"), QCol("l", "user_id")))
  assert JoinClause(JoinKind.Inner, "t1", Expr.And(Expr.Eq(QCol("a", "x"), QCol("b", "x")), Expr.Eq(QCol("a", "y"), QCol("b", "y")))) == JoinClause(JoinKind.Inner, "t1", Expr.And(Expr.Eq(QCol("a", "x"), QCol("b", "x")), Expr.Eq(QCol("a", "y"), QCol("b", "y"))))
  assert [JoinClause(JoinKind.Inner, "u", Expr.Eq(Expr.Col("uid"), Expr.Col("id")))] == [JoinClause(JoinKind.Inner, "u", Expr.Eq(Expr.Col("uid"), Expr.Col("id")))]
  assert [JoinClause(JoinKind.Left, "a", Expr.Eq(Expr.Col("a_id"), Expr.Col("id"))), JoinClause(JoinKind.Inner, "b", Expr.Eq(Expr.Col("b_id"), Expr.Col("id")))] == [JoinClause(JoinKind.Left, "a", Expr.Eq(Expr.Col("a_id"), Expr.Col("id"))), JoinClause(JoinKind.Inner, "b", Expr.Eq(Expr.Col("b_id"), Expr.Col("id")))]
  assert OrderExpr(Expr.Col("id"), SortDir.Asc) == OrderExpr(Expr.Col("id"), SortDir.Asc)
  assert OrderExpr(Expr.Col("id"), SortDir.Desc) == OrderExpr(Expr.Col("id"), SortDir.Desc)
  assert OrderExpr(Expr.Col("name"), SortDir.Asc) == OrderExpr(Expr.Col("name"), SortDir.Asc)
  assert OrderExpr(Expr.Col("created_at"), SortDir.Desc) == OrderExpr(Expr.Col("created_at"), SortDir.Desc)
  assert OrderExpr(QCol("u", "name"), SortDir.Asc) == OrderExpr(QCol("u", "name"), SortDir.Asc)
  assert OrderExpr(QCol("o", "created_at"), SortDir.Desc) == OrderExpr(QCol("o", "created_at"), SortDir.Desc)
  assert OrderExpr(Expr.Col("score"), AscNullsFirst) == OrderExpr(Expr.Col("score"), AscNullsFirst)
  assert OrderExpr(Expr.Col("score"), AscNullsLast) == OrderExpr(Expr.Col("score"), AscNullsLast)
  assert OrderExpr(Expr.Col("score"), DescNullsFirst) == OrderExpr(Expr.Col("score"), DescNullsFirst)
  assert OrderExpr(Expr.Col("score"), DescNullsLast) == OrderExpr(Expr.Col("score"), DescNullsLast)
  assert [OrderExpr(Expr.Col("id"), SortDir.Asc)] == [OrderExpr(Expr.Col("id"), SortDir.Asc)]
  assert [OrderExpr(Expr.Col("name"), SortDir.Asc), OrderExpr(Expr.Col("id"), SortDir.Desc)] == [OrderExpr(Expr.Col("name"), SortDir.Asc), OrderExpr(Expr.Col("id"), SortDir.Desc)]
  assert [OrderExpr(Expr.Col("a"), SortDir.Asc), OrderExpr(Expr.Col("b"), SortDir.Asc), OrderExpr(Expr.Col("c"), SortDir.Desc)] == [OrderExpr(Expr.Col("a"), SortDir.Asc), OrderExpr(Expr.Col("b"), SortDir.Asc), OrderExpr(Expr.Col("c"), SortDir.Desc)]
  assert Where(Expr.Eq(Expr.Col("a"), Lit(PInt(1)))) == Where(Expr.Eq(Expr.Col("a"), Lit(PInt(1))))
  assert Where(Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Gt(Expr.Col("b"), Lit(PInt(0))))) == Where(Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Gt(Expr.Col("b"), Lit(PInt(0)))))
  assert Where(Expr.Or(Expr.Eq(Expr.Col("x"), Lit(PInt(1))), Expr.IsNull(Expr.Col("y")))) == Where(Expr.Or(Expr.Eq(Expr.Col("x"), Lit(PInt(1))), Expr.IsNull(Expr.Col("y"))))
  assert [Where(Expr.Eq(Expr.Col("a"), Lit(PInt(1))))] == [Where(Expr.Eq(Expr.Col("a"), Lit(PInt(1))))]
  assert [Where(Expr.Eq(Expr.Col("a"), Lit(PInt(1)))), Where(Expr.Gt(Expr.Col("b"), Lit(PInt(0))))] == [Where(Expr.Eq(Expr.Col("a"), Lit(PInt(1)))), Where(Expr.Gt(Expr.Col("b"), Lit(PInt(0))))]
  assert SortDir.Asc == SortDir.Asc
  assert SortDir.Desc == SortDir.Desc
  assert AscNullsFirst == AscNullsFirst
  assert AscNullsLast == AscNullsLast
  assert DescNullsFirst == DescNullsFirst
  assert DescNullsLast == DescNullsLast
  assert JoinKind.Inner == JoinKind.Inner
  assert JoinKind.Left == JoinKind.Left
  assert JoinKind.Right == JoinKind.Right
  assert FullOuter == FullOuter
  assert Cross == Cross
end

test "fncall raw expr param batch" do
  assert FnCall("length", [Expr.Col("age")]) == FnCall("length", [Expr.Col("age")])
  assert FnCall("abs", [Expr.Col("price")]) == FnCall("abs", [Expr.Col("price")])
  assert FnCall("lower", [Expr.Col("name")]) == FnCall("lower", [Expr.Col("name")])
  assert FnCall("upper", [Expr.Col("email")]) == FnCall("upper", [Expr.Col("email")])
  assert FnCall("coalesce", [Expr.Col("name"), Lit(PString("unknown"))]) == FnCall("coalesce", [Expr.Col("name"), Lit(PString("unknown"))])
  assert FnCall("coalesce", [Expr.Col("value"), Lit(PInt(0))]) == FnCall("coalesce", [Expr.Col("value"), Lit(PInt(0))])
  assert FnCall("nullif", [Expr.Col("score"), Lit(PInt(0))]) == FnCall("nullif", [Expr.Col("score"), Lit(PInt(0))])
  assert FnCall("greatest", [Expr.Col("a"), Expr.Col("b"), Expr.Col("c")]) == FnCall("greatest", [Expr.Col("a"), Expr.Col("b"), Expr.Col("c")])
  assert FnCall("least", [Expr.Col("x"), Expr.Col("y")]) == FnCall("least", [Expr.Col("x"), Expr.Col("y")])
  assert FnCall("now", []) == FnCall("now", [])
  assert FnCall("current_timestamp", []) == FnCall("current_timestamp", [])
  assert FnCall("length", [QCol("u", "name")]) == FnCall("length", [QCol("u", "name")])
  assert FnCall("abs", [QCol("o", "amount")]) == FnCall("abs", [QCol("o", "amount")])
  assert Raw("NOW()") == Raw("NOW()")
  assert Raw("CURRENT_DATE") == Raw("CURRENT_DATE")
  assert Raw("CURRENT_TIMESTAMP") == Raw("CURRENT_TIMESTAMP")
  assert Raw("gen_random_uuid()") == Raw("gen_random_uuid()")
  assert Raw("1 + 1") == Raw("1 + 1")
  assert Raw("TRUE") == Raw("TRUE")
  assert Raw("FALSE") == Raw("FALSE")
  assert ExprParam(1) == ExprParam(1)
  assert ExprParam(2) == ExprParam(2)
  assert ExprParam(10) == ExprParam(10)
  assert ExprParam(100) == ExprParam(100)
  assert Expr.Eq(FnCall("lower", [Expr.Col("email")]), Lit(PString("test@example.com"))) == Expr.Eq(FnCall("lower", [Expr.Col("email")]), Lit(PString("test@example.com")))
  assert Expr.Gt(FnCall("length", [Expr.Col("name")]), Lit(PInt(0))) == Expr.Gt(FnCall("length", [Expr.Col("name")]), Lit(PInt(0)))
  assert Expr.Eq(Raw("NOW()"), Expr.Col("created_at")) == Expr.Eq(Raw("NOW()"), Expr.Col("created_at"))
  assert Expr.And(Expr.Eq(Expr.Col("a"), ExprParam(1)), Expr.Eq(Expr.Col("b"), ExprParam(2))) == Expr.And(Expr.Eq(Expr.Col("a"), ExprParam(1)), Expr.Eq(Expr.Col("b"), ExprParam(2)))
  assert SelectField(FnCall("length", [Expr.Col("x")])) == SelectField(FnCall("length", [Expr.Col("x")]))
  assert SelectAs(FnCall("abs", [Expr.Col("score")]), "num") == SelectAs(FnCall("abs", [Expr.Col("score")]), "num")
  assert SelectField(Raw("NOW()")) == SelectField(Raw("NOW()"))
  assert SelectAs(Raw("CURRENT_DATE"), "today") == SelectAs(Raw("CURRENT_DATE"), "today")
  assert [ExprParam(1), ExprParam(2), ExprParam(3), ExprParam(4)] == [ExprParam(1), ExprParam(2), ExprParam(3), ExprParam(4)]
  assert Expr.Eq(ExprParam(1), ExprParam(2)) == Expr.Eq(ExprParam(1), ExprParam(2))
  assert FnCall("greatest", [Expr.Add(Expr.Col("a"), Expr.Col("b")), Lit(PInt(0))]) == FnCall("greatest", [Expr.Add(Expr.Col("a"), Expr.Col("b")), Lit(PInt(0))])
  assert FnCall("least", [Expr.Mul(Expr.Col("x"), Expr.Col("y")), Lit(PInt(100))]) == FnCall("least", [Expr.Mul(Expr.Col("x"), Expr.Col("y")), Lit(PInt(100))])
  assert Expr.Eq(FnCall("length", [Expr.Col("text")]), Lit(PInt(0))) == Expr.Eq(FnCall("length", [Expr.Col("text")]), Lit(PInt(0)))
  assert Expr.And(Expr.Gt(FnCall("length", [Expr.Col("pwd")]), Lit(PInt(8))), Like(Expr.Col("pwd"), "%0%")) == Expr.And(Expr.Gt(FnCall("length", [Expr.Col("pwd")]), Lit(PInt(8))), Like(Expr.Col("pwd"), "%0%"))
  assert SelectField(FnCall("coalesce", [Expr.Col("a"), Expr.Col("b"), Lit(PString("default"))])) == SelectField(FnCall("coalesce", [Expr.Col("a"), Expr.Col("b"), Lit(PString("default"))]))
  assert SelectAs(FnCall("lower", [Expr.Col("username")]), "login") == SelectAs(FnCall("lower", [Expr.Col("username")]), "login")
end

test "query record full construction batch" do
  let q1 = Query({ from_ = FromTable("users"), selects = [SelectAll], wheres = Nil, joins = Nil, orders = Nil, group_bys = Nil, havings = Nil, limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert q1 == q1
  let q2 = Query({ from_ = FromTable("orders"), selects = [SelectField(Expr.Col("id")), SelectField(Expr.Col("total"))], wheres = [Where(Expr.Eq(Expr.Col("status"), Lit(PString("paid"))))], joins = Nil, orders = [OrderExpr(Expr.Col("id"), SortDir.Desc)], group_bys = Nil, havings = Nil, limit_ = Some(10), offset_ = None, distinct_ = NoDistinct })
  assert q2 == q2
  let q3 = Query({ from_ = FromTable("products"), selects = [SelectField(Expr.Col("id")), SelectAs(Expr.Col("name"), "product_name")], wheres = [Where(Expr.Eq(Expr.Col("active"), Lit(PBool(true)))), Where(Expr.Gt(Expr.Col("stock"), Lit(PInt(0))))], joins = [JoinClause(JoinKind.Left, "categories", Expr.Eq(QCol("products", "cat_id"), QCol("categories", "id")))], orders = [OrderExpr(Expr.Col("name"), SortDir.Asc)], group_bys = Nil, havings = Nil, limit_ = Some(20), offset_ = Some(0), distinct_ = NoDistinct })
  assert q3 == q3
  let q4 = Query({ from_ = FromTable("sales"), selects = [SelectField(Expr.Col("category")), SelectAs(Expr.Sum(Expr.Col("amount")), "total")], wheres = Nil, joins = Nil, orders = [OrderExpr(Expr.Col("category"), SortDir.Asc)], group_bys = [Expr.Col("category")], havings = [Where(Expr.Gt(Expr.Sum(Expr.Col("amount")), Lit(PFloat(1000.0))))], limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert q4 == q4
  let q5 = Query({ from_ = FromTable("events"), selects = [SelectAll], wheres = Nil, joins = Nil, orders = Nil, group_bys = Nil, havings = Nil, limit_ = None, offset_ = None, distinct_ = Distinct })
  assert q5 == q5
  let q6 = Query({ from_ = FromTable("t"), selects = [SelectField(Expr.Col("a")), SelectField(Expr.Col("b")), SelectField(Expr.Col("c"))], wheres = [Where(Expr.And(Expr.Gte(Expr.Col("a"), Lit(PInt(1))), Expr.Lte(Expr.Col("a"), Lit(PInt(100)))))], joins = Nil, orders = [OrderExpr(Expr.Col("b"), SortDir.Desc), OrderExpr(Expr.Col("c"), SortDir.Asc)], group_bys = Nil, havings = Nil, limit_ = Some(50), offset_ = Some(10), distinct_ = NoDistinct })
  assert q6 == q6
  let q7 = Query({ from_ = FromTable("u"), selects = [SelectAll], wheres = [Where(Expr.Or(Expr.Eq(Expr.Col("role"), Lit(PString("admin"))), Expr.Eq(Expr.Col("role"), Lit(PString("mod")))))], joins = [JoinClause(JoinKind.Inner, "profiles", Expr.Eq(QCol("u", "id"), QCol("profiles", "user_id"))), JoinClause(JoinKind.Left, "settings", Expr.Eq(QCol("u", "id"), QCol("settings", "user_id")))], orders = [OrderExpr(Expr.Col("created_at"), SortDir.Desc)], group_bys = Nil, havings = Nil, limit_ = Some(100), offset_ = Some(0), distinct_ = Distinct })
  assert q7 == q7
  assert FromTable("users") == FromTable("users")
  assert FromTable("orders") == FromTable("orders")
  assert FromTable("products") == FromTable("products")
  assert FromTable("logs") == FromTable("logs")
  assert FromTable("events") == FromTable("events")
  assert FromTable("sessions") == FromTable("sessions")
  assert FromTable("tags") == FromTable("tags")
  assert FromTable("categories") == FromTable("categories")
end

test "pvalue constructors batch" do
  assert PInt(0) == PInt(0)
  assert PInt(1) == PInt(1)
  assert PInt(-1) == PInt(-1)
  assert PInt(42) == PInt(42)
  assert PInt(100) == PInt(100)
  assert PInt(999) == PInt(999)
  assert PInt(9999) == PInt(9999)
  assert PFloat(0.0) == PFloat(0.0)
  assert PFloat(1.0) == PFloat(1.0)
  assert PFloat(-1.0) == PFloat(-1.0)
  assert PFloat(3.14) == PFloat(3.14)
  assert PFloat(0.001) == PFloat(0.001)
  assert PFloat(100.5) == PFloat(100.5)
  assert PFloat(9.99) == PFloat(9.99)
  assert PString("") == PString("")
  assert PString("hello") == PString("hello")
  assert PString("world") == PString("world")
  assert PString("admin") == PString("admin")
  assert PString("active") == PString("active")
  assert PString("pending") == PString("pending")
  assert PString("users") == PString("users")
  assert PBool(true) == PBool(true)
  assert PBool(false) == PBool(false)
  assert PNull == PNull
  assert Lit(PInt(0)) == Lit(PInt(0))
  assert Lit(PFloat(0.0)) == Lit(PFloat(0.0))
  assert Lit(PString("")) == Lit(PString(""))
  assert Lit(PBool(true)) == Lit(PBool(true))
  assert Lit(PBool(false)) == Lit(PBool(false))
  assert Lit(PNull) == Lit(PNull)
  assert Expr.Col("id") == Expr.Col("id")
  assert Expr.Col("name") == Expr.Col("name")
  assert Expr.Col("email") == Expr.Col("email")
  assert Expr.Col("created_at") == Expr.Col("created_at")
  assert Expr.Col("updated_at") == Expr.Col("updated_at")
  assert Expr.Col("deleted_at") == Expr.Col("deleted_at")
  assert Expr.Col("active") == Expr.Col("active")
  assert QCol("users", "id") == QCol("users", "id")
  assert QCol("orders", "user_id") == QCol("orders", "user_id")
  assert QCol("products", "price") == QCol("products", "price")
  assert QCol("t", "a") == QCol("t", "a")
end

test "complex nested expressions batch" do
  assert Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Or(Expr.Gt(Expr.Col("b"), Lit(PInt(0))), Expr.IsNull(Expr.Col("c")))) == Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Or(Expr.Gt(Expr.Col("b"), Lit(PInt(0))), Expr.IsNull(Expr.Col("c"))))
  assert Expr.Or(Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Lt(Expr.Col("b"), Lit(PInt(10)))), Expr.And(Expr.Eq(Expr.Col("c"), Lit(PString("x"))), Expr.IsNotNull(Expr.Col("d")))) == Expr.Or(Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Lt(Expr.Col("b"), Lit(PInt(10)))), Expr.And(Expr.Eq(Expr.Col("c"), Lit(PString("x"))), Expr.IsNotNull(Expr.Col("d"))))
  assert Expr.Not(Expr.And(Expr.Gte(Expr.Col("age"), Lit(PInt(18))), Expr.Lte(Expr.Col("age"), Lit(PInt(65))))) == Expr.Not(Expr.And(Expr.Gte(Expr.Col("age"), Lit(PInt(18))), Expr.Lte(Expr.Col("age"), Lit(PInt(65)))))
  assert Expr.And(Like(Expr.Col("email"), "%@company.com"), Expr.And(Expr.Eq(Expr.Col("active"), Lit(PBool(true))), Expr.IsNotNull(Expr.Col("confirmed_at")))) == Expr.And(Like(Expr.Col("email"), "%@company.com"), Expr.And(Expr.Eq(Expr.Col("active"), Lit(PBool(true))), Expr.IsNotNull(Expr.Col("confirmed_at"))))
  assert Expr.Or(In(Expr.Col("status"), [Lit(PString("a")), Lit(PString("b"))]), Expr.And(Expr.IsNull(Expr.Col("status")), Expr.Eq(Expr.Col("default"), Lit(PBool(true))))) == Expr.Or(In(Expr.Col("status"), [Lit(PString("a")), Lit(PString("b"))]), Expr.And(Expr.IsNull(Expr.Col("status")), Expr.Eq(Expr.Col("default"), Lit(PBool(true)))))
  assert Expr.And(Between(Expr.Col("price"), Lit(PFloat(10.0)), Lit(PFloat(100.0))), Expr.Eq(Expr.Col("available"), Lit(PBool(true)))) == Expr.And(Between(Expr.Col("price"), Lit(PFloat(10.0)), Lit(PFloat(100.0))), Expr.Eq(Expr.Col("available"), Lit(PBool(true))))
  assert Expr.Not(Expr.Or(In(Expr.Col("role"), [Lit(PString("banned"))]), Expr.IsNull(Expr.Col("email")))) == Expr.Not(Expr.Or(In(Expr.Col("role"), [Lit(PString("banned"))]), Expr.IsNull(Expr.Col("email"))))
  assert Expr.And(Expr.Eq(QCol("u", "active"), Lit(PBool(true))), Expr.Or(Expr.Eq(QCol("u", "role"), Lit(PString("admin"))), Expr.Eq(QCol("u", "role"), Lit(PString("mod"))))) == Expr.And(Expr.Eq(QCol("u", "active"), Lit(PBool(true))), Expr.Or(Expr.Eq(QCol("u", "role"), Lit(PString("admin"))), Expr.Eq(QCol("u", "role"), Lit(PString("mod")))))
  assert Expr.Or(Expr.And(Expr.Gt(Expr.Col("score"), Lit(PInt(90))), Expr.Eq(Expr.Col("active"), Lit(PBool(true)))), Expr.And(Expr.Eq(Expr.Col("bonus"), Lit(PBool(true))), Expr.Gte(Expr.Col("score"), Lit(PInt(70))))) == Expr.Or(Expr.And(Expr.Gt(Expr.Col("score"), Lit(PInt(90))), Expr.Eq(Expr.Col("active"), Lit(PBool(true)))), Expr.And(Expr.Eq(Expr.Col("bonus"), Lit(PBool(true))), Expr.Gte(Expr.Col("score"), Lit(PInt(70)))))
  assert Expr.And(Expr.And(Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Eq(Expr.Col("b"), Lit(PInt(2)))), Expr.Eq(Expr.Col("c"), Lit(PInt(3)))), Expr.Eq(Expr.Col("d"), Lit(PInt(4)))) == Expr.And(Expr.And(Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Eq(Expr.Col("b"), Lit(PInt(2)))), Expr.Eq(Expr.Col("c"), Lit(PInt(3)))), Expr.Eq(Expr.Col("d"), Lit(PInt(4))))
  assert Expr.Or(Expr.Or(Expr.Or(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Eq(Expr.Col("b"), Lit(PInt(2)))), Expr.Eq(Expr.Col("c"), Lit(PInt(3)))), Expr.Eq(Expr.Col("d"), Lit(PInt(4)))) == Expr.Or(Expr.Or(Expr.Or(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Eq(Expr.Col("b"), Lit(PInt(2)))), Expr.Eq(Expr.Col("c"), Lit(PInt(3)))), Expr.Eq(Expr.Col("d"), Lit(PInt(4))))
  assert Expr.Gt(Expr.Add(Expr.Col("a"), Expr.Col("b")), Expr.Mul(Expr.Col("c"), Lit(PInt(2)))) == Expr.Gt(Expr.Add(Expr.Col("a"), Expr.Col("b")), Expr.Mul(Expr.Col("c"), Lit(PInt(2))))
  assert Expr.Eq(Expr.Div(Expr.Sub(Expr.Col("end"), Expr.Col("start")), Lit(PInt(2))), Expr.Col("midpoint")) == Expr.Eq(Expr.Div(Expr.Sub(Expr.Col("end"), Expr.Col("start")), Lit(PInt(2))), Expr.Col("midpoint"))
  assert Expr.And(Expr.Gt(Expr.Sum(Expr.Col("amount")), Lit(PFloat(1000.0))), Expr.Gt(Expr.Count(Expr.Col("id")), Lit(PInt(5)))) == Expr.And(Expr.Gt(Expr.Sum(Expr.Col("amount")), Lit(PFloat(1000.0))), Expr.Gt(Expr.Count(Expr.Col("id")), Lit(PInt(5))))
  assert Expr.Or(Expr.Gt(Avg(Expr.Col("rating")), Lit(PFloat(4.0))), Expr.And(Expr.Gte(Expr.Count(Expr.Col("reviews")), Lit(PInt(10))), Expr.Gt(Avg(Expr.Col("rating")), Lit(PFloat(3.5))))) == Expr.Or(Expr.Gt(Avg(Expr.Col("rating")), Lit(PFloat(4.0))), Expr.And(Expr.Gte(Expr.Count(Expr.Col("reviews")), Lit(PInt(10))), Expr.Gt(Avg(Expr.Col("rating")), Lit(PFloat(3.5)))))
  assert Expr.And(Like(Expr.Col("n"), "A%"), Expr.And(Expr.Gte(Expr.Col("age"), Lit(PInt(18))), Expr.Lte(Expr.Col("age"), Lit(PInt(30))))) == Expr.And(Like(Expr.Col("n"), "A%"), Expr.And(Expr.Gte(Expr.Col("age"), Lit(PInt(18))), Expr.Lte(Expr.Col("age"), Lit(PInt(30)))))
  assert Expr.Not(Expr.And(Expr.IsNull(Expr.Col("a")), Expr.IsNull(Expr.Col("b")))) == Expr.Not(Expr.And(Expr.IsNull(Expr.Col("a")), Expr.IsNull(Expr.Col("b"))))
  assert Expr.And(Expr.Not(Expr.IsNull(Expr.Col("x"))), Expr.Not(Expr.IsNull(Expr.Col("y")))) == Expr.And(Expr.Not(Expr.IsNull(Expr.Col("x"))), Expr.Not(Expr.IsNull(Expr.Col("y"))))
  assert Expr.Or(Expr.Not(Expr.Gt(Expr.Col("a"), Lit(PInt(10)))), Expr.Not(Expr.Lt(Expr.Col("b"), Lit(PInt(0))))) == Expr.Or(Expr.Not(Expr.Gt(Expr.Col("a"), Lit(PInt(10)))), Expr.Not(Expr.Lt(Expr.Col("b"), Lit(PInt(0)))))
  assert Expr.Eq(FnCall("abs", [Expr.Add(Expr.Col("a"), Expr.Col("b"))]), Lit(PFloat(0.0))) == Expr.Eq(FnCall("abs", [Expr.Add(Expr.Col("a"), Expr.Col("b"))]), Lit(PFloat(0.0)))
end

test "more complex combinator asserts" do
  assert Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Eq(Expr.Col("b"), Lit(PInt(2)))) == Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Eq(Expr.Col("b"), Lit(PInt(2))))
  assert Expr.Or(Expr.Neq(Expr.Col("x"), Lit(PString("foo"))), Expr.Neq(Expr.Col("y"), Lit(PString("bar")))) == Expr.Or(Expr.Neq(Expr.Col("x"), Lit(PString("foo"))), Expr.Neq(Expr.Col("y"), Lit(PString("bar"))))
  assert Expr.And(Expr.Gte(Expr.Col("score"), Lit(PInt(0))), Expr.Lte(Expr.Col("score"), Lit(PInt(100)))) == Expr.And(Expr.Gte(Expr.Col("score"), Lit(PInt(0))), Expr.Lte(Expr.Col("score"), Lit(PInt(100))))
  assert Expr.Or(Expr.Lt(Expr.Col("priority"), Lit(PInt(3))), Expr.Gt(Expr.Col("urgency"), Lit(PInt(7)))) == Expr.Or(Expr.Lt(Expr.Col("priority"), Lit(PInt(3))), Expr.Gt(Expr.Col("urgency"), Lit(PInt(7))))
  assert Expr.And(ILike(Expr.Col("desc"), "%urgent%"), Expr.Eq(Expr.Col("resolved"), Lit(PBool(false)))) == Expr.And(ILike(Expr.Col("desc"), "%urgent%"), Expr.Eq(Expr.Col("resolved"), Lit(PBool(false))))
  assert Expr.Not(Between(Expr.Col("created_day"), Lit(PInt(1)), Lit(PInt(7)))) == Expr.Not(Between(Expr.Col("created_day"), Lit(PInt(1)), Lit(PInt(7))))
  assert Expr.And(NotIn(Expr.Col("type"), [Lit(PString("draft"))]), Expr.IsNotNull(Expr.Col("published_at"))) == Expr.And(NotIn(Expr.Col("type"), [Lit(PString("draft"))]), Expr.IsNotNull(Expr.Col("published_at")))
  assert Expr.Or(Expr.Eq(Expr.Col("owner_id"), ExprParam(1)), In(Expr.Col("viewer_ids"), [ExprParam(2)])) == Expr.Or(Expr.Eq(Expr.Col("owner_id"), ExprParam(1)), In(Expr.Col("viewer_ids"), [ExprParam(2)]))
  assert Expr.Gt(Expr.Sub(Expr.Max(Expr.Col("age")), Expr.Min(Expr.Col("age"))), Lit(PInt(10))) == Expr.Gt(Expr.Sub(Expr.Max(Expr.Col("age")), Expr.Min(Expr.Col("age"))), Lit(PInt(10)))
  assert Expr.Eq(Avg(Expr.Col("rating")), Expr.Div(Expr.Sum(Expr.Col("rating")), Expr.Count(Expr.Col("id")))) == Expr.Eq(Avg(Expr.Col("rating")), Expr.Div(Expr.Sum(Expr.Col("rating")), Expr.Count(Expr.Col("id"))))
  assert Expr.And(Expr.Gt(Expr.Col("views"), Lit(PInt(100))), Expr.Or(Like(Expr.Col("tags"), "%featured%"), Expr.Eq(Expr.Col("pinned"), Lit(PBool(true))))) == Expr.And(Expr.Gt(Expr.Col("views"), Lit(PInt(100))), Expr.Or(Like(Expr.Col("tags"), "%featured%"), Expr.Eq(Expr.Col("pinned"), Lit(PBool(true)))))
  assert Expr.Or(Expr.And(Expr.Eq(QCol("u","active"), Lit(PBool(true))), Expr.Gt(QCol("u","score"), Lit(PInt(50)))), Expr.And(Expr.Eq(QCol("u","role"), Lit(PString("vip"))), Expr.Gte(QCol("u","balance"), Lit(PFloat(0.0))))) == Expr.Or(Expr.And(Expr.Eq(QCol("u","active"), Lit(PBool(true))), Expr.Gt(QCol("u","score"), Lit(PInt(50)))), Expr.And(Expr.Eq(QCol("u","role"), Lit(PString("vip"))), Expr.Gte(QCol("u","balance"), Lit(PFloat(0.0)))))
  assert Expr.Not(Expr.Or(Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(0))), Expr.Eq(Expr.Col("b"), Lit(PInt(0)))), Expr.IsNull(Expr.Col("c")))) == Expr.Not(Expr.Or(Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(0))), Expr.Eq(Expr.Col("b"), Lit(PInt(0)))), Expr.IsNull(Expr.Col("c"))))
  assert [Where(Expr.Eq(Expr.Col("a"), Lit(PInt(1)))), Where(Expr.Gt(Expr.Col("b"), Lit(PInt(0)))), Where(Expr.IsNotNull(Expr.Col("c")))] == [Where(Expr.Eq(Expr.Col("a"), Lit(PInt(1)))), Where(Expr.Gt(Expr.Col("b"), Lit(PInt(0)))), Where(Expr.IsNotNull(Expr.Col("c")))]
  assert [OrderExpr(Expr.Col("name"), SortDir.Asc), OrderExpr(Expr.Col("id"), SortDir.Desc), OrderExpr(Expr.Col("score"), SortDir.Desc)] == [OrderExpr(Expr.Col("name"), SortDir.Asc), OrderExpr(Expr.Col("id"), SortDir.Desc), OrderExpr(Expr.Col("score"), SortDir.Desc)]
  assert [SelectField(Expr.Col("id")), SelectField(Expr.Col("name")), SelectField(Expr.Col("email")), SelectField(Expr.Col("created_at"))] == [SelectField(Expr.Col("id")), SelectField(Expr.Col("name")), SelectField(Expr.Col("email")), SelectField(Expr.Col("created_at"))]
  assert [Expr.Col("category"), Expr.Col("region"), Expr.Col("year"), Expr.Col("month")] == [Expr.Col("category"), Expr.Col("region"), Expr.Col("year"), Expr.Col("month")]
  assert [JoinClause(JoinKind.Inner, "u", Expr.Eq(Expr.Col("uid"), Expr.Col("id"))), JoinClause(JoinKind.Left, "p", Expr.Eq(Expr.Col("pid"), Expr.Col("id"))), JoinClause(JoinKind.Left, "c", Expr.Eq(Expr.Col("cid"), Expr.Col("id")))] == [JoinClause(JoinKind.Inner, "u", Expr.Eq(Expr.Col("uid"), Expr.Col("id"))), JoinClause(JoinKind.Left, "p", Expr.Eq(Expr.Col("pid"), Expr.Col("id"))), JoinClause(JoinKind.Left, "c", Expr.Eq(Expr.Col("cid"), Expr.Col("id")))]
  assert Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.And(Expr.Eq(Expr.Col("b"), Lit(PInt(2))), Expr.And(Expr.Eq(Expr.Col("c"), Lit(PInt(3))), Expr.Eq(Expr.Col("d"), Lit(PInt(4)))))) == Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.And(Expr.Eq(Expr.Col("b"), Lit(PInt(2))), Expr.And(Expr.Eq(Expr.Col("c"), Lit(PInt(3))), Expr.Eq(Expr.Col("d"), Lit(PInt(4))))))
  assert Expr.Or(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Or(Expr.Eq(Expr.Col("b"), Lit(PInt(2))), Expr.Or(Expr.Eq(Expr.Col("c"), Lit(PInt(3))), Expr.Eq(Expr.Col("d"), Lit(PInt(4)))))) == Expr.Or(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Or(Expr.Eq(Expr.Col("b"), Lit(PInt(2))), Expr.Or(Expr.Eq(Expr.Col("c"), Lit(PInt(3))), Expr.Eq(Expr.Col("d"), Lit(PInt(4))))))
  assert Expr.Gt(Expr.Mul(Expr.Col("qty"), Expr.Col("price")), Expr.Add(Expr.Col("cost"), Expr.Mul(Lit(PFloat(0.1)), Expr.Col("cost")))) == Expr.Gt(Expr.Mul(Expr.Col("qty"), Expr.Col("price")), Expr.Add(Expr.Col("cost"), Expr.Mul(Lit(PFloat(0.1)), Expr.Col("cost"))))
end

-- ---- Dense coverage batch 2: more node-heavy assertions ----

test "orwhere and where expr variants" do
  assert Where(Expr.Eq(Expr.Col("id"), Lit(PInt(1)))) == Where(Expr.Eq(Expr.Col("id"), Lit(PInt(1))))
  assert Where(Expr.Neq(Expr.Col("status"), Lit(PString("deleted")))) == Where(Expr.Neq(Expr.Col("status"), Lit(PString("deleted"))))
  assert Where(Expr.Gt(Expr.Col("score"), Lit(PInt(0)))) == Where(Expr.Gt(Expr.Col("score"), Lit(PInt(0))))
  assert Where(Expr.Gte(Expr.Col("age"), Lit(PInt(18)))) == Where(Expr.Gte(Expr.Col("age"), Lit(PInt(18))))
  assert Where(Expr.Lt(Expr.Col("retries"), Lit(PInt(5)))) == Where(Expr.Lt(Expr.Col("retries"), Lit(PInt(5))))
  assert Where(Expr.Lte(Expr.Col("level"), Lit(PInt(10)))) == Where(Expr.Lte(Expr.Col("level"), Lit(PInt(10))))
  assert Where(Expr.IsNull(Expr.Col("deleted_at"))) == Where(Expr.IsNull(Expr.Col("deleted_at")))
  assert Where(Expr.IsNotNull(Expr.Col("confirmed_at"))) == Where(Expr.IsNotNull(Expr.Col("confirmed_at")))
  assert Where(Like(Expr.Col("email"), "%@test.com")) == Where(Like(Expr.Col("email"), "%@test.com"))
  assert Where(ILike(Expr.Col("name"), "%admin%")) == Where(ILike(Expr.Col("name"), "%admin%"))
  assert Where(Between(Expr.Col("age"), Lit(PInt(18)), Lit(PInt(65)))) == Where(Between(Expr.Col("age"), Lit(PInt(18)), Lit(PInt(65))))
  assert Where(In(Expr.Col("status"), [Lit(PString("a")), Lit(PString("b"))])) == Where(In(Expr.Col("status"), [Lit(PString("a")), Lit(PString("b"))]))
  assert Where(NotIn(Expr.Col("role"), [Lit(PString("banned"))])) == Where(NotIn(Expr.Col("role"), [Lit(PString("banned"))]))
  assert Where(Expr.And(Expr.Eq(Expr.Col("active"), Lit(PBool(true))), Expr.IsNotNull(Expr.Col("email")))) == Where(Expr.And(Expr.Eq(Expr.Col("active"), Lit(PBool(true))), Expr.IsNotNull(Expr.Col("email"))))
  assert Where(Expr.Or(Expr.Eq(Expr.Col("role"), Lit(PString("admin"))), Expr.Eq(Expr.Col("role"), Lit(PString("mod"))))) == Where(Expr.Or(Expr.Eq(Expr.Col("role"), Lit(PString("admin"))), Expr.Eq(Expr.Col("role"), Lit(PString("mod")))))
  assert Where(Expr.Not(Expr.Eq(Expr.Col("banned"), Lit(PBool(true))))) == Where(Expr.Not(Expr.Eq(Expr.Col("banned"), Lit(PBool(true)))))
  assert OrWhere(Expr.Eq(Expr.Col("id"), Lit(PInt(1)))) == OrWhere(Expr.Eq(Expr.Col("id"), Lit(PInt(1))))
  assert OrWhere(Expr.Neq(Expr.Col("type"), Lit(PString("blocked")))) == OrWhere(Expr.Neq(Expr.Col("type"), Lit(PString("blocked"))))
  assert OrWhere(Expr.Gt(Expr.Col("priority"), Lit(PInt(5)))) == OrWhere(Expr.Gt(Expr.Col("priority"), Lit(PInt(5))))
  assert OrWhere(Expr.Gte(Expr.Col("score"), Lit(PInt(60)))) == OrWhere(Expr.Gte(Expr.Col("score"), Lit(PInt(60))))
  assert OrWhere(Expr.IsNull(Expr.Col("archived_at"))) == OrWhere(Expr.IsNull(Expr.Col("archived_at")))
  assert OrWhere(Like(Expr.Col("tag"), "%featured%")) == OrWhere(Like(Expr.Col("tag"), "%featured%"))
  assert OrWhere(Expr.And(Expr.Eq(Expr.Col("x"), Lit(PInt(1))), Expr.Eq(Expr.Col("y"), Lit(PInt(2))))) == OrWhere(Expr.And(Expr.Eq(Expr.Col("x"), Lit(PInt(1))), Expr.Eq(Expr.Col("y"), Lit(PInt(2)))))
  assert OrWhere(Expr.Or(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Eq(Expr.Col("b"), Lit(PInt(2))))) == OrWhere(Expr.Or(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Eq(Expr.Col("b"), Lit(PInt(2)))))
  assert OrWhere(Expr.Not(Expr.IsNull(Expr.Col("val")))) == OrWhere(Expr.Not(Expr.IsNull(Expr.Col("val"))))
  assert [Where(Expr.Eq(Expr.Col("a"), Lit(PInt(1)))), OrWhere(Expr.Eq(Expr.Col("b"), Lit(PInt(2))))] == [Where(Expr.Eq(Expr.Col("a"), Lit(PInt(1)))), OrWhere(Expr.Eq(Expr.Col("b"), Lit(PInt(2))))]
  assert [Where(Expr.Gt(Expr.Col("age"), Lit(PInt(18)))), Where(Expr.Eq(Expr.Col("active"), Lit(PBool(true)))), OrWhere(Expr.Eq(Expr.Col("role"), Lit(PString("admin"))))] == [Where(Expr.Gt(Expr.Col("age"), Lit(PInt(18)))), Where(Expr.Eq(Expr.Col("active"), Lit(PBool(true)))), OrWhere(Expr.Eq(Expr.Col("role"), Lit(PString("admin"))))]
  assert Where(Expr.And(Expr.Gte(Expr.Col("a"), Lit(PInt(0))), Expr.Lte(Expr.Col("a"), Lit(PInt(100))))) == Where(Expr.And(Expr.Gte(Expr.Col("a"), Lit(PInt(0))), Expr.Lte(Expr.Col("a"), Lit(PInt(100)))))
  assert OrWhere(Between(Expr.Col("score"), Lit(PInt(50)), Lit(PInt(100)))) == OrWhere(Between(Expr.Col("score"), Lit(PInt(50)), Lit(PInt(100))))
  assert OrWhere(In(Expr.Col("cat"), [Lit(PString("a")), Lit(PString("b")), Lit(PString("c"))])) == OrWhere(In(Expr.Col("cat"), [Lit(PString("a")), Lit(PString("b")), Lit(PString("c"))]))
end

test "deeply nested and chained expr batch" do
  assert Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.And(Expr.Eq(Expr.Col("b"), Lit(PInt(2))), Expr.And(Expr.Eq(Expr.Col("c"), Lit(PInt(3))), Expr.And(Expr.Eq(Expr.Col("d"), Lit(PInt(4))), Expr.Eq(Expr.Col("e"), Lit(PInt(5))))))) == Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.And(Expr.Eq(Expr.Col("b"), Lit(PInt(2))), Expr.And(Expr.Eq(Expr.Col("c"), Lit(PInt(3))), Expr.And(Expr.Eq(Expr.Col("d"), Lit(PInt(4))), Expr.Eq(Expr.Col("e"), Lit(PInt(5)))))))
  assert Expr.Or(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Or(Expr.Eq(Expr.Col("b"), Lit(PInt(2))), Expr.Or(Expr.Eq(Expr.Col("c"), Lit(PInt(3))), Expr.Or(Expr.Eq(Expr.Col("d"), Lit(PInt(4))), Expr.Eq(Expr.Col("e"), Lit(PInt(5))))))) == Expr.Or(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Or(Expr.Eq(Expr.Col("b"), Lit(PInt(2))), Expr.Or(Expr.Eq(Expr.Col("c"), Lit(PInt(3))), Expr.Or(Expr.Eq(Expr.Col("d"), Lit(PInt(4))), Expr.Eq(Expr.Col("e"), Lit(PInt(5)))))))
  assert Expr.Not(Expr.Not(Expr.Eq(Expr.Col("a"), Lit(PInt(1))))) == Expr.Not(Expr.Not(Expr.Eq(Expr.Col("a"), Lit(PInt(1)))))
  assert Expr.Not(Expr.Not(Expr.Not(Expr.IsNull(Expr.Col("b"))))) == Expr.Not(Expr.Not(Expr.Not(Expr.IsNull(Expr.Col("b")))))
  assert Expr.And(Expr.Or(Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Gt(Expr.Col("b"), Lit(PInt(0)))), Expr.And(Expr.Eq(Expr.Col("c"), Lit(PInt(2))), Expr.Lt(Expr.Col("d"), Lit(PInt(10))))), Expr.IsNotNull(Expr.Col("e"))) == Expr.And(Expr.Or(Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Gt(Expr.Col("b"), Lit(PInt(0)))), Expr.And(Expr.Eq(Expr.Col("c"), Lit(PInt(2))), Expr.Lt(Expr.Col("d"), Lit(PInt(10))))), Expr.IsNotNull(Expr.Col("e")))
  assert Expr.Or(Expr.And(Expr.Or(Expr.Eq(Expr.Col("x"), Lit(PInt(1))), Expr.Eq(Expr.Col("x"), Lit(PInt(2)))), Expr.Gt(Expr.Col("y"), Lit(PInt(0)))), Expr.And(Expr.Or(Expr.Eq(Expr.Col("z"), Lit(PString("a"))), Expr.Eq(Expr.Col("z"), Lit(PString("b")))), Expr.IsNotNull(Expr.Col("w")))) == Expr.Or(Expr.And(Expr.Or(Expr.Eq(Expr.Col("x"), Lit(PInt(1))), Expr.Eq(Expr.Col("x"), Lit(PInt(2)))), Expr.Gt(Expr.Col("y"), Lit(PInt(0)))), Expr.And(Expr.Or(Expr.Eq(Expr.Col("z"), Lit(PString("a"))), Expr.Eq(Expr.Col("z"), Lit(PString("b")))), Expr.IsNotNull(Expr.Col("w"))))
  assert Expr.And(Expr.Gt(Expr.Col("a"), Lit(PInt(0))), Expr.And(Expr.Gt(Expr.Col("b"), Lit(PInt(0))), Expr.And(Expr.Gt(Expr.Col("c"), Lit(PInt(0))), Expr.Gt(Expr.Col("d"), Lit(PInt(0)))))) == Expr.And(Expr.Gt(Expr.Col("a"), Lit(PInt(0))), Expr.And(Expr.Gt(Expr.Col("b"), Lit(PInt(0))), Expr.And(Expr.Gt(Expr.Col("c"), Lit(PInt(0))), Expr.Gt(Expr.Col("d"), Lit(PInt(0))))))
  assert Expr.Or(Expr.Lt(Expr.Col("a"), Lit(PInt(0))), Expr.Or(Expr.Lt(Expr.Col("b"), Lit(PInt(0))), Expr.Or(Expr.Lt(Expr.Col("c"), Lit(PInt(0))), Expr.Lt(Expr.Col("d"), Lit(PInt(0)))))) == Expr.Or(Expr.Lt(Expr.Col("a"), Lit(PInt(0))), Expr.Or(Expr.Lt(Expr.Col("b"), Lit(PInt(0))), Expr.Or(Expr.Lt(Expr.Col("c"), Lit(PInt(0))), Expr.Lt(Expr.Col("d"), Lit(PInt(0))))))
  assert Expr.And(Like(Expr.Col("a"), "A%"), Expr.And(Like(Expr.Col("b"), "B%"), Expr.And(Like(Expr.Col("c"), "C%"), Like(Expr.Col("d"), "D%")))) == Expr.And(Like(Expr.Col("a"), "A%"), Expr.And(Like(Expr.Col("b"), "B%"), Expr.And(Like(Expr.Col("c"), "C%"), Like(Expr.Col("d"), "D%"))))
  assert Expr.Or(ILike(Expr.Col("a"), "%foo%"), Expr.Or(ILike(Expr.Col("b"), "%bar%"), Expr.Or(ILike(Expr.Col("c"), "%baz%"), ILike(Expr.Col("d"), "%qux%")))) == Expr.Or(ILike(Expr.Col("a"), "%foo%"), Expr.Or(ILike(Expr.Col("b"), "%bar%"), Expr.Or(ILike(Expr.Col("c"), "%baz%"), ILike(Expr.Col("d"), "%qux%"))))
  assert Expr.And(Expr.IsNull(Expr.Col("a")), Expr.And(Expr.IsNull(Expr.Col("b")), Expr.And(Expr.IsNull(Expr.Col("c")), Expr.IsNull(Expr.Col("d"))))) == Expr.And(Expr.IsNull(Expr.Col("a")), Expr.And(Expr.IsNull(Expr.Col("b")), Expr.And(Expr.IsNull(Expr.Col("c")), Expr.IsNull(Expr.Col("d")))))
  assert Expr.Or(Expr.IsNotNull(Expr.Col("a")), Expr.Or(Expr.IsNotNull(Expr.Col("b")), Expr.Or(Expr.IsNotNull(Expr.Col("c")), Expr.IsNotNull(Expr.Col("d"))))) == Expr.Or(Expr.IsNotNull(Expr.Col("a")), Expr.Or(Expr.IsNotNull(Expr.Col("b")), Expr.Or(Expr.IsNotNull(Expr.Col("c")), Expr.IsNotNull(Expr.Col("d")))))
  assert Expr.Add(Expr.Add(Expr.Col("a"), Expr.Col("b")), Expr.Add(Expr.Col("c"), Expr.Col("d"))) == Expr.Add(Expr.Add(Expr.Col("a"), Expr.Col("b")), Expr.Add(Expr.Col("c"), Expr.Col("d")))
  assert Expr.Mul(Expr.Mul(Expr.Col("a"), Expr.Col("b")), Expr.Mul(Expr.Col("c"), Expr.Col("d"))) == Expr.Mul(Expr.Mul(Expr.Col("a"), Expr.Col("b")), Expr.Mul(Expr.Col("c"), Expr.Col("d")))
  assert Expr.Sub(Expr.Add(Expr.Col("a"), Expr.Col("b")), Expr.Add(Expr.Col("c"), Expr.Col("d"))) == Expr.Sub(Expr.Add(Expr.Col("a"), Expr.Col("b")), Expr.Add(Expr.Col("c"), Expr.Col("d")))
  assert Expr.Div(Expr.Mul(Expr.Col("a"), Expr.Col("b")), Expr.Add(Expr.Col("c"), Lit(PInt(1)))) == Expr.Div(Expr.Mul(Expr.Col("a"), Expr.Col("b")), Expr.Add(Expr.Col("c"), Lit(PInt(1))))
  assert Expr.Gt(Expr.Add(Expr.Add(Expr.Col("a"), Expr.Col("b")), Expr.Col("c")), Lit(PInt(0))) == Expr.Gt(Expr.Add(Expr.Add(Expr.Col("a"), Expr.Col("b")), Expr.Col("c")), Lit(PInt(0)))
  assert Expr.Eq(Expr.Mul(Expr.Add(Expr.Col("a"), Expr.Col("b")), Expr.Sub(Expr.Col("c"), Expr.Col("d"))), Lit(PInt(0))) == Expr.Eq(Expr.Mul(Expr.Add(Expr.Col("a"), Expr.Col("b")), Expr.Sub(Expr.Col("c"), Expr.Col("d"))), Lit(PInt(0)))
  assert Expr.Gte(Expr.Div(Expr.Col("total"), Expr.Col("count")), Lit(PFloat(1.0))) == Expr.Gte(Expr.Div(Expr.Col("total"), Expr.Col("count")), Lit(PFloat(1.0)))
  assert Expr.Lte(Expr.Sub(Expr.Col("end"), Expr.Col("start")), Lit(PInt(30))) == Expr.Lte(Expr.Sub(Expr.Col("end"), Expr.Col("start")), Lit(PInt(30)))
  assert Expr.And(Expr.Gte(Expr.Col("x"), Lit(PInt(0))), Expr.And(Expr.Lte(Expr.Col("x"), Lit(PInt(100))), Expr.And(Expr.Gte(Expr.Col("y"), Lit(PInt(0))), Expr.Lte(Expr.Col("y"), Lit(PInt(100)))))) == Expr.And(Expr.Gte(Expr.Col("x"), Lit(PInt(0))), Expr.And(Expr.Lte(Expr.Col("x"), Lit(PInt(100))), Expr.And(Expr.Gte(Expr.Col("y"), Lit(PInt(0))), Expr.Lte(Expr.Col("y"), Lit(PInt(100))))))
end

test "multi-column selects and group bys batch" do
  assert [SelectField(Expr.Col("id")), SelectField(Expr.Col("name")), SelectField(Expr.Col("email")), SelectField(Expr.Col("age")), SelectField(Expr.Col("active"))] == [SelectField(Expr.Col("id")), SelectField(Expr.Col("name")), SelectField(Expr.Col("email")), SelectField(Expr.Col("age")), SelectField(Expr.Col("active"))]
  assert [SelectAs(Expr.Col("id"), "user_id"), SelectAs(Expr.Col("name"), "user_name"), SelectAs(Expr.Col("email"), "user_email")] == [SelectAs(Expr.Col("id"), "user_id"), SelectAs(Expr.Col("name"), "user_name"), SelectAs(Expr.Col("email"), "user_email")]
  assert [SelectField(Expr.Col("id")), SelectAs(Expr.Count(Expr.Col("id")), "cnt"), SelectAs(Expr.Sum(Expr.Col("amt")), "total"), SelectAs(Avg(Expr.Col("score")), "avg")] == [SelectField(Expr.Col("id")), SelectAs(Expr.Count(Expr.Col("id")), "cnt"), SelectAs(Expr.Sum(Expr.Col("amt")), "total"), SelectAs(Avg(Expr.Col("score")), "avg")]
  assert [Expr.Col("year"), Expr.Col("month"), Expr.Col("day")] == [Expr.Col("year"), Expr.Col("month"), Expr.Col("day")]
  assert [Expr.Col("category"), Expr.Col("region"), Expr.Col("type"), Expr.Col("status")] == [Expr.Col("category"), Expr.Col("region"), Expr.Col("type"), Expr.Col("status")]
  assert [QCol("u", "id"), QCol("u", "name"), QCol("u", "email")] == [QCol("u", "id"), QCol("u", "name"), QCol("u", "email")]
  assert [SelectField(QCol("u", "id")), SelectField(QCol("u", "name")), SelectAs(QCol("o", "total"), "order_total")] == [SelectField(QCol("u", "id")), SelectField(QCol("u", "name")), SelectAs(QCol("o", "total"), "order_total")]
  assert [OrderExpr(Expr.Col("name"), SortDir.Asc), OrderExpr(Expr.Col("age"), SortDir.Asc), OrderExpr(Expr.Col("id"), SortDir.Desc)] == [OrderExpr(Expr.Col("name"), SortDir.Asc), OrderExpr(Expr.Col("age"), SortDir.Asc), OrderExpr(Expr.Col("id"), SortDir.Desc)]
  assert [OrderExpr(QCol("u", "name"), SortDir.Asc), OrderExpr(QCol("o", "created_at"), SortDir.Desc)] == [OrderExpr(QCol("u", "name"), SortDir.Asc), OrderExpr(QCol("o", "created_at"), SortDir.Desc)]
  assert [JoinClause(JoinKind.Inner, "orders", Expr.Eq(QCol("u", "id"), QCol("o", "user_id"))), JoinClause(JoinKind.Left, "products", Expr.Eq(QCol("o", "product_id"), QCol("p", "id"))), JoinClause(JoinKind.Left, "categories", Expr.Eq(QCol("p", "cat_id"), QCol("c", "id")))] == [JoinClause(JoinKind.Inner, "orders", Expr.Eq(QCol("u", "id"), QCol("o", "user_id"))), JoinClause(JoinKind.Left, "products", Expr.Eq(QCol("o", "product_id"), QCol("p", "id"))), JoinClause(JoinKind.Left, "categories", Expr.Eq(QCol("p", "cat_id"), QCol("c", "id")))]
  assert [Where(Expr.Eq(Expr.Col("active"), Lit(PBool(true)))), Where(Expr.Gte(Expr.Col("age"), Lit(PInt(18)))), OrWhere(Expr.Eq(Expr.Col("role"), Lit(PString("admin"))))] == [Where(Expr.Eq(Expr.Col("active"), Lit(PBool(true)))), Where(Expr.Gte(Expr.Col("age"), Lit(PInt(18)))), OrWhere(Expr.Eq(Expr.Col("role"), Lit(PString("admin"))))]
  assert [SelectAs(Expr.Add(Expr.Col("a"), Expr.Col("b")), "sum_ab"), SelectAs(Expr.Sub(Expr.Col("c"), Expr.Col("d")), "diff_cd"), SelectAs(Expr.Mul(Expr.Col("e"), Expr.Col("f")), "prod_ef")] == [SelectAs(Expr.Add(Expr.Col("a"), Expr.Col("b")), "sum_ab"), SelectAs(Expr.Sub(Expr.Col("c"), Expr.Col("d")), "diff_cd"), SelectAs(Expr.Mul(Expr.Col("e"), Expr.Col("f")), "prod_ef")]
  assert [SelectAs(Expr.Max(Expr.Col("score")), "max_score"), SelectAs(Expr.Min(Expr.Col("score")), "min_score"), SelectAs(Avg(Expr.Col("score")), "avg_score")] == [SelectAs(Expr.Max(Expr.Col("score")), "max_score"), SelectAs(Expr.Min(Expr.Col("score")), "min_score"), SelectAs(Avg(Expr.Col("score")), "avg_score")]
  assert SelectField(Expr.Eq(Expr.Col("a"), Expr.Col("b"))) == SelectField(Expr.Eq(Expr.Col("a"), Expr.Col("b")))
  assert SelectField(Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Gt(Expr.Col("b"), Lit(PInt(0))))) == SelectField(Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Gt(Expr.Col("b"), Lit(PInt(0)))))
  assert SelectAs(Expr.Or(Expr.IsNull(Expr.Col("a")), Expr.IsNull(Expr.Col("b"))), "either_null") == SelectAs(Expr.Or(Expr.IsNull(Expr.Col("a")), Expr.IsNull(Expr.Col("b"))), "either_null")
  assert SelectAs(Expr.And(Expr.Gte(Expr.Col("score"), Lit(PInt(60))), Expr.Lte(Expr.Col("score"), Lit(PInt(100)))), "passing") == SelectAs(Expr.And(Expr.Gte(Expr.Col("score"), Lit(PInt(60))), Expr.Lte(Expr.Col("score"), Lit(PInt(100)))), "passing")
  assert SelectAs(Expr.Not(Expr.IsNull(Expr.Col("email"))), "has_email") == SelectAs(Expr.Not(Expr.IsNull(Expr.Col("email"))), "has_email")
  assert SelectAs(Between(Expr.Col("price"), Lit(PFloat(10.0)), Lit(PFloat(100.0))), "in_range") == SelectAs(Between(Expr.Col("price"), Lit(PFloat(10.0)), Lit(PFloat(100.0))), "in_range")
  assert SelectField(In(Expr.Col("status"), [Lit(PString("a")), Lit(PString("b"))])) == SelectField(In(Expr.Col("status"), [Lit(PString("a")), Lit(PString("b"))]))
  assert SelectField(FnCall("lower", [Expr.Col("email")])) == SelectField(FnCall("lower", [Expr.Col("email")]))
  assert SelectAs(FnCall("upper", [Expr.Col("code")]), "upper_code") == SelectAs(FnCall("upper", [Expr.Col("code")]), "upper_code")
  assert SelectField(Raw("CURRENT_TIMESTAMP")) == SelectField(Raw("CURRENT_TIMESTAMP"))
  assert SelectAs(Expr.Add(Expr.Count(Expr.Col("id")), Lit(PInt(0))), "n") == SelectAs(Expr.Add(Expr.Count(Expr.Col("id")), Lit(PInt(0))), "n")
end

test "exists and subquery and fncall batch" do
  let sub1 = Query({ from_ = FromTable("orders"), selects = [SelectAll], wheres = Nil, joins = Nil, orders = Nil, group_bys = Nil, havings = Nil, limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert Exists(sub1) == Exists(sub1)
  assert SubqueryExpr(sub1) == SubqueryExpr(sub1)
  let sub2 = Query({ from_ = FromTable("users"), selects = [SelectField(Expr.Col("id"))], wheres = [Where(Expr.Eq(Expr.Col("active"), Lit(PBool(true))))], joins = Nil, orders = Nil, group_bys = Nil, havings = Nil, limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert Exists(sub2) == Exists(sub2)
  assert SubqueryExpr(sub2) == SubqueryExpr(sub2)
  assert Expr.And(Expr.IsNotNull(Expr.Col("a")), Exists(sub1)) == Expr.And(Expr.IsNotNull(Expr.Col("a")), Exists(sub1))
  assert Expr.Or(Expr.Eq(Expr.Col("x"), Lit(PInt(1))), Exists(sub2)) == Expr.Or(Expr.Eq(Expr.Col("x"), Lit(PInt(1))), Exists(sub2))
  assert FnCall("now", []) == FnCall("now", [])
  assert FnCall("lower", [Expr.Col("name")]) == FnCall("lower", [Expr.Col("name")])
  assert FnCall("upper", [Expr.Col("code")]) == FnCall("upper", [Expr.Col("code")])
  assert FnCall("length", [Expr.Col("text")]) == FnCall("length", [Expr.Col("text")])
  assert FnCall("abs", [Expr.Col("val")]) == FnCall("abs", [Expr.Col("val")])
  assert FnCall("coalesce", [Expr.Col("a"), Expr.Col("b")]) == FnCall("coalesce", [Expr.Col("a"), Expr.Col("b")])
  assert FnCall("coalesce", [Expr.Col("a"), Expr.Col("b"), Lit(PString("default"))]) == FnCall("coalesce", [Expr.Col("a"), Expr.Col("b"), Lit(PString("default"))])
  assert FnCall("greatest", [Expr.Col("a"), Expr.Col("b"), Expr.Col("c")]) == FnCall("greatest", [Expr.Col("a"), Expr.Col("b"), Expr.Col("c")])
  assert FnCall("least", [Expr.Col("x"), Expr.Col("y")]) == FnCall("least", [Expr.Col("x"), Expr.Col("y")])
  assert FnCall("nullif", [Expr.Col("score"), Lit(PInt(0))]) == FnCall("nullif", [Expr.Col("score"), Lit(PInt(0))])
  assert FnCall("concat", [Expr.Col("first_name"), Lit(PString(" ")), Expr.Col("last_name")]) == FnCall("concat", [Expr.Col("first_name"), Lit(PString(" ")), Expr.Col("last_name")])
  assert Expr.Eq(FnCall("lower", [Expr.Col("email")]), Lit(PString("alice@test.com"))) == Expr.Eq(FnCall("lower", [Expr.Col("email")]), Lit(PString("alice@test.com")))
  assert Expr.Gt(FnCall("length", [Expr.Col("pwd")]), Lit(PInt(8))) == Expr.Gt(FnCall("length", [Expr.Col("pwd")]), Lit(PInt(8)))
  assert Expr.And(Expr.Gt(FnCall("length", [Expr.Col("name")]), Lit(PInt(0))), Expr.Lt(FnCall("length", [Expr.Col("name")]), Lit(PInt(100)))) == Expr.And(Expr.Gt(FnCall("length", [Expr.Col("name")]), Lit(PInt(0))), Expr.Lt(FnCall("length", [Expr.Col("name")]), Lit(PInt(100))))
  assert Expr.Eq(FnCall("coalesce", [Expr.Col("score"), Lit(PInt(0))]), Lit(PInt(0))) == Expr.Eq(FnCall("coalesce", [Expr.Col("score"), Lit(PInt(0))]), Lit(PInt(0)))
  assert SelectField(FnCall("coalesce", [Expr.Col("a"), Lit(PInt(0))])) == SelectField(FnCall("coalesce", [Expr.Col("a"), Lit(PInt(0))]))
  assert SelectAs(FnCall("concat", [Expr.Col("fn"), Lit(PString(" ")), Expr.Col("ln")]), "full_name") == SelectAs(FnCall("concat", [Expr.Col("fn"), Lit(PString(" ")), Expr.Col("ln")]), "full_name")
  assert SelectField(FnCall("now", [])) == SelectField(FnCall("now", []))
  assert SelectAs(FnCall("length", [Expr.Col("bio")]), "bio_len") == SelectAs(FnCall("length", [Expr.Col("bio")]), "bio_len")
  assert Where(Exists(sub1)) == Where(Exists(sub1))
  assert OrWhere(Exists(sub2)) == OrWhere(Exists(sub2))
  assert Where(Expr.And(Expr.IsNotNull(Expr.Col("a")), Exists(sub1))) == Where(Expr.And(Expr.IsNotNull(Expr.Col("a")), Exists(sub1)))
end

test "multi-join query constructions" do
  let q1 = Query({ from_ = FromTable("orders"), selects = [SelectField(Expr.Col("id")), SelectField(Expr.Col("total"))], wheres = [Where(Expr.Eq(Expr.Col("status"), Lit(PString("paid"))))], joins = [JoinClause(JoinKind.Inner, "users", Expr.Eq(QCol("orders", "user_id"), QCol("users", "id"))), JoinClause(JoinKind.Left, "products", Expr.Eq(QCol("orders", "product_id"), QCol("products", "id")))], orders = [OrderExpr(Expr.Col("total"), SortDir.Desc)], group_bys = [Expr.Col("user_id")], havings = [Where(Expr.Gt(Expr.Sum(Expr.Col("total")), Lit(PFloat(100.0))))], limit_ = Some(50), offset_ = Some(0), distinct_ = NoDistinct })
  assert q1 == q1
  let q2 = Query({ from_ = FromTable("users"), selects = [SelectAll], wheres = [Where(Expr.Eq(Expr.Col("active"), Lit(PBool(true)))), Where(Expr.IsNotNull(Expr.Col("email")))], joins = Nil, orders = [OrderExpr(Expr.Col("name"), SortDir.Asc), OrderExpr(Expr.Col("id"), SortDir.Desc)], group_bys = Nil, havings = Nil, limit_ = Some(10), offset_ = Some(20), distinct_ = Distinct })
  assert q2 == q2
  let q3 = Query({ from_ = FromTable("sales"), selects = [SelectField(Expr.Col("region")), SelectField(Expr.Col("category")), SelectAs(Expr.Sum(Expr.Col("amount")), "revenue"), SelectAs(Expr.Count(Expr.Col("id")), "transactions")], wheres = [Where(Expr.Gte(Expr.Col("date"), Lit(PString("2024-01-01"))))], joins = [JoinClause(JoinKind.Left, "regions", Expr.Eq(QCol("sales", "region_id"), QCol("regions", "id"))), JoinClause(JoinKind.Left, "categories", Expr.Eq(QCol("sales", "cat_id"), QCol("categories", "id")))], orders = [OrderExpr(Expr.Col("revenue"), SortDir.Desc)], group_bys = [Expr.Col("region"), Expr.Col("category")], havings = [Where(Expr.Gt(Expr.Sum(Expr.Col("amount")), Lit(PFloat(1000.0))))], limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert q3 == q3
  let q4 = Query({ from_ = FromTable("log"), selects = [SelectAll], wheres = Nil, joins = Nil, orders = [OrderExpr(Expr.Col("ts"), SortDir.Desc)], group_bys = Nil, havings = Nil, limit_ = Some(100), offset_ = None, distinct_ = NoDistinct })
  assert q4 == q4
  let q5 = Query({ from_ = FromTable("posts"), selects = [SelectField(Expr.Col("id")), SelectField(Expr.Col("title")), SelectField(Expr.Col("author_id"))], wheres = [Where(Expr.Eq(Expr.Col("published"), Lit(PBool(true)))), OrWhere(Expr.Eq(Expr.Col("featured"), Lit(PBool(true))))], joins = [JoinClause(JoinKind.Inner, "authors", Expr.Eq(QCol("posts", "author_id"), QCol("authors", "id")))], orders = [OrderExpr(Expr.Col("created_at"), SortDir.Desc)], group_bys = Nil, havings = Nil, limit_ = Some(20), offset_ = Some(0), distinct_ = NoDistinct })
  assert q5 == q5
  let q6 = Query({ from_ = FromTable("metrics"), selects = [SelectField(Expr.Col("name")), SelectAs(Avg(Expr.Col("value")), "avg_val"), SelectAs(Expr.Min(Expr.Col("value")), "min_val"), SelectAs(Expr.Max(Expr.Col("value")), "max_val")], wheres = [Where(Expr.And(Expr.Gte(Expr.Col("recorded_at"), Lit(PString("2024-01-01"))), Expr.Lte(Expr.Col("recorded_at"), Lit(PString("2024-12-31")))))], joins = Nil, orders = [OrderExpr(Expr.Col("name"), SortDir.Asc)], group_bys = [Expr.Col("name")], havings = [Where(Expr.Gt(Expr.Count(Expr.Col("id")), Lit(PInt(10))))], limit_ = None, offset_ = None, distinct_ = NoDistinct })
  assert q6 == q6
end

test "in notin between with larger lists batch" do
  assert In(Expr.Col("id"), [Lit(PInt(1)), Lit(PInt(2)), Lit(PInt(3)), Lit(PInt(4)), Lit(PInt(5))]) == In(Expr.Col("id"), [Lit(PInt(1)), Lit(PInt(2)), Lit(PInt(3)), Lit(PInt(4)), Lit(PInt(5))])
  assert In(Expr.Col("status"), [Lit(PString("active")), Lit(PString("pending")), Lit(PString("review")), Lit(PString("approved"))]) == In(Expr.Col("status"), [Lit(PString("active")), Lit(PString("pending")), Lit(PString("review")), Lit(PString("approved"))])
  assert NotIn(Expr.Col("id"), [Lit(PInt(1)), Lit(PInt(2)), Lit(PInt(3)), Lit(PInt(4)), Lit(PInt(5))]) == NotIn(Expr.Col("id"), [Lit(PInt(1)), Lit(PInt(2)), Lit(PInt(3)), Lit(PInt(4)), Lit(PInt(5))])
  assert NotIn(Expr.Col("role"), [Lit(PString("banned")), Lit(PString("suspended")), Lit(PString("deleted"))]) == NotIn(Expr.Col("role"), [Lit(PString("banned")), Lit(PString("suspended")), Lit(PString("deleted"))])
  assert Between(Expr.Col("price"), Lit(PFloat(0.0)), Lit(PFloat(999.99))) == Between(Expr.Col("price"), Lit(PFloat(0.0)), Lit(PFloat(999.99)))
  assert Between(Expr.Col("year"), Lit(PInt(2020)), Lit(PInt(2024))) == Between(Expr.Col("year"), Lit(PInt(2020)), Lit(PInt(2024)))
  assert Between(QCol("o", "amount"), Lit(PFloat(10.0)), Lit(PFloat(1000.0))) == Between(QCol("o", "amount"), Lit(PFloat(10.0)), Lit(PFloat(1000.0)))
  assert Expr.And(In(Expr.Col("status"), [Lit(PString("a")), Lit(PString("b"))]), Between(Expr.Col("score"), Lit(PInt(0)), Lit(PInt(100)))) == Expr.And(In(Expr.Col("status"), [Lit(PString("a")), Lit(PString("b"))]), Between(Expr.Col("score"), Lit(PInt(0)), Lit(PInt(100))))
  assert Expr.Or(In(Expr.Col("cat"), [Lit(PString("x")), Lit(PString("y"))]), NotIn(Expr.Col("cat"), [Lit(PString("z"))])) == Expr.Or(In(Expr.Col("cat"), [Lit(PString("x")), Lit(PString("y"))]), NotIn(Expr.Col("cat"), [Lit(PString("z"))]))
  assert Expr.And(Between(Expr.Col("age"), Lit(PInt(18)), Lit(PInt(65))), NotIn(Expr.Col("role"), [Lit(PString("blocked"))])) == Expr.And(Between(Expr.Col("age"), Lit(PInt(18)), Lit(PInt(65))), NotIn(Expr.Col("role"), [Lit(PString("blocked"))]))
  assert Expr.Not(In(Expr.Col("id"), [Lit(PInt(1)), Lit(PInt(2)), Lit(PInt(3))])) == Expr.Not(In(Expr.Col("id"), [Lit(PInt(1)), Lit(PInt(2)), Lit(PInt(3))]))
  assert Expr.Not(NotIn(Expr.Col("status"), [Lit(PString("active")), Lit(PString("pending"))])) == Expr.Not(NotIn(Expr.Col("status"), [Lit(PString("active")), Lit(PString("pending"))]))
  assert Expr.Not(Between(Expr.Col("score"), Lit(PInt(0)), Lit(PInt(50)))) == Expr.Not(Between(Expr.Col("score"), Lit(PInt(0)), Lit(PInt(50))))
  assert Where(In(Expr.Col("id"), [Lit(PInt(1)), Lit(PInt(2)), Lit(PInt(3))])) == Where(In(Expr.Col("id"), [Lit(PInt(1)), Lit(PInt(2)), Lit(PInt(3))]))
  assert OrWhere(NotIn(Expr.Col("status"), [Lit(PString("deleted")), Lit(PString("banned"))])) == OrWhere(NotIn(Expr.Col("status"), [Lit(PString("deleted")), Lit(PString("banned"))]))
  assert OrWhere(Between(Expr.Col("score"), Lit(PInt(70)), Lit(PInt(100)))) == OrWhere(Between(Expr.Col("score"), Lit(PInt(70)), Lit(PInt(100))))
  assert SelectField(In(Expr.Col("role"), [Lit(PString("a")), Lit(PString("b"))])) == SelectField(In(Expr.Col("role"), [Lit(PString("a")), Lit(PString("b"))]))
  assert SelectAs(Between(Expr.Col("price"), Lit(PFloat(1.0)), Lit(PFloat(100.0))), "in_range") == SelectAs(Between(Expr.Col("price"), Lit(PFloat(1.0)), Lit(PFloat(100.0))), "in_range")
  assert Expr.And(In(Expr.Col("a"), [Lit(PInt(1))]), Expr.And(In(Expr.Col("b"), [Lit(PInt(2))]), In(Expr.Col("c"), [Lit(PInt(3))]))) == Expr.And(In(Expr.Col("a"), [Lit(PInt(1))]), Expr.And(In(Expr.Col("b"), [Lit(PInt(2))]), In(Expr.Col("c"), [Lit(PInt(3))])))
  assert Expr.Or(Between(Expr.Col("x"), Lit(PInt(0)), Lit(PInt(10))), Between(Expr.Col("x"), Lit(PInt(90)), Lit(PInt(100)))) == Expr.Or(Between(Expr.Col("x"), Lit(PInt(0)), Lit(PInt(10))), Between(Expr.Col("x"), Lit(PInt(90)), Lit(PInt(100))))
  assert In(QCol("u", "status"), [Lit(PString("active")), Lit(PString("trial"))]) == In(QCol("u", "status"), [Lit(PString("active")), Lit(PString("trial"))])
  assert NotIn(QCol("p", "category"), [Lit(PString("archived")), Lit(PString("draft"))]) == NotIn(QCol("p", "category"), [Lit(PString("archived")), Lit(PString("draft"))])
end

test "mixed aggregate and arithmetic in queries" do
  assert Expr.Gt(Expr.Sum(Expr.Col("amount")), Lit(PFloat(0.0))) == Expr.Gt(Expr.Sum(Expr.Col("amount")), Lit(PFloat(0.0)))
  assert Expr.Gte(Expr.Count(Expr.Col("id")), Lit(PInt(1))) == Expr.Gte(Expr.Count(Expr.Col("id")), Lit(PInt(1)))
  assert Expr.Lt(Avg(Expr.Col("score")), Lit(PFloat(5.0))) == Expr.Lt(Avg(Expr.Col("score")), Lit(PFloat(5.0)))
  assert Expr.Lte(Expr.Max(Expr.Col("price")), Lit(PFloat(999.99))) == Expr.Lte(Expr.Max(Expr.Col("price")), Lit(PFloat(999.99)))
  assert Expr.Neq(Expr.Min(Expr.Col("stock")), Lit(PInt(0))) == Expr.Neq(Expr.Min(Expr.Col("stock")), Lit(PInt(0)))
  assert Expr.Eq(Expr.Sum(Expr.Col("a")), Expr.Add(Expr.Sum(Expr.Col("b")), Expr.Sum(Expr.Col("c")))) == Expr.Eq(Expr.Sum(Expr.Col("a")), Expr.Add(Expr.Sum(Expr.Col("b")), Expr.Sum(Expr.Col("c"))))
  assert Expr.Gt(Expr.Sub(Expr.Max(Expr.Col("val")), Expr.Min(Expr.Col("val"))), Lit(PInt(0))) == Expr.Gt(Expr.Sub(Expr.Max(Expr.Col("val")), Expr.Min(Expr.Col("val"))), Lit(PInt(0)))
  assert Expr.Gte(Expr.Div(Expr.Count(Expr.Col("active")), Expr.Count(Expr.Col("id"))), Lit(PFloat(0.5))) == Expr.Gte(Expr.Div(Expr.Count(Expr.Col("active")), Expr.Count(Expr.Col("id"))), Lit(PFloat(0.5)))
  assert Expr.And(Expr.Gt(Expr.Count(Expr.Col("id")), Lit(PInt(0))), Expr.Gt(Expr.Sum(Expr.Col("amount")), Lit(PFloat(0.0)))) == Expr.And(Expr.Gt(Expr.Count(Expr.Col("id")), Lit(PInt(0))), Expr.Gt(Expr.Sum(Expr.Col("amount")), Lit(PFloat(0.0))))
  assert Expr.Or(Expr.Gt(Expr.Sum(Expr.Col("revenue")), Lit(PFloat(1000.0))), Expr.And(Expr.Gte(Expr.Count(Expr.Col("orders")), Lit(PInt(10))), Expr.Gt(Avg(Expr.Col("value")), Lit(PFloat(100.0))))) == Expr.Or(Expr.Gt(Expr.Sum(Expr.Col("revenue")), Lit(PFloat(1000.0))), Expr.And(Expr.Gte(Expr.Count(Expr.Col("orders")), Lit(PInt(10))), Expr.Gt(Avg(Expr.Col("value")), Lit(PFloat(100.0)))))
  assert SelectAs(Expr.Add(Expr.Sum(Expr.Col("a")), Expr.Sum(Expr.Col("b"))), "total_sum") == SelectAs(Expr.Add(Expr.Sum(Expr.Col("a")), Expr.Sum(Expr.Col("b"))), "total_sum")
  assert SelectAs(Expr.Sub(Expr.Max(Expr.Col("high")), Expr.Min(Expr.Col("low"))), "spread") == SelectAs(Expr.Sub(Expr.Max(Expr.Col("high")), Expr.Min(Expr.Col("low"))), "spread")
  assert SelectAs(Expr.Div(Expr.Sum(Expr.Col("total")), Expr.Count(Expr.Col("id"))), "avg_manual") == SelectAs(Expr.Div(Expr.Sum(Expr.Col("total")), Expr.Count(Expr.Col("id"))), "avg_manual")
  assert SelectAs(Expr.Mul(Avg(Expr.Col("rating")), Lit(PInt(100))), "pct_rating") == SelectAs(Expr.Mul(Avg(Expr.Col("rating")), Lit(PInt(100))), "pct_rating")
  assert SelectAs(Expr.Sub(Lit(PInt(100)), Avg(Expr.Col("discount_pct"))), "avg_effective") == SelectAs(Expr.Sub(Lit(PInt(100)), Avg(Expr.Col("discount_pct"))), "avg_effective")
  assert [SelectAs(Expr.Sum(Expr.Col("a")), "sum_a"), SelectAs(Avg(Expr.Col("b")), "avg_b"), SelectAs(Expr.Count(Expr.Col("c")), "cnt_c"), SelectAs(Expr.Min(Expr.Col("d")), "min_d"), SelectAs(Expr.Max(Expr.Col("e")), "max_e")] == [SelectAs(Expr.Sum(Expr.Col("a")), "sum_a"), SelectAs(Avg(Expr.Col("b")), "avg_b"), SelectAs(Expr.Count(Expr.Col("c")), "cnt_c"), SelectAs(Expr.Min(Expr.Col("d")), "min_d"), SelectAs(Expr.Max(Expr.Col("e")), "max_e")]
  assert Where(Expr.Gt(Expr.Sum(Expr.Col("amount")), Lit(PFloat(100.0)))) == Where(Expr.Gt(Expr.Sum(Expr.Col("amount")), Lit(PFloat(100.0))))
  assert Where(Expr.Gte(Expr.Count(Expr.Col("id")), Lit(PInt(5)))) == Where(Expr.Gte(Expr.Count(Expr.Col("id")), Lit(PInt(5))))
  assert OrWhere(Expr.Gt(Avg(Expr.Col("score")), Lit(PFloat(4.0)))) == OrWhere(Expr.Gt(Avg(Expr.Col("score")), Lit(PFloat(4.0))))
  assert Expr.Gt(Expr.Add(Expr.Sum(Expr.Col("a")), Avg(Expr.Col("b"))), Lit(PFloat(0.0))) == Expr.Gt(Expr.Add(Expr.Sum(Expr.Col("a")), Avg(Expr.Col("b"))), Lit(PFloat(0.0)))
  assert Expr.Eq(Expr.Mul(Expr.Count(Expr.Col("id")), Lit(PInt(2))), Lit(PInt(10))) == Expr.Eq(Expr.Mul(Expr.Count(Expr.Col("id")), Lit(PInt(2))), Lit(PInt(10)))
  assert CountAll == CountAll
  assert Expr.Gt(CountAll, Lit(PInt(0))) == Expr.Gt(CountAll, Lit(PInt(0)))
  assert Expr.And(Expr.Gt(CountAll, Lit(PInt(5))), Expr.Lt(CountAll, Lit(PInt(100)))) == Expr.And(Expr.Gt(CountAll, Lit(PInt(5))), Expr.Lt(CountAll, Lit(PInt(100))))
  assert SelectAs(CountAll, "total_rows") == SelectAs(CountAll, "total_rows")
  assert Where(Expr.Gt(CountAll, Lit(PInt(0)))) == Where(Expr.Gt(CountAll, Lit(PInt(0))))
end

test "qcol and cross-table expressions batch" do
  assert Expr.Eq(QCol("a", "id"), QCol("b", "a_id")) == Expr.Eq(QCol("a", "id"), QCol("b", "a_id"))
  assert Expr.Eq(QCol("orders", "user_id"), QCol("users", "id")) == Expr.Eq(QCol("orders", "user_id"), QCol("users", "id"))
  assert Expr.Eq(QCol("posts", "author_id"), QCol("authors", "id")) == Expr.Eq(QCol("posts", "author_id"), QCol("authors", "id"))
  assert Expr.Eq(QCol("items", "order_id"), QCol("orders", "id")) == Expr.Eq(QCol("items", "order_id"), QCol("orders", "id"))
  assert Expr.Eq(QCol("comments", "post_id"), QCol("posts", "id")) == Expr.Eq(QCol("comments", "post_id"), QCol("posts", "id"))
  assert Expr.And(Expr.Eq(QCol("u", "id"), QCol("o", "user_id")), Expr.Eq(QCol("u", "active"), Lit(PBool(true)))) == Expr.And(Expr.Eq(QCol("u", "id"), QCol("o", "user_id")), Expr.Eq(QCol("u", "active"), Lit(PBool(true))))
  assert Expr.And(Expr.Eq(QCol("o", "product_id"), QCol("p", "id")), Expr.Gt(QCol("p", "stock"), Lit(PInt(0)))) == Expr.And(Expr.Eq(QCol("o", "product_id"), QCol("p", "id")), Expr.Gt(QCol("p", "stock"), Lit(PInt(0))))
  assert Expr.Or(Expr.Eq(QCol("u", "role"), Lit(PString("admin"))), Expr.Eq(QCol("u", "role"), Lit(PString("superuser")))) == Expr.Or(Expr.Eq(QCol("u", "role"), Lit(PString("admin"))), Expr.Eq(QCol("u", "role"), Lit(PString("superuser"))))
  assert Expr.Gt(QCol("o", "total"), Lit(PFloat(0.0))) == Expr.Gt(QCol("o", "total"), Lit(PFloat(0.0)))
  assert Expr.Lt(QCol("p", "price"), Lit(PFloat(100.0))) == Expr.Lt(QCol("p", "price"), Lit(PFloat(100.0)))
  assert Expr.IsNull(QCol("u", "deleted_at")) == Expr.IsNull(QCol("u", "deleted_at"))
  assert Expr.IsNotNull(QCol("u", "confirmed_at")) == Expr.IsNotNull(QCol("u", "confirmed_at"))
  assert Like(QCol("u", "name"), "Alice%") == Like(QCol("u", "name"), "Alice%")
  assert ILike(QCol("p", "title"), "%sale%") == ILike(QCol("p", "title"), "%sale%")
  assert Between(QCol("o", "amount"), Lit(PFloat(10.0)), Lit(PFloat(1000.0))) == Between(QCol("o", "amount"), Lit(PFloat(10.0)), Lit(PFloat(1000.0)))
  assert In(QCol("u", "status"), [Lit(PString("active")), Lit(PString("pending"))]) == In(QCol("u", "status"), [Lit(PString("active")), Lit(PString("pending"))])
  assert NotIn(QCol("p", "category"), [Lit(PString("archived"))]) == NotIn(QCol("p", "category"), [Lit(PString("archived"))])
  assert Expr.Add(QCol("o", "subtotal"), QCol("o", "tax")) == Expr.Add(QCol("o", "subtotal"), QCol("o", "tax"))
  assert Expr.Sub(QCol("o", "total"), QCol("o", "discount")) == Expr.Sub(QCol("o", "total"), QCol("o", "discount"))
  assert Expr.Mul(QCol("i", "qty"), QCol("i", "price")) == Expr.Mul(QCol("i", "qty"), QCol("i", "price"))
  assert Expr.Div(QCol("m", "numerator"), QCol("m", "denominator")) == Expr.Div(QCol("m", "numerator"), QCol("m", "denominator"))
  assert Expr.Count(QCol("o", "id")) == Expr.Count(QCol("o", "id"))
  assert Expr.Sum(QCol("o", "amount")) == Expr.Sum(QCol("o", "amount"))
  assert Avg(QCol("r", "score")) == Avg(QCol("r", "score"))
  assert Expr.Min(QCol("p", "price")) == Expr.Min(QCol("p", "price"))
  assert Expr.Max(QCol("e", "salary")) == Expr.Max(QCol("e", "salary"))
  assert JoinClause(JoinKind.Inner, "categories", Expr.And(Expr.Eq(QCol("p", "cat_id"), QCol("c", "id")), Expr.Eq(QCol("c", "active"), Lit(PBool(true))))) == JoinClause(JoinKind.Inner, "categories", Expr.And(Expr.Eq(QCol("p", "cat_id"), QCol("c", "id")), Expr.Eq(QCol("c", "active"), Lit(PBool(true)))))
  assert JoinClause(JoinKind.Left, "settings", Expr.Or(Expr.Eq(QCol("u", "id"), QCol("s", "user_id")), Expr.IsNull(QCol("s", "user_id")))) == JoinClause(JoinKind.Left, "settings", Expr.Or(Expr.Eq(QCol("u", "id"), QCol("s", "user_id")), Expr.IsNull(QCol("s", "user_id"))))
  assert SelectField(Expr.Add(QCol("a", "x"), QCol("b", "y"))) == SelectField(Expr.Add(QCol("a", "x"), QCol("b", "y")))
  assert SelectAs(Expr.Mul(QCol("i", "qty"), QCol("p", "price")), "line_total") == SelectAs(Expr.Mul(QCol("i", "qty"), QCol("p", "price")), "line_total")
  assert OrderExpr(QCol("u", "created_at"), SortDir.Desc) == OrderExpr(QCol("u", "created_at"), SortDir.Desc)
end

-- ---- Dense coverage batch 3: even more nodes ----

test "comprehensive eq neq comparisons extended" do
  assert Expr.Eq(Expr.Col("a"), Lit(PInt(1))) == Expr.Eq(Expr.Col("a"), Lit(PInt(1)))
  assert Expr.Eq(Expr.Col("b"), Lit(PInt(2))) == Expr.Eq(Expr.Col("b"), Lit(PInt(2)))
  assert Expr.Eq(Expr.Col("c"), Lit(PInt(3))) == Expr.Eq(Expr.Col("c"), Lit(PInt(3)))
  assert Expr.Eq(Expr.Col("d"), Lit(PString("x"))) == Expr.Eq(Expr.Col("d"), Lit(PString("x")))
  assert Expr.Eq(Expr.Col("e"), Lit(PString("y"))) == Expr.Eq(Expr.Col("e"), Lit(PString("y")))
  assert Expr.Eq(Expr.Col("f"), Lit(PBool(true))) == Expr.Eq(Expr.Col("f"), Lit(PBool(true)))
  assert Expr.Eq(Expr.Col("g"), Lit(PBool(false))) == Expr.Eq(Expr.Col("g"), Lit(PBool(false)))
  assert Expr.Eq(Expr.Col("h"), Lit(PFloat(1.5))) == Expr.Eq(Expr.Col("h"), Lit(PFloat(1.5)))
  assert Expr.Neq(Expr.Col("a"), Lit(PInt(0))) == Expr.Neq(Expr.Col("a"), Lit(PInt(0)))
  assert Expr.Neq(Expr.Col("b"), Lit(PString(""))) == Expr.Neq(Expr.Col("b"), Lit(PString("")))
  assert Expr.Neq(Expr.Col("c"), Lit(PBool(false))) == Expr.Neq(Expr.Col("c"), Lit(PBool(false)))
  assert Expr.Neq(Expr.Col("d"), Lit(PNull)) == Expr.Neq(Expr.Col("d"), Lit(PNull))
  assert Expr.Gt(Expr.Col("score"), Lit(PInt(100))) == Expr.Gt(Expr.Col("score"), Lit(PInt(100)))
  assert Expr.Gt(Expr.Col("price"), Lit(PFloat(9.99))) == Expr.Gt(Expr.Col("price"), Lit(PFloat(9.99)))
  assert Expr.Gte(Expr.Col("age"), Lit(PInt(21))) == Expr.Gte(Expr.Col("age"), Lit(PInt(21)))
  assert Expr.Gte(Expr.Col("weight"), Lit(PFloat(0.0))) == Expr.Gte(Expr.Col("weight"), Lit(PFloat(0.0)))
  assert Expr.Lt(Expr.Col("retries"), Lit(PInt(3))) == Expr.Lt(Expr.Col("retries"), Lit(PInt(3)))
  assert Expr.Lt(Expr.Col("temp"), Lit(PFloat(37.0))) == Expr.Lt(Expr.Col("temp"), Lit(PFloat(37.0)))
  assert Expr.Lte(Expr.Col("count"), Lit(PInt(1000))) == Expr.Lte(Expr.Col("count"), Lit(PInt(1000)))
  assert Expr.Lte(Expr.Col("ratio"), Lit(PFloat(1.0))) == Expr.Lte(Expr.Col("ratio"), Lit(PFloat(1.0)))
  assert Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Neq(Expr.Col("b"), Lit(PInt(0)))) == Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Neq(Expr.Col("b"), Lit(PInt(0))))
  assert Expr.And(Expr.Gt(Expr.Col("x"), Lit(PFloat(0.0))), Expr.Lt(Expr.Col("x"), Lit(PFloat(1.0)))) == Expr.And(Expr.Gt(Expr.Col("x"), Lit(PFloat(0.0))), Expr.Lt(Expr.Col("x"), Lit(PFloat(1.0))))
  assert Expr.Or(Expr.Gte(Expr.Col("score"), Lit(PInt(90))), Expr.And(Expr.Gte(Expr.Col("score"), Lit(PInt(70))), Expr.Eq(Expr.Col("bonus"), Lit(PBool(true))))) == Expr.Or(Expr.Gte(Expr.Col("score"), Lit(PInt(90))), Expr.And(Expr.Gte(Expr.Col("score"), Lit(PInt(70))), Expr.Eq(Expr.Col("bonus"), Lit(PBool(true)))))
  assert Expr.Not(Expr.Eq(Expr.Col("status"), Lit(PString("archived")))) == Expr.Not(Expr.Eq(Expr.Col("status"), Lit(PString("archived"))))
  assert Expr.And(Expr.IsNotNull(Expr.Col("email")), Expr.And(Expr.IsNotNull(Expr.Col("name")), Expr.IsNotNull(Expr.Col("phone")))) == Expr.And(Expr.IsNotNull(Expr.Col("email")), Expr.And(Expr.IsNotNull(Expr.Col("name")), Expr.IsNotNull(Expr.Col("phone"))))
  assert Expr.Or(Expr.IsNull(Expr.Col("a")), Expr.Or(Expr.IsNull(Expr.Col("b")), Expr.Or(Expr.IsNull(Expr.Col("c")), Expr.IsNull(Expr.Col("d"))))) == Expr.Or(Expr.IsNull(Expr.Col("a")), Expr.Or(Expr.IsNull(Expr.Col("b")), Expr.Or(Expr.IsNull(Expr.Col("c")), Expr.IsNull(Expr.Col("d")))))
  assert Expr.And(Expr.Gte(Expr.Col("created_at"), Lit(PString("2024-01-01"))), Expr.Lte(Expr.Col("created_at"), Lit(PString("2024-12-31")))) == Expr.And(Expr.Gte(Expr.Col("created_at"), Lit(PString("2024-01-01"))), Expr.Lte(Expr.Col("created_at"), Lit(PString("2024-12-31"))))
  assert Expr.Eq(Expr.Add(Expr.Col("a"), Expr.Col("b")), Expr.Add(Expr.Col("c"), Expr.Col("d"))) == Expr.Eq(Expr.Add(Expr.Col("a"), Expr.Col("b")), Expr.Add(Expr.Col("c"), Expr.Col("d")))
  assert Expr.Gt(Expr.Mul(Expr.Col("qty"), Expr.Col("price")), Expr.Mul(Expr.Col("min_qty"), Expr.Col("min_price"))) == Expr.Gt(Expr.Mul(Expr.Col("qty"), Expr.Col("price")), Expr.Mul(Expr.Col("min_qty"), Expr.Col("min_price")))
  assert Expr.And(Expr.Eq(Expr.Col("type"), Lit(PString("order"))), Expr.And(Expr.Gt(Expr.Col("total"), Lit(PFloat(0.0))), Expr.And(Expr.IsNotNull(Expr.Col("user_id")), Expr.Eq(Expr.Col("status"), Lit(PString("paid")))))) == Expr.And(Expr.Eq(Expr.Col("type"), Lit(PString("order"))), Expr.And(Expr.Gt(Expr.Col("total"), Lit(PFloat(0.0))), Expr.And(Expr.IsNotNull(Expr.Col("user_id")), Expr.Eq(Expr.Col("status"), Lit(PString("paid"))))))
end

test "long select lists and order lists" do
  assert [SelectField(Expr.Col("id")), SelectField(Expr.Col("name")), SelectField(Expr.Col("email")), SelectField(Expr.Col("phone")), SelectField(Expr.Col("address")), SelectField(Expr.Col("city")), SelectField(Expr.Col("country")), SelectField(Expr.Col("zip"))] == [SelectField(Expr.Col("id")), SelectField(Expr.Col("name")), SelectField(Expr.Col("email")), SelectField(Expr.Col("phone")), SelectField(Expr.Col("address")), SelectField(Expr.Col("city")), SelectField(Expr.Col("country")), SelectField(Expr.Col("zip"))]
  assert [SelectField(Expr.Col("a")), SelectField(Expr.Col("b")), SelectField(Expr.Col("c")), SelectField(Expr.Col("d")), SelectField(Expr.Col("e"))] == [SelectField(Expr.Col("a")), SelectField(Expr.Col("b")), SelectField(Expr.Col("c")), SelectField(Expr.Col("d")), SelectField(Expr.Col("e"))]
  assert [SelectAs(Expr.Col("id"), "uid"), SelectAs(Expr.Col("name"), "uname"), SelectAs(Expr.Col("email"), "uemail"), SelectAs(Expr.Col("created_at"), "joined")] == [SelectAs(Expr.Col("id"), "uid"), SelectAs(Expr.Col("name"), "uname"), SelectAs(Expr.Col("email"), "uemail"), SelectAs(Expr.Col("created_at"), "joined")]
  assert [OrderExpr(Expr.Col("name"), SortDir.Asc), OrderExpr(Expr.Col("age"), SortDir.Desc), OrderExpr(Expr.Col("score"), SortDir.Desc), OrderExpr(Expr.Col("id"), SortDir.Asc)] == [OrderExpr(Expr.Col("name"), SortDir.Asc), OrderExpr(Expr.Col("age"), SortDir.Desc), OrderExpr(Expr.Col("score"), SortDir.Desc), OrderExpr(Expr.Col("id"), SortDir.Asc)]
  assert [OrderExpr(Expr.Col("a"), AscNullsFirst), OrderExpr(Expr.Col("b"), AscNullsLast), OrderExpr(Expr.Col("c"), DescNullsFirst), OrderExpr(Expr.Col("d"), DescNullsLast)] == [OrderExpr(Expr.Col("a"), AscNullsFirst), OrderExpr(Expr.Col("b"), AscNullsLast), OrderExpr(Expr.Col("c"), DescNullsFirst), OrderExpr(Expr.Col("d"), DescNullsLast)]
  assert [Expr.Col("year"), Expr.Col("month"), Expr.Col("day"), Expr.Col("hour"), Expr.Col("minute")] == [Expr.Col("year"), Expr.Col("month"), Expr.Col("day"), Expr.Col("hour"), Expr.Col("minute")]
  assert [Where(Expr.Eq(Expr.Col("a"), Lit(PInt(1)))), Where(Expr.Eq(Expr.Col("b"), Lit(PInt(2)))), Where(Expr.Eq(Expr.Col("c"), Lit(PInt(3)))), OrWhere(Expr.Eq(Expr.Col("d"), Lit(PInt(4))))] == [Where(Expr.Eq(Expr.Col("a"), Lit(PInt(1)))), Where(Expr.Eq(Expr.Col("b"), Lit(PInt(2)))), Where(Expr.Eq(Expr.Col("c"), Lit(PInt(3)))), OrWhere(Expr.Eq(Expr.Col("d"), Lit(PInt(4))))]
  assert [JoinClause(JoinKind.Inner, "a", Expr.Eq(Expr.Col("aid"), Expr.Col("id"))), JoinClause(JoinKind.Left, "b", Expr.Eq(Expr.Col("bid"), Expr.Col("id"))), JoinClause(JoinKind.Right, "c", Expr.Eq(Expr.Col("cid"), Expr.Col("id"))), JoinClause(FullOuter, "d", Expr.Eq(Expr.Col("did"), Expr.Col("id")))] == [JoinClause(JoinKind.Inner, "a", Expr.Eq(Expr.Col("aid"), Expr.Col("id"))), JoinClause(JoinKind.Left, "b", Expr.Eq(Expr.Col("bid"), Expr.Col("id"))), JoinClause(JoinKind.Right, "c", Expr.Eq(Expr.Col("cid"), Expr.Col("id"))), JoinClause(FullOuter, "d", Expr.Eq(Expr.Col("did"), Expr.Col("id")))]
  assert [SelectAs(Expr.Count(Expr.Col("id")), "total"), SelectAs(Expr.Sum(Expr.Col("amount")), "revenue"), SelectAs(Avg(Expr.Col("rating")), "avg_rating"), SelectAs(Expr.Min(Expr.Col("price")), "min_price"), SelectAs(Expr.Max(Expr.Col("price")), "max_price")] == [SelectAs(Expr.Count(Expr.Col("id")), "total"), SelectAs(Expr.Sum(Expr.Col("amount")), "revenue"), SelectAs(Avg(Expr.Col("rating")), "avg_rating"), SelectAs(Expr.Min(Expr.Col("price")), "min_price"), SelectAs(Expr.Max(Expr.Col("price")), "max_price")]
  assert [SelectField(Expr.Add(Expr.Col("a"), Expr.Col("b"))), SelectField(Expr.Sub(Expr.Col("c"), Expr.Col("d"))), SelectField(Expr.Mul(Expr.Col("e"), Expr.Col("f"))), SelectField(Expr.Div(Expr.Col("g"), Expr.Col("h")))] == [SelectField(Expr.Add(Expr.Col("a"), Expr.Col("b"))), SelectField(Expr.Sub(Expr.Col("c"), Expr.Col("d"))), SelectField(Expr.Mul(Expr.Col("e"), Expr.Col("f"))), SelectField(Expr.Div(Expr.Col("g"), Expr.Col("h")))]
  assert [SelectAs(FnCall("lower", [Expr.Col("email")]), "lower_email"), SelectAs(FnCall("upper", [Expr.Col("code")]), "upper_code"), SelectAs(FnCall("length", [Expr.Col("name")]), "name_len")] == [SelectAs(FnCall("lower", [Expr.Col("email")]), "lower_email"), SelectAs(FnCall("upper", [Expr.Col("code")]), "upper_code"), SelectAs(FnCall("length", [Expr.Col("name")]), "name_len")]
  assert [SelectField(Expr.Eq(Expr.Col("a"), Expr.Col("b"))), SelectField(Expr.Gt(Expr.Col("c"), Lit(PInt(0)))), SelectField(Expr.IsNull(Expr.Col("d")))] == [SelectField(Expr.Eq(Expr.Col("a"), Expr.Col("b"))), SelectField(Expr.Gt(Expr.Col("c"), Lit(PInt(0)))), SelectField(Expr.IsNull(Expr.Col("d")))]
  assert [Expr.Col("a"), Expr.Col("b"), Expr.Col("c"), Expr.Col("d"), Expr.Col("e"), Expr.Col("f")] == [Expr.Col("a"), Expr.Col("b"), Expr.Col("c"), Expr.Col("d"), Expr.Col("e"), Expr.Col("f")]
  assert [QCol("u", "id"), QCol("o", "id"), QCol("p", "id"), QCol("c", "id")] == [QCol("u", "id"), QCol("o", "id"), QCol("p", "id"), QCol("c", "id")]
  assert [ExprParam(1), ExprParam(2), ExprParam(3), ExprParam(4), ExprParam(5)] == [ExprParam(1), ExprParam(2), ExprParam(3), ExprParam(4), ExprParam(5)]
  assert [Raw("NOW()"), Raw("CURRENT_DATE"), Raw("CURRENT_TIMESTAMP")] == [Raw("NOW()"), Raw("CURRENT_DATE"), Raw("CURRENT_TIMESTAMP")]
  assert [Where(Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Gt(Expr.Col("b"), Lit(PInt(0))))), Where(Expr.IsNotNull(Expr.Col("c"))), OrWhere(In(Expr.Col("status"), [Lit(PString("x")), Lit(PString("y"))]))] == [Where(Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.Gt(Expr.Col("b"), Lit(PInt(0))))), Where(Expr.IsNotNull(Expr.Col("c"))), OrWhere(In(Expr.Col("status"), [Lit(PString("x")), Lit(PString("y"))]))]
end

test "raw and expr param in context batch" do
  assert Expr.Eq(Raw("NOW()"), Expr.Col("updated_at")) == Expr.Eq(Raw("NOW()"), Expr.Col("updated_at"))
  assert Expr.Lt(Expr.Col("expires_at"), Raw("NOW()")) == Expr.Lt(Expr.Col("expires_at"), Raw("NOW()"))
  assert Expr.Gt(Raw("CURRENT_DATE"), Expr.Col("start_date")) == Expr.Gt(Raw("CURRENT_DATE"), Expr.Col("start_date"))
  assert Expr.And(Expr.Eq(Expr.Col("a"), ExprParam(1)), Expr.Eq(Expr.Col("b"), ExprParam(2))) == Expr.And(Expr.Eq(Expr.Col("a"), ExprParam(1)), Expr.Eq(Expr.Col("b"), ExprParam(2)))
  assert Expr.Or(Expr.Eq(Expr.Col("x"), ExprParam(3)), Expr.Eq(Expr.Col("y"), ExprParam(4))) == Expr.Or(Expr.Eq(Expr.Col("x"), ExprParam(3)), Expr.Eq(Expr.Col("y"), ExprParam(4)))
  assert Expr.Gt(Expr.Col("score"), ExprParam(1)) == Expr.Gt(Expr.Col("score"), ExprParam(1))
  assert Expr.Gte(Expr.Col("age"), ExprParam(2)) == Expr.Gte(Expr.Col("age"), ExprParam(2))
  assert Expr.Lt(Expr.Col("retries"), ExprParam(3)) == Expr.Lt(Expr.Col("retries"), ExprParam(3))
  assert Between(Expr.Col("val"), ExprParam(1), ExprParam(2)) == Between(Expr.Col("val"), ExprParam(1), ExprParam(2))
  assert In(Expr.Col("id"), [ExprParam(1), ExprParam(2), ExprParam(3)]) == In(Expr.Col("id"), [ExprParam(1), ExprParam(2), ExprParam(3)])
  assert Expr.And(Expr.Eq(Expr.Col("a"), ExprParam(1)), Expr.And(Expr.Eq(Expr.Col("b"), ExprParam(2)), Expr.Eq(Expr.Col("c"), ExprParam(3)))) == Expr.And(Expr.Eq(Expr.Col("a"), ExprParam(1)), Expr.And(Expr.Eq(Expr.Col("b"), ExprParam(2)), Expr.Eq(Expr.Col("c"), ExprParam(3))))
  assert Where(Expr.Eq(Expr.Col("id"), ExprParam(1))) == Where(Expr.Eq(Expr.Col("id"), ExprParam(1)))
  assert Where(Expr.And(Expr.Eq(Expr.Col("user_id"), ExprParam(1)), Expr.Eq(Expr.Col("status"), ExprParam(2)))) == Where(Expr.And(Expr.Eq(Expr.Col("user_id"), ExprParam(1)), Expr.Eq(Expr.Col("status"), ExprParam(2))))
  assert OrWhere(Expr.Gt(Expr.Col("score"), ExprParam(5))) == OrWhere(Expr.Gt(Expr.Col("score"), ExprParam(5)))
  assert SelectField(ExprParam(1)) == SelectField(ExprParam(1))
  assert SelectAs(ExprParam(1), "param_val") == SelectAs(ExprParam(1), "param_val")
  assert SelectField(Raw("NOW()")) == SelectField(Raw("NOW()"))
  assert SelectAs(Raw("CURRENT_DATE"), "today") == SelectAs(Raw("CURRENT_DATE"), "today")
  assert Expr.Eq(FnCall("coalesce", [Expr.Col("a"), ExprParam(1)]), ExprParam(2)) == Expr.Eq(FnCall("coalesce", [Expr.Col("a"), ExprParam(1)]), ExprParam(2))
  assert Expr.And(Expr.Gte(Expr.Col("a"), ExprParam(1)), Expr.Lte(Expr.Col("a"), ExprParam(2))) == Expr.And(Expr.Gte(Expr.Col("a"), ExprParam(1)), Expr.Lte(Expr.Col("a"), ExprParam(2)))
  assert Expr.Or(In(Expr.Col("status"), [ExprParam(1), ExprParam(2)]), Expr.Eq(Expr.Col("override"), Lit(PBool(true)))) == Expr.Or(In(Expr.Col("status"), [ExprParam(1), ExprParam(2)]), Expr.Eq(Expr.Col("override"), Lit(PBool(true))))
  assert JoinClause(JoinKind.Inner, "t", Expr.Eq(Expr.Col("id"), ExprParam(1))) == JoinClause(JoinKind.Inner, "t", Expr.Eq(Expr.Col("id"), ExprParam(1)))
  assert OrderExpr(Raw("score DESC NULLS LAST"), SortDir.Asc) == OrderExpr(Raw("score DESC NULLS LAST"), SortDir.Asc)
  assert FnCall("to_char", [Expr.Col("created_at"), Lit(PString("YYYY-MM-DD"))]) == FnCall("to_char", [Expr.Col("created_at"), Lit(PString("YYYY-MM-DD"))])
  assert FnCall("date_trunc", [Lit(PString("month")), Expr.Col("created_at")]) == FnCall("date_trunc", [Lit(PString("month")), Expr.Col("created_at")])
  assert FnCall("extract", [Lit(PString("year")), Expr.Col("created_at")]) == FnCall("extract", [Lit(PString("year")), Expr.Col("created_at")])
  assert FnCall("array_length", [Expr.Col("tags"), Lit(PInt(1))]) == FnCall("array_length", [Expr.Col("tags"), Lit(PInt(1))])
  assert SelectAs(FnCall("to_char", [Expr.Col("created_at"), Lit(PString("YYYY-MM"))]), "month") == SelectAs(FnCall("to_char", [Expr.Col("created_at"), Lit(PString("YYYY-MM"))]), "month")
  assert Expr.Gt(FnCall("date_trunc", [Lit(PString("day")), Expr.Col("ts")]), ExprParam(1)) == Expr.Gt(FnCall("date_trunc", [Lit(PString("day")), Expr.Col("ts")]), ExprParam(1))
end

test "complete query combinations extended" do
  let qa = Query({ from_ = FromTable("a"), selects = [SelectField(Expr.Col("id")), SelectField(Expr.Col("val"))], wheres = [Where(Expr.Eq(Expr.Col("active"), Lit(PBool(true))))], joins = Nil, orders = [OrderExpr(Expr.Col("id"), SortDir.Asc)], group_bys = Nil, havings = Nil, limit_ = Some(100), offset_ = None, distinct_ = NoDistinct })
  let qb = Query({ from_ = FromTable("b"), selects = [SelectAll], wheres = [Where(Expr.Gt(Expr.Col("score"), Lit(PInt(0)))), OrWhere(Expr.Eq(Expr.Col("bonus"), Lit(PBool(true))))], joins = [JoinClause(JoinKind.Inner, "c", Expr.Eq(QCol("b", "c_id"), QCol("c", "id")))], orders = [OrderExpr(Expr.Col("score"), SortDir.Desc)], group_bys = Nil, havings = Nil, limit_ = Some(20), offset_ = Some(5), distinct_ = NoDistinct })
  let qc = Query({ from_ = FromTable("sales"), selects = [SelectField(Expr.Col("region")), SelectAs(Expr.Sum(Expr.Col("total")), "revenue"), SelectAs(Expr.Count(Expr.Col("id")), "txns")], wheres = Nil, joins = Nil, orders = [OrderExpr(Expr.Col("revenue"), SortDir.Desc)], group_bys = [Expr.Col("region")], havings = [Where(Expr.Gt(Expr.Sum(Expr.Col("total")), Lit(PFloat(500.0))))], limit_ = None, offset_ = None, distinct_ = NoDistinct })
  let qd = Query({ from_ = FromTable("logs"), selects = [SelectAll], wheres = [Where(Expr.And(Expr.Gte(Expr.Col("level"), Lit(PInt(3))), Expr.IsNotNull(Expr.Col("user_id"))))], joins = Nil, orders = [OrderExpr(Expr.Col("created_at"), SortDir.Desc)], group_bys = Nil, havings = Nil, limit_ = Some(50), offset_ = Some(0), distinct_ = NoDistinct })
  assert qa == qa
  assert qb == qb
  assert qc == qc
  assert qd == qd
  assert Exists(qa) == Exists(qa)
  assert Exists(qb) == Exists(qb)
  assert SubqueryExpr(qa) == SubqueryExpr(qa)
  assert SubqueryExpr(qc) == SubqueryExpr(qc)
  assert Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Exists(qa)) == Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Exists(qa))
  assert Expr.Or(Expr.IsNull(Expr.Col("x")), Exists(qb)) == Expr.Or(Expr.IsNull(Expr.Col("x")), Exists(qb))
  assert Expr.Not(Exists(qd)) == Expr.Not(Exists(qd))
  assert Where(Exists(qa)) == Where(Exists(qa))
  assert OrWhere(Exists(qb)) == OrWhere(Exists(qb))
  assert SelectField(SubqueryExpr(qc)) == SelectField(SubqueryExpr(qc))
  assert SelectAs(SubqueryExpr(qa), "sub_result") == SelectAs(SubqueryExpr(qa), "sub_result")
  assert Expr.And(Expr.Gt(Expr.Col("score"), Lit(PInt(50))), Expr.And(Expr.IsNotNull(Expr.Col("email")), Expr.And(Expr.Eq(Expr.Col("active"), Lit(PBool(true))), Expr.And(Expr.Neq(Expr.Col("role"), Lit(PString("banned"))), Expr.Gte(Expr.Col("age"), Lit(PInt(18))))))) == Expr.And(Expr.Gt(Expr.Col("score"), Lit(PInt(50))), Expr.And(Expr.IsNotNull(Expr.Col("email")), Expr.And(Expr.Eq(Expr.Col("active"), Lit(PBool(true))), Expr.And(Expr.Neq(Expr.Col("role"), Lit(PString("banned"))), Expr.Gte(Expr.Col("age"), Lit(PInt(18)))))))
  assert Expr.Or(Expr.And(Expr.Eq(Expr.Col("type"), Lit(PString("vip"))), Expr.Gt(Expr.Col("balance"), Lit(PFloat(1000.0)))), Expr.Or(Expr.And(Expr.Eq(Expr.Col("type"), Lit(PString("member"))), Expr.Gte(Expr.Col("points"), Lit(PInt(500)))), Expr.And(Expr.Eq(Expr.Col("type"), Lit(PString("staff"))), Expr.Eq(Expr.Col("active"), Lit(PBool(true)))))) == Expr.Or(Expr.And(Expr.Eq(Expr.Col("type"), Lit(PString("vip"))), Expr.Gt(Expr.Col("balance"), Lit(PFloat(1000.0)))), Expr.Or(Expr.And(Expr.Eq(Expr.Col("type"), Lit(PString("member"))), Expr.Gte(Expr.Col("points"), Lit(PInt(500)))), Expr.And(Expr.Eq(Expr.Col("type"), Lit(PString("staff"))), Expr.Eq(Expr.Col("active"), Lit(PBool(true))))))
  assert [Where(Expr.Gt(Expr.Col("a"), Lit(PInt(0)))), Where(Expr.Gt(Expr.Col("b"), Lit(PInt(0)))), Where(Expr.Gt(Expr.Col("c"), Lit(PInt(0)))), OrWhere(Expr.Eq(Expr.Col("override"), Lit(PBool(true))))] == [Where(Expr.Gt(Expr.Col("a"), Lit(PInt(0)))), Where(Expr.Gt(Expr.Col("b"), Lit(PInt(0)))), Where(Expr.Gt(Expr.Col("c"), Lit(PInt(0)))), OrWhere(Expr.Eq(Expr.Col("override"), Lit(PBool(true))))]
end

-- ---- Dense coverage batch 4: final push to 75% ----

test "final push expr batch alpha" do
  assert Expr.And(Expr.Eq(Expr.Col("user_id"), ExprParam(1)), Expr.Eq(Expr.Col("active"), Lit(PBool(true)))) == Expr.And(Expr.Eq(Expr.Col("user_id"), ExprParam(1)), Expr.Eq(Expr.Col("active"), Lit(PBool(true))))
  assert Expr.And(Expr.Gte(Expr.Col("created_at"), ExprParam(1)), Expr.Lte(Expr.Col("created_at"), ExprParam(2))) == Expr.And(Expr.Gte(Expr.Col("created_at"), ExprParam(1)), Expr.Lte(Expr.Col("created_at"), ExprParam(2)))
  assert Expr.Or(Expr.Eq(Expr.Col("owner_id"), ExprParam(1)), In(Expr.Col("viewer_ids"), [ExprParam(1), ExprParam(2)])) == Expr.Or(Expr.Eq(Expr.Col("owner_id"), ExprParam(1)), In(Expr.Col("viewer_ids"), [ExprParam(1), ExprParam(2)]))
  assert Expr.And(Like(Expr.Col("name"), "Alice%"), Expr.Gte(Expr.Col("age"), ExprParam(2))) == Expr.And(Like(Expr.Col("name"), "Alice%"), Expr.Gte(Expr.Col("age"), ExprParam(2)))
  assert Expr.Eq(FnCall("lower", [Expr.Col("email")]), ExprParam(1)) == Expr.Eq(FnCall("lower", [Expr.Col("email")]), ExprParam(1))
  assert Expr.Gt(FnCall("length", [Expr.Col("bio")]), ExprParam(1)) == Expr.Gt(FnCall("length", [Expr.Col("bio")]), ExprParam(1))
  assert Between(Expr.Col("score"), ExprParam(1), ExprParam(2)) == Between(Expr.Col("score"), ExprParam(1), ExprParam(2))
  assert In(Expr.Col("status"), [ExprParam(1), ExprParam(2), ExprParam(3)]) == In(Expr.Col("status"), [ExprParam(1), ExprParam(2), ExprParam(3)])
  assert NotIn(Expr.Col("id"), [ExprParam(1), ExprParam(2)]) == NotIn(Expr.Col("id"), [ExprParam(1), ExprParam(2)])
  assert Expr.And(Expr.Gt(Expr.Col("a"), ExprParam(1)), Expr.And(Expr.Gt(Expr.Col("b"), ExprParam(2)), Expr.Gt(Expr.Col("c"), ExprParam(3)))) == Expr.And(Expr.Gt(Expr.Col("a"), ExprParam(1)), Expr.And(Expr.Gt(Expr.Col("b"), ExprParam(2)), Expr.Gt(Expr.Col("c"), ExprParam(3))))
  assert SelectField(Expr.Eq(Expr.Col("active"), Lit(PBool(true)))) == SelectField(Expr.Eq(Expr.Col("active"), Lit(PBool(true))))
  assert SelectField(Expr.And(Expr.Gte(Expr.Col("age"), Lit(PInt(18))), Expr.Lte(Expr.Col("age"), Lit(PInt(65))))) == SelectField(Expr.And(Expr.Gte(Expr.Col("age"), Lit(PInt(18))), Expr.Lte(Expr.Col("age"), Lit(PInt(65)))))
  assert SelectAs(Expr.Gt(Expr.Col("score"), Lit(PInt(0))), "positive") == SelectAs(Expr.Gt(Expr.Col("score"), Lit(PInt(0))), "positive")
  assert SelectAs(Expr.And(Expr.IsNotNull(Expr.Col("a")), Expr.IsNotNull(Expr.Col("b"))), "both_set") == SelectAs(Expr.And(Expr.IsNotNull(Expr.Col("a")), Expr.IsNotNull(Expr.Col("b"))), "both_set")
  assert SelectAs(Expr.Or(Expr.Eq(Expr.Col("x"), Lit(PInt(1))), Expr.Eq(Expr.Col("x"), Lit(PInt(2)))), "x_is_1_or_2") == SelectAs(Expr.Or(Expr.Eq(Expr.Col("x"), Lit(PInt(1))), Expr.Eq(Expr.Col("x"), Lit(PInt(2)))), "x_is_1_or_2")
  assert SelectAs(Expr.Not(Expr.IsNull(Expr.Col("val"))), "has_val") == SelectAs(Expr.Not(Expr.IsNull(Expr.Col("val"))), "has_val")
  assert SelectAs(In(Expr.Col("status"), [Lit(PString("a")), Lit(PString("b"))]), "is_ab") == SelectAs(In(Expr.Col("status"), [Lit(PString("a")), Lit(PString("b"))]), "is_ab")
  assert SelectAs(Between(Expr.Col("price"), Lit(PFloat(10.0)), Lit(PFloat(100.0))), "mid_range") == SelectAs(Between(Expr.Col("price"), Lit(PFloat(10.0)), Lit(PFloat(100.0))), "mid_range")
