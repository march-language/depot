  assert Expr.And(Expr.Gte(Expr.Count(Expr.Col("id")), Lit(PInt(1))), Expr.And(Expr.Gt(Expr.Sum(Expr.Col("amount")), Lit(PFloat(0.0))), Expr.Lt(Avg(Expr.Col("score")), Lit(PFloat(10.0))))) == Expr.And(Expr.Gte(Expr.Count(Expr.Col("id")), Lit(PInt(1))), Expr.And(Expr.Gt(Expr.Sum(Expr.Col("amount")), Lit(PFloat(0.0))), Expr.Lt(Avg(Expr.Col("score")), Lit(PFloat(10.0)))))
  assert Expr.Or(Expr.Gt(Expr.Max(Expr.Col("score")), Lit(PInt(95))), Expr.And(Expr.Gt(Avg(Expr.Col("score")), Lit(PFloat(80.0))), Expr.Gte(Expr.Count(Expr.Col("id")), Lit(PInt(10))))) == Expr.Or(Expr.Gt(Expr.Max(Expr.Col("score")), Lit(PInt(95))), Expr.And(Expr.Gt(Avg(Expr.Col("score")), Lit(PFloat(80.0))), Expr.Gte(Expr.Count(Expr.Col("id")), Lit(PInt(10)))))
