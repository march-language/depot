  assert SelectAs(FnCall("coalesce", [Expr.Sum(Expr.Col("a")), Lit(PInt(0))]), "safe_sum") == SelectAs(FnCall("coalesce", [Expr.Sum(Expr.Col("a")), Lit(PInt(0))]), "safe_sum")
  assert SelectAs(FnCall("nullif", [Avg(Expr.Col("x")), Lit(PFloat(0.0))]), "safe_avg") == SelectAs(FnCall("nullif", [Avg(Expr.Col("x")), Lit(PFloat(0.0))]), "safe_avg")
  assert [SelectField(Expr.Col("id")), SelectField(Expr.Col("name")), SelectField(Expr.Col("status")), SelectField(Expr.Col("score")), SelectField(Expr.Col("created_at")), SelectField(Expr.Col("updated_at"))] == [SelectField(Expr.Col("id")), SelectField(Expr.Col("name")), SelectField(Expr.Col("status")), SelectField(Expr.Col("score")), SelectField(Expr.Col("created_at")), SelectField(Expr.Col("updated_at"))]
  assert [Where(Expr.Eq(Expr.Col("active"), Lit(PBool(true)))), Where(Expr.Neq(Expr.Col("status"), Lit(PString("banned")))), Where(Expr.IsNotNull(Expr.Col("email"))), Where(Expr.Gte(Expr.Col("age"), Lit(PInt(18))))] == [Where(Expr.Eq(Expr.Col("active"), Lit(PBool(true)))), Where(Expr.Neq(Expr.Col("status"), Lit(PString("banned")))), Where(Expr.IsNotNull(Expr.Col("email"))), Where(Expr.Gte(Expr.Col("age"), Lit(PInt(18))))]
  assert [JoinClause(JoinKind.Inner, "u", Expr.Eq(QCol("o", "user_id"), QCol("u", "id"))), JoinClause(JoinKind.Left, "p", Expr.Eq(QCol("o", "product_id"), QCol("p", "id"))), JoinClause(JoinKind.Left, "c", Expr.Eq(QCol("p", "cat_id"), QCol("c", "id"))), JoinClause(JoinKind.Left, "t", Expr.Eq(QCol("p", "type_id"), QCol("t", "id")))] == [JoinClause(JoinKind.Inner, "u", Expr.Eq(QCol("o", "user_id"), QCol("u", "id"))), JoinClause(JoinKind.Left, "p", Expr.Eq(QCol("o", "product_id"), QCol("p", "id"))), JoinClause(JoinKind.Left, "c", Expr.Eq(QCol("p", "cat_id"), QCol("c", "id"))), JoinClause(JoinKind.Left, "t", Expr.Eq(QCol("p", "type_id"), QCol("t", "id")))]
  assert [OrderExpr(Expr.Col("priority"), SortDir.Asc), OrderExpr(Expr.Col("created_at"), SortDir.Desc), OrderExpr(Expr.Col("id"), SortDir.Asc)] == [OrderExpr(Expr.Col("priority"), SortDir.Asc), OrderExpr(Expr.Col("created_at"), SortDir.Desc), OrderExpr(Expr.Col("id"), SortDir.Asc)]
  assert Expr.Or(In(Expr.Col("role"), [Lit(PString("admin")), Lit(PString("superuser"))]), Expr.And(Expr.Eq(Expr.Col("role"), Lit(PString("staff"))), Expr.Eq(Expr.Col("dept"), Lit(PString("engineering"))))) == Expr.Or(In(Expr.Col("role"), [Lit(PString("admin")), Lit(PString("superuser"))]), Expr.And(Expr.Eq(Expr.Col("role"), Lit(PString("staff"))), Expr.Eq(Expr.Col("dept"), Lit(PString("engineering")))))
  assert Expr.And(NotIn(Expr.Col("status"), [Lit(PString("x")), Lit(PString("y")), Lit(PString("z"))]), Expr.And(Expr.IsNotNull(Expr.Col("email")), Expr.IsNotNull(Expr.Col("name")))) == Expr.And(NotIn(Expr.Col("status"), [Lit(PString("x")), Lit(PString("y")), Lit(PString("z"))]), Expr.And(Expr.IsNotNull(Expr.Col("email")), Expr.IsNotNull(Expr.Col("name"))))
  assert Expr.Gt(FnCall("length", [Expr.Col("password")]), Lit(PInt(12))) == Expr.Gt(FnCall("length", [Expr.Col("password")]), Lit(PInt(12)))
  assert Expr.And(Like(Expr.Col("email"), "%@%"), Expr.Gt(FnCall("length", [Expr.Col("email")]), Lit(PInt(5)))) == Expr.And(Like(Expr.Col("email"), "%@%"), Expr.Gt(FnCall("length", [Expr.Col("email")]), Lit(PInt(5))))
  assert Expr.Or(ILike(Expr.Col("name"), "%alice%"), ILike(Expr.Col("username"), "%alice%")) == Expr.Or(ILike(Expr.Col("name"), "%alice%"), ILike(Expr.Col("username"), "%alice%"))
  assert Expr.And(Expr.Eq(QCol("u", "active"), Lit(PBool(true))), Expr.And(Expr.IsNotNull(QCol("u", "email")), Expr.Eq(QCol("u", "email_verified"), Lit(PBool(true))))) == Expr.And(Expr.Eq(QCol("u", "active"), Lit(PBool(true))), Expr.And(Expr.IsNotNull(QCol("u", "email")), Expr.Eq(QCol("u", "email_verified"), Lit(PBool(true)))))
  assert Expr.Eq(Expr.Add(Expr.Mul(Expr.Col("a"), Expr.Col("b")), Expr.Div(Expr.Col("c"), Expr.Col("d"))), Expr.Sub(Expr.Col("e"), Expr.Col("f"))) == Expr.Eq(Expr.Add(Expr.Mul(Expr.Col("a"), Expr.Col("b")), Expr.Div(Expr.Col("c"), Expr.Col("d"))), Expr.Sub(Expr.Col("e"), Expr.Col("f")))
  assert Expr.Gt(Expr.Div(Expr.Sum(Expr.Col("revenue")), Expr.Count(Expr.Col("id"))), Expr.Mul(Avg(Expr.Col("revenue")), Lit(PFloat(1.1)))) == Expr.Gt(Expr.Div(Expr.Sum(Expr.Col("revenue")), Expr.Count(Expr.Col("id"))), Expr.Mul(Avg(Expr.Col("revenue")), Lit(PFloat(1.1))))
  assert [SelectAs(Expr.Col("id"), "id"), SelectAs(Expr.Col("name"), "name"), SelectAs(Expr.Col("email"), "email"), SelectAs(Expr.Col("created_at"), "created"), SelectAs(Expr.Col("score"), "score"), SelectAs(Expr.Col("active"), "active")] == [SelectAs(Expr.Col("id"), "id"), SelectAs(Expr.Col("name"), "name"), SelectAs(Expr.Col("email"), "email"), SelectAs(Expr.Col("created_at"), "created"), SelectAs(Expr.Col("score"), "score"), SelectAs(Expr.Col("active"), "active")]
  assert [Expr.Col("a"), Expr.Col("b"), Expr.Col("c"), Expr.Col("d"), Expr.Col("e"), Expr.Col("f"), Expr.Col("g"), Expr.Col("h")] == [Expr.Col("a"), Expr.Col("b"), Expr.Col("c"), Expr.Col("d"), Expr.Col("e"), Expr.Col("f"), Expr.Col("g"), Expr.Col("h")]
  assert [ExprParam(1), ExprParam(2), ExprParam(3), ExprParam(4), ExprParam(5), ExprParam(6)] == [ExprParam(1), ExprParam(2), ExprParam(3), ExprParam(4), ExprParam(5), ExprParam(6)]
