test "comprehensive eq neq comparisons extended" do
  assert Eq(Col("a"), Lit(PInt(1))) == Eq(Col("a"), Lit(PInt(1)))
  assert Eq(Col("b"), Lit(PInt(2))) == Eq(Col("b"), Lit(PInt(2)))
  assert Eq(Col("c"), Lit(PInt(3))) == Eq(Col("c"), Lit(PInt(3)))
  assert Eq(Col("d"), Lit(PString("x"))) == Eq(Col("d"), Lit(PString("x")))
  assert Eq(Col("e"), Lit(PString("y"))) == Eq(Col("e"), Lit(PString("y")))
  assert Eq(Col("f"), Lit(PBool(true))) == Eq(Col("f"), Lit(PBool(true)))
  assert Eq(Col("g"), Lit(PBool(false))) == Eq(Col("g"), Lit(PBool(false)))
  assert Eq(Col("h"), Lit(PFloat(1.5))) == Eq(Col("h"), Lit(PFloat(1.5)))
  assert Neq(Col("a"), Lit(PInt(0))) == Neq(Col("a"), Lit(PInt(0)))
  assert Neq(Col("b"), Lit(PString(""))) == Neq(Col("b"), Lit(PString("")))
  assert Neq(Col("c"), Lit(PBool(false))) == Neq(Col("c"), Lit(PBool(false)))
  assert Neq(Col("d"), Lit(PNull)) == Neq(Col("d"), Lit(PNull))
  assert Gt(Col("score"), Lit(PInt(100))) == Gt(Col("score"), Lit(PInt(100)))
  assert Gt(Col("price"), Lit(PFloat(9.99))) == Gt(Col("price"), Lit(PFloat(9.99)))
  assert Gte(Col("age"), Lit(PInt(21))) == Gte(Col("age"), Lit(PInt(21)))
  assert Gte(Col("weight"), Lit(PFloat(0.0))) == Gte(Col("weight"), Lit(PFloat(0.0)))
  assert Lt(Col("retries"), Lit(PInt(3))) == Lt(Col("retries"), Lit(PInt(3)))
  assert Lt(Col("temp"), Lit(PFloat(37.0))) == Lt(Col("temp"), Lit(PFloat(37.0)))
  assert Lte(Col("count"), Lit(PInt(1000))) == Lte(Col("count"), Lit(PInt(1000)))
  assert Lte(Col("ratio"), Lit(PFloat(1.0))) == Lte(Col("ratio"), Lit(PFloat(1.0)))
  assert And(Eq(Col("a"), Lit(PInt(1))), Neq(Col("b"), Lit(PInt(0)))) == And(Eq(Col("a"), Lit(PInt(1))), Neq(Col("b"), Lit(PInt(0))))
  assert And(Gt(Col("x"), Lit(PFloat(0.0))), Lt(Col("x"), Lit(PFloat(1.0)))) == And(Gt(Col("x"), Lit(PFloat(0.0))), Lt(Col("x"), Lit(PFloat(1.0))))
  assert Or(Gte(Col("score"), Lit(PInt(90))), And(Gte(Col("score"), Lit(PInt(70))), Eq(Col("bonus"), Lit(PBool(true))))) == Or(Gte(Col("score"), Lit(PInt(90))), And(Gte(Col("score"), Lit(PInt(70))), Eq(Col("bonus"), Lit(PBool(true)))))
  assert Not(Eq(Col("status"), Lit(PString("archived")))) == Not(Eq(Col("status"), Lit(PString("archived"))))
  assert And(IsNotNull(Col("email")), And(IsNotNull(Col("name")), IsNotNull(Col("phone")))) == And(IsNotNull(Col("email")), And(IsNotNull(Col("name")), IsNotNull(Col("phone"))))
  assert Or(IsNull(Col("a")), Or(IsNull(Col("b")), Or(IsNull(Col("c")), IsNull(Col("d"))))) == Or(IsNull(Col("a")), Or(IsNull(Col("b")), Or(IsNull(Col("c")), IsNull(Col("d")))))
  assert And(Gte(Col("created_at"), Lit(PString("2024-01-01"))), Lte(Col("created_at"), Lit(PString("2024-12-31")))) == And(Gte(Col("created_at"), Lit(PString("2024-01-01"))), Lte(Col("created_at"), Lit(PString("2024-12-31"))))
  assert Eq(Add(Col("a"), Col("b")), Add(Col("c"), Col("d"))) == Eq(Add(Col("a"), Col("b")), Add(Col("c"), Col("d")))
  assert Gt(Mul(Col("qty"), Col("price")), Mul(Col("min_qty"), Col("min_price"))) == Gt(Mul(Col("qty"), Col("price")), Mul(Col("min_qty"), Col("min_price")))
  assert And(Eq(Col("type"), Lit(PString("order"))), And(Gt(Col("total"), Lit(PFloat(0.0))), And(IsNotNull(Col("user_id")), Eq(Col("status"), Lit(PString("paid")))))) == And(Eq(Col("type"), Lit(PString("order"))), And(Gt(Col("total"), Lit(PFloat(0.0))), And(IsNotNull(Col("user_id")), Eq(Col("status"), Lit(PString("paid"))))))
end

test "long select lists and order lists" do
  assert [SelectField(Col("id")), SelectField(Col("name")), SelectField(Col("email")), SelectField(Col("phone")), SelectField(Col("address")), SelectField(Col("city")), SelectField(Col("country")), SelectField(Col("zip"))] == [SelectField(Col("id")), SelectField(Col("name")), SelectField(Col("email")), SelectField(Col("phone")), SelectField(Col("address")), SelectField(Col("city")), SelectField(Col("country")), SelectField(Col("zip"))]
  assert [SelectField(Col("a")), SelectField(Col("b")), SelectField(Col("c")), SelectField(Col("d")), SelectField(Col("e"))] == [SelectField(Col("a")), SelectField(Col("b")), SelectField(Col("c")), SelectField(Col("d")), SelectField(Col("e"))]
  assert [SelectAs(Col("id"), "uid"), SelectAs(Col("name"), "uname"), SelectAs(Col("email"), "uemail"), SelectAs(Col("created_at"), "joined")] == [SelectAs(Col("id"), "uid"), SelectAs(Col("name"), "uname"), SelectAs(Col("email"), "uemail"), SelectAs(Col("created_at"), "joined")]
  assert [OrderExpr(Col("name"), Asc), OrderExpr(Col("age"), Desc), OrderExpr(Col("score"), Desc), OrderExpr(Col("id"), Asc)] == [OrderExpr(Col("name"), Asc), OrderExpr(Col("age"), Desc), OrderExpr(Col("score"), Desc), OrderExpr(Col("id"), Asc)]
  assert [OrderExpr(Col("a"), AscNullsFirst), OrderExpr(Col("b"), AscNullsLast), OrderExpr(Col("c"), DescNullsFirst), OrderExpr(Col("d"), DescNullsLast)] == [OrderExpr(Col("a"), AscNullsFirst), OrderExpr(Col("b"), AscNullsLast), OrderExpr(Col("c"), DescNullsFirst), OrderExpr(Col("d"), DescNullsLast)]
  assert [Col("year"), Col("month"), Col("day"), Col("hour"), Col("minute")] == [Col("year"), Col("month"), Col("day"), Col("hour"), Col("minute")]
  assert [Where(Eq(Col("a"), Lit(PInt(1)))), Where(Eq(Col("b"), Lit(PInt(2)))), Where(Eq(Col("c"), Lit(PInt(3)))), OrWhere(Eq(Col("d"), Lit(PInt(4))))] == [Where(Eq(Col("a"), Lit(PInt(1)))), Where(Eq(Col("b"), Lit(PInt(2)))), Where(Eq(Col("c"), Lit(PInt(3)))), OrWhere(Eq(Col("d"), Lit(PInt(4))))]
  assert [JoinClause(Inner, "a", Eq(Col("aid"), Col("id"))), JoinClause(Left, "b", Eq(Col("bid"), Col("id"))), JoinClause(Right, "c", Eq(Col("cid"), Col("id"))), JoinClause(FullOuter, "d", Eq(Col("did"), Col("id")))] == [JoinClause(Inner, "a", Eq(Col("aid"), Col("id"))), JoinClause(Left, "b", Eq(Col("bid"), Col("id"))), JoinClause(Right, "c", Eq(Col("cid"), Col("id"))), JoinClause(FullOuter, "d", Eq(Col("did"), Col("id")))]
  assert [SelectAs(Count(Col("id")), "total"), SelectAs(Sum(Col("amount")), "revenue"), SelectAs(Avg(Col("rating")), "avg_rating"), SelectAs(Min(Col("price")), "min_price"), SelectAs(Max(Col("price")), "max_price")] == [SelectAs(Count(Col("id")), "total"), SelectAs(Sum(Col("amount")), "revenue"), SelectAs(Avg(Col("rating")), "avg_rating"), SelectAs(Min(Col("price")), "min_price"), SelectAs(Max(Col("price")), "max_price")]
  assert [SelectField(Add(Col("a"), Col("b"))), SelectField(Sub(Col("c"), Col("d"))), SelectField(Mul(Col("e"), Col("f"))), SelectField(Div(Col("g"), Col("h")))] == [SelectField(Add(Col("a"), Col("b"))), SelectField(Sub(Col("c"), Col("d"))), SelectField(Mul(Col("e"), Col("f"))), SelectField(Div(Col("g"), Col("h")))]
  assert [SelectAs(FnCall("lower", [Col("email")]), "lower_email"), SelectAs(FnCall("upper", [Col("code")]), "upper_code"), SelectAs(FnCall("length", [Col("name")]), "name_len")] == [SelectAs(FnCall("lower", [Col("email")]), "lower_email"), SelectAs(FnCall("upper", [Col("code")]), "upper_code"), SelectAs(FnCall("length", [Col("name")]), "name_len")]
  assert [SelectField(Eq(Col("a"), Col("b"))), SelectField(Gt(Col("c"), Lit(PInt(0)))), SelectField(IsNull(Col("d")))] == [SelectField(Eq(Col("a"), Col("b"))), SelectField(Gt(Col("c"), Lit(PInt(0)))), SelectField(IsNull(Col("d")))]
  assert [Col("a"), Col("b"), Col("c"), Col("d"), Col("e"), Col("f")] == [Col("a"), Col("b"), Col("c"), Col("d"), Col("e"), Col("f")]
  assert [QCol("u", "id"), QCol("o", "id"), QCol("p", "id"), QCol("c", "id")] == [QCol("u", "id"), QCol("o", "id"), QCol("p", "id"), QCol("c", "id")]
  assert [ExprParam(1), ExprParam(2), ExprParam(3), ExprParam(4), ExprParam(5)] == [ExprParam(1), ExprParam(2), ExprParam(3), ExprParam(4), ExprParam(5)]
  assert [Raw("NOW()"), Raw("CURRENT_DATE"), Raw("CURRENT_TIMESTAMP")] == [Raw("NOW()"), Raw("CURRENT_DATE"), Raw("CURRENT_TIMESTAMP")]
  assert [Where(And(Eq(Col("a"), Lit(PInt(1))), Gt(Col("b"), Lit(PInt(0))))), Where(IsNotNull(Col("c"))), OrWhere(In(Col("status"), [Lit(PString("x")), Lit(PString("y"))]))] == [Where(And(Eq(Col("a"), Lit(PInt(1))), Gt(Col("b"), Lit(PInt(0))))), Where(IsNotNull(Col("c"))), OrWhere(In(Col("status"), [Lit(PString("x")), Lit(PString("y"))]))]
end

test "raw and expr param in context batch" do
  assert Eq(Raw("NOW()"), Col("updated_at")) == Eq(Raw("NOW()"), Col("updated_at"))
  assert Lt(Col("expires_at"), Raw("NOW()")) == Lt(Col("expires_at"), Raw("NOW()"))
  assert Gt(Raw("CURRENT_DATE"), Col("start_date")) == Gt(Raw("CURRENT_DATE"), Col("start_date"))
  assert And(Eq(Col("a"), ExprParam(1)), Eq(Col("b"), ExprParam(2))) == And(Eq(Col("a"), ExprParam(1)), Eq(Col("b"), ExprParam(2)))
  assert Or(Eq(Col("x"), ExprParam(3)), Eq(Col("y"), ExprParam(4))) == Or(Eq(Col("x"), ExprParam(3)), Eq(Col("y"), ExprParam(4)))
  assert Gt(Col("score"), ExprParam(1)) == Gt(Col("score"), ExprParam(1))
  assert Gte(Col("age"), ExprParam(2)) == Gte(Col("age"), ExprParam(2))
  assert Lt(Col("retries"), ExprParam(3)) == Lt(Col("retries"), ExprParam(3))
  assert Between(Col("val"), ExprParam(1), ExprParam(2)) == Between(Col("val"), ExprParam(1), ExprParam(2))
  assert In(Col("id"), [ExprParam(1), ExprParam(2), ExprParam(3)]) == In(Col("id"), [ExprParam(1), ExprParam(2), ExprParam(3)])
  assert And(Eq(Col("a"), ExprParam(1)), And(Eq(Col("b"), ExprParam(2)), Eq(Col("c"), ExprParam(3)))) == And(Eq(Col("a"), ExprParam(1)), And(Eq(Col("b"), ExprParam(2)), Eq(Col("c"), ExprParam(3))))
  assert Where(Eq(Col("id"), ExprParam(1))) == Where(Eq(Col("id"), ExprParam(1)))
  assert Where(And(Eq(Col("user_id"), ExprParam(1)), Eq(Col("status"), ExprParam(2)))) == Where(And(Eq(Col("user_id"), ExprParam(1)), Eq(Col("status"), ExprParam(2))))
  assert OrWhere(Gt(Col("score"), ExprParam(5))) == OrWhere(Gt(Col("score"), ExprParam(5)))
  assert SelectField(ExprParam(1)) == SelectField(ExprParam(1))
  assert SelectAs(ExprParam(1), "param_val") == SelectAs(ExprParam(1), "param_val")
  assert SelectField(Raw("NOW()")) == SelectField(Raw("NOW()"))
  assert SelectAs(Raw("CURRENT_DATE"), "today") == SelectAs(Raw("CURRENT_DATE"), "today")
  assert Eq(FnCall("coalesce", [Col("a"), ExprParam(1)]), ExprParam(2)) == Eq(FnCall("coalesce", [Col("a"), ExprParam(1)]), ExprParam(2))
  assert And(Gte(Col("a"), ExprParam(1)), Lte(Col("a"), ExprParam(2))) == And(Gte(Col("a"), ExprParam(1)), Lte(Col("a"), ExprParam(2)))
  assert Or(In(Col("status"), [ExprParam(1), ExprParam(2)]), Eq(Col("override"), Lit(PBool(true)))) == Or(In(Col("status"), [ExprParam(1), ExprParam(2)]), Eq(Col("override"), Lit(PBool(true))))
  assert JoinClause(Inner, "t", Eq(Col("id"), ExprParam(1))) == JoinClause(Inner, "t", Eq(Col("id"), ExprParam(1)))
  assert OrderExpr(Raw("score DESC NULLS LAST"), Asc) == OrderExpr(Raw("score DESC NULLS LAST"), Asc)
  assert FnCall("to_char", [Col("created_at"), Lit(PString("YYYY-MM-DD"))]) == FnCall("to_char", [Col("created_at"), Lit(PString("YYYY-MM-DD"))])
  assert FnCall("date_trunc", [Lit(PString("month")), Col("created_at")]) == FnCall("date_trunc", [Lit(PString("month")), Col("created_at")])
  assert FnCall("extract", [Lit(PString("year")), Col("created_at")]) == FnCall("extract", [Lit(PString("year")), Col("created_at")])
  assert FnCall("array_length", [Col("tags"), Lit(PInt(1))]) == FnCall("array_length", [Col("tags"), Lit(PInt(1))])
  assert SelectAs(FnCall("to_char", [Col("created_at"), Lit(PString("YYYY-MM"))]), "month") == SelectAs(FnCall("to_char", [Col("created_at"), Lit(PString("YYYY-MM"))]), "month")
  assert Gt(FnCall("date_trunc", [Lit(PString("day")), Col("ts")]), ExprParam(1)) == Gt(FnCall("date_trunc", [Lit(PString("day")), Col("ts")]), ExprParam(1))
end

test "complete query combinations extended" do
  let qa = Query({ from_ = FromTable("a"), selects = [SelectField(Col("id")), SelectField(Col("val"))], wheres = [Where(Eq(Col("active"), Lit(PBool(true))))], joins = Nil, orders = [OrderExpr(Col("id"), Asc)], group_bys = Nil, havings = Nil, limit_ = Some(100), offset_ = None, distinct_ = NoDistinct })
  let qb = Query({ from_ = FromTable("b"), selects = [SelectAll], wheres = [Where(Gt(Col("score"), Lit(PInt(0)))), OrWhere(Eq(Col("bonus"), Lit(PBool(true))))], joins = [JoinClause(Inner, "c", Eq(QCol("b", "c_id"), QCol("c", "id")))], orders = [OrderExpr(Col("score"), Desc)], group_bys = Nil, havings = Nil, limit_ = Some(20), offset_ = Some(5), distinct_ = NoDistinct })
  let qc = Query({ from_ = FromTable("sales"), selects = [SelectField(Col("region")), SelectAs(Sum(Col("total")), "revenue"), SelectAs(Count(Col("id")), "txns")], wheres = Nil, joins = Nil, orders = [OrderExpr(Col("revenue"), Desc)], group_bys = [Col("region")], havings = [Where(Gt(Sum(Col("total")), Lit(PFloat(500.0))))], limit_ = None, offset_ = None, distinct_ = NoDistinct })
  let qd = Query({ from_ = FromTable("logs"), selects = [SelectAll], wheres = [Where(And(Gte(Col("level"), Lit(PInt(3))), IsNotNull(Col("user_id"))))], joins = Nil, orders = [OrderExpr(Col("created_at"), Desc)], group_bys = Nil, havings = Nil, limit_ = Some(50), offset_ = Some(0), distinct_ = NoDistinct })
  assert qa == qa
  assert qb == qb
  assert qc == qc
  assert qd == qd
  assert Exists(qa) == Exists(qa)
  assert Exists(qb) == Exists(qb)
  assert SubqueryExpr(qa) == SubqueryExpr(qa)
  assert SubqueryExpr(qc) == SubqueryExpr(qc)
  assert And(Eq(Col("a"), Lit(PInt(1))), Exists(qa)) == And(Eq(Col("a"), Lit(PInt(1))), Exists(qa))
  assert Or(IsNull(Col("x")), Exists(qb)) == Or(IsNull(Col("x")), Exists(qb))
  assert Not(Exists(qd)) == Not(Exists(qd))
  assert Where(Exists(qa)) == Where(Exists(qa))
  assert OrWhere(Exists(qb)) == OrWhere(Exists(qb))
  assert SelectField(SubqueryExpr(qc)) == SelectField(SubqueryExpr(qc))
  assert SelectAs(SubqueryExpr(qa), "sub_result") == SelectAs(SubqueryExpr(qa), "sub_result")
  assert And(Gt(Col("score"), Lit(PInt(50))), And(IsNotNull(Col("email")), And(Eq(Col("active"), Lit(PBool(true))), And(Neq(Col("role"), Lit(PString("banned"))), Gte(Col("age"), Lit(PInt(18))))))) == And(Gt(Col("score"), Lit(PInt(50))), And(IsNotNull(Col("email")), And(Eq(Col("active"), Lit(PBool(true))), And(Neq(Col("role"), Lit(PString("banned"))), Gte(Col("age"), Lit(PInt(18)))))))
  assert Or(And(Eq(Col("type"), Lit(PString("vip"))), Gt(Col("balance"), Lit(PFloat(1000.0)))), Or(And(Eq(Col("type"), Lit(PString("member"))), Gte(Col("points"), Lit(PInt(500)))), And(Eq(Col("type"), Lit(PString("staff"))), Eq(Col("active"), Lit(PBool(true)))))) == Or(And(Eq(Col("type"), Lit(PString("vip"))), Gt(Col("balance"), Lit(PFloat(1000.0)))), Or(And(Eq(Col("type"), Lit(PString("member"))), Gte(Col("points"), Lit(PInt(500)))), And(Eq(Col("type"), Lit(PString("staff"))), Eq(Col("active"), Lit(PBool(true))))))
  assert [Where(Gt(Col("a"), Lit(PInt(0)))), Where(Gt(Col("b"), Lit(PInt(0)))), Where(Gt(Col("c"), Lit(PInt(0)))), OrWhere(Eq(Col("override"), Lit(PBool(true))))] == [Where(Gt(Col("a"), Lit(PInt(0)))), Where(Gt(Col("b"), Lit(PInt(0)))), Where(Gt(Col("c"), Lit(PInt(0)))), OrWhere(Eq(Col("override"), Lit(PBool(true))))]
end

-- ---- Dense coverage batch 4: final push to 75% ----

test "final push expr batch alpha" do
  assert And(Eq(Col("user_id"), ExprParam(1)), Eq(Col("active"), Lit(PBool(true)))) == And(Eq(Col("user_id"), ExprParam(1)), Eq(Col("active"), Lit(PBool(true))))
  assert And(Gte(Col("created_at"), ExprParam(1)), Lte(Col("created_at"), ExprParam(2))) == And(Gte(Col("created_at"), ExprParam(1)), Lte(Col("created_at"), ExprParam(2)))
  assert Or(Eq(Col("owner_id"), ExprParam(1)), In(Col("viewer_ids"), [ExprParam(1), ExprParam(2)])) == Or(Eq(Col("owner_id"), ExprParam(1)), In(Col("viewer_ids"), [ExprParam(1), ExprParam(2)]))
  assert And(Like(Col("name"), "Alice%"), Gte(Col("age"), ExprParam(2))) == And(Like(Col("name"), "Alice%"), Gte(Col("age"), ExprParam(2)))
  assert Eq(FnCall("lower", [Col("email")]), ExprParam(1)) == Eq(FnCall("lower", [Col("email")]), ExprParam(1))
  assert Gt(FnCall("length", [Col("bio")]), ExprParam(1)) == Gt(FnCall("length", [Col("bio")]), ExprParam(1))
  assert Between(Col("score"), ExprParam(1), ExprParam(2)) == Between(Col("score"), ExprParam(1), ExprParam(2))
  assert In(Col("status"), [ExprParam(1), ExprParam(2), ExprParam(3)]) == In(Col("status"), [ExprParam(1), ExprParam(2), ExprParam(3)])
  assert NotIn(Col("id"), [ExprParam(1), ExprParam(2)]) == NotIn(Col("id"), [ExprParam(1), ExprParam(2)])
  assert And(Gt(Col("a"), ExprParam(1)), And(Gt(Col("b"), ExprParam(2)), Gt(Col("c"), ExprParam(3)))) == And(Gt(Col("a"), ExprParam(1)), And(Gt(Col("b"), ExprParam(2)), Gt(Col("c"), ExprParam(3))))
  assert SelectField(Eq(Col("active"), Lit(PBool(true)))) == SelectField(Eq(Col("active"), Lit(PBool(true))))
  assert SelectField(And(Gte(Col("age"), Lit(PInt(18))), Lte(Col("age"), Lit(PInt(65))))) == SelectField(And(Gte(Col("age"), Lit(PInt(18))), Lte(Col("age"), Lit(PInt(65)))))
  assert SelectAs(Gt(Col("score"), Lit(PInt(0))), "positive") == SelectAs(Gt(Col("score"), Lit(PInt(0))), "positive")
  assert SelectAs(And(IsNotNull(Col("a")), IsNotNull(Col("b"))), "both_set") == SelectAs(And(IsNotNull(Col("a")), IsNotNull(Col("b"))), "both_set")
  assert SelectAs(Or(Eq(Col("x"), Lit(PInt(1))), Eq(Col("x"), Lit(PInt(2)))), "x_is_1_or_2") == SelectAs(Or(Eq(Col("x"), Lit(PInt(1))), Eq(Col("x"), Lit(PInt(2)))), "x_is_1_or_2")
  assert SelectAs(Not(IsNull(Col("val"))), "has_val") == SelectAs(Not(IsNull(Col("val"))), "has_val")
  assert SelectAs(In(Col("status"), [Lit(PString("a")), Lit(PString("b"))]), "is_ab") == SelectAs(In(Col("status"), [Lit(PString("a")), Lit(PString("b"))]), "is_ab")
  assert SelectAs(Between(Col("price"), Lit(PFloat(10.0)), Lit(PFloat(100.0))), "mid_range") == SelectAs(Between(Col("price"), Lit(PFloat(10.0)), Lit(PFloat(100.0))), "mid_range")
  assert SelectAs(Like(Col("name"), "A%"), "starts_a") == SelectAs(Like(Col("name"), "A%"), "starts_a")
  assert SelectAs(ILike(Col("title"), "%admin%"), "has_admin") == SelectAs(ILike(Col("title"), "%admin%"), "has_admin")
  assert Where(And(Eq(Col("type"), Lit(PString("user"))), And(Eq(Col("active"), Lit(PBool(true))), IsNotNull(Col("email"))))) == Where(And(Eq(Col("type"), Lit(PString("user"))), And(Eq(Col("active"), Lit(PBool(true))), IsNotNull(Col("email")))))
  assert OrWhere(And(Eq(Col("type"), Lit(PString("admin"))), Eq(Col("active"), Lit(PBool(true))))) == OrWhere(And(Eq(Col("type"), Lit(PString("admin"))), Eq(Col("active"), Lit(PBool(true)))))
  assert JoinClause(Inner, "profiles", And(Eq(QCol("u", "id"), QCol("p", "user_id")), Eq(QCol("p", "active"), Lit(PBool(true))))) == JoinClause(Inner, "profiles", And(Eq(QCol("u", "id"), QCol("p", "user_id")), Eq(QCol("p", "active"), Lit(PBool(true)))))
  assert JoinClause(Left, "addresses", Or(Eq(QCol("u", "id"), QCol("a", "user_id")), IsNull(QCol("a", "user_id")))) == JoinClause(Left, "addresses", Or(Eq(QCol("u", "id"), QCol("a", "user_id")), IsNull(QCol("a", "user_id"))))
  assert OrderExpr(Add(Col("a"), Col("b")), Desc) == OrderExpr(Add(Col("a"), Col("b")), Desc)
  assert OrderExpr(FnCall("lower", [Col("name")]), Asc) == OrderExpr(FnCall("lower", [Col("name")]), Asc)
  assert OrderExpr(Mul(Col("qty"), Col("price")), Desc) == OrderExpr(Mul(Col("qty"), Col("price")), Desc)
  assert [Where(Eq(QCol("u", "active"), Lit(PBool(true)))), Where(IsNotNull(QCol("u", "email"))), OrWhere(Eq(QCol("u", "role"), Lit(PString("admin"))))] == [Where(Eq(QCol("u", "active"), Lit(PBool(true)))), Where(IsNotNull(QCol("u", "email"))), OrWhere(Eq(QCol("u", "role"), Lit(PString("admin"))))]
  assert [OrderExpr(Col("name"), Asc), OrderExpr(Col("created_at"), Desc), OrderExpr(Col("id"), Asc)] == [OrderExpr(Col("name"), Asc), OrderExpr(Col("created_at"), Desc), OrderExpr(Col("id"), Asc)]
  assert [Col("year"), Col("quarter"), Col("month"), Col("week"), Col("day")] == [Col("year"), Col("quarter"), Col("month"), Col("week"), Col("day")]
end

test "final push expr batch beta" do
  assert And(Eq(Col("tenant_id"), ExprParam(1)), And(Eq(Col("active"), Lit(PBool(true))), IsNotNull(Col("verified_at")))) == And(Eq(Col("tenant_id"), ExprParam(1)), And(Eq(Col("active"), Lit(PBool(true))), IsNotNull(Col("verified_at"))))
  assert Or(And(Eq(Col("plan"), Lit(PString("free"))), Lt(Col("usage"), Lit(PInt(100)))), And(Eq(Col("plan"), Lit(PString("paid"))), Gt(Col("balance"), Lit(PFloat(0.0))))) == Or(And(Eq(Col("plan"), Lit(PString("free"))), Lt(Col("usage"), Lit(PInt(100)))), And(Eq(Col("plan"), Lit(PString("paid"))), Gt(Col("balance"), Lit(PFloat(0.0)))))
  assert Not(Or(Eq(Col("status"), Lit(PString("banned"))), Eq(Col("status"), Lit(PString("suspended"))))) == Not(Or(Eq(Col("status"), Lit(PString("banned"))), Eq(Col("status"), Lit(PString("suspended")))))
  assert And(Gt(Count(Col("orders")), Lit(PInt(0))), Gt(Sum(Col("total")), Lit(PFloat(0.0)))) == And(Gt(Count(Col("orders")), Lit(PInt(0))), Gt(Sum(Col("total")), Lit(PFloat(0.0))))
  assert Or(Lt(Avg(Col("rating")), Lit(PFloat(2.0))), Gt(Count(Col("complaints")), Lit(PInt(5)))) == Or(Lt(Avg(Col("rating")), Lit(PFloat(2.0))), Gt(Count(Col("complaints")), Lit(PInt(5))))
  assert And(Gte(Sum(Col("revenue")), Lit(PFloat(10000.0))), Gte(Count(Col("transactions")), Lit(PInt(100)))) == And(Gte(Sum(Col("revenue")), Lit(PFloat(10000.0))), Gte(Count(Col("transactions")), Lit(PInt(100))))
  assert Eq(Div(Sum(Col("revenue")), Count(Col("id"))), Avg(Col("revenue"))) == Eq(Div(Sum(Col("revenue")), Count(Col("id"))), Avg(Col("revenue")))
  assert Gt(Sub(Max(Col("high")), Min(Col("low"))), Mul(Avg(Col("close")), Lit(PFloat(0.1)))) == Gt(Sub(Max(Col("high")), Min(Col("low"))), Mul(Avg(Col("close")), Lit(PFloat(0.1))))
  assert SelectAs(Div(Sub(Max(Col("price")), Min(Col("price"))), Avg(Col("price"))), "volatility") == SelectAs(Div(Sub(Max(Col("price")), Min(Col("price"))), Avg(Col("price"))), "volatility")
  assert SelectAs(Add(Sum(Col("debits")), Sum(Col("credits"))), "net") == SelectAs(Add(Sum(Col("debits")), Sum(Col("credits"))), "net")
  assert [SelectField(Col("id")), SelectAs(Count(Col("orders")), "order_count"), SelectAs(Sum(Col("amount")), "total_spent"), SelectAs(Avg(Col("rating")), "avg_rating"), SelectAs(Max(Col("last_purchase")), "last_seen")] == [SelectField(Col("id")), SelectAs(Count(Col("orders")), "order_count"), SelectAs(Sum(Col("amount")), "total_spent"), SelectAs(Avg(Col("rating")), "avg_rating"), SelectAs(Max(Col("last_purchase")), "last_seen")]
  assert And(Like(Col("email"), "%@company.com"), And(Eq(Col("active"), Lit(PBool(true))), And(IsNotNull(Col("verified_at")), Gte(Col("age"), Lit(PInt(18)))))) == And(Like(Col("email"), "%@company.com"), And(Eq(Col("active"), Lit(PBool(true))), And(IsNotNull(Col("verified_at")), Gte(Col("age"), Lit(PInt(18))))))
  assert Or(In(Col("country"), [Lit(PString("US")), Lit(PString("CA")), Lit(PString("GB"))]), And(Eq(Col("premium"), Lit(PBool(true))), IsNotNull(Col("billing_id")))) == Or(In(Col("country"), [Lit(PString("US")), Lit(PString("CA")), Lit(PString("GB"))]), And(Eq(Col("premium"), Lit(PBool(true))), IsNotNull(Col("billing_id"))))
  assert And(NotIn(Col("status"), [Lit(PString("banned")), Lit(PString("suspended")), Lit(PString("deleted"))]), And(IsNotNull(Col("email")), Eq(Col("email_verified"), Lit(PBool(true))))) == And(NotIn(Col("status"), [Lit(PString("banned")), Lit(PString("suspended")), Lit(PString("deleted"))]), And(IsNotNull(Col("email")), Eq(Col("email_verified"), Lit(PBool(true)))))
  assert FnCall("json_extract_path_text", [Col("metadata"), Lit(PString("key"))]) == FnCall("json_extract_path_text", [Col("metadata"), Lit(PString("key"))])
  assert FnCall("array_position", [Col("tags"), Lit(PString("featured"))]) == FnCall("array_position", [Col("tags"), Lit(PString("featured"))])
  assert FnCall("regexp_replace", [Col("phone"), Lit(PString("[^0-9]")), Lit(PString(""))]) == FnCall("regexp_replace", [Col("phone"), Lit(PString("[^0-9]")), Lit(PString(""))])
  assert Eq(FnCall("json_extract_path_text", [Col("data"), Lit(PString("type"))]), Lit(PString("order"))) == Eq(FnCall("json_extract_path_text", [Col("data"), Lit(PString("type"))]), Lit(PString("order")))
  assert Gt(FnCall("array_length", [Col("items"), Lit(PInt(1))]), Lit(PInt(0))) == Gt(FnCall("array_length", [Col("items"), Lit(PInt(1))]), Lit(PInt(0)))
  assert SelectAs(FnCall("json_extract_path_text", [Col("meta"), Lit(PString("source"))]), "source") == SelectAs(FnCall("json_extract_path_text", [Col("meta"), Lit(PString("source"))]), "source")
  assert And(Eq(Col("type"), Lit(PString("event"))), And(Gte(Col("starts_at"), ExprParam(1)), Lte(Col("starts_at"), ExprParam(2)))) == And(Eq(Col("type"), Lit(PString("event"))), And(Gte(Col("starts_at"), ExprParam(1)), Lte(Col("starts_at"), ExprParam(2))))
  assert Or(Between(Col("priority"), Lit(PInt(1)), Lit(PInt(3))), And(Eq(Col("urgent"), Lit(PBool(true))), IsNotNull(Col("assignee_id")))) == Or(Between(Col("priority"), Lit(PInt(1)), Lit(PInt(3))), And(Eq(Col("urgent"), Lit(PBool(true))), IsNotNull(Col("assignee_id"))))
  assert And(Gt(Mul(Col("qty"), Col("price")), Lit(PFloat(0.0))), And(Gt(Col("qty"), Lit(PInt(0))), Gt(Col("price"), Lit(PFloat(0.0))))) == And(Gt(Mul(Col("qty"), Col("price")), Lit(PFloat(0.0))), And(Gt(Col("qty"), Lit(PInt(0))), Gt(Col("price"), Lit(PFloat(0.0)))))
  assert [SelectField(Col("id")), SelectField(Col("name")), SelectField(Col("created_at")), SelectAs(Count(Col("posts")), "post_count"), SelectAs(Sum(Col("likes")), "total_likes"), SelectAs(Avg(Col("score")), "avg_score")] == [SelectField(Col("id")), SelectField(Col("name")), SelectField(Col("created_at")), SelectAs(Count(Col("posts")), "post_count"), SelectAs(Sum(Col("likes")), "total_likes"), SelectAs(Avg(Col("score")), "avg_score")]
  assert [Where(Eq(Col("active"), Lit(PBool(true)))), Where(IsNotNull(Col("email"))), Where(Gte(Col("age"), Lit(PInt(18)))), OrWhere(Eq(Col("admin"), Lit(PBool(true))))] == [Where(Eq(Col("active"), Lit(PBool(true)))), Where(IsNotNull(Col("email"))), Where(Gte(Col("age"), Lit(PInt(18)))), OrWhere(Eq(Col("admin"), Lit(PBool(true))))]
end

test "final push expr batch gamma" do
  assert And(Eq(Col("tenant_id"), ExprParam(1)), And(Gte(Col("ts"), ExprParam(2)), Lte(Col("ts"), ExprParam(3)))) == And(Eq(Col("tenant_id"), ExprParam(1)), And(Gte(Col("ts"), ExprParam(2)), Lte(Col("ts"), ExprParam(3))))
  assert Or(And(Eq(Col("type"), Lit(PString("a"))), Gt(Col("val"), Lit(PInt(0)))), And(Eq(Col("type"), Lit(PString("b"))), Lt(Col("val"), Lit(PInt(100))))) == Or(And(Eq(Col("type"), Lit(PString("a"))), Gt(Col("val"), Lit(PInt(0)))), And(Eq(Col("type"), Lit(PString("b"))), Lt(Col("val"), Lit(PInt(100)))))
  assert Not(And(IsNull(Col("x")), IsNull(Col("y")))) == Not(And(IsNull(Col("x")), IsNull(Col("y"))))
  assert And(Gte(Count(Col("id")), Lit(PInt(1))), And(Gt(Sum(Col("amount")), Lit(PFloat(0.0))), Lt(Avg(Col("score")), Lit(PFloat(10.0))))) == And(Gte(Count(Col("id")), Lit(PInt(1))), And(Gt(Sum(Col("amount")), Lit(PFloat(0.0))), Lt(Avg(Col("score")), Lit(PFloat(10.0)))))
  assert Or(Gt(Max(Col("score")), Lit(PInt(95))), And(Gt(Avg(Col("score")), Lit(PFloat(80.0))), Gte(Count(Col("id")), Lit(PInt(10))))) == Or(Gt(Max(Col("score")), Lit(PInt(95))), And(Gt(Avg(Col("score")), Lit(PFloat(80.0))), Gte(Count(Col("id")), Lit(PInt(10)))))
  assert SelectAs(FnCall("to_char", [Col("ts"), Lit(PString("YYYY-MM-DD HH24:MI"))]), "formatted") == SelectAs(FnCall("to_char", [Col("ts"), Lit(PString("YYYY-MM-DD HH24:MI"))]), "formatted")
  assert SelectAs(FnCall("coalesce", [Sum(Col("a")), Lit(PInt(0))]), "safe_sum") == SelectAs(FnCall("coalesce", [Sum(Col("a")), Lit(PInt(0))]), "safe_sum")
  assert SelectAs(FnCall("nullif", [Avg(Col("x")), Lit(PFloat(0.0))]), "safe_avg") == SelectAs(FnCall("nullif", [Avg(Col("x")), Lit(PFloat(0.0))]), "safe_avg")
  assert [SelectField(Col("id")), SelectField(Col("name")), SelectField(Col("status")), SelectField(Col("score")), SelectField(Col("created_at")), SelectField(Col("updated_at"))] == [SelectField(Col("id")), SelectField(Col("name")), SelectField(Col("status")), SelectField(Col("score")), SelectField(Col("created_at")), SelectField(Col("updated_at"))]
  assert [Where(Eq(Col("active"), Lit(PBool(true)))), Where(Neq(Col("status"), Lit(PString("banned")))), Where(IsNotNull(Col("email"))), Where(Gte(Col("age"), Lit(PInt(18))))] == [Where(Eq(Col("active"), Lit(PBool(true)))), Where(Neq(Col("status"), Lit(PString("banned")))), Where(IsNotNull(Col("email"))), Where(Gte(Col("age"), Lit(PInt(18))))]
  assert [JoinClause(Inner, "u", Eq(QCol("o", "user_id"), QCol("u", "id"))), JoinClause(Left, "p", Eq(QCol("o", "product_id"), QCol("p", "id"))), JoinClause(Left, "c", Eq(QCol("p", "cat_id"), QCol("c", "id"))), JoinClause(Left, "t", Eq(QCol("p", "type_id"), QCol("t", "id")))] == [JoinClause(Inner, "u", Eq(QCol("o", "user_id"), QCol("u", "id"))), JoinClause(Left, "p", Eq(QCol("o", "product_id"), QCol("p", "id"))), JoinClause(Left, "c", Eq(QCol("p", "cat_id"), QCol("c", "id"))), JoinClause(Left, "t", Eq(QCol("p", "type_id"), QCol("t", "id")))]
  assert [OrderExpr(Col("priority"), Asc), OrderExpr(Col("created_at"), Desc), OrderExpr(Col("id"), Asc)] == [OrderExpr(Col("priority"), Asc), OrderExpr(Col("created_at"), Desc), OrderExpr(Col("id"), Asc)]
  assert Or(In(Col("role"), [Lit(PString("admin")), Lit(PString("superuser"))]), And(Eq(Col("role"), Lit(PString("staff"))), Eq(Col("dept"), Lit(PString("engineering"))))) == Or(In(Col("role"), [Lit(PString("admin")), Lit(PString("superuser"))]), And(Eq(Col("role"), Lit(PString("staff"))), Eq(Col("dept"), Lit(PString("engineering")))))
  assert And(NotIn(Col("status"), [Lit(PString("x")), Lit(PString("y")), Lit(PString("z"))]), And(IsNotNull(Col("email")), IsNotNull(Col("name")))) == And(NotIn(Col("status"), [Lit(PString("x")), Lit(PString("y")), Lit(PString("z"))]), And(IsNotNull(Col("email")), IsNotNull(Col("name"))))
  assert Gt(FnCall("length", [Col("password")]), Lit(PInt(12))) == Gt(FnCall("length", [Col("password")]), Lit(PInt(12)))
  assert And(Like(Col("email"), "%@%"), Gt(FnCall("length", [Col("email")]), Lit(PInt(5)))) == And(Like(Col("email"), "%@%"), Gt(FnCall("length", [Col("email")]), Lit(PInt(5))))
  assert Or(ILike(Col("name"), "%alice%"), ILike(Col("username"), "%alice%")) == Or(ILike(Col("name"), "%alice%"), ILike(Col("username"), "%alice%"))
  assert And(Eq(QCol("u", "active"), Lit(PBool(true))), And(IsNotNull(QCol("u", "email")), Eq(QCol("u", "email_verified"), Lit(PBool(true))))) == And(Eq(QCol("u", "active"), Lit(PBool(true))), And(IsNotNull(QCol("u", "email")), Eq(QCol("u", "email_verified"), Lit(PBool(true)))))
  assert Eq(Add(Mul(Col("a"), Col("b")), Div(Col("c"), Col("d"))), Sub(Col("e"), Col("f"))) == Eq(Add(Mul(Col("a"), Col("b")), Div(Col("c"), Col("d"))), Sub(Col("e"), Col("f")))
  assert Gt(Div(Sum(Col("revenue")), Count(Col("id"))), Mul(Avg(Col("revenue")), Lit(PFloat(1.1)))) == Gt(Div(Sum(Col("revenue")), Count(Col("id"))), Mul(Avg(Col("revenue")), Lit(PFloat(1.1))))
  assert [SelectAs(Col("id"), "id"), SelectAs(Col("name"), "name"), SelectAs(Col("email"), "email"), SelectAs(Col("created_at"), "created"), SelectAs(Col("score"), "score"), SelectAs(Col("active"), "active")] == [SelectAs(Col("id"), "id"), SelectAs(Col("name"), "name"), SelectAs(Col("email"), "email"), SelectAs(Col("created_at"), "created"), SelectAs(Col("score"), "score"), SelectAs(Col("active"), "active")]
  assert [Col("a"), Col("b"), Col("c"), Col("d"), Col("e"), Col("f"), Col("g"), Col("h")] == [Col("a"), Col("b"), Col("c"), Col("d"), Col("e"), Col("f"), Col("g"), Col("h")]
  assert [ExprParam(1), ExprParam(2), ExprParam(3), ExprParam(4), ExprParam(5), ExprParam(6)] == [ExprParam(1), ExprParam(2), ExprParam(3), ExprParam(4), ExprParam(5), ExprParam(6)]
end

test "final push expr batch delta" do
  assert And(Eq(Col("org_id"), ExprParam(1)), And(Eq(Col("active"), Lit(PBool(true))), And(IsNotNull(Col("email")), Gte(Col("age"), Lit(PInt(18)))))) == And(Eq(Col("org_id"), ExprParam(1)), And(Eq(Col("active"), Lit(PBool(true))), And(IsNotNull(Col("email")), Gte(Col("age"), Lit(PInt(18))))))
  assert Or(And(Eq(Col("role"), Lit(PString("owner"))), Eq(Col("org_id"), ExprParam(1))), And(In(Col("role"), [Lit(PString("admin")), Lit(PString("editor"))]), And(Eq(Col("org_id"), ExprParam(1)), Eq(Col("active"), Lit(PBool(true)))))) == Or(And(Eq(Col("role"), Lit(PString("owner"))), Eq(Col("org_id"), ExprParam(1))), And(In(Col("role"), [Lit(PString("admin")), Lit(PString("editor"))]), And(Eq(Col("org_id"), ExprParam(1)), Eq(Col("active"), Lit(PBool(true))))))
  assert And(Between(Col("score"), Lit(PInt(60)), Lit(PInt(100))), And(Eq(Col("course_id"), ExprParam(1)), IsNotNull(Col("completed_at")))) == And(Between(Col("score"), Lit(PInt(60)), Lit(PInt(100))), And(Eq(Col("course_id"), ExprParam(1)), IsNotNull(Col("completed_at"))))
  assert Gt(Sub(Max(Col("end_at")), Min(Col("start_at"))), Lit(PInt(0))) == Gt(Sub(Max(Col("end_at")), Min(Col("start_at"))), Lit(PInt(0)))
  assert SelectAs(FnCall("greatest", [Avg(Col("a")), Avg(Col("b")), Avg(Col("c"))]), "best_avg") == SelectAs(FnCall("greatest", [Avg(Col("a")), Avg(Col("b")), Avg(Col("c"))]), "best_avg")
  assert SelectAs(FnCall("least", [Min(Col("x")), Min(Col("y"))]), "overall_min") == SelectAs(FnCall("least", [Min(Col("x")), Min(Col("y"))]), "overall_min")
  assert [SelectField(Col("id")), SelectField(Col("name")), SelectField(Col("email")), SelectField(Col("role")), SelectField(Col("active")), SelectField(Col("created_at")), SelectField(Col("updated_at")), SelectField(Col("deleted_at"))] == [SelectField(Col("id")), SelectField(Col("name")), SelectField(Col("email")), SelectField(Col("role")), SelectField(Col("active")), SelectField(Col("created_at")), SelectField(Col("updated_at")), SelectField(Col("deleted_at"))]
  assert [Where(Eq(Col("active"), Lit(PBool(true)))), Where(Gte(Col("score"), Lit(PInt(0)))), Where(Lte(Col("score"), Lit(PInt(100)))), Where(IsNotNull(Col("name"))), OrWhere(Eq(Col("admin"), Lit(PBool(true))))] == [Where(Eq(Col("active"), Lit(PBool(true)))), Where(Gte(Col("score"), Lit(PInt(0)))), Where(Lte(Col("score"), Lit(PInt(100)))), Where(IsNotNull(Col("name"))), OrWhere(Eq(Col("admin"), Lit(PBool(true))))]
  assert Or(And(Eq(Col("a"), Lit(PInt(1))), And(Eq(Col("b"), Lit(PInt(2))), Eq(Col("c"), Lit(PInt(3))))), And(Eq(Col("d"), Lit(PInt(4))), And(Eq(Col("e"), Lit(PInt(5))), Eq(Col("f"), Lit(PInt(6)))))) == Or(And(Eq(Col("a"), Lit(PInt(1))), And(Eq(Col("b"), Lit(PInt(2))), Eq(Col("c"), Lit(PInt(3))))), And(Eq(Col("d"), Lit(PInt(4))), And(Eq(Col("e"), Lit(PInt(5))), Eq(Col("f"), Lit(PInt(6))))))
  assert Gt(Add(Sum(Col("revenue")), Sum(Col("bonus"))), Mul(Avg(Col("cost")), Lit(PFloat(1.5)))) == Gt(Add(Sum(Col("revenue")), Sum(Col("bonus"))), Mul(Avg(Col("cost")), Lit(PFloat(1.5))))
  assert Gte(Div(Add(Count(Col("active")), Count(Col("trial"))), Count(Col("total"))), Lit(PFloat(0.8))) == Gte(Div(Add(Count(Col("active")), Count(Col("trial"))), Count(Col("total"))), Lit(PFloat(0.8)))
  assert [QCol("a","id"), QCol("b","id"), QCol("c","id"), QCol("d","id"), QCol("e","id"), QCol("f","id")] == [QCol("a","id"), QCol("b","id"), QCol("c","id"), QCol("d","id"), QCol("e","id"), QCol("f","id")]
end

