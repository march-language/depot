test "final push expr batch delta" do
  assert Expr.And(Expr.Eq(Expr.Col("org_id"), ExprParam(1)), Expr.And(Expr.Eq(Expr.Col("active"), Lit(PBool(true))), Expr.And(Expr.IsNotNull(Expr.Col("email")), Expr.Gte(Expr.Col("age"), Lit(PInt(18)))))) == Expr.And(Expr.Eq(Expr.Col("org_id"), ExprParam(1)), Expr.And(Expr.Eq(Expr.Col("active"), Lit(PBool(true))), Expr.And(Expr.IsNotNull(Expr.Col("email")), Expr.Gte(Expr.Col("age"), Lit(PInt(18))))))
  assert Expr.Or(Expr.And(Expr.Eq(Expr.Col("role"), Lit(PString("owner"))), Expr.Eq(Expr.Col("org_id"), ExprParam(1))), Expr.And(In(Expr.Col("role"), [Lit(PString("admin")), Lit(PString("editor"))]), Expr.And(Expr.Eq(Expr.Col("org_id"), ExprParam(1)), Expr.Eq(Expr.Col("active"), Lit(PBool(true)))))) == Expr.Or(Expr.And(Expr.Eq(Expr.Col("role"), Lit(PString("owner"))), Expr.Eq(Expr.Col("org_id"), ExprParam(1))), Expr.And(In(Expr.Col("role"), [Lit(PString("admin")), Lit(PString("editor"))]), Expr.And(Expr.Eq(Expr.Col("org_id"), ExprParam(1)), Expr.Eq(Expr.Col("active"), Lit(PBool(true))))))
  assert Expr.And(Between(Expr.Col("score"), Lit(PInt(60)), Lit(PInt(100))), Expr.And(Expr.Eq(Expr.Col("course_id"), ExprParam(1)), Expr.IsNotNull(Expr.Col("completed_at")))) == Expr.And(Between(Expr.Col("score"), Lit(PInt(60)), Lit(PInt(100))), Expr.And(Expr.Eq(Expr.Col("course_id"), ExprParam(1)), Expr.IsNotNull(Expr.Col("completed_at"))))
  assert Expr.Gt(Expr.Sub(Expr.Max(Expr.Col("end_at")), Expr.Min(Expr.Col("start_at"))), Lit(PInt(0))) == Expr.Gt(Expr.Sub(Expr.Max(Expr.Col("end_at")), Expr.Min(Expr.Col("start_at"))), Lit(PInt(0)))
  assert SelectAs(FnCall("greatest", [Avg(Expr.Col("a")), Avg(Expr.Col("b")), Avg(Expr.Col("c"))]), "best_avg") == SelectAs(FnCall("greatest", [Avg(Expr.Col("a")), Avg(Expr.Col("b")), Avg(Expr.Col("c"))]), "best_avg")
  assert SelectAs(FnCall("least", [Expr.Min(Expr.Col("x")), Expr.Min(Expr.Col("y"))]), "overall_min") == SelectAs(FnCall("least", [Expr.Min(Expr.Col("x")), Expr.Min(Expr.Col("y"))]), "overall_min")
  assert [SelectField(Expr.Col("id")), SelectField(Expr.Col("name")), SelectField(Expr.Col("email")), SelectField(Expr.Col("role")), SelectField(Expr.Col("active")), SelectField(Expr.Col("created_at")), SelectField(Expr.Col("updated_at")), SelectField(Expr.Col("deleted_at"))] == [SelectField(Expr.Col("id")), SelectField(Expr.Col("name")), SelectField(Expr.Col("email")), SelectField(Expr.Col("role")), SelectField(Expr.Col("active")), SelectField(Expr.Col("created_at")), SelectField(Expr.Col("updated_at")), SelectField(Expr.Col("deleted_at"))]
  assert [Where(Expr.Eq(Expr.Col("active"), Lit(PBool(true)))), Where(Expr.Gte(Expr.Col("score"), Lit(PInt(0)))), Where(Expr.Lte(Expr.Col("score"), Lit(PInt(100)))), Where(Expr.IsNotNull(Expr.Col("name"))), OrWhere(Expr.Eq(Expr.Col("admin"), Lit(PBool(true))))] == [Where(Expr.Eq(Expr.Col("active"), Lit(PBool(true)))), Where(Expr.Gte(Expr.Col("score"), Lit(PInt(0)))), Where(Expr.Lte(Expr.Col("score"), Lit(PInt(100)))), Where(Expr.IsNotNull(Expr.Col("name"))), OrWhere(Expr.Eq(Expr.Col("admin"), Lit(PBool(true))))]
  assert Expr.Or(Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.And(Expr.Eq(Expr.Col("b"), Lit(PInt(2))), Expr.Eq(Expr.Col("c"), Lit(PInt(3))))), Expr.And(Expr.Eq(Expr.Col("d"), Lit(PInt(4))), Expr.And(Expr.Eq(Expr.Col("e"), Lit(PInt(5))), Expr.Eq(Expr.Col("f"), Lit(PInt(6)))))) == Expr.Or(Expr.And(Expr.Eq(Expr.Col("a"), Lit(PInt(1))), Expr.And(Expr.Eq(Expr.Col("b"), Lit(PInt(2))), Expr.Eq(Expr.Col("c"), Lit(PInt(3))))), Expr.And(Expr.Eq(Expr.Col("d"), Lit(PInt(4))), Expr.And(Expr.Eq(Expr.Col("e"), Lit(PInt(5))), Expr.Eq(Expr.Col("f"), Lit(PInt(6))))))
  assert Expr.Gt(Expr.Add(Expr.Sum(Expr.Col("revenue")), Expr.Sum(Expr.Col("bonus"))), Expr.Mul(Avg(Expr.Col("cost")), Lit(PFloat(1.5)))) == Expr.Gt(Expr.Add(Expr.Sum(Expr.Col("revenue")), Expr.Sum(Expr.Col("bonus"))), Expr.Mul(Avg(Expr.Col("cost")), Lit(PFloat(1.5))))
  assert Expr.Gte(Expr.Div(Expr.Add(Expr.Count(Expr.Col("active")), Expr.Count(Expr.Col("trial"))), Expr.Count(Expr.Col("total"))), Lit(PFloat(0.8))) == Expr.Gte(Expr.Div(Expr.Add(Expr.Count(Expr.Col("active")), Expr.Count(Expr.Col("trial"))), Expr.Count(Expr.Col("total"))), Lit(PFloat(0.8)))
  assert [QCol("a","id"), QCol("b","id"), QCol("c","id"), QCol("d","id"), QCol("e","id"), QCol("f","id")] == [QCol("a","id"), QCol("b","id"), QCol("c","id"), QCol("d","id"), QCol("e","id"), QCol("f","id")]
end

