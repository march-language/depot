-- Tests for Depot.Repo: in-memory Vault-backed repository.

mod TestDepotRepo do

-- Helper: define a simple users schema for testing.
fn user_schema() do
  Depot.Schema.define("test_repo_users", {
    fields: {
      name: "String",
      email: "String",
      age: ("Int", { default: 0 }),
      role: ("String", { default: "user" })
    }
  })
end

-- Helper: check if result is Err.
fn is_err(result) do
  match result do
    Ok(_) -> false
    Err(_) -> true
  end
end

-- Helper: check if option is None.
fn is_none(opt) do
  match opt do
    Some(_) -> false
    None -> true
  end
end

-- Helper: insert a user and return Result(record, gate).
fn insert_user(name, email, age, role) do
  let schema = user_schema()
  let blank = Depot.Schema.blank(schema)
  let params = { name: name, email: email, age: age, role: role }
  let gate = Depot.Gate.cast_record(blank, params, ["name", "email", "age", "role"])
  Depot.Repo.insert(schema, gate)
end

-- Helper: clear all test data before each test group.
fn clear_users() do
  Depot.Repo.delete_all(user_schema())
end

-- =========================================================================
-- insert tests
-- =========================================================================

test "insert returns Ok with a record" do
  clear_users()
  let schema = user_schema()
  let blank = Depot.Schema.blank(schema)
  let params = { name: "Alice", email: "alice@test.com", age: 30, role: "admin" }
  let gate = Depot.Gate.cast_record(blank, params, ["name", "email", "age", "role"])
  match Depot.Repo.insert(schema, gate) do
    Err(_) -> assert false
    Ok(record) -> do
      assert record.name == "Alice"
      assert record.email == "alice@test.com"
      assert to_string(record.age) == "30"
      assert record.role == "admin"
    end
  end
end

test "insert auto-generates a primary key (id)" do
  clear_users()
  let schema = user_schema()
  let blank = Depot.Schema.blank(schema)
  let params = { name: "Bob", email: "bob@test.com", age: 25, role: "user" }
  let gate = Depot.Gate.cast_record(blank, params, ["name", "email", "age", "role"])
  match Depot.Repo.insert(schema, gate) do
    Err(_) -> assert false
    Ok(record) -> assert String.byte_size(record.id) > 0
  end
end

test "insert returns Err when gate is invalid" do
  clear_users()
  let schema = user_schema()
  let blank = Depot.Schema.blank(schema)
  let params = { name: "", email: "", age: 0, role: "user" }
  let gate = Depot.Gate.cast_record(blank, params, ["name", "email"])
    |> Depot.Gate.validate_required(["name", "email"])
  let result = Depot.Repo.insert(schema, gate)
  assert is_err(result) == true
  match result do
    Err(g) -> assert Depot.Gate.is_valid(g) == false
    Ok(_)  -> assert false
  end
end

test "insert stores the record in Vault" do
  clear_users()
  match insert_user("Charlie", "charlie@test.com", 35, "user") do
    Err(_) -> assert false
    Ok(record) ->
      match Depot.Repo.get(user_schema(), record.id) do
        None    -> assert false
        Some(fetched) -> assert fetched.name == "Charlie"
      end
  end
end

test "insert multiple records" do
  clear_users()
  let _ = insert_user("Alice", "alice@test.com", 30, "admin")
  let _ = insert_user("Bob", "bob@test.com", 25, "user")
  let _ = insert_user("Charlie", "charlie@test.com", 35, "user")
  assert Depot.Repo.count(user_schema()) == 3
end

-- =========================================================================
-- all tests
-- =========================================================================

test "all returns empty list when no records" do
  clear_users()
  let rows = Depot.Repo.all(user_schema())
  assert List.length(rows) == 0
end

test "all returns all inserted records" do
  clear_users()
  let _ = insert_user("Alice", "alice@test.com", 30, "admin")
  let _ = insert_user("Bob", "bob@test.com", 25, "user")
  let rows = Depot.Repo.all(user_schema())
  assert List.length(rows) == 2
end

-- =========================================================================
-- get tests
-- =========================================================================

test "get returns Some for existing record" do
  clear_users()
  match insert_user("Alice", "alice@test.com", 30, "admin") do
    Err(_) -> assert false
    Ok(record) ->
      match Depot.Repo.get(user_schema(), record.id) do
        None    -> assert false
        Some(fetched) -> assert fetched.email == "alice@test.com"
      end
  end
end

test "get returns None for missing id" do
  clear_users()
  assert is_none(Depot.Repo.get(user_schema(), "nonexistent")) == true
end

-- =========================================================================
-- get_bang tests
-- =========================================================================

test "get_bang returns record for existing id" do
  clear_users()
  match insert_user("Alice", "alice@test.com", 30, "admin") do
    Err(_) -> assert false
    Ok(record) ->
      match Depot.Repo.get_bang(user_schema(), record.id) do
        Err(_)       -> assert false
        Ok(fetched)  -> assert fetched.name == "Alice"
      end
  end
end

-- =========================================================================
-- get_by tests
-- =========================================================================

test "get_by finds record matching single field" do
  clear_users()
  let _ = insert_user("Alice", "alice@test.com", 30, "admin")
  let _ = insert_user("Bob", "bob@test.com", 25, "user")
  match Depot.Repo.get_by(user_schema(), { email: "bob@test.com" }) do
    None    -> assert false
    Some(found) -> assert found.name == "Bob"
  end
end

test "get_by finds record matching multiple fields" do
  clear_users()
  let _ = insert_user("Alice", "alice@test.com", 30, "admin")
  let _ = insert_user("Bob", "bob@test.com", 25, "user")
  let _ = insert_user("Charlie", "charlie@test.com", 35, "user")
  match Depot.Repo.get_by(user_schema(), { role: "user", name: "Charlie" }) do
    None    -> assert false
    Some(found) -> assert found.email == "charlie@test.com"
  end
end

test "get_by returns None when no match" do
  clear_users()
  let _ = insert_user("Alice", "alice@test.com", 30, "admin")
  assert is_none(Depot.Repo.get_by(user_schema(), { email: "nobody@test.com" })) == true
end

-- =========================================================================
-- one tests
-- =========================================================================

test "one returns Some when exactly one record" do
  clear_users()
  let _ = insert_user("Alice", "alice@test.com", 30, "admin")
  match Depot.Repo.one(user_schema()) do
    None    -> assert false
    Some(found) -> assert found.name == "Alice"
  end
end

test "one returns None when zero records" do
  clear_users()
  assert is_none(Depot.Repo.one(user_schema())) == true
end

test "one returns None when multiple records" do
  clear_users()
  let _ = insert_user("Alice", "alice@test.com", 30, "admin")
  let _ = insert_user("Bob", "bob@test.com", 25, "user")
  assert is_none(Depot.Repo.one(user_schema())) == true
end

-- =========================================================================
-- count tests
-- =========================================================================

test "count returns 0 when empty" do
  clear_users()
  assert Depot.Repo.count(user_schema()) == 0
end

test "count returns correct number" do
  clear_users()
  let _ = insert_user("A", "a@test.com", 1, "user")
  let _ = insert_user("B", "b@test.com", 2, "user")
  let _ = insert_user("C", "c@test.com", 3, "admin")
  assert Depot.Repo.count(user_schema()) == 3
end

-- =========================================================================
-- exists tests
-- =========================================================================

test "exists returns false when empty" do
  clear_users()
  assert Depot.Repo.exists(user_schema()) == false
end

test "exists returns true when records present" do
  clear_users()
  let _ = insert_user("Alice", "alice@test.com", 30, "admin")
  assert Depot.Repo.exists(user_schema()) == true
end

-- =========================================================================
-- delete tests
-- =========================================================================

test "delete removes a record by id and returns Ok" do
  clear_users()
  match insert_user("Alice", "alice@test.com", 30, "admin") do
    Err(_) -> assert false
    Ok(record) -> do
      assert Depot.Repo.count(user_schema()) == 1
      match Depot.Repo.delete(user_schema(), record.id) do
        Ok(id) -> assert id == record.id
        Err(_) -> assert false
      end
      assert Depot.Repo.count(user_schema()) == 0
    end
  end
end

test "delete returns Err for missing id" do
  clear_users()
  let _ = insert_user("Alice", "alice@test.com", 30, "admin")
  match Depot.Repo.delete(user_schema(), "nonexistent") do
    Err(msg) -> assert msg == "not found"
    Ok(_)    -> assert false
  end
  assert Depot.Repo.count(user_schema()) == 1
end

-- =========================================================================
-- delete_all tests
-- =========================================================================

test "delete_all removes all records" do
  clear_users()
  let _ = insert_user("A", "a@test.com", 1, "user")
  let _ = insert_user("B", "b@test.com", 2, "user")
  let _ = insert_user("C", "c@test.com", 3, "admin")
  let n = Depot.Repo.delete_all(user_schema())
  assert n == 3
  assert Depot.Repo.count(user_schema()) == 0
end

test "delete_all returns 0 when empty" do
  clear_users()
  let n = Depot.Repo.delete_all(user_schema())
  assert n == 0
end

-- =========================================================================
-- update tests
-- =========================================================================

test "update changes fields on existing record" do
  clear_users()
  match insert_user("Alice", "alice@test.com", 30, "user") do
    Err(_) -> assert false
    Ok(record) -> do
      let schema = user_schema()
      let params = { name: "Alicia", email: "alice@test.com", age: 30, role: "admin" }
      let gate = Depot.Gate.cast_record(record, params, ["name", "role"])
      match Depot.Repo.update(schema, gate) do
        Err(_) -> assert false
        Ok(updated) -> do
          assert updated.name == "Alicia"
          assert updated.role == "admin"
          assert updated.id == record.id
        end
      end
    end
  end
end

test "update persists to Vault" do
  clear_users()
  match insert_user("Alice", "alice@test.com", 30, "user") do
    Err(_) -> assert false
    Ok(record) -> do
      let schema = user_schema()
      let params = { name: "Alicia", email: "alice@test.com", age: 30, role: "admin" }
      let gate = Depot.Gate.cast_record(record, params, ["name", "role"])
      let _ = Depot.Repo.update(schema, gate)
      match Depot.Repo.get(schema, record.id) do
        None    -> assert false
        Some(fetched) -> do
          assert fetched.name == "Alicia"
          assert fetched.role == "admin"
        end
      end
    end
  end
end

test "update returns Err when gate is invalid" do
  clear_users()
  match insert_user("Alice", "alice@test.com", 30, "user") do
    Err(_) -> assert false
    Ok(record) -> do
      let schema = user_schema()
      let params = { name: "", email: "alice@test.com", age: 30, role: "admin" }
      let gate = Depot.Gate.cast_record(record, params, ["name", "role"])
        |> Depot.Gate.validate_required(["name"])
      let result = Depot.Repo.update(schema, gate)
      assert is_err(result) == true
      match result do
        Err(g) -> assert Depot.Gate.is_valid(g) == false
        Ok(_)  -> assert false
      end
    end
  end
end

test "update returns Err when pk not in gate base" do
  let schema = user_schema()
  let base_no_pk = { name: "Alice", email: "alice@test.com" }
  let params = { name: "Bob", email: "bob@test.com" }
  let gate = Depot.Gate.cast_record(base_no_pk, params, ["name", "email"])
  let result = Depot.Repo.update(schema, gate)
  assert is_err(result) == true
end

test "insert then get by id" do
  clear_users()
  match insert_user("Charlie", "charlie@test.com", 25, "user") do
    Err(_) -> assert false
    Ok(record) -> do
      let schema = user_schema()
      let found = Depot.Repo.get(schema, record.id)
      assert found != None
    end
  end
end

test "insert then delete then get returns None" do
  clear_users()
  match insert_user("Dana", "dana@test.com", 28, "user") do
    Err(_) -> assert false
    Ok(record) -> do
      let schema = user_schema()
      let del_result = Depot.Repo.delete(schema, record.id)
      assert del_result != Err("not found")
      let after = Depot.Repo.get(schema, record.id)
      assert after == None
    end
  end
end

test "delete returns Err for missing id" do
  let schema = user_schema()
  let result = Depot.Repo.delete(schema, "nonexistent-id-xyz")
  assert result == Err("not found")
end

test "all returns list of all records" do
  clear_users()
  let _ = insert_user("E1", "e1@test.com", 20, "user")
  let _ = insert_user("E2", "e2@test.com", 21, "user")
  let schema = user_schema()
  let records = Depot.Repo.all(schema)
  assert List.length(records) == 2
end

test "delete_all removes all records" do
  clear_users()
  let _ = insert_user("F1", "f1@test.com", 20, "user")
  let schema = user_schema()
  Depot.Repo.delete_all(schema)
  let records = Depot.Repo.all(schema)
  assert List.length(records) == 0
end

test "update changes field value" do
  clear_users()
  match insert_user("Greta", "g@test.com", 30, "user") do
    Err(_) -> assert false
    Ok(record) -> do
      let schema = user_schema()
      let params = { name: "Greta Updated", email: "g@test.com", age: 30, role: "user" }
      let gate = Depot.Gate.cast_record(record, params, ["name"])
      let result = Depot.Repo.update(schema, gate)
      assert is_err(result) == false
    end
  end
end

test "get returns None for missing id" do
  let schema = user_schema()
  let result = Depot.Repo.get(schema, "no-such-id-123")
  assert result == None
end

test "insert multiple users then all count" do
  clear_users()
  let _ = insert_user("H1", "h1@test.com", 20, "user")
  let _ = insert_user("H2", "h2@test.com", 21, "user")
  let _ = insert_user("H3", "h3@test.com", 22, "user")
  let schema = user_schema()
  let records = Depot.Repo.all(schema)
  assert List.length(records) == 3
end

end -- mod TestDepotRepo
