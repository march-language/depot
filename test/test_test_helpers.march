-- test/test_test_helpers.march
-- Tests for TestHelpers module (sandbox lifecycle).

mod TestTestHelpers do

import TestHelpers

-- ---- sandbox lifecycle ----

fn test_start_makes_active() do
  start_sandbox()
  assert(active())
  stop_sandbox()
end

fn test_stop_makes_inactive() do
  start_sandbox()
  stop_sandbox()
  assert(!active())
end

fn test_initially_inactive_after_stop() do
  stop_sandbox()
  assert(!active())
end

-- ---- checkout / checkin ----

fn test_checkout_checkin_roundtrip() do
  start_sandbox()
  let tbl = Vault.new("__th_test_tbl__")
  Vault.set(tbl, "key1", "original")
  checkout(Cons("__th_test_tbl__", Nil))
  Vault.set(tbl, "key1", "modified")
  assert(Vault.get(tbl, "key1") == Some("modified"))
  checkin()
  assert(Vault.get(tbl, "key1") == Some("original"))
  stop_sandbox()
end

fn test_checkin_restores_deleted_key() do
  start_sandbox()
  let tbl = Vault.new("__th_test_del__")
  Vault.set(tbl, "k", "value")
  checkout(Cons("__th_test_del__", Nil))
  Vault.drop(tbl, "k")
  assert(Vault.get(tbl, "k") == None)
  checkin()
  assert(Vault.get(tbl, "k") == Some("value"))
  stop_sandbox()
end

-- ---- sandboxed ----

fn test_sandboxed_returns_result() do
  start_sandbox()
  let result = sandboxed(Nil, fn () -> 42)
  stop_sandbox()
  assert(result == 42)
end

fn test_sandboxed_rolls_back() do
  start_sandbox()
  let tbl = Vault.new("__th_test_sb__")
  Vault.set(tbl, "x", "before")
  sandboxed(Cons("__th_test_sb__", Nil), fn () -> do
    Vault.set(tbl, "x", "during")
    ()
  end)
  assert(Vault.get(tbl, "x") == Some("before"))
  stop_sandbox()
end

end -- mod TestTestHelpers
