-- test/test_compile.march
-- Tests for SQL query compiler (compile).

mod TestCompile do

import Ast
import Message
import Compile

-- ---- Helpers ----

fn list_len(lst) do
  match lst do | Nil -> 0 | Cons(_, rest) -> 1 + list_len(rest) end
end

fn make_query(table) do
  Query({
    from_: FromTable(table), selects: Nil, wheres: Nil,
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct
  })
end

-- ---- Tests ----

test "simple SELECT *" do
  let q = make_query("users")
  let r = compile(q)
  assert r.sql == "SELECT * FROM \"users\""
  assert list_len(r.params) == 0
end

test "SELECT with columns" do
  let q = Query({
    from_: FromTable("posts"), selects: [SelectField(Col("id")), SelectField(Col("title"))],
    wheres: Nil, joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct
  })
  let r = compile(q)
  assert r.sql == "SELECT \"id\", \"title\" FROM \"posts\""
  assert list_len(r.params) == 0
end

test "WHERE with param" do
  let q = Query({
    from_: FromTable("users"),
    selects: Nil,
    wheres: [Where(Eq(Col("id"), Lit(PInt(42))))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct
  })
  let r = compile(q)
  assert r.sql == "SELECT * FROM \"users\" WHERE \"id\" = $1"
  assert list_len(r.params) == 1
  assert r.params == [ParamText("42")]
end

test "two WHERE params joined with AND" do
  let q = Query({
    from_: FromTable("products"),
    selects: Nil,
    wheres: [Where(Eq(Col("active"), Lit(PBool(true)))),
              Where(Eq(Col("price"), Lit(PInt(100))))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct
  })
  let r = compile(q)
  assert list_len(r.params) == 2
  assert r.sql == "SELECT * FROM \"products\" WHERE \"active\" = $1 AND \"price\" = $2"
end

test "NULL param" do
  let q = Query({
    from_: FromTable("t"),
    selects: Nil,
    wheres: [Where(Eq(Col("x"), Lit(PNull)))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct
  })
  let r = compile(q)
  assert r.params == [ParamNull]
end

test "LIMIT and OFFSET" do
  let q = Query({
    from_: FromTable("events"), selects: Nil, wheres: Nil,
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: Some(10), offset_: Some(20), distinct_: NoDistinct
  })
  let r = compile(q)
  assert r.sql == "SELECT * FROM \"events\" LIMIT 10 OFFSET 20"
end

test "SELECT DISTINCT" do
  let q = Query({
    from_: FromTable("tags"), selects: Nil, wheres: Nil,
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: Distinct
  })
  let r = compile(q)
  assert r.sql == "SELECT DISTINCT * FROM \"tags\""
end

test "ORDER BY DESC" do
  let q = Query({
    from_: FromTable("logs"), selects: Nil, wheres: Nil,
    joins: Nil, orders: [OrderExpr(Col("created_at"), Desc)],
    group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct
  })
  let r = compile(q)
  assert r.sql == "SELECT * FROM \"logs\" ORDER BY \"created_at\" DESC"
end

test "SELECT AS alias" do
  let q = Query({
    from_: FromTable("t"),
    selects: [SelectAs(CountAll, "total")],
    wheres: Nil, joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct
  })
  let r = compile(q)
  assert r.sql == "SELECT COUNT(*) AS \"total\" FROM \"t\""
end

test "IS NULL" do
  let q = Query({
    from_: FromTable("users"), selects: Nil,
    wheres: [Where(IsNull(Col("deleted_at")))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct
  })
  let r = compile(q)
  assert r.sql == "SELECT * FROM \"users\" WHERE \"deleted_at\" IS NULL"
end

test "IS NOT NULL" do
  let q = Query({
    from_: FromTable("users"), selects: Nil,
    wheres: [Where(IsNotNull(Col("confirmed_at")))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct
  })
  let r = compile(q)
  assert r.sql == "SELECT * FROM \"users\" WHERE \"confirmed_at\" IS NOT NULL"
end

test "Raw expr" do
  let q = Query({
    from_: FromTable("t"), selects: [SelectField(Raw("1+1"))],
    wheres: Nil, joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct
  })
  let r = compile(q)
  assert r.sql == "SELECT 1+1 FROM \"t\""
end

test "IN expr" do
  let q = Query({
    from_: FromTable("users"), selects: Nil,
    wheres: [Where(In(Col("id"), [Lit(PInt(1)), Lit(PInt(2)), Lit(PInt(3))]))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct
  })
  let r = compile(q)
  assert r.sql == "SELECT * FROM \"users\" WHERE \"id\" IN ($1, $2, $3)"
  assert list_len(r.params) == 3
end

test "NOT IN expr" do
  let q = Query({
    from_: FromTable("t"), selects: Nil,
    wheres: [Where(NotIn(Col("status"), [Lit(PString("banned")), Lit(PString("deleted"))]))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct
  })
  let r = compile(q)
  assert r.sql == "SELECT * FROM \"t\" WHERE \"status\" NOT IN ($1, $2)"
  assert list_len(r.params) == 2
end

test "BETWEEN expr" do
  let q = Query({
    from_: FromTable("products"), selects: Nil,
    wheres: [Where(Between(Col("price"), Lit(PInt(10)), Lit(PInt(100))))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct
  })
  let r = compile(q)
  assert r.sql == "SELECT * FROM \"products\" WHERE \"price\" BETWEEN $1 AND $2"
  assert list_len(r.params) == 2
end

test "IN inline" do
  let q = Query({
    from_: FromTable("t"), selects: Nil,
    wheres: [Where(In(Col("id"), [Lit(PInt(10)), Lit(PInt(20))]))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct
  })
  let r = compile_inline(q)
  assert r.sql == "SELECT * FROM \"t\" WHERE \"id\" IN (10, 20)"
end

test "BETWEEN inline" do
  let q = Query({
    from_: FromTable("t"), selects: Nil,
    wheres: [Where(Between(Col("score"), Lit(PInt(0)), Lit(PInt(100))))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct
  })
  let r = compile_inline(q)
  assert r.sql == "SELECT * FROM \"t\" WHERE \"score\" BETWEEN 0 AND 100"
end

test "qualified column QCol" do
  let q = Query({
    from_: FromTable("users"),
    selects: [SelectField(QCol("users", "id")), SelectField(QCol("orders", "total"))],
    wheres: Nil, joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct
  })
  let r = compile(q)
  assert r.sql == "SELECT \"users\".\"id\", \"orders\".\"total\" FROM \"users\""
end

test "AND / OR / NOT boolean operators" do
  let q = Query({
    from_: FromTable("t"), selects: Nil,
    wheres: [Where(And(
      Eq(Col("a"), Lit(PInt(1))),
      Or(Eq(Col("b"), Lit(PInt(2))), Not(IsNull(Col("c"))))
    ))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct
  })
  let r = compile(q)
  assert r.sql == "SELECT * FROM \"t\" WHERE (\"a\" = $1 AND (\"b\" = $2 OR NOT (\"c\" IS NULL)))"
end

test "OrWhere clause" do
  let q = Query({
    from_: FromTable("t"), selects: Nil,
    wheres: [Where(Eq(Col("a"), Lit(PInt(1)))), OrWhere(Eq(Col("b"), Lit(PInt(2))))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct
  })
  let r = compile(q)
  assert r.sql == "SELECT * FROM \"t\" WHERE \"a\" = $1 OR \"b\" = $2"
  assert list_len(r.params) == 2
end

test "INNER JOIN" do
  let q = Query({
    from_: FromTable("orders"), selects: Nil, wheres: Nil,
    joins: [JoinClause(Inner, "users", Eq(QCol("orders", "user_id"), QCol("users", "id")))],
    orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct
  })
  let r = compile(q)
  assert r.sql == "SELECT * FROM \"orders\" INNER JOIN \"users\" ON \"orders\".\"user_id\" = \"users\".\"id\""
end

test "LEFT JOIN" do
  let q = Query({
    from_: FromTable("users"), selects: Nil, wheres: Nil,
    joins: [JoinClause(Left, "posts", Eq(QCol("posts", "user_id"), QCol("users", "id")))],
    orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct
  })
  let r = compile(q)
  assert r.sql == "SELECT * FROM \"users\" LEFT JOIN \"posts\" ON \"posts\".\"user_id\" = \"users\".\"id\""
end

test "GROUP BY" do
  let q = Query({
    from_: FromTable("orders"),
    selects: [SelectField(Col("status")), SelectAs(CountAll, "n")],
    wheres: Nil, joins: Nil, orders: Nil,
    group_bys: [Col("status")],
    havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct
  })
  let r = compile(q)
  assert r.sql == "SELECT \"status\", COUNT(*) AS \"n\" FROM \"orders\" GROUP BY \"status\""
end

test "ORDER BY NULLS variants" do
  let q = Query({
    from_: FromTable("t"), selects: Nil, wheres: Nil, joins: Nil,
    orders: [
      OrderExpr(Col("a"), AscNullsFirst),
      OrderExpr(Col("b"), AscNullsLast),
      OrderExpr(Col("c"), DescNullsFirst),
      OrderExpr(Col("d"), DescNullsLast)
    ],
    group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct
  })
  let r = compile(q)
  assert r.sql == "SELECT * FROM \"t\" ORDER BY \"a\" ASC NULLS FIRST, \"b\" ASC NULLS LAST, \"c\" DESC NULLS FIRST, \"d\" DESC NULLS LAST"
end

test "FnCall expr" do
  let q = Query({
    from_: FromTable("t"),
    selects: [SelectField(FnCall("LOWER", [Col("email")]))],
    wheres: Nil, joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct
  })
  let r = compile(q)
  assert r.sql == "SELECT LOWER(\"email\") FROM \"t\""
end

test "LIKE with param" do
  let q = Query({
    from_: FromTable("users"), selects: Nil,
    wheres: [Where(Like(Col("name"), "%alice%"))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct
  })
  let r = compile(q)
  assert r.sql == "SELECT * FROM \"users\" WHERE \"name\" LIKE $1"
  assert list_len(r.params) == 1
end

test "string escaping in inline compile" do
  let q = Query({
    from_: FromTable("t"), selects: Nil,
    wheres: [Where(Eq(Col("name"), Lit(PString("O'Reilly"))))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct
  })
  let r = compile_inline(q)
  assert r.sql == "SELECT * FROM \"t\" WHERE \"name\" = 'O''Reilly'"
end

test "ILIKE in inline compile" do
  let q = Query({
    from_: FromTable("t"), selects: Nil,
    wheres: [Where(ILike(Col("bio"), "%engineer%"))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct
  })
  let r = compile_inline(q)
  assert r.sql == "SELECT * FROM \"t\" WHERE \"bio\" ILIKE '%engineer%'"
end

test "Neq operator" do
  let r = compile(Query({ from_: FromTable("users"), selects: Nil,
    wheres: [Where(Neq(Col("status"), Lit(PString("banned"))))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct }))
  assert r.sql == "SELECT * FROM \"users\" WHERE \"status\" <> $1"
  assert list_len(r.params) == 1
end

test "Lt Gt Lte Gte operators" do
  let lt_q = Query({ from_: FromTable("t"), selects: Nil,
    wheres: [Where(Lt(Col("age"), Lit(PInt(18))))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  assert (compile(lt_q)).sql == "SELECT * FROM \"t\" WHERE \"age\" < $1"

  let gt_q = Query({ from_: FromTable("t"), selects: Nil,
    wheres: [Where(Gt(Col("score"), Lit(PInt(100))))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  assert (compile(gt_q)).sql == "SELECT * FROM \"t\" WHERE \"score\" > $1"

  let lte_q = Query({ from_: FromTable("t"), selects: Nil,
    wheres: [Where(Lte(Col("n"), Lit(PInt(5))))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  assert (compile(lte_q)).sql == "SELECT * FROM \"t\" WHERE \"n\" <= $1"

  let gte_q = Query({ from_: FromTable("t"), selects: Nil,
    wheres: [Where(Gte(Col("n"), Lit(PInt(0))))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  assert (compile(gte_q)).sql == "SELECT * FROM \"t\" WHERE \"n\" >= $1"
end

test "Add Sub Mul Div arithmetic in WHERE" do
  let add_q = Query({ from_: FromTable("t"), selects: Nil,
    wheres: [Where(Eq(Add(Col("x"), Lit(PInt(1))), Lit(PInt(5))))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  assert (compile(add_q)).sql == "SELECT * FROM \"t\" WHERE \"x\" + $1 = $2"

  let sub_q = Query({ from_: FromTable("t"), selects: Nil,
    wheres: [Where(Eq(Sub(Col("a"), Col("b")), Lit(PInt(0))))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  assert (compile(sub_q)).sql == "SELECT * FROM \"t\" WHERE \"a\" - \"b\" = $1"

  let mul_q = Query({ from_: FromTable("t"), selects: Nil,
    wheres: [Where(Eq(Mul(Col("price"), Lit(PInt(2))), Lit(PInt(100))))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  assert (compile(mul_q)).sql == "SELECT * FROM \"t\" WHERE \"price\" * $1 = $2"

  let div_q = Query({ from_: FromTable("t"), selects: Nil,
    wheres: [Where(Eq(Div(Col("total"), Lit(PInt(100))), Lit(PInt(1))))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  assert (compile(div_q)).sql == "SELECT * FROM \"t\" WHERE \"total\" / $1 = $2"
end

test "aggregate functions in SELECT" do
  let q = Query({ from_: FromTable("sales"),
    selects: [SelectField(Sum(Col("amount"))),
               SelectField(Avg(Col("score"))),
               SelectField(Min(Col("price"))),
               SelectField(Max(Col("price"))),
               SelectField(Count(Col("id"))),
               SelectField(CountAll)],
    wheres: Nil, joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let r = compile(q)
  assert r.sql == "SELECT SUM(\"amount\"), AVG(\"score\"), MIN(\"price\"), MAX(\"price\"), COUNT(\"id\"), COUNT(*) FROM \"sales\""
end

test "ExprParam in WHERE" do
  let q = Query({ from_: FromTable("t"), selects: Nil,
    wheres: [Where(Gte(Col("n"), ExprParam(5)))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let r = compile(q)
  assert r.sql == "SELECT * FROM \"t\" WHERE \"n\" >= $5"
  assert list_len(r.params) == 0
end

test "Exists in WHERE" do
  let sub = Query({ from_: FromTable("orders"), selects: Nil,
    wheres: [Where(Eq(Col("user_id"), Col("id")))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let q = Query({ from_: FromTable("users"), selects: Nil,
    wheres: [Where(Exists(sub))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let r = compile(q)
  assert r.sql == "SELECT * FROM \"users\" WHERE EXISTS (SELECT * FROM \"orders\" WHERE \"user_id\" = \"id\")"
end

test "SubqueryExpr in SELECT" do
  let sub = Query({ from_: FromTable("counts"), selects: [SelectField(CountAll)],
    wheres: Nil, joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let q = Query({ from_: FromTable("t"),
    selects: [SelectAs(SubqueryExpr(sub), "total")],
    wheres: Nil, joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let r = compile(q)
  assert r.sql == "SELECT (SELECT COUNT(*) FROM \"counts\") AS \"total\" FROM \"t\""
end

test "SelectAll in SELECT list" do
  let q = Query({ from_: FromTable("t"),
    selects: [SelectAll],
    wheres: Nil, joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let r = compile(q)
  assert r.sql == "SELECT * FROM \"t\""
end

test "compile_inline with comparison operators" do
  let q = Query({ from_: FromTable("t"), selects: Nil,
    wheres: [Where(Neq(Col("x"), Lit(PInt(0)))),
              Where(Lt(Col("age"), Lit(PInt(18)))),
              Where(Gt(Col("score"), Lit(PInt(100)))),
              Where(Lte(Col("n"), Lit(PInt(5)))),
              Where(Gte(Col("n"), Lit(PInt(0))))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let r = compile_inline(q)
  assert r.sql == "SELECT * FROM \"t\" WHERE \"x\" <> 0 AND \"age\" < 18 AND \"score\" > 100 AND \"n\" <= 5 AND \"n\" >= 0"
end

test "compile_inline with arithmetic" do
  let q = Query({ from_: FromTable("t"), selects: Nil,
    wheres: [Where(Eq(Add(Col("a"), Col("b")), Lit(PInt(10)))),
              Where(Eq(Sub(Col("x"), Lit(PInt(1))), Lit(PInt(0)))),
              Where(Eq(Mul(Col("p"), Lit(PInt(2))), Lit(PInt(8)))),
              Where(Eq(Div(Col("total"), Lit(PInt(4))), Lit(PInt(5))))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let r = compile_inline(q)
  assert r.sql == "SELECT * FROM \"t\" WHERE \"a\" + \"b\" = 10 AND \"x\" - 1 = 0 AND \"p\" * 2 = 8 AND \"total\" / 4 = 5"
end

test "compile_inline with aggregates in SELECT" do
  let q = Query({ from_: FromTable("sales"),
    selects: [SelectField(Sum(Col("amount"))), SelectField(Avg(Col("score"))),
               SelectField(Min(Col("price"))), SelectField(Max(Col("price"))),
               SelectField(Count(Col("id"))), SelectField(CountAll)],
    wheres: Nil, joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let r = compile_inline(q)
  assert r.sql == "SELECT SUM(\"amount\"), AVG(\"score\"), MIN(\"price\"), MAX(\"price\"), COUNT(\"id\"), COUNT(*) FROM \"sales\""
end

test "compile_inline ExprParam and Raw" do
  let q = Query({ from_: FromTable("t"), selects: Nil,
    wheres: [Where(Gte(Col("n"), ExprParam(3))),
              Where(Raw("x IS DISTINCT FROM NULL"))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let r = compile_inline(q)
  assert r.sql == "SELECT * FROM \"t\" WHERE \"n\" >= $3 AND x IS DISTINCT FROM NULL"
end

test "compile_inline Exists" do
  let sub = Query({ from_: FromTable("orders"), selects: Nil,
    wheres: [Where(Eq(Col("user_id"), Col("id")))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let q = Query({ from_: FromTable("users"), selects: Nil,
    wheres: [Where(Exists(sub))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let r = compile_inline(q)
  assert r.sql == "SELECT * FROM \"users\" WHERE EXISTS (SELECT * FROM \"orders\" WHERE \"user_id\" = \"id\")"
end

test "compile_inline SubqueryExpr" do
  let sub = Query({ from_: FromTable("counts"), selects: [SelectField(CountAll)],
    wheres: Nil, joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let q = Query({ from_: FromTable("t"),
    selects: [SelectAs(SubqueryExpr(sub), "cnt")],
    wheres: Nil, joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let r = compile_inline(q)
  assert r.sql == "SELECT (SELECT COUNT(*) FROM \"counts\") AS \"cnt\" FROM \"t\""
end

test "compile_inline SelectAll item" do
  let q = Query({ from_: FromTable("t"), selects: [SelectAll],
    wheres: Nil, joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let r = compile_inline(q)
  assert r.sql == "SELECT * FROM \"t\""
end

test "compile_inline RIGHT JOIN and FULL OUTER JOIN" do
  let rj_q = Query({ from_: FromTable("a"), selects: Nil,
    joins: [JoinClause(Right, "b", Eq(Col("a_id"), Col("id")))],
    wheres: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let rj = compile_inline(rj_q)
  assert rj.sql == "SELECT * FROM \"a\" RIGHT JOIN \"b\" ON \"a_id\" = \"id\""

  let fj_q = Query({ from_: FromTable("a"), selects: Nil,
    joins: [JoinClause(FullOuter, "b", Eq(Col("a_id"), Col("id")))],
    wheres: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let fj = compile_inline(fj_q)
  assert fj.sql == "SELECT * FROM \"a\" FULL OUTER JOIN \"b\" ON \"a_id\" = \"id\""
end

test "compile_inline CROSS JOIN" do
  let q = Query({ from_: FromTable("a"), selects: Nil,
    joins: [JoinClause(Cross, "b", Raw("TRUE"))],
    wheres: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let r = compile_inline(q)
  assert r.sql == "SELECT * FROM \"a\" CROSS JOIN \"b\" ON TRUE"
end

test "compile_inline NOT expr" do
  let q = Query({ from_: FromTable("t"), selects: Nil,
    wheres: [Where(Not(Eq(Col("active"), Lit(PBool(false)))))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
