-- ---- Multi-arg FnCall + nested arithmetic ----

test "multi-arg FnCall in parameterized select" do
  let q = Query({ from_: FromTable("t"),
    selects: [SelectField(FnCall("COALESCE", [Col("a"), Col("b"), Lit(PInt(0))]))],
    wheres: Nil, joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  assert String.contains((compile(q)).sql, "COALESCE(") == true
end

test "nested arithmetic in parameterized SELECT" do
  let q = Query({ from_: FromTable("t"),
    selects: [SelectAs(Add(Mul(Col("a"), Col("b")),
                            Div(Col("c"), Lit(PInt(2)))), "computed")],
    wheres: Nil, joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let s = (compile(q)).sql
  assert String.contains(s, "+") == true
  assert String.contains(s, "*") == true
  assert String.contains(s, "/") == true
  assert String.contains(s, "AS \"computed\"") == true
end

test "aggregate in SelectAs parameterized" do
  let q = Query({ from_: FromTable("t"),
    selects: [SelectAs(Sum(Col("x")), "total"),
               SelectAs(Count(Col("id")), "n"),
               SelectAs(Avg(Col("score")), "avg_score"),
               SelectAs(Min(Col("v")), "mn"),
               SelectAs(Max(Col("v")), "mx"),
               SelectAs(CountAll, "total_rows")],
    wheres: Nil, joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let s = (compile(q)).sql
  assert String.contains(s, "SUM(") == true
  assert String.contains(s, "COUNT(") == true
  assert String.contains(s, "AVG(") == true
  assert String.contains(s, "MIN(") == true
  assert String.contains(s, "MAX(") == true
  assert String.contains(s, "COUNT(*)") == true
end

test "parameterized DISTINCT" do
  let q = Query({ from_: FromTable("t"), selects: Nil, wheres: Nil,
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: Distinct })
