-- test/test_compile.march
-- Tests for SQL query compiler (compile).

mod TestCompile do

import Ast
import Message
import Compile

-- ---- Helpers ----

pfn list_len(lst) do
  match lst do | Nil -> 0 | Cons(_, rest) -> 1 + list_len(rest) end
end

pfn make_query(table) do
  Query({
    from_ = FromTable(table), selects = Nil, wheres = Nil,
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = false
  })
end

-- ---- Tests ----

fn test_simple_select_star() do
  let q = make_query("users")
  let r = compile(q)
  assert(r.sql == "SELECT * FROM \"users\"")
  assert(list_len(r.params) == 0)
end

fn test_select_with_columns() do
  let q = Query({
    from_ = FromTable("posts"), selects = [SelectField(Col("id")), SelectField(Col("title"))],
    wheres = Nil, joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = false
  })
  let r = compile(q)
  assert(r.sql == "SELECT \"id\", \"title\" FROM \"posts\"")
  assert(list_len(r.params) == 0)
end

fn test_where_with_param() do
  let q = Query({
    from_ = FromTable("users"),
    selects = Nil,
    wheres = [Where(Eq(Col("id"), Lit(PInt(42))))],
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = false
  })
  let r = compile(q)
  assert(r.sql == "SELECT * FROM \"users\" WHERE \"id\" = $1")
  assert(list_len(r.params) == 1)
  match r.params do
  Cons(ParamText(s), Nil) -> assert(s == "42")
  _ -> assert(false)
  end
end

fn test_two_where_params() do
  let q = Query({
    from_ = FromTable("products"),
    selects = Nil,
    wheres = [Where(Eq(Col("active"), Lit(PBool(true)))),
              Where(Eq(Col("price"), Lit(PInt(100))))],
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = false
  })
  let r = compile(q)
  assert(list_len(r.params) == 2)
  assert(r.sql == "SELECT * FROM \"products\" WHERE \"active\" = $1 AND \"price\" = $2")
end

fn test_null_param() do
  let q = Query({
    from_ = FromTable("t"),
    selects = Nil,
    wheres = [Where(Eq(Col("x"), Lit(PNull)))],
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = false
  })
  let r = compile(q)
  match r.params do
  Cons(ParamNull, Nil) -> ()
  _ -> assert(false)
  end
end

fn test_limit_and_offset() do
  let q = Query({
    from_ = FromTable("events"), selects = Nil, wheres = Nil,
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = Some(10), offset_ = Some(20), distinct_ = false
  })
  let r = compile(q)
  assert(r.sql == "SELECT * FROM \"events\" LIMIT 10 OFFSET 20")
end

fn test_distinct() do
  let q = Query({
    from_ = FromTable("tags"), selects = Nil, wheres = Nil,
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = true
  })
  let r = compile(q)
  assert(r.sql == "SELECT DISTINCT * FROM \"tags\"")
end

fn test_order_by() do
  let q = Query({
    from_ = FromTable("logs"), selects = Nil, wheres = Nil,
    joins = Nil, orders = [OrderExpr(Col("created_at"), Desc)],
    group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = false
  })
  let r = compile(q)
  assert(r.sql == "SELECT * FROM \"logs\" ORDER BY \"created_at\" DESC")
end

fn test_select_as() do
  let q = Query({
    from_ = FromTable("t"),
    selects = [SelectAs(CountAll, "total")],
    wheres = Nil, joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = false
  })
  let r = compile(q)
  assert(r.sql == "SELECT COUNT(*) AS \"total\" FROM \"t\"")
end

fn test_is_null() do
  let q = Query({
    from_ = FromTable("users"), selects = Nil,
    wheres = [Where(IsNull(Col("deleted_at")))],
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = false
  })
  let r = compile(q)
  assert(r.sql == "SELECT * FROM \"users\" WHERE \"deleted_at\" IS NULL")
end

fn test_raw_expr() do
  let q = Query({
    from_ = FromTable("t"), selects = [SelectField(Raw("1+1"))],
    wheres = Nil, joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = false
  })
  let r = compile(q)
  assert(r.sql == "SELECT 1+1 FROM \"t\"")
end

fn test_in_expr() do
  let q = Query({
    from_ = FromTable("users"), selects = Nil,
    wheres = [Where(In(Col("id"), [Lit(PInt(1)), Lit(PInt(2)), Lit(PInt(3))]))],
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = false
  })
  let r = compile(q)
  assert(r.sql == "SELECT * FROM \"users\" WHERE \"id\" IN ($1, $2, $3)")
  assert(list_len(r.params) == 3)
end

fn test_not_in_expr() do
  let q = Query({
    from_ = FromTable("t"), selects = Nil,
    wheres = [Where(NotIn(Col("status"), [Lit(PString("banned")), Lit(PString("deleted"))]))],
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = false
  })
  let r = compile(q)
  assert(r.sql == "SELECT * FROM \"t\" WHERE \"status\" NOT IN ($1, $2)")
  assert(list_len(r.params) == 2)
end

fn test_between_expr() do
  let q = Query({
    from_ = FromTable("products"), selects = Nil,
    wheres = [Where(Between(Col("price"), Lit(PInt(10)), Lit(PInt(100))))],
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = false
  })
  let r = compile(q)
  assert(r.sql == "SELECT * FROM \"products\" WHERE \"price\" BETWEEN $1 AND $2")
  assert(list_len(r.params) == 2)
end

fn test_in_inline() do
  let q = Query({
    from_ = FromTable("t"), selects = Nil,
    wheres = [Where(In(Col("id"), [Lit(PInt(10)), Lit(PInt(20))]))],
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = false
  })
  let r = compile_inline(q)
  assert(r.sql == "SELECT * FROM \"t\" WHERE \"id\" IN (10, 20)")
end

fn test_between_inline() do
  let q = Query({
    from_ = FromTable("t"), selects = Nil,
    wheres = [Where(Between(Col("score"), Lit(PInt(0)), Lit(PInt(100))))],
    joins = Nil, orders = Nil, group_bys = Nil, havings = Nil,
    limit_ = None, offset_ = None, distinct_ = false
  })
  let r = compile_inline(q)
  assert(r.sql == "SELECT * FROM \"t\" WHERE \"score\" BETWEEN 0 AND 100")
end

fn main() : Unit do
  test_simple_select_star()
  test_select_with_columns()
  test_where_with_param()
  test_two_where_params()
  test_null_param()
  test_limit_and_offset()
  test_distinct()
  test_order_by()
  test_select_as()
  test_is_null()
  test_raw_expr()
  test_in_expr()
  test_not_in_expr()
  test_between_expr()
  test_in_inline()
  test_between_inline()
  println("test_compile: all tests passed")
end

end
