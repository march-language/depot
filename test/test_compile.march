test "compile_inline full complex query" do
  let q = Query({ from_: FromTable("orders"),
    selects: [SelectField(Col("user_id")), SelectAs(Sum(Col("amount")), "total")],
    joins: [JoinClause(Inner, "users", Eq(QCol("orders", "user_id"), QCol("users", "id")))],
    wheres: [Where(Eq(Col("status"), Lit(PString("completed"))))],
    group_bys: [Col("user_id")],
    havings: [Where(Gt(Sum(Col("amount")), Lit(PInt(100))))],
    orders: [OrderExpr(Col("total"), Desc)],
    limit_: Some(10), offset_: Some(0), distinct_: NoDistinct })
  let r = compile_inline(q)
  assert String.contains(r.sql, "GROUP BY") == true
  assert String.contains(r.sql, "HAVING") == true
  assert String.contains(r.sql, "ORDER BY") == true
  assert String.contains(r.sql, "LIMIT") == true
end

-- ---- compile params correctness ----

test "compile params list grows with Lit values" do
  let q = Query({ from_: FromTable("t"), selects: Nil,
    wheres: [Where(Eq(Col("a"), Lit(PString("x")))),
