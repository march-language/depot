-- ---- escape_ident double-quote branch ----

test "quote_ident escapes embedded double quote" do
  -- Col with a double-quote in name triggers the b==34 branch in escape_ident
  let q = Query({ from_: FromTable("t"),
    selects: [SelectField(Col("weird\"col"))],
    wheres: Nil, joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let r = compile_inline(q)
  -- The double quote is doubled: "weird""col"
  assert String.contains(r.sql, "weird\"\"col") == true
end

