-- ---- Subquery expression branches ----

test "subquery with all comparison operators" do
  let sub = Query({ from_: FromTable("t"), selects: Nil,
    wheres: [Where(And(Or(Lt(Col("a"), Lit(PInt(1))), Gt(Col("b"), Lit(PInt(2)))),
                       Not(Eq(Col("c"), Lit(PInt(3))))))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let q = Query({ from_: FromTable("u"), selects: Nil,
    wheres: [Where(Exists(sub))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let s = (compile_inline(q)).sql
  assert String.contains(s, "EXISTS (") == true
  assert String.contains(s, "AND") == true
  assert String.contains(s, "OR") == true
  assert String.contains(s, "NOT") == true
end

test "subquery with arithmetic" do
  let sub = Query({ from_: FromTable("t"),
    selects: [SelectField(Add(Col("a"), Sub(Col("b"), Mul(Col("c"), Div(Col("d"), Lit(PInt(2)))))))],
    wheres: Nil, joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let q = Query({ from_: FromTable("u"), selects: [SelectAs(SubqueryExpr(sub), "x")],
    wheres: Nil, joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let s = (compile_inline(q)).sql
  assert String.contains(s, "+") == true
  assert String.contains(s, "-") == true
  assert String.contains(s, "*") == true
  assert String.contains(s, "/") == true
end

test "subquery with IsNull/IsNotNull/Neq/Lte/Gte" do
  let sub = Query({ from_: FromTable("t"), selects: Nil,
    wheres: [Where(And(IsNull(Col("a")),
                   And(IsNotNull(Col("b")),
                   And(Neq(Col("c"), Lit(PInt(1))),
                   And(Lte(Col("d"), Lit(PInt(2))), Gte(Col("e"), Lit(PInt(3)))))))) ],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let q = Query({ from_: FromTable("u"), selects: Nil,
    wheres: [Where(Exists(sub))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let s = (compile_inline(q)).sql
  assert String.contains(s, "IS NULL") == true
  assert String.contains(s, "IS NOT NULL") == true
  assert String.contains(s, "<>") == true
  assert String.contains(s, "<=") == true
  assert String.contains(s, ">=") == true
end

test "subquery with In/NotIn/Between" do
  let sub = Query({ from_: FromTable("t"), selects: Nil,
    wheres: [Where(And(In(Col("a"), [Lit(PInt(1)), Lit(PInt(2))]),
                   And(NotIn(Col("b"), [Lit(PInt(3))]),
                       Between(Col("c"), Lit(PInt(0)), Lit(PInt(10))))))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let q = Query({ from_: FromTable("u"), selects: Nil,
    wheres: [Where(Exists(sub))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let s = (compile_inline(q)).sql
  assert String.contains(s, "IN (") == true
  assert String.contains(s, "NOT IN") == true
  assert String.contains(s, "BETWEEN") == true
end

test "subquery with Like/ILike/FnCall/aggregates" do
  let sub = Query({ from_: FromTable("t"),
    selects: [SelectField(Count(Col("a"))), SelectField(Sum(Col("b"))),
               SelectField(Avg(Col("c"))), SelectField(Min(Col("d"))),
               SelectField(Max(Col("e"))), SelectAll],
    wheres: [Where(And(Like(Col("n"), "x%"), ILike(Col("m"), "y%")))],
    joins: Nil, orders: Nil, group_bys: [Col("g")],
    havings: [Where(Gt(Count(Col("a")), Lit(PInt(0))))],
    limit_: Some(5), offset_: Some(1), distinct_: Distinct })
  let q = Query({ from_: FromTable("u"), selects: [SelectAs(SubqueryExpr(sub), "x")],
    wheres: Nil, joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let s = (compile_inline(q)).sql
  assert String.contains(s, "COUNT") == true
  assert String.contains(s, "SUM") == true
  assert String.contains(s, "AVG") == true
  assert String.contains(s, "MIN") == true
  assert String.contains(s, "MAX") == true
  assert String.contains(s, "LIKE") == true
  assert String.contains(s, "ILIKE") == true
  assert String.contains(s, "GROUP BY") == true
  assert String.contains(s, "HAVING") == true
  assert String.contains(s, "DISTINCT") == true
  assert String.contains(s, "LIMIT") == true
  assert String.contains(s, "OFFSET") == true
end

test "subquery with FnCall and QCol" do
  let sub = Query({ from_: FromTable("t"),
    selects: [SelectField(FnCall("COALESCE", [Col("a"), Col("b"), Lit(PInt(0))]))],
    wheres: [Where(Eq(QCol("t", "id"), Lit(PInt(1))))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let q = Query({ from_: FromTable("u"), selects: [SelectAs(SubqueryExpr(sub), "x")],
    wheres: Nil, joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let s = (compile_inline(q)).sql
  assert String.contains(s, "COALESCE(") == true
  assert String.contains(s, "\"t\".\"id\"") == true
end

test "subquery with CountAll/ExprParam/Raw/OrWhere" do
  let sub = Query({ from_: FromTable("t"),
    selects: [SelectField(CountAll), SelectField(ExprParam(7)), SelectField(Raw("CAST(x AS INT)"))],
    wheres: [Where(Eq(Col("a"), Lit(PInt(1)))), OrWhere(Eq(Col("b"), Lit(PInt(2))))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let q = Query({ from_: FromTable("u"), selects: [SelectAs(SubqueryExpr(sub), "x")],
    wheres: Nil, joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let s = (compile_inline(q)).sql
  assert String.contains(s, "COUNT(*)") == true
  assert String.contains(s, "$7") == true
  assert String.contains(s, "CAST(x AS INT)") == true
  assert String.contains(s, "OR") == true
end

