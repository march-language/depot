  let q = Query({ from_: FromTable("t"), selects: Nil,
    wheres: [Where(ILike(Col("n"), "al%"))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let r = compile(q)
  assert String.contains(r.sql, "ILIKE") == true
  assert list_len(r.params) == 1
end

test "parameterized Between" do
  let q = Query({ from_: FromTable("t"), selects: Nil,
    wheres: [Where(Between(Col("age"), Lit(PInt(18)), Lit(PInt(65))))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let r = compile(q)
  assert String.contains(r.sql, "BETWEEN") == true
  assert list_len(r.params) == 2
end

test "parameterized Exists and SubqueryExpr" do
  let sub = Query({ from_: FromTable("orders"), selects: [SelectField(CountAll)],
    wheres: Nil, joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let q = Query({ from_: FromTable("users"),
    selects: [SelectAs(SubqueryExpr(sub), "order_count")],
    wheres: [Where(Exists(sub))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let s = (compile(q)).sql
  assert String.contains(s, "EXISTS (") == true
  assert String.contains(s, "(SELECT") == true
end

test "parameterized ExprParam and Raw" do
  let q = Query({ from_: FromTable("t"), selects: [SelectField(Raw("CAST(x AS INT)"))],
    wheres: [Where(Eq(Col("id"), ExprParam(3)))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let s = (compile(q)).sql
  assert String.contains(s, "CAST(x AS INT)") == true
  assert String.contains(s, "$3") == true
end

