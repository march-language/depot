test "compile_inline In NotIn Between" do
  let in_q = Query({ from_: FromTable("t"), selects: Nil,
    wheres: [Where(In(Col("id"), [Lit(PInt(1)), Lit(PInt(2))]))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let r_in = compile_inline(in_q)
  assert r_in.sql == "SELECT * FROM \"t\" WHERE \"id\" IN (1, 2)"

  let nin_q = Query({ from_: FromTable("t"), selects: Nil,
    wheres: [Where(NotIn(Col("id"), [Lit(PInt(3))]))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let r_nin = compile_inline(nin_q)
  assert r_nin.sql == "SELECT * FROM \"t\" WHERE \"id\" NOT IN (3)"

  let btw_q = Query({ from_: FromTable("t"), selects: Nil,
    wheres: [Where(Between(Col("age"), Lit(PInt(18)), Lit(PInt(65))))],
    joins: Nil, orders: Nil, group_bys: Nil, havings: Nil,
    limit_: None, offset_: None, distinct_: NoDistinct })
  let r_btw = compile_inline(btw_q)
  assert r_btw.sql == "SELECT * FROM \"t\" WHERE \"age\" BETWEEN 18 AND 65"
end

