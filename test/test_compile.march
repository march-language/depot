test "parameterized OrWhere in havings" do
  let q = Query({ from_: FromTable("t"), selects: Nil, wheres: Nil, joins: Nil,
    orders: Nil, group_bys: [Col("g")],
    havings: [Where(Gt(Count(Col("a")), Lit(PInt(1)))),
               OrWhere(Lt(Sum(Col("b")), Lit(PInt(100))))],
    limit_: None, offset_: None, distinct_: NoDistinct })
  let s = (compile(q)).sql
  assert String.contains(s, "HAVING") == true
  assert String.contains(s, "OR") == true
end

