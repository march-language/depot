mod TestDepotSchema do

-- ---------------------------------------------------------------------------
-- Helpers
-- ---------------------------------------------------------------------------

fn simple_schema() do
  Depot.Schema.define("users", {
    fields = {
      name  = "String",
      email = "String",
      age   = ("Int", { default = 0 }),
      role  = ("String", { default = "user" })
    }
  })
end

fn full_schema() do
  Depot.Schema.define("users", {
    fields = {
      name         = "String",
      email        = "String",
      age          = ("Int", { default = 0 }),
      role         = ("String", { default = "user" }),
      confirmed_at = ("String", { nullable = true }),
      password     = ("String", { virtual = true })
    },
    belongs_to = {
      org = "SomeModule"
    },
    has_many = {
      posts = "SomeModule"
    }
  })
end

-- ---------------------------------------------------------------------------

describe "Depot.Schema.define" do
  test "creates a schema value" do
    let s = simple_schema()
    assert Depot.Schema.table(s) == "users"
  end

  test "default primary key is id" do
    let s = simple_schema()
    assert Depot.Schema.primary_key(s) == "id"
  end
end

-- ---------------------------------------------------------------------------

describe "Depot.Schema.table" do
  test "returns the table name" do
    let s = Depot.Schema.define("posts", {
      fields = { title = "String", body = "String" }
    })
    assert Depot.Schema.table(s) == "posts"
  end
end

-- ---------------------------------------------------------------------------

describe "Depot.Schema.field_names" do
  test "returns all field names" do
    let s = simple_schema()
    let names = Depot.Schema.field_names(s)
    assert List.length(names) == 4
    assert List.member(names, "name")
    assert List.member(names, "email")
    assert List.member(names, "age")
    assert List.member(names, "role")
  end

  test "includes virtual fields" do
    let s = full_schema()
    let names = Depot.Schema.field_names(s)
    assert List.member(names, "password")
  end
end

-- ---------------------------------------------------------------------------

describe "Depot.Schema.field_type" do
  test "returns Some for existing field" do
    let s = simple_schema()
    assert Depot.Schema.field_type(s, "name") == Some("String")
    assert Depot.Schema.field_type(s, "age") == Some("Int")
  end

  test "returns None for missing field" do
    let s = simple_schema()
    assert Depot.Schema.field_type(s, "nonexistent") == None
  end
end

-- ---------------------------------------------------------------------------

describe "Depot.Schema.is_virtual" do
  test "returns true for virtual fields" do
    let s = full_schema()
    assert Depot.Schema.is_virtual(s, "password") == true
  end

  test "returns false for regular fields" do
    let s = full_schema()
    assert Depot.Schema.is_virtual(s, "name") == false
  end

  test "returns false for nonexistent fields" do
    let s = simple_schema()
    assert Depot.Schema.is_virtual(s, "nope") == false
  end
end

-- ---------------------------------------------------------------------------

describe "Depot.Schema.db_fields" do
  test "excludes virtual fields" do
    let s = full_schema()
    let db = Depot.Schema.db_fields(s)
    assert List.member(db, "name") == true
    assert List.member(db, "email") == true
    assert List.member(db, "password") == false
  end
end

-- ---------------------------------------------------------------------------

describe "Depot.Schema.associations" do
  test "returns empty list when no associations" do
    let s = simple_schema()
    assert Depot.Schema.associations(s) == Nil
  end

  test "parses belongs_to associations" do
    let s = full_schema()
    let assocs = Depot.Schema.associations(s)
    assert List.length(assocs) > 0
  end

  test "association lookup returns Some for existing" do
    let s = full_schema()
    match Depot.Schema.association(s, "org") do
      Some((kind, n, target, opts)) -> assert kind == "belongs_to"
      None -> assert false
    end
  end

  test "association lookup returns None for missing" do
    let s = full_schema()
    assert Depot.Schema.association(s, "nonexistent") == None
  end
end

-- ---------------------------------------------------------------------------

describe "Depot.Schema.blank" do
  test "creates a record with type defaults" do
    let s = simple_schema()
    let b = Depot.Schema.blank(s)
    assert b.name == ""
    assert b.email == ""
  end

  test "uses explicit defaults from field options" do
    let s = simple_schema()
    let b = Depot.Schema.blank(s)
    assert b.age == 0
    assert b.role == "user"
  end

  test "nullable fields default to None" do
    let s = full_schema()
    let b = Depot.Schema.blank(s)
    assert b.confirmed_at == None
  end

  test "includes virtual fields" do
    let s = full_schema()
    let b = Depot.Schema.blank(s)
    assert b.password == ""
  end
end

-- ---------------------------------------------------------------------------

describe "record introspection builtins" do
  test "record_keys returns field names" do
    let r = { a = 1, b = 2, c = 3 }
    let keys = record_keys(r)
    assert List.length(keys) == 3
    assert List.member(keys, "a")
    assert List.member(keys, "b")
    assert List.member(keys, "c")
  end

  test "record_values returns field values" do
    let r = { x = 10, y = 20 }
    let vals = record_values(r)
    assert List.member(vals, 10)
    assert List.member(vals, 20)
  end

  test "record_entries returns pairs" do
    let r = { name = "Alice", age = 30 }
    let entries = record_entries(r)
    assert List.length(entries) == 2
    assert List.member(entries, ("name", "Alice"))
    assert List.member(entries, ("age", 30))
  end

  test "record_get returns Some for existing key" do
    let r = { foo = 42 }
    assert record_get(r, "foo") == Some(42)
  end

  test "record_get returns None for missing key" do
    let r = { foo = 42 }
    assert record_get(r, "bar") == None
  end

  test "record_put adds a new field" do
    let r = { a = 1 }
    let r2 = record_put(r, "b", 2)
    assert record_get(r2, "b") == Some(2)
    assert record_get(r2, "a") == Some(1)
  end

  test "record_put overwrites existing field" do
    let r = { a = 1 }
    let r2 = record_put(r, "a", 99)
    assert record_get(r2, "a") == Some(99)
  end

  test "record_has_key returns true/false" do
    let r = { x = 1 }
    assert record_has_key(r, "x") == true
    assert record_has_key(r, "y") == false
  end

  test "record_from_list builds a record" do
    let pairs = [("a", 1), ("b", 2)]
    let r = record_from_list(pairs)
    assert r.a == 1
    assert r.b == 2
  end
end

-- ---------------------------------------------------------------------------
-- Additional coverage tests
-- ---------------------------------------------------------------------------

test "bare string field spec (no opts tuple)" do
  let s = Depot.Schema.define("articles", {
    fields = {
      title   = "String",
      content = "String",
      views   = "Int"
    }
  })
  -- march orders record fields alphabetically, so field_names reflects that.
  assert Depot.Schema.field_names(s) == ["content", "title", "views"]
  let b = Depot.Schema.blank(s)
  assert List.member(record_entries(b), ("title", ""))
  assert List.member(record_entries(b), ("views", 0))
end

test "Float type default in blank" do
  let s = Depot.Schema.define("metrics", {
    fields = {
      score = ("Float", { default = 0.0 }),
      ratio = "Float"
    }
  })
  let b = Depot.Schema.blank(s)
  assert to_string(record_get(b, "ratio")) == "Some(0.)"
end

test "Bool type default in blank" do
  let s = Depot.Schema.define("flags", {
    fields = { enabled = "Bool" }
  })
  let b = Depot.Schema.blank(s)
  assert to_string(record_get(b, "enabled")) == "Some(false)"
end

test "nullable field defaults to None" do
  let s = Depot.Schema.define("profiles", {
    fields = {
      bio  = ("String", { nullable = true }),
      name = "String"
    }
  })
  let b = Depot.Schema.blank(s)
  assert record_get(b, "bio") == Some(None)
  assert record_get(b, "name") == Some("")
end

test "field with explicit custom default overrides type default" do
  let s = Depot.Schema.define("settings", {
    fields = {
      theme = ("String", { default = "dark" }),
      level = ("Int", { default = 5 })
    }
  })
  let b = Depot.Schema.blank(s)
  assert record_get(b, "theme") == Some("dark")
  assert record_get(b, "level") == Some(5)
end

test "virtual fields excluded from db_fields" do
  let s = Depot.Schema.define("users", {
    fields = {
      name          = "String",
      password      = ("String", { virtual = true }),
      password_hash = "String"
    }
  })
  let db = Depot.Schema.db_fields(s)
  assert List.member(db, "name")
  assert List.member(db, "password_hash")
  assert List.member(db, "password") == false
end

test "all-virtual schema yields empty db_fields" do
  let s = Depot.Schema.define("temp", {
    fields = {
      a = ("String", { virtual = true }),
      b = ("Int", { virtual = true })
    }
  })
  assert Depot.Schema.db_fields(s) == Nil
end

test "custom primary_key" do
  let s = Depot.Schema.define("products", {
    primary_key = "sku",
    fields = { sku = "String", name = "String" }
  })
  assert Depot.Schema.primary_key(s) == "sku"
end

test "has_one association" do
  let s = Depot.Schema.define("users", {
    fields  = { name = "String" },
    has_one = { profile = "Profile" }
  })
  let assoc = Depot.Schema.association(s, "profile")
  match assoc do
  Some(("has_one", "profile", "Profile", _)) -> ()
  end
end

test "many_to_many association" do
  let s = Depot.Schema.define("posts", {
    fields        = { title = "String" },
    many_to_many  = { tags = ("Tag", { join_through = "posts_tags" }) }
  })
  let assoc = Depot.Schema.association(s, "tags")
  match assoc do
  Some(("many_to_many", "tags", "Tag", _)) -> ()
  end
end

test "associations returns all kinds" do
  let s = Depot.Schema.define("posts", {
    fields        = { title = "String" },
    belongs_to    = { user = "User" },
    has_many      = { comments = "Comment" },
    has_one       = { featured_image = "Image" },
    many_to_many  = { tags = "Tag" }
  })
  let assocs = Depot.Schema.associations(s)
  assert List.length(assocs) == 4
end

test "field_type returns Some for known field and None for unknown" do
  let s = Depot.Schema.define("t", {
    fields = { name = "String", age = "Int" }
  })
  assert Depot.Schema.field_type(s, "name") == Some("String")
  assert Depot.Schema.field_type(s, "age") == Some("Int")
  assert Depot.Schema.field_type(s, "unknown") == None
end

test "field_opts returns Some for field with opts and None for unknown" do
  let s = Depot.Schema.define("t", {
    fields = { bio = ("String", { nullable = true }) }
  })
  match Depot.Schema.field_opts(s, "bio") do
  Some(_) -> ()
  None    -> assert false
  end
  assert Depot.Schema.field_opts(s, "nonexistent") == None
end

test "is_virtual returns correct values" do
  let s = Depot.Schema.define("t", {
    fields = {
      pw      = ("String", { virtual = true }),
      pw_hash = "String"
    }
  })
  assert Depot.Schema.is_virtual(s, "pw") == true
  assert Depot.Schema.is_virtual(s, "pw_hash") == false
  assert Depot.Schema.is_virtual(s, "nonexistent") == false
end

end -- mod TestDepotSchema
