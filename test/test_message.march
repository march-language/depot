-- test/test_message.march
-- Tests for wire message types and constructors.

mod TestMessage do

import Message

test "ParamNull" do
  assert ParamNull == ParamNull
end

test "ParamText" do
  assert ParamText("hello") == ParamText("hello")
end

test "ParamBinary" do
  let b = Bytes.from_list([1, 2, 3])
  match ParamBinary(b) do
  ParamBinary(data) -> assert Bytes.length(data) == 3
  end
end

test "DescribeStatement target" do
  assert DescribeStatement("my_stmt") == DescribeStatement("my_stmt")
end

test "DescribePortal target" do
  assert DescribePortal("my_portal") == DescribePortal("my_portal")
end

test "CloseStatement target" do
  assert CloseStatement("s") == CloseStatement("s")
end

test "transaction status variants" do
  assert Idle == Idle
  assert InTransaction == InTransaction
  assert InFailedTransaction == InFailedTransaction
end

test "error fields record" do
  let ef = {
    severity = "ERROR",
    code = "42P01",
    message = "relation does not exist",
    detail = None,
    hint = None,
    position = None
  }
  assert ef.severity == "ERROR"
  assert ef.code == "42P01"
  assert ef.message == "relation does not exist"
  assert ef.detail == None
end

test "error fields with detail" do
  let ef = {
    severity = "ERROR",
    code = "23505",
    message = "duplicate key",
    detail = Some("Key (id)=(1) already exists."),
    hint = None,
    position = None
  }
  assert ef.detail == Some("Key (id)=(1) already exists.")
end

test "ClosePortal target" do
  assert ClosePortal("my_portal") == ClosePortal("my_portal")
end

test "FieldDesc constructor" do
  let fd = FieldDesc("col", 0, 1, 23, 4, -1, 0)
  match fd do
  FieldDesc(name, toid, anum, tyoid, tysize, tymod, fmt) -> do
    assert name == "col"
    assert tyoid == 23
    assert fmt == 0
  end
  end
end

test "BackendMessage AuthOk" do
  assert AuthOk == AuthOk
end

test "BackendMessage ParseComplete" do
  assert ParseComplete == ParseComplete
end

test "BackendMessage BindComplete" do
  assert BindComplete == BindComplete
end

test "BackendMessage CloseComplete" do
  assert CloseComplete == CloseComplete
end

test "BackendMessage NoData" do
  assert NoData == NoData
end

test "BackendMessage EmptyQueryResponse" do
  assert EmptyQueryResponse == EmptyQueryResponse
end

test "BackendMessage PortalSuspended" do
  assert PortalSuspended == PortalSuspended
end

test "BackendMessage CommandComplete" do
  assert CommandComplete("SELECT 1") == CommandComplete("SELECT 1")
end

test "BackendMessage BackendKeyData" do
  assert BackendKeyData(1234, 5678) == BackendKeyData(1234, 5678)
end

test "BackendMessage ParameterStatus" do
  assert ParameterStatus("client_encoding", "UTF8") == ParameterStatus("client_encoding", "UTF8")
end

test "BackendMessage ReadyForQuery" do
  assert ReadyForQuery(Idle) == ReadyForQuery(Idle)
end

end -- mod TestMessage
